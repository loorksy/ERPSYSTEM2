<div class="max-w-4xl mx-auto" dir="rtl">
  <div class="flex flex-wrap items-center justify-between gap-4 mb-8">
    <div>
      <h2 class="text-2xl font-bold text-slate-800">الديون والملفات</h2>
      <p class="text-sm text-slate-500 mt-1">ملخص الديون مع روابط لسجلات الشركات والصناديق</p>
    </div>
    <a href="/dashboard" class="text-sm text-indigo-600 font-semibold hover:underline">← لوحة التحكم</a>
  </div>

  <div id="debtsSummary" class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-8">
    <p class="text-slate-400 col-span-full text-center py-6">جاري التحميل...</p>
  </div>

  <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6 mb-8">
    <h3 class="text-lg font-bold text-slate-800 mb-4">تسجيل دين (مديونية على حسابنا)</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="text-sm font-semibold text-slate-700">النوع</label>
        <select id="debtRegEntityType" class="w-full mt-1 px-4 py-2.5 rounded-xl border border-slate-200">
          <option value="transfer_company">شركة تحويل</option>
          <option value="fund">صندوق</option>
        </select>
      </div>
      <div>
        <label class="text-sm font-semibold text-slate-700">الكيان</label>
        <select id="debtRegEntityId" class="w-full mt-1 px-4 py-2.5 rounded-xl border border-slate-200">
          <option value="">— اختر —</option>
        </select>
      </div>
      <div>
        <label class="text-sm font-semibold text-slate-700">المبلغ</label>
        <input type="number" id="debtRegAmount" step="0.01" min="0" class="w-full mt-1 px-4 py-2.5 rounded-xl border border-slate-200" placeholder="0.00">
      </div>
      <div>
        <label class="text-sm font-semibold text-slate-700">العملة</label>
        <select id="debtRegCurrency" class="w-full mt-1 px-4 py-2.5 rounded-xl border border-slate-200">
          <option value="USD">USD</option>
          <option value="TRY">TRY</option>
          <option value="SYP">SYP</option>
        </select>
      </div>
      <div>
        <label class="text-sm font-semibold text-slate-700">طريقة التسوية</label>
        <select id="debtRegSettlement" class="w-full mt-1 px-4 py-2.5 rounded-xl border border-slate-200">
          <option value="payable">دين علينا (افتراضي)</option>
          <option value="cash">كاش — إيداع في الصندوق الرئيسي (USD)</option>
        </select>
      </div>
      <div class="md:col-span-2">
        <label class="text-sm font-semibold text-slate-700">ملاحظات</label>
        <input type="text" id="debtRegNotes" class="w-full mt-1 px-4 py-2.5 rounded-xl border border-slate-200" placeholder="اختياري">
      </div>
    </div>
    <button type="button" id="debtRegSubmit" class="mt-4 px-6 py-3 rounded-xl bg-red-600 text-white font-semibold hover:bg-red-700">تسجيل الدين</button>
  </div>

  <div class="space-y-6">
    <section>
      <h3 class="font-bold text-slate-800 mb-3">شركات تحويل (رصيد سالب = مديونية)</h3>
      <div id="debtsCompanies" class="space-y-2"></div>
    </section>
    <section>
      <h3 class="font-bold text-slate-800 mb-3">صناديع (رصيد سالب USD)</h3>
      <div id="debtsFunds" class="space-y-2"></div>
    </section>
    <section>
      <h3 class="font-bold text-slate-800 mb-3">مديونيات مسجّلة يدوياً</h3>
      <div id="debtsPayables" class="space-y-2 text-sm"></div>
    </section>
    <section>
      <h3 class="font-bold text-slate-800 mb-3">روابط سريعة</h3>
      <div class="flex flex-wrap gap-3">
        <a href="/shipping" class="px-4 py-2 rounded-xl bg-slate-100 text-slate-800 text-sm font-medium hover:bg-slate-200">الشحن</a>
        <a href="/approvals" class="px-4 py-2 rounded-xl bg-slate-100 text-slate-800 text-sm font-medium hover:bg-slate-200">الاعتمادات</a>
        <a href="/fx-spread" class="px-4 py-2 rounded-xl bg-indigo-50 text-indigo-800 text-sm font-medium hover:bg-indigo-100">فرق التصريف</a>
        <a href="/transfer-companies" class="px-4 py-2 rounded-xl bg-slate-100 text-slate-800 text-sm font-medium hover:bg-slate-200">شركات التحويل</a>
        <a href="/funds" class="px-4 py-2 rounded-xl bg-slate-100 text-slate-800 text-sm font-medium hover:bg-slate-200">الصناديق</a>
      </div>
    </section>
  </div>
</div>
