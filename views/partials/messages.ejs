<div class="max-w-6xl">
  <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
    <div class="flex items-center justify-between flex-wrap gap-3 py-5 px-6 border-b border-slate-100">
      <div class="flex items-center gap-3">
        <i class="fas fa-envelope-open-text text-xl text-indigo-600"></i>
        <h3 class="text-lg font-bold">ترتيب الرسائل</h3>
      </div>
      <div class="flex items-center gap-2 flex-wrap" id="aiProviderInfo">
        <span class="text-xs text-slate-400" id="activeProviderLabel"></span>
        <span class="text-xs text-slate-400" id="aiConnectionHint"></span>
      </div>
    </div>

    <div class="p-4 md:p-6">
      <!-- Input Section -->
      <div class="mb-6">
        <label class="block mb-2 font-semibold text-sm text-slate-800">
          <i class="fab fa-whatsapp text-[#25d366] ml-1"></i>
          الصق رسائل واتساب هنا
        </label>
        <textarea id="messagesInput" dir="auto" rows="10" placeholder="الصق رسائل واتساب هنا للتحليل والاستخراج..."
          class="w-full py-4 px-5 border-2 border-slate-200 rounded-xl text-sm bg-slate-50 text-slate-800 transition-all duration-300 focus:outline-none focus:border-indigo-600 focus:bg-white focus:ring-2 focus:ring-indigo-600/10 placeholder:text-slate-400 resize-y leading-7"></textarea>
        <div class="flex items-center justify-between mt-2">
          <span class="text-xs text-slate-400" id="charCount">0 حرف</span>
          <span class="text-xs text-slate-400" id="chunkEstimate"></span>
        </div>
      </div>

      <!-- Actions -->
      <div class="flex gap-3 mb-6 flex-wrap">
        <button onclick="startAnalysis()" id="analyzeBtn"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-semibold text-[0.95rem] transition-all duration-300 cursor-pointer whitespace-nowrap active:scale-[0.97] bg-indigo-600 text-white hover:bg-indigo-700 hover:shadow-[0_4px_12px_rgba(79,70,229,0.4)]">
          <i class="fas fa-wand-magic-sparkles"></i>
          <span>تحليل واستخراج</span>
        </button>
        <button onclick="clearAll()" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-semibold text-[0.95rem] transition-all duration-300 cursor-pointer whitespace-nowrap active:scale-[0.97] bg-slate-100 text-slate-600 hover:bg-slate-200">
          <i class="fas fa-eraser"></i>
          <span>مسح</span>
        </button>
      </div>

      <!-- Progress -->
      <div class="mb-6 hidden" id="progressSection">
        <div class="p-5 bg-indigo-50 border border-indigo-200 rounded-xl">
          <div class="flex items-center gap-3 mb-3">
            <i class="fas fa-spinner fa-spin text-indigo-600"></i>
            <span class="font-semibold text-sm text-indigo-700" id="progressText">جاري التحليل...</span>
          </div>
          <div class="w-full h-2 bg-indigo-200 rounded-full overflow-hidden">
            <div class="h-full bg-indigo-600 rounded-full transition-all duration-500" id="progressBar"></div>
          </div>
          <p class="text-xs text-indigo-500 mt-2" id="progressDetail"></p>
          <p class="text-xs text-slate-500 mt-1" id="progressHint">يمكنك إغلاق الصفحة والعودة لاحقاً لمشاهدة النتائج من التحليلات الأخيرة.</p>
        </div>
      </div>

      <!-- Recent jobs (open past analysis) -->
      <div class="mb-6 hidden" id="recentJobsSection">
        <h4 class="font-bold text-slate-800 mb-2 flex items-center gap-2"><i class="fas fa-history text-indigo-600"></i> التحليلات الأخيرة</h4>
        <div id="recentJobsList" class="flex flex-wrap gap-2"></div>
      </div>

      <!-- Results -->
      <div class="hidden" id="resultsSection">
        <div class="flex items-center justify-between mb-4 flex-wrap gap-3">
          <h4 class="font-bold text-slate-800 flex items-center gap-2">
            <i class="fas fa-table text-indigo-600"></i> النتائج
          </h4>
          <div class="flex gap-2 flex-wrap">
            <button onclick="copyResults()" class="inline-flex items-center justify-center gap-2 px-4 py-2 rounded-lg font-semibold text-xs transition-all duration-300 cursor-pointer active:scale-[0.97] bg-emerald-500 text-white hover:bg-emerald-600">
              <i class="fas fa-copy"></i> نسخ الجدول
            </button>
            <button onclick="copyAsCSV()" class="inline-flex items-center justify-center gap-2 px-4 py-2 rounded-lg font-semibold text-xs transition-all duration-300 cursor-pointer active:scale-[0.97] bg-sky-500 text-white hover:bg-sky-600">
              <i class="fas fa-file-csv"></i> نسخ CSV
            </button>
            <button onclick="openExportSheetsModal()" class="inline-flex items-center justify-center gap-2 px-4 py-2 rounded-lg font-semibold text-xs transition-all duration-300 cursor-pointer active:scale-[0.97] bg-[#0f9d58] text-white hover:bg-[#0d8a4d]">
              <i class="fas fa-file-excel"></i> تصدير إلى Google Sheets
            </button>
          </div>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-3 mb-4">
          <div class="bg-slate-50 rounded-xl p-3 text-center border border-slate-100">
            <p class="text-lg font-bold text-indigo-600" id="rowCount">0</p>
            <p class="text-xs text-slate-500">صف</p>
          </div>
          <div class="bg-slate-50 rounded-xl p-3 text-center border border-slate-100">
            <p class="text-lg font-bold text-indigo-600" id="chunkCount">0</p>
            <p class="text-xs text-slate-500">أجزاء</p>
          </div>
          <div class="bg-slate-50 rounded-xl p-3 text-center border border-slate-100">
            <p class="text-lg font-bold text-indigo-600" id="usedModel">-</p>
            <p class="text-xs text-slate-500">الموديل</p>
          </div>
        </div>

        <!-- Table Container -->
        <div class="overflow-x-auto border border-slate-200 rounded-xl" id="tableContainer">
        </div>

        <!-- Raw Markdown -->
        <details class="mt-4">
          <summary class="text-sm text-slate-500 cursor-pointer hover:text-indigo-600 font-medium">
            <i class="fas fa-code ml-1"></i> عرض Markdown الخام
          </summary>
          <pre id="rawMarkdown" dir="ltr" class="mt-2 p-4 bg-slate-900 text-slate-200 rounded-xl text-xs overflow-x-auto leading-6 max-h-[400px] overflow-y-auto"></pre>
        </details>
      </div>

      <!-- Export to Google Sheets Modal -->
      <div id="exportSheetsModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4" style="display: none;">
        <div class="bg-white rounded-2xl shadow-xl max-w-md w-full p-6">
          <h4 class="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2"><i class="fas fa-file-excel text-[#0f9d58]"></i> تصدير إلى Google Sheets</h4>
          <div class="mb-4">
            <label class="block mb-2 font-semibold text-sm text-slate-800">اسم الورقة (اختياري)</label>
            <input type="text" id="exportSheetName" placeholder="تحليل رسائل — تاريخ تلقائي إن تركت فارغاً"
              class="w-full py-3 px-4 border-2 border-slate-200 rounded-xl text-sm bg-slate-50 text-slate-800 focus:outline-none focus:border-indigo-600">
          </div>
          <div class="mb-4">
            <label class="block mb-2 font-semibold text-sm text-slate-800">الوجهة</label>
            <div class="flex gap-4">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="exportMode" value="newSheet" checked class="text-indigo-600">
                <span class="text-sm">ورقة جديدة</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="exportMode" value="appendToSheet" class="text-indigo-600">
                <span class="text-sm">إلحاق بورقة موجودة</span>
              </label>
            </div>
          </div>
          <div id="exportSheetSelectWrap" class="mb-4 hidden">
            <label class="block mb-2 font-semibold text-sm text-slate-800">اختر الورقة</label>
            <select id="exportSheetSelect" class="w-full py-3 px-4 border-2 border-slate-200 rounded-xl text-sm bg-white text-slate-800 focus:outline-none focus:border-indigo-600">
              <option value="">جاري التحميل...</option>
            </select>
          </div>
          <div class="flex gap-2 justify-end">
            <button type="button" onclick="closeExportSheetsModal()" class="px-4 py-2 rounded-xl font-semibold text-sm bg-slate-100 text-slate-600 hover:bg-slate-200">إلغاء</button>
            <button type="button" id="exportSheetsSubmitBtn" onclick="doExportToSheets()" class="px-5 py-2 rounded-xl font-semibold text-sm bg-[#0f9d58] text-white hover:bg-[#0d8a4d]">تصدير</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const messagesInput = document.getElementById('messagesInput');
const charCount = document.getElementById('charCount');
const chunkEstimate = document.getElementById('chunkEstimate');

messagesInput.addEventListener('input', () => {
  const len = messagesInput.value.length;
  charCount.textContent = len.toLocaleString('ar-SA') + ' حرف';
  const chunks = Math.ceil(len / 12000);
  chunkEstimate.textContent = len > 12000 ? `سيتم تقسيمه إلى ${chunks} أجزاء` : '';
});

let currentJobId = null;
let displayedJobId = null;
let pollTimer = null;

function resetAnalyzeButton() {
  const btn = document.getElementById('analyzeBtn');
  btn.disabled = false;
  btn.innerHTML = '<i class="fas fa-wand-magic-sparkles"></i><span>تحليل واستخراج</span>';
}

function stopPolling() {
  if (pollTimer) {
    clearInterval(pollTimer);
    pollTimer = null;
  }
  currentJobId = null;
}

function showProgress(percent, text, detail) {
  const progress = document.getElementById('progressSection');
  progress.classList.remove('hidden');
  document.getElementById('progressBar').style.width = (percent || 0) + '%';
  if (text) document.getElementById('progressText').textContent = text;
  if (detail !== undefined) document.getElementById('progressDetail').textContent = detail;
}

function finishProgressAndShowResults(data, jobId) {
  displayedJobId = jobId != null ? jobId : currentJobId;
  stopPolling();
  showProgress(100, 'تم الانتهاء', document.getElementById('progressDetail').textContent);
  renderResults(data);
  showToast('تم التحليل بنجاح', 'success');
  resetAnalyzeButton();
  setTimeout(() => document.getElementById('progressSection').classList.add('hidden'), 800);
  loadRecentJobs();
}

function finishProgressWithError(msg) {
  stopPolling();
  showToast(msg || 'فشل التحليل', 'error');
  resetAnalyzeButton();
  document.getElementById('progressSection').classList.add('hidden');
}

function pollJobStatus(jobId) {
  if (pollTimer) return;
  currentJobId = jobId;
  pollTimer = setInterval(async () => {
    try {
      const res = await fetch('/ai/analysis/' + jobId);
      const data = await res.json();
      if (!data.success) {
        finishProgressWithError(data.message);
        return;
      }
      if (data.status === 'running') {
        const total = data.progressTotal || 1;
        const current = data.progressCurrent || 0;
        const pct = total ? Math.round((current / total) * 100) : 0;
        showProgress(pct, `جاري التحليل... (${current}/${total})`, document.getElementById('progressDetail').textContent);
      } else if (data.status === 'completed') {
        finishProgressAndShowResults({
          table: data.table,
          chunks: data.chunks,
          model: data.model,
          provider: data.provider,
        }, jobId);
      } else if (data.status === 'failed') {
        finishProgressWithError(data.message);
      }
    } catch (_) {}
  }, 2000);
}

async function startAnalysis() {
  const text = messagesInput.value.trim();
  if (!text || text.length < 10) {
    showToast('الرجاء إدخال رسائل كافية للتحليل', 'error');
    return;
  }

  const btn = document.getElementById('analyzeBtn');
  const progress = document.getElementById('progressSection');
  const results = document.getElementById('resultsSection');

  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i><span>جاري الإرسال...</span>';
  results.classList.add('hidden');
  stopPolling();

  const totalChunks = Math.ceil(text.length / 12000) || 1;
  document.getElementById('progressDetail').textContent = `حجم النص: ${text.length.toLocaleString()} حرف${totalChunks > 1 ? ` — ${totalChunks} أجزاء` : ''}`;
  progress.classList.remove('hidden');
  showProgress(5, 'جاري التحليل في الخلفية...', document.getElementById('progressDetail').textContent);

  try {
    const res = await fetch('/ai/analyze', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ text }),
    });
    const data = await res.json();

    if (!data.success) {
      finishProgressWithError(data.message);
      return;
    }

    const jobId = data.jobId;
    if (!jobId) {
      finishProgressWithError('لم يُرجع الخادم معرف المهمة');
      return;
    }

    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i><span>جاري التحليل...</span>';
    if (typeof io !== 'undefined') {
      if (!window._analysisSocket) window._analysisSocket = io();
      const socket = window._analysisSocket;
      socket.emit('subscribe_analysis', jobId);
      function onProgress(p) {
        if (p.jobId !== jobId) return;
        const total = p.total || 1;
        const current = p.chunk || 0;
        const pct = total ? Math.round((current / total) * 100) : 0;
        showProgress(pct, `جاري التحليل... (${current}/${total})`, document.getElementById('progressDetail').textContent);
      }
      function onDone(p) {
        if (p.jobId !== jobId) return;
        socket.off('analysis:progress', onProgress);
        finishProgressAndShowResults({ table: p.table, chunks: p.chunks, model: p.model, provider: p.provider }, p.jobId);
      }
      function onErr(p) {
        if (p.jobId !== jobId) return;
        socket.off('analysis:progress', onProgress);
        finishProgressWithError(p.message);
      }
      socket.on('analysis:progress', onProgress);
      socket.once('analysis:done', onDone);
      socket.once('analysis:error', onErr);
    }
    pollJobStatus(jobId);
  } catch (err) {
    finishProgressWithError('خطأ في الاتصال بالخادم');
  }
}

function renderResults(data) {
  if (!data || data.table == null) {
    document.getElementById('rawMarkdown').textContent = '';
    document.getElementById('rowCount').textContent = '0';
    document.getElementById('chunkCount').textContent = '0';
    document.getElementById('usedModel').textContent = '-';
    document.getElementById('tableContainer').innerHTML = '';
    return;
  }
  var table = typeof data.table === 'string' ? data.table : '';
  const results = document.getElementById('resultsSection');
  results.classList.remove('hidden');

  document.getElementById('rawMarkdown').textContent = table;
  document.getElementById('chunkCount').textContent = data.chunks != null ? data.chunks : '0';
  document.getElementById('usedModel').textContent = data.model ? (data.model.split('/').pop().split('-').slice(0, 2).join('-') || data.model) : '-';

  const lines = table.split('\n').filter(function(l) { return l.trim().startsWith('|'); });
  const rows = Math.max(0, lines.length - 2);
  document.getElementById('rowCount').textContent = rows;

  if (lines.length >= 2) {
    const headers = lines[0].split('|').filter(c => c.trim()).map(c => c.trim());
    const dataRows = lines.slice(2);

    let html = '<table class="w-full text-sm">';
    html += '<thead><tr class="bg-indigo-600 text-white">';
    headers.forEach(h => { html += `<th class="py-3 px-4 text-right font-semibold whitespace-nowrap">${h}</th>`; });
    html += '</tr></thead><tbody>';

    dataRows.forEach((row, i) => {
      const cells = row.split('|').filter(c => c.trim() !== '' || c === '');
      const cleanCells = row.split('|');
      cleanCells.shift();
      if (cleanCells[cleanCells.length - 1]?.trim() === '') cleanCells.pop();

      const bg = i % 2 === 0 ? 'bg-white' : 'bg-slate-50';
      html += `<tr class="${bg} hover:bg-indigo-50 transition-colors border-b border-slate-100">`;
      cleanCells.forEach(c => { html += `<td class="py-3 px-4 text-right whitespace-nowrap">${c.trim()}</td>`; });
      html += '</tr>';
    });
    html += '</tbody></table>';
    document.getElementById('tableContainer').innerHTML = html;
  } else {
    document.getElementById('tableContainer').innerHTML = '<p class="p-4 text-center text-slate-500">لا توجد صفوف في الجدول.</p>';
  }
}

function copyResults() {
  const md = document.getElementById('rawMarkdown').textContent;
  navigator.clipboard.writeText(md).then(() => showToast('تم نسخ الجدول', 'success'));
}

function copyAsCSV() {
  const md = document.getElementById('rawMarkdown').textContent;
  const lines = md.split('\n').filter(l => l.trim().startsWith('|'));
  const csv = lines.filter((_, i) => i !== 1).map(l => {
    const cells = l.split('|');
    cells.shift();
    if (cells[cells.length - 1]?.trim() === '') cells.pop();
    return cells.map(c => `"${c.trim().replace(/"/g, '""')}"`).join(',');
  }).join('\n');
  const bom = '\uFEFF';
  navigator.clipboard.writeText(bom + csv).then(() => showToast('تم نسخ CSV (جاهز لـ Excel)', 'success'));
}

function clearAll() {
  messagesInput.value = '';
  charCount.textContent = '0 حرف';
  chunkEstimate.textContent = '';
  document.getElementById('resultsSection').classList.add('hidden');
  document.getElementById('progressSection').classList.add('hidden');
}

async function loadRecentJobs() {
  try {
    const res = await fetch('/ai/jobs');
    const data = await res.json();
    const list = document.getElementById('recentJobsList');
    const section = document.getElementById('recentJobsSection');
    if (!list || !section) return;
    if (!data.success || !data.jobs || data.jobs.length === 0) {
      section.classList.add('hidden');
      return;
    }
    list.innerHTML = data.jobs.slice(0, 10).map(j => {
      const date = j.created_at ? new Date(j.created_at).toLocaleString('ar-SA') : '';
      const label = j.status === 'completed' ? `#${j.id} — ${j.chunks_count || 0} أجزاء — ${date}` : j.status === 'failed' ? `#${j.id} — فشل` : `#${j.id} — جاري...`;
      const canOpen = j.status === 'completed';
      const exported = j.exported_to_sheets ? ' <span class="inline-flex items-center gap-0.5 text-[#0f9d58]" title="تم التصدير إلى Google Sheets"><i class="fas fa-file-excel text-[10px]"></i></span>' : '';
      return `<button type="button" onclick="openJob(${j.id})" ${!canOpen ? 'disabled' : ''} class="px-3 py-2 rounded-lg text-xs font-medium ${canOpen ? 'bg-indigo-100 text-indigo-700 hover:bg-indigo-200' : 'bg-slate-100 text-slate-400'}">${label}${exported}</button>`;
    }).join('');
    section.classList.remove('hidden');
  } catch (_) {}
}

async function openJob(jobId) {
  try {
    const res = await fetch('/ai/analysis/' + jobId);
    const data = await res.json();
    if (!data.success || data.status !== 'completed') {
      showToast(data.message || 'لا يمكن فتح هذه المهمة', 'error');
      return;
    }
    displayedJobId = jobId;
    renderResults({ table: data.table, chunks: data.chunks, model: data.model, provider: data.provider });
    document.getElementById('resultsSection').classList.remove('hidden');
    document.getElementById('progressSection').classList.add('hidden');
    showToast('تم تحميل النتائج', 'success');
  } catch (_) {
    showToast('خطأ في تحميل النتائج', 'error');
  }
}

(async function loadAIInfo() {
  try {
    const res = await fetch('/ai/status');
    const data = await res.json();
    const label = document.getElementById('activeProviderLabel');
    const hint = document.getElementById('aiConnectionHint');
    if (data.openai?.selectedModel) {
      label.innerHTML = '<span class="py-1 px-3 rounded-full bg-emerald-50 text-emerald-600 font-medium">OpenAI: ' + data.openai.selectedModel + '</span>';
      if (hint) hint.textContent = '— متصل، يُستخدم للتحليل أدناه';
    } else if (data.gemini?.selectedModel) {
      label.innerHTML = '<span class="py-1 px-3 rounded-full bg-blue-50 text-blue-600 font-medium">Gemini: ' + data.gemini.selectedModel + '</span>';
      if (hint) hint.textContent = '— متصل، يُستخدم للتحليل أدناه';
    } else {
      label.innerHTML = '<a href="/settings" class="py-1 px-3 rounded-full bg-amber-50 text-amber-600 font-medium text-xs hover:bg-amber-100">⚠ ربط الذكاء الاصطناعي من الإعدادات</a>';
      if (hint) hint.textContent = '— ضع المفتاح واختر الموديل في الإعدادات ثم استخدم التحليل هنا';
    }
  } catch {}
})();

function openExportSheetsModal() {
  var md = document.getElementById('rawMarkdown').textContent;
  if (!md || !md.trim().startsWith('|')) {
    showToast('لا توجد نتائج جدول للتصدير', 'error');
    return;
  }
  var modal = document.getElementById('exportSheetsModal');
  if (!modal) return;
  modal.classList.remove('hidden');
  modal.style.display = 'flex';
  document.getElementById('exportSheetName').value = '';
  document.querySelector('input[name="exportMode"][value="newSheet"]').checked = true;
  document.getElementById('exportSheetSelectWrap').classList.add('hidden');
  var sel = document.getElementById('exportSheetSelect');
  if (sel) sel.innerHTML = '<option value="">اختر الورقة</option>';
}
function closeExportSheetsModal() {
  var modal = document.getElementById('exportSheetsModal');
  if (modal) { modal.classList.add('hidden'); modal.style.display = 'none'; }
}
async function loadSheetsListForExport() {
  var wrap = document.getElementById('exportSheetSelectWrap');
  var sel = document.getElementById('exportSheetSelect');
  if (!sel) return;
  wrap.classList.remove('hidden');
  try {
    var res = await fetch('/sheets/sheets-list');
    var data = await res.json();
    if (!data.success) {
      sel.innerHTML = '<option value="">' + (data.message || 'لم يتم ربط جدول') + '</option>';
      return;
    }
    sel.innerHTML = (data.sheets && data.sheets.length)
      ? data.sheets.map(function(s) { return '<option value="' + (s.title || '').replace(/"/g, '&quot;') + '">' + (s.title || '') + '</option>'; }).join('')
      : '<option value="">لا توجد أوراق</option>';
  } catch (_) {
    sel.innerHTML = '<option value="">خطأ في التحميل</option>';
  }
}
async function doExportToSheets() {
  var md = document.getElementById('rawMarkdown').textContent;
  if (!md || !md.trim().startsWith('|')) {
    showToast('لا توجد نتائج للتصدير', 'error');
    return;
  }
  var mode = (document.querySelector('input[name="exportMode"]:checked') || {}).value || 'newSheet';
  var sheetName = document.getElementById('exportSheetName').value.trim();
  var targetSheetTitle = mode === 'appendToSheet' ? (document.getElementById('exportSheetSelect').value || '').trim() : '';
  if (mode === 'appendToSheet' && !targetSheetTitle) {
    showToast('اختر ورقة للإلحاق', 'error');
    return;
  }
  var btn = document.getElementById('exportSheetsSubmitBtn');
  if (btn) { btn.disabled = true; btn.textContent = 'جاري التصدير...'; }
  try {
    var res = await fetch('/sheets/export', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ tableMarkdown: md, sheetName: sheetName || undefined, mode: mode, targetSheetTitle: targetSheetTitle || undefined, jobId: displayedJobId != null ? displayedJobId : undefined })
    });
    var data = await res.json();
    if (data.success) {
      showToast(data.message, 'success');
      closeExportSheetsModal();
      loadRecentJobs();
    } else {
      showToast(data.message || 'فشل التصدير', 'error');
    }
  } catch (_) {
    showToast('خطأ في الاتصال', 'error');
  }
  if (btn) { btn.disabled = false; btn.textContent = 'تصدير'; }
}

(function initExportModeRadios() {
  document.querySelectorAll('input[name="exportMode"]').forEach(function(r) {
    r.addEventListener('change', function() {
      var wrap = document.getElementById('exportSheetSelectWrap');
      if (r.value === 'appendToSheet') { wrap.classList.remove('hidden'); loadSheetsListForExport(); }
      else if (wrap) wrap.classList.add('hidden');
    });
  });
})();

(async function initMessagesPage() {
  await loadRecentJobs();
})();
</script>
