<div class="max-w-6xl mx-auto px-4 sm:px-0 pb-10 space-y-6 lg:space-y-8" dir="rtl" id="recvPageRoot">
  <header class="relative overflow-hidden rounded-2xl border border-emerald-200/80 bg-gradient-to-br from-emerald-50/90 via-white to-slate-50 shadow-sm">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_50%_at_100%_0%,rgba(16,185,129,0.1),transparent)] pointer-events-none"></div>
    <div class="relative p-5 sm:p-7 lg:p-8">
      <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-5">
        <div class="min-w-0 flex-1">
          <p class="text-xs font-semibold uppercase tracking-wider text-emerald-700 mb-1">مستحقات</p>
          <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight">ديين لنا</h2>
          <p class="text-sm text-slate-600 mt-2 max-w-2xl leading-relaxed">
            وكالات فرعية، معتمدون، ومستخدمون بأرصدة لصالحنا؛ والمرتجعات المعلّقة لدى الكيان.
            <span class="block mt-2 text-xs text-slate-500">لمستحقات <strong class="text-slate-700">الدفع</strong> تجاه المعتمدين والوكالات راجع <a href="/payment-due" class="text-sky-600 font-semibold hover:underline">مطلوب دفع</a>.</span>
          </p>
        </div>
        <div class="flex flex-wrap gap-2 shrink-0">
          <a href="/payables-us" class="inline-flex items-center gap-2 rounded-xl border border-rose-200 bg-rose-50 px-4 py-2.5 text-sm font-semibold text-rose-900 shadow-sm transition hover:bg-rose-100">
            <i class="fas fa-hand-holding-usd text-rose-600 text-xs"></i>
            دين علينا
          </a>
          <a href="/payment-due" class="inline-flex items-center gap-2 rounded-xl border border-amber-200 bg-amber-50 px-4 py-2.5 text-sm font-semibold text-amber-900 shadow-sm transition hover:bg-amber-100">
            <i class="fas fa-money-check-alt text-amber-600 text-xs"></i>
            مطلوب دفع
          </a>
          <a href="/debts" class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 shadow-sm transition hover:border-emerald-200 hover:bg-emerald-50">
            <i class="fas fa-file-invoice-dollar text-emerald-600 text-xs"></i>
            الديون
          </a>
          <a href="/dashboard" class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 shadow-sm transition hover:border-sky-200 hover:bg-sky-50">
            <i class="fas fa-arrow-right text-xs opacity-70"></i>
            لوحة التحكم
          </a>
        </div>
      </div>
    </div>
  </header>

  <!-- إجمالي + شبكة لوحة لابتوب -->
  <section class="grid grid-cols-1 lg:grid-cols-12 gap-4 lg:gap-6 items-stretch">
    <div class="lg:col-span-5 rounded-2xl border border-emerald-200/90 bg-gradient-to-br from-emerald-600 via-emerald-700 to-teal-800 p-6 sm:p-8 text-white shadow-lg shadow-emerald-900/25">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-white/15 backdrop-blur-sm"><i class="fas fa-coins text-xl"></i></span>
        <div>
          <p class="text-sm text-emerald-100">الإجمالي التقريبي</p>
          <p class="text-xs text-emerald-200/90">USD — مجموع المصادر أدناه</p>
        </div>
      </div>
      <p class="font-mono text-4xl sm:text-5xl font-bold tabular-nums tracking-tight" id="recvToUsTotalVal">—</p>
    </div>
    <div class="lg:col-span-7 grid grid-cols-2 gap-3 sm:gap-4">
      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm flex flex-col gap-2">
        <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-sky-100 text-sky-700"><i class="fas fa-warehouse"></i></span>
        <p class="text-xs font-bold text-slate-700">وكالات فرعية</p>
        <p class="text-[0.65rem] text-slate-500 leading-snug">رصيد سالب للوكالة = لنا</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm flex flex-col gap-2">
        <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-violet-100 text-violet-800"><i class="fas fa-stamp"></i></span>
        <p class="text-xs font-bold text-slate-700">معتمدون</p>
        <p class="text-[0.65rem] text-slate-500 leading-snug">رصيد سالب = لنا على المعتمد</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm flex flex-col gap-2">
        <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-sky-100 text-sky-800"><i class="fas fa-user"></i></span>
        <p class="text-xs font-bold text-slate-700">مستخدمون</p>
        <p class="text-[0.65rem] text-slate-500 leading-snug">دين على العضو</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm flex flex-col gap-2">
        <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-orange-100 text-orange-800"><i class="fas fa-undo"></i></span>
        <p class="text-xs font-bold text-slate-700">مرتجعات</p>
        <p class="text-[0.65rem] text-slate-500 leading-snug">معلّقة لدى الكيان</p>
      </div>
    </div>
  </section>

  <!-- أقسام التفاصيل: عمود واحد بالموبايل، صفّان باللابتوب -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-6">
    <section class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden flex flex-col min-h-[12rem]">
      <div class="flex items-center gap-3 border-b border-slate-100 bg-sky-50/50 px-5 py-4">
        <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-sky-100 text-sky-800"><i class="fas fa-warehouse"></i></span>
        <div>
          <h3 class="text-base font-bold text-slate-900">وكالات فرعية — دين لنا</h3>
          <p class="text-xs text-slate-500">من سجل معاملات الوكالة</p>
        </div>
      </div>
      <div id="recvAgencies" class="flex-1 p-2 sm:p-4 space-y-2 text-sm"></div>
    </section>
    <section class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden flex flex-col min-h-[12rem]">
      <div class="flex items-center gap-3 border-b border-slate-100 bg-violet-50/50 px-5 py-4">
        <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-violet-100 text-violet-800"><i class="fas fa-stamp"></i></span>
        <div>
          <h3 class="text-base font-bold text-slate-900">معتمدون — دين لنا</h3>
          <p class="text-xs text-slate-500">رصيد سالب للمعتمد</p>
        </div>
      </div>
      <div id="recvAccred" class="flex-1 p-2 sm:p-4 space-y-2 text-sm"></div>
    </section>
    <section class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden flex flex-col min-h-[12rem]">
      <div class="flex items-center gap-3 border-b border-slate-100 bg-sky-50/50 px-5 py-4">
        <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-sky-100 text-sky-800"><i class="fas fa-users"></i></span>
        <div>
          <h3 class="text-base font-bold text-slate-900">مستخدمون — دين على العضو</h3>
          <p class="text-xs text-slate-500">أرقام تعريف المستخدم</p>
        </div>
      </div>
      <div id="recvMembers" class="flex-1 p-2 sm:p-4 space-y-2 text-sm"></div>
    </section>
    <section class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden flex flex-col min-h-[10rem]">
      <div class="flex items-center gap-3 border-b border-slate-100 bg-orange-50/50 px-5 py-4">
        <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-orange-100 text-orange-800"><i class="fas fa-box-open"></i></span>
        <div>
          <h3 class="text-base font-bold text-slate-900">مرتجعات معلّقة</h3>
          <p class="text-xs text-slate-500">لدى الكيان</p>
        </div>
      </div>
      <div class="p-5">
        <p id="recvReturns" class="text-sm text-slate-700 leading-relaxed">—</p>
      </div>
    </section>
  </div>
</div>
