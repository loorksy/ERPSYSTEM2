<div class="sub-agencies-page w-full max-w-6xl mx-auto px-4 sm:px-0 pb-10" dir="rtl">
  <!-- قائمة الوكالات -->
  <div id="subAgenciesList">
    <div class="erp-module-shell rounded-2xl border border-slate-200/90 bg-white shadow-sm overflow-hidden mb-6">
      <div class="relative overflow-hidden border-b border-slate-200/80 bg-gradient-to-br from-fuchsia-50/90 via-white to-slate-50 px-4 py-5 sm:px-7 sm:py-6">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_50%_at_0%_0%,rgba(192,38,211,0.08),transparent)] pointer-events-none"></div>
        <div class="relative flex items-start gap-3 sm:gap-4">
          <div class="flex h-11 w-11 sm:h-12 sm:w-12 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-fuchsia-600 to-purple-700 text-white shadow-md">
            <i class="fas fa-store text-lg sm:text-xl"></i>
          </div>
          <div class="min-w-0 flex-1">
            <p class="text-xs font-semibold text-fuchsia-800 mb-0.5">الوكالات والمزامنة</p>
            <h2 class="text-lg sm:text-2xl font-bold text-slate-900 tracking-tight">الوكالات الفرعية</h2>
            <p class="text-sm text-slate-600 mt-1 leading-relaxed">إدارة الوكالات، التسليم، والمزامنة من ملف الإدارة.</p>
          </div>
        </div>
      </div>
      <div class="border-b border-slate-100 bg-slate-50/95 px-4 py-4 sm:px-6 sm:py-5">
        <p class="text-xs font-semibold text-slate-500 mb-3 sm:mb-4">الإجراءات والمزامنة</p>
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
          <div class="flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-stretch sm:gap-2">
            <button type="button" onclick="subAgenciesOpenDeliveryModal()" class="w-full sm:w-auto px-4 py-2.5 rounded-xl bg-emerald-600 text-white text-sm font-semibold shadow-md hover:bg-emerald-700 active:scale-[0.99] transition text-center">
              تسليم
            </button>
            <button type="button" onclick="subAgenciesOpenAddModal()" class="btn-add inline-flex w-full sm:w-auto items-center justify-center">
              <i class="fas fa-plus ml-2"></i>
              إضافة وكالة
            </button>
          </div>
          <div class="w-full lg:max-w-md xl:max-w-lg flex flex-col gap-2 sm:flex-row sm:items-end sm:gap-3 pt-2 border-t border-slate-200/80 lg:border-t-0 lg:pt-0">
            <div class="flex-1 min-w-0">
              <label class="block text-xs font-medium text-slate-600 mb-1.5">مزامنة من ملف الإدارة (كل ورقة بعد ورقة الإدارة = وكالة)</label>
              <select id="subAgencySyncCycleSelect" class="input-select w-full max-w-full"></select>
            </div>
            <button type="button" onclick="subAgenciesRunManagementSync()" class="w-full sm:w-auto shrink-0 px-4 py-2.5 rounded-xl bg-indigo-600 text-white text-sm font-semibold shadow-md hover:bg-indigo-700 active:scale-[0.99] transition whitespace-nowrap">
              مزامنة من Google
            </button>
          </div>
        </div>
      </div>
    </div>
    <div id="subAgenciesCards" class="agencies-grid">
      <p class="text-slate-400 col-span-full text-center py-12">جاري التحميل...</p>
    </div>
  </div>

  <!-- لوحة تحكم الوكالة -->
  <div id="subAgencyDashboard" class="hidden">
    <div class="mb-8 flex items-center gap-4 flex-wrap">
      <button type="button" onclick="subAgenciesBackToList()" class="btn-back">
        <i class="fas fa-arrow-right"></i>
      </button>
      <h2 id="subAgencyDashboardTitle" class="text-2xl font-bold text-slate-800">لوحة الوكالة</h2>
      <button type="button" onclick="subAgenciesDownloadPdfCurrent()" class="px-3 py-2 rounded-xl bg-slate-700 text-white text-sm font-semibold hover:bg-slate-800 inline-flex items-center gap-2" title="تنزيل تقرير PDF لهذه الوكالة">
        <i class="fas fa-file-pdf"></i>
        تنزيل PDF
      </button>
    </div>

    <div class="mb-8">
      <label class="block text-sm font-medium text-slate-600 mb-2">الدورة المالية</label>
      <select id="subAgencyCycleSelect" class="input-select" onchange="subAgenciesLoadDashboard()">
        <option value="">-- اختر الدورة --</option>
      </select>
    </div>

    <div class="dashboard-cards">
      <div class="dash-card dash-card-profit">
        <p class="dash-card-label">ربح الوكالة</p>
        <p id="subAgencyProfit" class="dash-card-value">0</p>
      </div>
      <div class="dash-card dash-card-users" onclick="subAgenciesShowUsers()">
        <p class="dash-card-label">المستخدمين</p>
        <p id="subAgencyUsersCount" class="dash-card-value">0</p>
      </div>
      <div class="dash-card dash-card-percent">
        <p class="dash-card-label">حصة ربح الشركة من عمود و (٪)</p>
        <div class="flex flex-wrap items-center gap-2">
          <input type="number" id="subAgencyPercentInput" step="0.1" min="0" max="100" class="input-percent" placeholder="0" title="مثال: 10 تعني 10 للشركة و90 للوكالة من كل 100 في عمود W">
          <span class="text-amber-700 font-bold">%</span>
          <button type="button" onclick="subAgenciesSaveCyclePercent()" class="px-3 py-1.5 rounded-lg bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700">
            حفظ للدورة
          </button>
        </div>
        <p class="text-xs text-slate-500 mt-2">القيمة = نسبة الشركة من عمود W؛ الباقي لربح الوكالة ويُحفظ للدورة فقط ويُعاد احتساب أرباح المزامنة.</p>
      </div>
    </div>

    <div class="mb-8 flex flex-wrap gap-3">
      <button type="button" onclick="subAgenciesOpenRewardModal()" class="btn-reward">
        <i class="fas fa-gift ml-2"></i>
        إضافة مكافأة
      </button>
      <button type="button" onclick="subAgenciesOpenDeductModal()" class="btn-deduct">
        <i class="fas fa-minus-circle ml-2"></i>
        خصم (شحن / راتب)
      </button>
    </div>

    <section class="tx-section">
      <h5 class="tx-section-title">سجل المعاملات</h5>
      <div class="tx-filters">
        <select id="subAgencyTxTypeFilter" class="input-filter" onchange="subAgenciesLoadTransactions()">
          <option value="">كل الأنواع</option>
          <option value="profit">ربح</option>
          <option value="reward">مكافأة</option>
          <option value="deduction">خصم</option>
          <option value="due">مستحقات</option>
        </select>
        <input type="date" id="subAgencyTxFrom" class="input-filter">
        <input type="date" id="subAgencyTxTo" class="input-filter">
        <button type="button" onclick="subAgenciesLoadTransactions()" class="btn-filter">تطبيق</button>
      </div>
      <div id="subAgencyTxList" class="tx-list">
        <p class="text-slate-400 text-center py-8">جاري التحميل...</p>
      </div>
    </section>
  </div>
</div>

<!-- نافذة إضافة وكالة -->
<div id="subAgencyAddModal" class="modal-overlay hidden">
  <div class="modal-box">
    <div class="modal-header">
      <h4>إضافة وكالة</h4>
      <button type="button" onclick="subAgenciesCloseAddModal()" class="modal-close"><i class="fas fa-times"></i></button>
    </div>
    <form id="subAgencyAddForm" class="modal-form">
      <div class="form-group">
        <label>اسم الوكالة</label>
        <input type="text" id="subAgencyAddName" required placeholder="اسم الوكالة">
      </div>
      <div class="form-group">
        <label>حصة ربح الشركة من عمود و (%)</label>
        <input type="number" id="subAgencyAddPercent" step="0.1" min="0" max="100" value="0" placeholder="0" title="مثال: 10 = شركة 10٪ ووكالة 90٪ من كل 100">
      </div>
      <div class="form-actions">
        <button type="submit" class="btn-submit">حفظ</button>
        <button type="button" onclick="subAgenciesCloseAddModal()" class="btn-cancel">إلغاء</button>
      </div>
    </form>
  </div>
</div>

<!-- نافذة إضافة مكافأة -->
<div id="subAgencyRewardModal" class="modal-overlay hidden">
  <div class="modal-box">
    <div class="modal-header">
      <h4>إضافة مكافأة</h4>
      <button type="button" onclick="subAgenciesCloseRewardModal()" class="modal-close"><i class="fas fa-times"></i></button>
    </div>
    <form id="subAgencyRewardForm" class="modal-form">
      <p id="subAgencyRewardBalanceHint" class="text-sm rounded-lg p-3 mb-3 bg-slate-50 text-slate-600 border border-slate-100 hidden"></p>
      <div class="form-group">
        <label>مبلغ المكافأة</label>
        <input type="number" id="subAgencyRewardAmount" step="0.01" min="0.01" required>
      </div>
      <div class="form-group flex items-start gap-2">
        <input type="checkbox" id="subAgencyRewardDeductFromFund" class="mt-1">
        <label for="subAgencyRewardDeductFromFund" class="text-sm leading-relaxed">خصم المبلغ من الصندوق الرئيسي وتسجيله مصروفاً</label>
      </div>
      <div class="form-group">
        <label>ملاحظة</label>
        <textarea id="subAgencyRewardNotes" rows="2" placeholder="اختياري"></textarea>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn-submit">إضافة</button>
        <button type="button" onclick="subAgenciesCloseRewardModal()" class="btn-cancel">إلغاء</button>
      </div>
    </form>
  </div>
</div>

<!-- نافذة خصم (شحن / راتب) -->
<div id="subAgencyDeductModal" class="modal-overlay hidden">
  <div class="modal-box">
    <div class="modal-header">
      <h4>خصم وكالة</h4>
      <button type="button" onclick="subAgenciesCloseDeductModal()" class="modal-close"><i class="fas fa-times"></i></button>
    </div>
    <form id="subAgencyDeductForm" class="modal-form">
      <div class="form-group">
        <label>نوع الخصم</label>
        <select id="subAgencyDeductKind" class="w-full px-3 py-2 rounded-lg border border-slate-200" onchange="subAgenciesDeductKindChange()">
          <option value="shipping">شحن (فتح بيع مربوط بالوكالة)</option>
          <option value="salary">راتب / مستحقات</option>
        </select>
      </div>
      <div id="subAgencyDeductSalaryFields" class="space-y-3 hidden">
        <div class="form-group">
          <label>المبلغ (USD)</label>
          <input type="number" id="subAgencyDeductAmount" step="0.01" min="0.01" class="w-full px-3 py-2 rounded-lg border border-slate-200">
        </div>
        <div class="form-group">
          <label>السداد</label>
          <select id="subAgencyDeductPayrollMode" class="w-full px-3 py-2 rounded-lg border border-slate-200">
            <option value="fund">خصم من الصندوق الرئيسي</option>
            <option value="debt_only">تسجيل دين علينا فقط (بدون صندوق)</option>
          </select>
        </div>
        <div class="form-group">
          <label>ملاحظة</label>
          <textarea id="subAgencyDeductNotes" rows="2" placeholder="اختياري"></textarea>
        </div>
      </div>
      <p id="subAgencyDeductShipHint" class="text-sm text-slate-600 mb-3">سيتم فتح صفحة الشحن لبيع مربوط بهذه الوكالة.</p>
      <div class="form-actions">
        <button type="submit" class="btn-submit" id="subAgencyDeductSubmit">متابعة</button>
        <button type="button" onclick="subAgenciesCloseDeductModal()" class="btn-cancel">إلغاء</button>
      </div>
    </form>
  </div>
</div>

<!-- نافذة قائمة المستخدمين -->
<div id="subAgencyUsersModal" class="modal-overlay hidden">
  <div class="modal-box modal-box-tall">
    <div class="modal-header">
      <h4>المستخدمين التابعين للوكالة</h4>
      <button type="button" onclick="subAgenciesCloseUsersModal()" class="modal-close"><i class="fas fa-times"></i></button>
    </div>
    <div id="subAgencyUsersList" class="modal-body">
      <p class="text-slate-400 text-center py-8">جاري التحميل...</p>
    </div>
  </div>
</div>

<div id="subAgencyDeliveryModal" class="modal-overlay hidden">
  <div class="modal-box">
    <div class="modal-header">
      <h4>تسليم أرصدة وكالات</h4>
      <button type="button" onclick="subAgenciesCloseDeliveryModal()" class="modal-close"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-form space-y-3">
      <div class="form-group">
        <label>الدورة</label>
        <select id="saDeliveryCycle" class="w-full px-3 py-2 rounded-xl border border-slate-200"></select>
      </div>
      <div id="saDeliveryChecks" class="text-sm max-h-48 overflow-y-auto space-y-2"></div>
      <button type="button" onclick="subAgenciesSubmitDelivery()" class="btn-submit w-full">تسليم الراتب</button>
    </div>
  </div>
</div>

<style>
.agencies-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.25rem; }
.btn-add { padding: 0.75rem 1.25rem; border-radius: 0.75rem; font-weight: 600; font-size: 0.875rem; background: linear-gradient(135deg, #4f46e5, #6366f1); color: white; transition: all 0.2s; }
.btn-add:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(79, 70, 229, 0.4); }
