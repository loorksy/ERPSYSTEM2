<div class="sub-agencies-page w-full max-w-5xl mx-auto" dir="rtl">
  <!-- قائمة الوكالات -->
  <div id="subAgenciesList">
    <div class="flex items-center justify-between mb-8 flex-wrap gap-3">
      <h2 class="text-2xl font-bold text-slate-800">الوكالات الفرعية</h2>
      <div class="flex gap-2 flex-wrap">
        <button type="button" onclick="subAgenciesOpenDeliveryModal()" class="px-4 py-2.5 rounded-xl bg-emerald-600 text-white text-sm font-semibold shadow-md hover:bg-emerald-700 active:scale-[0.99] transition">
          تسليم
        </button>
        <button type="button" onclick="subAgenciesOpenAddModal()" class="btn-add">
          <i class="fas fa-plus ml-2"></i>
          إضافة وكالة
        </button>
      </div>
    </div>
    <div class="mb-6 flex flex-wrap items-end gap-3 p-4 rounded-xl bg-slate-50 border border-slate-100">
      <div class="min-w-[200px]">
        <label class="block text-xs text-slate-500 mb-1">مزامنة من ملف الإدارة (كل ورقة بعد ورقة الإدارة = وكالة)</label>
        <select id="subAgencySyncCycleSelect" class="input-select w-full max-w-xs"></select>
      </div>
      <button type="button" onclick="subAgenciesRunManagementSync()" class="px-4 py-2.5 rounded-xl bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700">
        مزامنة من Google
      </button>
    </div>
    <div id="subAgenciesCards" class="agencies-grid">
      <p class="text-slate-400 col-span-full text-center py-12">جاري التحميل...</p>
    </div>
  </div>

  <!-- لوحة تحكم الوكالة -->
  <div id="subAgencyDashboard" class="hidden">
    <div class="mb-8 flex items-center gap-4 flex-wrap">
      <button type="button" onclick="subAgenciesBackToList()" class="btn-back">
        <i class="fas fa-arrow-right"></i>
      </button>
      <h2 id="subAgencyDashboardTitle" class="text-2xl font-bold text-slate-800">لوحة الوكالة</h2>
      <button type="button" onclick="subAgenciesDownloadPdfCurrent()" class="px-3 py-2 rounded-xl bg-slate-700 text-white text-sm font-semibold hover:bg-slate-800 inline-flex items-center gap-2" title="تنزيل تقرير PDF لهذه الوكالة">
        <i class="fas fa-file-pdf"></i>
        تنزيل PDF
      </button>
    </div>

    <div class="mb-8">
      <label class="block text-sm font-medium text-slate-600 mb-2">الدورة المالية</label>
      <select id="subAgencyCycleSelect" class="input-select" onchange="subAgenciesLoadDashboard()">
        <option value="">-- اختر الدورة --</option>
      </select>
    </div>

    <div class="dashboard-cards">
      <div class="dash-card dash-card-profit">
        <p class="dash-card-label">ربح الوكالة</p>
        <p id="subAgencyProfit" class="dash-card-value">0</p>
      </div>
      <div class="dash-card dash-card-users" onclick="subAgenciesShowUsers()">
        <p class="dash-card-label">المستخدمين</p>
        <p id="subAgencyUsersCount" class="dash-card-value">0</p>
      </div>
      <div class="dash-card dash-card-percent">
        <p class="dash-card-label">نسبة الوكالة</p>
        <div class="flex flex-wrap items-center gap-2">
          <input type="number" id="subAgencyPercentInput" step="0.1" min="0" max="100" class="input-percent" placeholder="0">
          <span class="text-amber-700 font-bold">%</span>
          <button type="button" onclick="subAgenciesSaveCyclePercent()" class="px-3 py-1.5 rounded-lg bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700">
            حفظ للدورة
          </button>
        </div>
        <p class="text-xs text-slate-500 mt-2">يُحفظ النسبة لهذه الدورة فقط ويُعاد احتساب ربح عمود W من المزامنة.</p>
      </div>
    </div>

    <div class="mb-8">
      <button type="button" onclick="subAgenciesOpenRewardModal()" class="btn-reward">
        <i class="fas fa-gift ml-2"></i>
        إضافة مكافأة
      </button>
    </div>

    <section class="tx-section">
      <h5 class="tx-section-title">سجل المعاملات</h5>
      <div class="tx-filters">
        <select id="subAgencyTxTypeFilter" class="input-filter" onchange="subAgenciesLoadTransactions()">
          <option value="">كل الأنواع</option>
          <option value="profit">ربح</option>
          <option value="reward">مكافأة</option>
          <option value="deduction">خصم</option>
          <option value="due">مستحقات</option>
        </select>
        <input type="date" id="subAgencyTxFrom" class="input-filter">
        <input type="date" id="subAgencyTxTo" class="input-filter">
        <button type="button" onclick="subAgenciesLoadTransactions()" class="btn-filter">تطبيق</button>
      </div>
      <div id="subAgencyTxList" class="tx-list">
        <p class="text-slate-400 text-center py-8">جاري التحميل...</p>
      </div>
    </section>
  </div>
</div>

<!-- نافذة إضافة وكالة -->
<div id="subAgencyAddModal" class="modal-overlay hidden">
  <div class="modal-box">
    <div class="modal-header">
      <h4>إضافة وكالة</h4>
      <button type="button" onclick="subAgenciesCloseAddModal()" class="modal-close"><i class="fas fa-times"></i></button>
    </div>
    <form id="subAgencyAddForm" class="modal-form">
      <div class="form-group">
        <label>اسم الوكالة</label>
        <input type="text" id="subAgencyAddName" required placeholder="اسم الوكالة">
      </div>
      <div class="form-group">
        <label>نسبة الوكالة (%)</label>
        <input type="number" id="subAgencyAddPercent" step="0.1" min="0" max="100" value="0" placeholder="0">
      </div>
      <div class="form-actions">
        <button type="submit" class="btn-submit">حفظ</button>
        <button type="button" onclick="subAgenciesCloseAddModal()" class="btn-cancel">إلغاء</button>
      </div>
    </form>
  </div>
</div>

<!-- نافذة إضافة مكافأة -->
<div id="subAgencyRewardModal" class="modal-overlay hidden">
  <div class="modal-box">
    <div class="modal-header">
      <h4>إضافة مكافأة</h4>
      <button type="button" onclick="subAgenciesCloseRewardModal()" class="modal-close"><i class="fas fa-times"></i></button>
    </div>
    <form id="subAgencyRewardForm" class="modal-form">
      <p id="subAgencyRewardBalanceHint" class="text-sm rounded-lg p-3 mb-3 bg-slate-50 text-slate-600 border border-slate-100 hidden"></p>
      <div class="form-group">
        <label>مبلغ المكافأة</label>
        <input type="number" id="subAgencyRewardAmount" step="0.01" min="0.01" required>
      </div>
      <div class="form-group flex items-start gap-2">
        <input type="checkbox" id="subAgencyRewardDeductFromFund" class="mt-1">
        <label for="subAgencyRewardDeductFromFund" class="text-sm leading-relaxed">خصم المبلغ من الصندوق الرئيسي وتسجيله مصروفاً</label>
      </div>
      <div class="form-group">
        <label>ملاحظة</label>
        <textarea id="subAgencyRewardNotes" rows="2" placeholder="اختياري"></textarea>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn-submit">إضافة</button>
        <button type="button" onclick="subAgenciesCloseRewardModal()" class="btn-cancel">إلغاء</button>
      </div>
    </form>
  </div>
</div>

<!-- نافذة قائمة المستخدمين -->
<div id="subAgencyUsersModal" class="modal-overlay hidden">
  <div class="modal-box modal-box-tall">
    <div class="modal-header">
      <h4>المستخدمين التابعين للوكالة</h4>
      <button type="button" onclick="subAgenciesCloseUsersModal()" class="modal-close"><i class="fas fa-times"></i></button>
    </div>
    <div id="subAgencyUsersList" class="modal-body">
      <p class="text-slate-400 text-center py-8">جاري التحميل...</p>
    </div>
  </div>
</div>

<div id="subAgencyDeliveryModal" class="modal-overlay hidden">
  <div class="modal-box">
    <div class="modal-header">
      <h4>تسليم أرصدة وكالات</h4>
      <button type="button" onclick="subAgenciesCloseDeliveryModal()" class="modal-close"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-form space-y-3">
      <div class="form-group">
        <label>الدورة</label>
        <select id="saDeliveryCycle" class="w-full px-3 py-2 rounded-xl border border-slate-200"></select>
      </div>
      <div id="saDeliveryChecks" class="text-sm max-h-48 overflow-y-auto space-y-2"></div>
      <button type="button" onclick="subAgenciesSubmitDelivery()" class="btn-submit w-full">تسليم الراتب</button>
    </div>
  </div>
</div>

<style>
.agencies-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.25rem; }
.btn-add { padding: 0.75rem 1.25rem; border-radius: 0.75rem; font-weight: 600; font-size: 0.875rem; background: linear-gradient(135deg, #4f46e5, #6366f1); color: white; transition: all 0.2s; }
.btn-add:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(79, 70, 229, 0.4); }
.btn-back { width: 2.5rem; height: 2.5rem; border-radius: 0.75rem; background: #f1f5f9; color: #64748b; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
.btn-back:hover { background: #e2e8f0; color: #475569; }
.input-select { max-width: 16rem; padding: 0.625rem 1rem; border-radius: 0.75rem; border: 1px solid #e2e8f0; }
.dashboard-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
.dash-card { padding: 1.25rem; border-radius: 1rem; transition: transform 0.2s; }
.dash-card-users { cursor: pointer; }
.dash-card-users:hover { transform: scale(1.02); }
.dash-card-profit { background: linear-gradient(135deg, #d1fae5, #a7f3d0); color: #047857; }
.dash-card-users { background: linear-gradient(135deg, #e0e7ff, #c7d2fe); color: #3730a3; }
.dash-card-percent { background: linear-gradient(135deg, #fef3c7, #fde68a); color: #b45309; }
.dash-card-label { font-size: 0.875rem; font-weight: 500; margin-bottom: 0.25rem; opacity: 0.9; }
.dash-card-value { font-size: 1.5rem; font-weight: 700; }
.input-percent { width: 5rem; padding: 0.25rem 0.5rem; border-radius: 0.5rem; border: 1px solid #fcd34d; font-weight: 700; color: #b45309; }
.btn-reward { padding: 0.75rem 1.25rem; border-radius: 0.75rem; font-weight: 600; font-size: 0.875rem; background: linear-gradient(135deg, #4f46e5, #6366f1); color: white; transition: all 0.2s; box-shadow: 0 4px 12px rgba(79, 70, 229, 0.25); }
.btn-reward:hover { transform: translateY(-1px); box-shadow: 0 6px 16px rgba(79, 70, 229, 0.35); }
.tx-section { padding-top: 1.5rem; border-top: 1px solid #e2e8f0; }
.tx-section-title { font-size: 0.875rem; font-weight: 700; color: #334155; margin-bottom: 1rem; }
.tx-filters { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }
.input-filter { padding: 0.5rem 0.75rem; border-radius: 0.5rem; border: 1px solid #e2e8f0; font-size: 0.875rem; }
.btn-filter { padding: 0.5rem 1rem; border-radius: 0.5rem; background: #4f46e5; color: white; font-size: 0.875rem; font-weight: 500; }
.tx-list { display: flex; flex-direction: column; gap: 0.5rem; }
.modal-overlay { position: fixed; inset: 0; z-index: 2000; background: rgba(15, 23, 42, 0.45); backdrop-filter: blur(2px); display: flex; align-items: center; justify-content: center; padding: 1rem; }
.modal-overlay.hidden { display: none; }
.modal-overlay:not(.hidden) { display: flex; }
.modal-box { background: white; border-radius: 1rem; border: 1px solid #f1f5f9; box-shadow: 0 25px 50px -12px rgba(15, 23, 42, 0.15); max-width: 28rem; width: 100%; max-height: 90vh; overflow-y: auto; }
.modal-box-tall { max-height: 80vh; display: flex; flex-direction: column; }
.modal-header { padding: 1rem 1.5rem; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; justify-content: space-between; }
.modal-header h4 { font-size: 1.125rem; font-weight: 700; color: #1e293b; }
.modal-close { width: 2.5rem; height: 2.5rem; border-radius: 0.75rem; color: #94a3b8; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
.modal-close:hover { background: #f1f5f9; color: #64748b; }
.modal-form { padding: 1.5rem; }
.modal-body { padding: 1rem; overflow-y: auto; flex: 1; }
.form-group { margin-bottom: 1rem; }
.form-group label { display: block; font-size: 0.875rem; font-weight: 600; color: #334155; margin-bottom: 0.5rem; }
.form-group input, .form-group textarea { width: 100%; padding: 0.625rem 1rem; border-radius: 0.75rem; border: 1px solid #e2e8f0; }
.form-actions { display: flex; gap: 0.75rem; padding-top: 0.5rem; }
.btn-submit { flex: 1; padding: 0.75rem; border-radius: 0.75rem; font-weight: 600; background: #4f46e5; color: white; box-shadow: 0 4px 12px rgba(79, 70, 229, 0.25); }
.btn-submit:hover { background: #4338ca; }
.btn-cancel { padding: 0.75rem 1.25rem; border-radius: 0.75rem; font-weight: 600; background: #f1f5f9; color: #475569; }
.agency-card { padding: 1.25rem; border-radius: 1rem; cursor: pointer; transition: all 0.2s; border: none; }
.agency-card:hover { transform: translateY(-2px); box-shadow: 0 12px 24px -8px rgba(0,0,0,0.15); }
.agency-card h5 { font-weight: 700; font-size: 1rem; margin-bottom: 0.5rem; }
.agency-card .agency-meta { font-size: 0.8125rem; opacity: 0.9; margin-bottom: 0.25rem; }
.agency-card .agency-balance { font-size: 0.875rem; font-weight: 600; }
.tx-item { padding: 1rem; border-radius: 0.75rem; background: #f8fafc; display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 0.5rem; }
</style>
