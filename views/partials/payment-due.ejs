<div class="payment-due-page max-w-5xl mx-auto" dir="rtl">
  <!-- رأس الصفحة -->
  <div class="flex flex-wrap items-start justify-between gap-4 mb-8">
    <div class="flex items-start gap-4">
      <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-amber-500 to-orange-600 text-white shadow-lg shadow-amber-500/25">
        <i class="fas fa-money-bill-wave text-2xl"></i>
      </div>
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight">مطلوب دفع</h1>
        <p class="text-sm text-slate-500 mt-1.5 max-w-xl leading-relaxed">
          التزامات نقدية تجاه المعتمدين (رصيد موجب) والوكالات الفرعية عندما يكون الرصيد لصالحها. لا يُخلط مع «ديين لنا».
        </p>
      </div>
    </div>
    <div class="flex flex-wrap items-center gap-2">
      <a href="/receivables-to-us" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-semibold text-indigo-700 bg-indigo-50 border border-indigo-100 hover:bg-indigo-100 transition-colors">
        <i class="fas fa-hand-holding-heart text-indigo-500"></i>
        ديين لنا
      </a>
      <a href="/dashboard" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-semibold text-slate-600 bg-slate-100 hover:bg-slate-200 transition-colors">
        <i class="fas fa-arrow-right"></i>
        لوحة التحكم
      </a>
    </div>
  </div>

  <!-- بطاقة الإجمالي -->
  <div class="relative overflow-hidden rounded-3xl border border-amber-200/80 bg-gradient-to-br from-amber-500 via-amber-600 to-orange-600 p-6 sm:p-8 text-white shadow-xl shadow-amber-900/10 mb-8">
    <div class="absolute -left-16 -top-16 h-48 w-48 rounded-full bg-white/10 blur-2xl pointer-events-none"></div>
    <div class="absolute -right-8 bottom-0 h-32 w-32 rounded-full bg-orange-400/20 blur-xl pointer-events-none"></div>
    <div class="relative">
      <p class="text-sm font-medium text-amber-100/95 mb-1">الإجمالي التقريبي (USD)</p>
      <p class="text-4xl sm:text-5xl font-bold tabular-nums tracking-tight" id="paymentDueTotalVal">—</p>
      <p class="text-xs text-amber-100/80 mt-3 max-w-md">يُحدَّث من أرصدة المعتمدين والوكالات الفرعية حسب تعريف النظام الحالي.</p>
    </div>
  </div>

  <!-- تسليم -->
  <div class="rounded-2xl border border-slate-200/90 bg-white p-6 sm:p-8 shadow-sm mb-8 ring-1 ring-slate-900/5">
    <div class="flex flex-wrap items-center gap-3 mb-4">
      <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-slate-100 text-slate-700">
        <i class="fas fa-check-double"></i>
      </span>
      <div>
        <h2 class="text-lg font-bold text-slate-800">تسليم وتصفير</h2>
        <p class="text-xs text-slate-500">اختر البنود ثم نفّذ التسليم (نفس منطق تسليم الاعتمادات والوكالات).</p>
      </div>
    </div>
    <div class="grid sm:grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block text-xs font-semibold text-slate-600 mb-1.5">دورة مالية (اختياري)</label>
        <select id="paymentDueCycle" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50/50 text-slate-800 text-sm focus:ring-2 focus:ring-amber-500/30 focus:border-amber-400 transition-shadow"></select>
      </div>
    </div>
    <div id="paymentDueAccList" class="text-sm min-h-[3rem] text-slate-500">جاري التحميل…</div>
    <div id="paymentDueSubList" class="text-sm min-h-[3rem] mt-4 pt-4 border-t border-slate-100 text-slate-500">—</div>
    <button type="button" id="paymentDueSettleBtn" class="mt-6 w-full sm:w-auto sm:min-w-[200px] py-3 px-6 rounded-xl bg-gradient-to-l from-amber-600 to-orange-600 text-white font-bold text-sm shadow-md shadow-amber-600/25 hover:from-amber-700 hover:to-orange-700 active:scale-[0.99] transition-all disabled:opacity-50 disabled:pointer-events-none">
      <i class="fas fa-paper-plane ml-2"></i>
      تسليم المحدد
    </button>
  </div>

  <!-- تفاصيل منفصلة -->
  <div class="grid md:grid-cols-2 gap-6">
    <section class="rounded-2xl border border-slate-100 bg-white p-6 shadow-sm">
      <h3 class="text-base font-bold text-slate-800 mb-1 flex items-center gap-2">
        <i class="fas fa-user-check text-amber-600 text-sm"></i>
        معتمدون — مستحق دفع
      </h3>
      <p class="text-xs text-slate-500 mb-4">رصيد موجب في ملف المعتمد = التزام دفع تجاهه.</p>
      <div id="paymentDueAccDetail" class="text-sm text-slate-600 space-y-2">—</div>
    </section>
    <section class="rounded-2xl border border-slate-100 bg-white p-6 shadow-sm">
      <h3 class="text-base font-bold text-slate-800 mb-1 flex items-center gap-2">
        <i class="fas fa-store text-amber-600 text-sm"></i>
        وكالات فرعية — لصالحها
      </h3>
      <p class="text-xs text-slate-500 mb-4">رصيد محاسبي موجب = ما للوكالة علينا ضمن السجل.</p>
      <div id="paymentDueSubDetail" class="text-sm text-slate-600 space-y-2">—</div>
    </section>
  </div>
</div>
