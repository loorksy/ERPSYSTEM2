<div class="payment-due-page max-w-6xl mx-auto px-4 sm:px-0 pb-10 space-y-6 lg:space-y-8 min-w-0" dir="rtl">
  <header class="relative overflow-hidden rounded-2xl border border-amber-200/80 bg-gradient-to-br from-amber-50/90 via-white to-slate-50 shadow-sm">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_50%_at_100%_0%,rgba(245,158,11,0.12),transparent)] pointer-events-none"></div>
    <div class="relative p-5 sm:p-7 lg:p-8">
      <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-5">
        <div class="min-w-0 flex-1">
          <p class="text-xs font-semibold uppercase tracking-wider text-amber-800 mb-1">التزامات نقدية</p>
          <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight">مطلوب دفع</h2>
          <p class="text-sm text-slate-600 mt-2 max-w-2xl leading-relaxed">
            التزامات نقدية تجاه المعتمدين (رصيد موجب) والوكالات الفرعية عندما يكون الرصيد لصالحها. لا يُخلط مع «ديين لنا».
            <span class="block mt-2 text-xs text-slate-500">للمستحقات <strong class="text-slate-700">لصالحنا</strong> راجع <a href="/receivables-to-us" class="text-emerald-700 font-semibold hover:underline">ديين لنا</a>.</span>
          </p>
        </div>
        <div class="flex flex-wrap gap-2 shrink-0">
          <a href="/receivables-to-us" class="inline-flex items-center gap-2 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-2.5 text-sm font-semibold text-emerald-900 shadow-sm transition hover:bg-emerald-100">
            <i class="fas fa-hand-holding-heart text-emerald-600 text-xs"></i>
            ديين لنا
          </a>
          <a href="/payables-us" class="inline-flex items-center gap-2 rounded-xl border border-rose-200 bg-rose-50 px-4 py-2.5 text-sm font-semibold text-rose-900 shadow-sm transition hover:bg-rose-100">
            <i class="fas fa-hand-holding-usd text-rose-600 text-xs"></i>
            دين علينا
          </a>
          <a href="/debts" class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 shadow-sm transition hover:border-amber-200 hover:bg-amber-50/80">
            <i class="fas fa-file-invoice-dollar text-amber-700 text-xs"></i>
            الديون والملفات
          </a>
          <a href="/dashboard" class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 shadow-sm transition hover:border-indigo-200 hover:bg-indigo-50">
            <i class="fas fa-arrow-right text-xs opacity-70"></i>
            لوحة التحكم
          </a>
        </div>
      </div>
    </div>
  </header>

  <section class="grid grid-cols-1 lg:grid-cols-12 gap-4 lg:gap-6 items-stretch">
    <div class="lg:col-span-5 rounded-2xl border border-amber-200/90 bg-gradient-to-br from-amber-500 via-amber-600 to-orange-700 p-6 sm:p-8 text-white shadow-lg shadow-amber-900/25">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-white/15 backdrop-blur-sm"><i class="fas fa-money-bill-wave text-xl"></i></span>
        <div>
          <p class="text-sm text-amber-100">الإجمالي التقريبي</p>
          <p class="text-xs text-amber-200/90">USD — معتمدون + وكالات (مستحق دفع)</p>
        </div>
      </div>
      <p class="font-mono text-4xl sm:text-5xl font-bold tabular-nums tracking-tight" id="paymentDueTotalVal">—</p>
      <p class="mt-4 text-xs text-amber-100/90 leading-relaxed max-w-sm">يُحدَّث من أرصدة المعتمدين والوكالات الفرعية حسب تعريف النظام الحالي.</p>
    </div>
    <div class="lg:col-span-7 grid grid-cols-2 gap-3 sm:gap-4">
      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm flex flex-col gap-2 min-h-[5.5rem] justify-between">
        <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-indigo-100 text-indigo-800"><i class="fas fa-user-check"></i></span>
        <div>
          <p class="text-xs font-bold text-slate-800">معتمدون</p>
          <p class="text-[0.65rem] text-slate-500 leading-snug">رصيد موجب = التزام دفع</p>
        </div>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm flex flex-col gap-2 min-h-[5.5rem] justify-between">
        <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-sky-100 text-sky-800"><i class="fas fa-store"></i></span>
        <div>
          <p class="text-xs font-bold text-slate-800">وكالات فرعية</p>
          <p class="text-[0.65rem] text-slate-500 leading-snug">رصيد لصالح الوكالة</p>
        </div>
      </div>
      <div class="col-span-2 rounded-2xl border border-dashed border-amber-200/80 bg-amber-50/40 p-4 flex items-center gap-3">
        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-white text-amber-700 shadow-sm border border-amber-100"><i class="fas fa-circle-info"></i></span>
        <p class="text-xs text-amber-900/90 leading-relaxed">استخدم قسم «تسليم وتصفير» أدناه لاختيار البنود وتنفيذ التسليم (نفس منطق الاعتمادات والوكالات).</p>
      </div>
    </div>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
    <div class="flex flex-col sm:flex-row sm:items-center gap-3 border-b border-slate-100 bg-amber-50/50 px-5 py-4">
      <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-amber-100 text-amber-800 shrink-0"><i class="fas fa-check-double"></i></span>
      <div class="min-w-0 flex-1">
        <h3 class="text-base font-bold text-slate-900">تسليم وتصفير</h3>
        <p class="text-xs text-slate-500 mt-0.5">اختر البنود ثم نفّذ التسليم</p>
      </div>
    </div>
    <div class="p-4 sm:p-6 space-y-4">
      <div class="grid sm:grid-cols-2 gap-4 max-w-xl">
        <div>
          <label class="block text-xs font-semibold text-slate-600 mb-1.5">دورة مالية (اختياري)</label>
          <select id="paymentDueCycle" class="w-full px-4 py-2.5 rounded-xl border-2 border-slate-200 bg-slate-50/50 text-slate-800 text-sm focus:border-indigo-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/15"></select>
        </div>
      </div>
      <div id="paymentDueAccList" class="text-sm min-h-[3rem] text-slate-500 rounded-xl border border-slate-100 bg-slate-50/40 p-3 sm:p-4">جاري التحميل…</div>
      <div id="paymentDueSubList" class="text-sm min-h-[3rem] rounded-xl border border-slate-100 bg-slate-50/40 p-3 sm:p-4 text-slate-500">—</div>
      <button type="button" id="paymentDueSettleBtn" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 py-3 px-6 rounded-xl bg-indigo-600 text-white font-bold text-sm shadow-md shadow-indigo-600/20 hover:bg-indigo-700 active:scale-[0.99] transition-all disabled:opacity-50 disabled:pointer-events-none">
        <i class="fas fa-paper-plane ml-1"></i>
        تسليم المحدد
      </button>
    </div>
  </section>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-6">
    <section class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden flex flex-col min-h-[12rem]">
      <div class="flex items-center gap-3 border-b border-slate-100 bg-indigo-50/50 px-5 py-4">
        <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-100 text-indigo-800"><i class="fas fa-user-check"></i></span>
        <div>
          <h3 class="text-base font-bold text-slate-900">معتمدون — مستحق دفع</h3>
          <p class="text-xs text-slate-500">رصيد موجب في ملف المعتمد = التزام دفع تجاهه</p>
        </div>
      </div>
      <div id="paymentDueAccDetail" class="flex-1 p-4 sm:p-5 text-sm text-slate-600">—</div>
    </section>
    <section class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden flex flex-col min-h-[12rem]">
      <div class="flex items-center gap-3 border-b border-slate-100 bg-sky-50/50 px-5 py-4">
        <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-sky-100 text-sky-800"><i class="fas fa-store"></i></span>
        <div>
          <h3 class="text-base font-bold text-slate-900">وكالات فرعية — لصالحها</h3>
          <p class="text-xs text-slate-500">رصيد محاسبي موجب = ما للوكالة علينا ضمن السجل</p>
        </div>
      </div>
      <div id="paymentDueSubDetail" class="flex-1 p-4 sm:p-5 text-sm text-slate-600">—</div>
    </section>
  </div>
</div>
