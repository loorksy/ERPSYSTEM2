<style>
  @media (max-width: 1023px) {
    body.cycle-modal-open #mobileHeader { display: none !important; }
    body.cycle-modal-open #mobileBottomNav { display: none !important; }
  }
</style>
<div class="max-w-6xl" dir="rtl">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
    <div>
      <h2 class="text-2xl font-bold text-slate-800 flex items-center gap-3">
        <div class="w-12 h-12 rounded-2xl bg-[#1e3a5f] flex items-center justify-center">
          <i class="fas fa-file-invoice-dollar text-white text-xl"></i>
        </div>
        الدورات المالية
      </h2>
    </div>
    <button type="button" onclick="openCycleModal()" class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-2xl font-semibold text-sm transition-all duration-300 cursor-pointer active:scale-[0.98] bg-[#1e3a5f] text-white hover:bg-[#2d5a87] border-0 shadow-md">
      <i class="fas fa-plus text-lg"></i>
      <span>إنشاء دورة مالية</span>
    </button>
  </div>

  <!-- Cycles Grid -->
  <div id="cyclesList" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    <!-- Cards rendered by JS -->
  </div>
  <div id="cyclesEmpty" class="text-center py-16 px-4 bg-slate-50 rounded-3xl border-2 border-dashed border-slate-200">
    <div class="w-20 h-20 mx-auto mb-4 rounded-2xl bg-slate-100 flex items-center justify-center">
      <i class="fas fa-folder-open text-4xl text-slate-400"></i>
    </div>
    <p class="text-slate-600 font-medium mb-1">لا توجد دورات محفوظة</p>
    <p class="text-slate-500 text-sm mb-6">أنشئ دورة مالية جديدة لربط جداول الإدارة والوكيل</p>
    <button type="button" onclick="openCycleModal()" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl font-semibold text-sm bg-[#1e3a5f] text-white hover:bg-[#2d5a87]">
      <i class="fas fa-plus"></i> إنشاء أول دورة
    </button>
  </div>
</div>

<!-- Modal إنشاء/تعديل دورة مالية -->
<div id="cycleModal" class="fixed inset-0 z-[1100] hidden items-center justify-center p-4 max-lg:p-0 max-lg:items-end max-lg:pb-[70px] bg-black/60 backdrop-blur-sm overflow-hidden" style="display: none;" onclick="if(event.target===this)closeCycleModal()">
  <div class="bg-white rounded-3xl max-w-2xl w-full max-h-[90vh] max-lg:max-h-[calc(100vh-70px)] max-lg:h-[calc(100vh-70px)] flex flex-col overflow-hidden shadow-2xl" onclick="event.stopPropagation()">
    <div class="p-4 border-b border-slate-100 flex items-center justify-between shrink-0">
      <h4 id="cycleModalTitle" class="text-xl font-bold text-slate-800 flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-[#1e3a5f]/10 flex items-center justify-center">
          <i class="fas fa-file-excel text-[#1e3a5f]"></i>
        </div>
        إنشاء دورة مالية
      </h4>
      <button type="button" onclick="closeCycleModal()" class="w-10 h-10 rounded-xl text-slate-500 hover:bg-slate-100 flex items-center justify-center transition-colors">
        <i class="fas fa-times text-lg"></i>
      </button>
    </div>
    <div class="p-4 overflow-y-auto flex-1 min-h-0 overscroll-contain">
      <input type="hidden" id="cycleEditId" value="">
      <div class="flex gap-2 p-1 bg-slate-100 rounded-xl mb-4 max-lg:mb-4">
        <button type="button" id="tabGoogle" onclick="setCycleTab('google')" class="flex-1 px-4 py-2.5 rounded-lg font-semibold text-sm transition-all bg-white text-[#1e3a5f] shadow-sm">استيراد من Google</button>
        <button type="button" id="tabUpload" onclick="setCycleTab('upload')" class="flex-1 px-4 py-2.5 rounded-lg font-semibold text-sm transition-all text-slate-600 hover:bg-white/50">رفع يدوي (Excel / CSV)</button>
      </div>

      <!-- استيراد من Google -->
      <div id="panelGoogle" class="space-y-5">
        <p class="text-sm text-slate-600">اختر من جداول البيانات في حسابك — يتم جلب القائمة تلقائياً من Google.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <!-- الإدارة -->
          <div class="p-4 rounded-2xl bg-amber-50/80 border border-amber-100 space-y-3">
            <h4 class="font-bold text-slate-800 text-sm flex items-center gap-2">
              <i class="fas fa-building text-amber-600"></i>
              الإدارة
            </h4>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-medium text-slate-600 mb-1">جدول الإدارة</label>
                <select id="mgmtSpreadsheetId" class="w-full py-2.5 px-3 border-2 border-slate-200 rounded-xl text-sm bg-white focus:outline-none focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20 transition-all min-w-0">
                  <option value="">— جاري التحميل... —</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-medium text-slate-600 mb-1">ورقة الإدارة</label>
                <select id="mgmtSheetName" class="w-full py-2.5 px-3 border border-slate-200 rounded-xl text-sm bg-white min-w-0">
                  <option value="">أول ورقة تلقائياً</option>
                </select>
              </div>
            </div>
          </div>
          <!-- الوكيل -->
          <div class="p-4 rounded-2xl bg-sky-50/80 border border-sky-100 space-y-3">
            <h4 class="font-bold text-slate-800 text-sm flex items-center gap-2">
              <i class="fas fa-user-tie text-[#1e3a5f]"></i>
              الوكيل
            </h4>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-medium text-slate-600 mb-1">جدول الوكيل</label>
                <select id="agentSpreadsheetId" class="w-full py-2.5 px-3 border-2 border-slate-200 rounded-xl text-sm bg-white focus:outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-500/20 transition-all min-w-0">
                  <option value="">— جاري التحميل... —</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-medium text-slate-600 mb-1">ورقة الوكيل</label>
                <select id="agentSheetName" class="w-full py-2.5 px-3 border border-slate-200 rounded-xl text-sm bg-white min-w-0">
                  <option value="">أول ورقة تلقائياً</option>
                </select>
              </div>
            </div>
          </div>
        </div>
        <button type="button" id="btnFetchGoogle" onclick="fetchFromGoogle()" class="w-full inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl font-semibold text-sm bg-emerald-600 text-white hover:bg-emerald-700 transition-colors">
          <i class="fas fa-cloud-download-alt"></i> جلب البيانات من Google
        </button>
      </div>

      <!-- رفع يدوي -->
      <div id="panelUpload" class="space-y-5 hidden">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="p-4 rounded-2xl bg-amber-50/80 border border-amber-100">
            <label class="block font-semibold text-sm text-slate-800 mb-2 flex items-center gap-2"><i class="fas fa-building text-amber-600"></i> ملف الإدارة</label>
            <input type="file" id="fileManagement" accept=".xlsx,.xls,.csv" class="w-full py-2.5 px-4 border-2 border-dashed border-slate-200 rounded-xl text-sm bg-white hover:border-amber-300 transition-colors file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-amber-50 file:text-amber-700 file:font-semibold">
          </div>
          <div class="p-4 rounded-2xl bg-sky-50/80 border border-sky-100">
            <label class="block font-semibold text-sm text-slate-800 mb-2 flex items-center gap-2"><i class="fas fa-user-tie text-[#1e3a5f]"></i> ملف الوكيل</label>
            <input type="file" id="fileAgent" accept=".xlsx,.xls,.csv" class="w-full py-2.5 px-4 border-2 border-dashed border-slate-200 rounded-xl text-sm bg-white hover:border-sky-300 transition-colors file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-sky-50 file:text-sky-700 file:font-semibold">
          </div>
        </div>
        <button type="button" id="btnUploadFiles" onclick="uploadFiles()" class="w-full inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl font-semibold text-sm bg-sky-600 text-white hover:bg-sky-700 transition-colors">
          <i class="fas fa-upload"></i> تحميل وقراءة الملفات
        </button>
      </div>

      <!-- معاينة + اسم الدورة (داخل المنطقة القابلة للتمرير) -->
      <div id="panelSave" class="mt-4 pt-4 border-t border-slate-200 hidden">
        <div class="flex gap-4 mb-3 p-3 bg-slate-50 rounded-xl">
          <span class="text-slate-600">الإدارة: <strong id="previewMgmtRows" class="text-[#1e3a5f]">0</strong> صف</span>
          <span class="text-slate-600">الوكيل: <strong id="previewAgentRows" class="text-[#1e3a5f]">0</strong> صف</span>
        </div>
        <div class="mb-4">
          <label class="block mb-2 font-semibold text-sm text-slate-800">اسم الدورة المالية</label>
          <input type="text" id="cycleName" placeholder="مثال: دورة يناير 2025" class="w-full py-3 px-4 border-2 border-slate-200 rounded-xl text-sm bg-white focus:outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-500/20 transition-all">
        </div>
        <div class="mb-4">
          <label class="block mb-2 font-semibold text-sm text-slate-800">نسبة خصم التحويل للدورة (%)</label>
          <input type="number" id="cycleTransferDiscountPct" min="0" max="100" step="0.1" placeholder="0" class="w-full py-3 px-4 border-2 border-slate-200 rounded-xl text-sm bg-white focus:outline-none focus:border-sky-500">
          <p class="text-xs text-slate-500 mt-1">تُطبّق على جدول الوكيل؛ الجزء المخصوم يُسجّل كربح عند إعادة بناء المؤجل.</p>
        </div>
      </div>
    </div>
    <!-- زر الحفظ ثابت أسفل النافذة (دائماً ظاهر على الموبايل) -->
    <div id="cycleModalFooter" class="hidden p-4 pt-0 border-t border-slate-200 bg-white shrink-0 max-lg:pb-[env(safe-area-inset-bottom,0)]">
      <button type="button" id="btnSaveCycle" onclick="saveCycle()" class="w-full inline-flex items-center justify-center gap-2 px-5 py-3.5 rounded-xl font-semibold text-sm bg-[#1e3a5f] text-white hover:bg-[#2d5a87] transition-colors border-0 shadow-md">
        <i class="fas fa-save"></i> حفظ الدورة
      </button>
    </div>
  </div>
</div>

<!-- Modal تأكيد الحذف -->
<div id="deleteConfirmModal" class="fixed inset-0 z-[1100] hidden items-center justify-center p-4 py-6 max-lg:py-6 bg-black/60 backdrop-blur-sm" style="display: none;" onclick="if(event.target===this)closeDeleteConfirm()">
  <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full p-6" onclick="event.stopPropagation()">
    <div class="w-14 h-14 mx-auto mb-4 rounded-2xl bg-red-100 flex items-center justify-center">
      <i class="fas fa-trash-alt text-red-600 text-xl"></i>
    </div>
    <h4 class="text-lg font-bold text-slate-800 text-center mb-2">حذف الدورة المالية</h4>
    <p id="deleteConfirmText" class="text-slate-600 text-sm text-center mb-6">هل أنت متأكد من حذف هذه الدورة؟ لا يمكن التراجع.</p>
    <div class="flex gap-3">
      <button type="button" onclick="closeDeleteConfirm()" class="flex-1 py-3 rounded-xl font-semibold text-sm bg-slate-100 text-slate-700 hover:bg-slate-200">إلغاء</button>
      <button type="button" id="btnConfirmDelete" onclick="confirmDeleteCycle()" class="flex-1 py-3 rounded-xl font-semibold text-sm bg-red-600 text-white hover:bg-red-700">حذف</button>
    </div>
  </div>
</div>

<script>
(function() {
  var modal = document.getElementById('cycleModal');
  var deleteModal = document.getElementById('deleteConfirmModal');
  if (!modal) return;

  function hideMobileHeader() {
    document.body.classList.add('cycle-modal-open');
  }
  function showMobileHeader() {
    document.body.classList.remove('cycle-modal-open');
  }

  window.openCycleModal = function(editId) {
    hideMobileHeader();
    document.getElementById('cycleEditId').value = editId || '';
    document.getElementById('cycleModalTitle').innerHTML = '<div class="w-10 h-10 rounded-xl bg-[#1e3a5f]/10 flex items-center justify-center"><i class="fas fa-file-excel text-[#1e3a5f]"></i></div>' + (editId ? 'تعديل الدورة المالية' : 'إنشاء دورة مالية');
    document.getElementById('panelSave').classList.add('hidden');
    var footer = document.getElementById('cycleModalFooter');
    if (footer) footer.classList.add('hidden');
    document.getElementById('cycleName').value = '';
    var tdp = document.getElementById('cycleTransferDiscountPct');
    if (tdp) tdp.value = '';
    document.getElementById('fileManagement').value = '';
    document.getElementById('fileAgent').value = '';
    currentManagementRows = [];
    currentAgentRows = [];
    setCycleTab('google');
    loadSpreadsheetsList();
    if (editId) {
      loadCycleForEdit(editId).then(function() {
        document.getElementById('panelSave').classList.remove('hidden');
        var footer = document.getElementById('cycleModalFooter');
        if (footer) footer.classList.remove('hidden');
        document.getElementById('previewMgmtRows').textContent = '—';
        document.getElementById('previewAgentRows').textContent = '—';
      });
    }
    modal.classList.remove('hidden');
    modal.style.display = 'flex';
  };

  window.closeCycleModal = function() {
    showMobileHeader();
    modal.classList.add('hidden');
    modal.style.display = 'none';
  };

  window.setCycleTab = function(tab) {
    var panelGoogle = document.getElementById('panelGoogle');
    var panelUpload = document.getElementById('panelUpload');
    var tabGoogle = document.getElementById('tabGoogle');
    var tabUpload = document.getElementById('tabUpload');
    if (tab === 'google') {
      panelGoogle.classList.remove('hidden');
      panelUpload.classList.add('hidden');
      tabGoogle.className = 'flex-1 px-4 py-2.5 rounded-lg font-semibold text-sm transition-all bg-white text-[#1e3a5f] shadow-sm';
      tabUpload.className = 'flex-1 px-4 py-2.5 rounded-lg font-semibold text-sm transition-all text-slate-600 hover:bg-white/50';
      loadSpreadsheetsList();
    } else {
      panelGoogle.classList.add('hidden');
      panelUpload.classList.remove('hidden');
      tabUpload.className = 'flex-1 px-4 py-2.5 rounded-lg font-semibold text-sm transition-all bg-white text-[#1e3a5f] shadow-sm';
      tabGoogle.className = 'flex-1 px-4 py-2.5 rounded-lg font-semibold text-sm transition-all text-slate-600 hover:bg-white/50';
    }
  };

  window.openDeleteConfirm = function(cycleId, cycleName) {
    hideMobileHeader();
    window._deleteCycleId = cycleId;
    document.getElementById('deleteConfirmText').textContent = 'هل أنت متأكد من حذف "' + (cycleName || 'الدورة') + '"؟ لا يمكن التراجع عن هذا الإجراء.';
    deleteModal.classList.remove('hidden');
    deleteModal.style.display = 'flex';
  };

  window.closeDeleteConfirm = function() {
    showMobileHeader();
    deleteModal.classList.add('hidden');
    deleteModal.style.display = 'none';
    window._deleteCycleId = null;
  };
})();

async function loadCycleForEdit(cycleId) {
  try {
    var res = await fetch('/api/sheet/cycles/' + cycleId);
    var data = await res.json();
    if (!data.success || !data.cycle) return;
    var c = data.cycle;
    document.getElementById('cycleName').value = c.name || '';
    var tdpEl = document.getElementById('cycleTransferDiscountPct');
    if (tdpEl) tdpEl.value = c.transfer_discount_pct != null && c.transfer_discount_pct !== '' ? c.transfer_discount_pct : '';
    if (c.management_spreadsheet_id) {
      document.getElementById('mgmtSpreadsheetId').value = c.management_spreadsheet_id;
      await loadSheetsForSpreadsheet(c.management_spreadsheet_id, 'mgmt');
      if (c.management_sheet_name) document.getElementById('mgmtSheetName').value = c.management_sheet_name;
    }
    if (c.agent_spreadsheet_id) {
      document.getElementById('agentSpreadsheetId').value = c.agent_spreadsheet_id;
      await loadSheetsForSpreadsheet(c.agent_spreadsheet_id, 'agent');
      if (c.agent_sheet_name) document.getElementById('agentSheetName').value = c.agent_sheet_name;
    }
  } catch (_) {}
}

async function loadSpreadsheetsList() {
  var selMgmt = document.getElementById('mgmtSpreadsheetId');
  var selAgent = document.getElementById('agentSpreadsheetId');
  if (!selMgmt || !selAgent) return;
  selMgmt.innerHTML = '<option value="">— جاري التحميل... —</option>';
  selAgent.innerHTML = '<option value="">— جاري التحميل... —</option>';
  document.getElementById('mgmtSheetName').innerHTML = '<option value="">أول ورقة تلقائياً</option>';
  document.getElementById('agentSheetName').innerHTML = '<option value="">أول ورقة تلقائياً</option>';
  try {
    var res = await fetch('/api/sheet/spreadsheets-list');
    var data = await res.json();
    if (!data.success) {
      selMgmt.innerHTML = '<option value="">' + (data.message || 'لم يتم الربط بـ Google') + '</option>';
      selAgent.innerHTML = '<option value="">' + (data.message || 'لم يتم الربط بـ Google') + '</option>';
      return;
    }
    var list = data.spreadsheets || [];
    var opt = '<option value="">— اختر الجدول —</option>' + list.map(function(f) { return '<option value="' + (f.id || '').replace(/"/g, '&quot;') + '">' + (f.name || f.id) + '</option>'; }).join('');
    selMgmt.innerHTML = opt;
    selAgent.innerHTML = opt;
    if (!window._sheetSelectListenersAdded) {
      window._sheetSelectListenersAdded = true;
      selMgmt.addEventListener('change', function() { loadSheetsForSpreadsheet(this.value, 'mgmt'); });
      selAgent.addEventListener('change', function() { loadSheetsForSpreadsheet(this.value, 'agent'); });
    }
  } catch (_) {
    selMgmt.innerHTML = '<option value="">خطأ في التحميل</option>';
    selAgent.innerHTML = '<option value="">خطأ في التحميل</option>';
  }
}

async function loadSheetsForSpreadsheet(spreadsheetId, which) {
  var sel = document.getElementById(which === 'mgmt' ? 'mgmtSheetName' : 'agentSheetName');
  if (!sel) return;
  sel.innerHTML = '<option value="">جاري التحميل...</option>';
  if (!spreadsheetId) { sel.innerHTML = '<option value="">أول ورقة تلقائياً</option>'; return; }
  try {
    var res = await fetch('/api/sheet/spreadsheet-sheets?spreadsheetId=' + encodeURIComponent(spreadsheetId));
    var data = await res.json();
    if (!data.success || !data.sheets || !data.sheets.length) {
      sel.innerHTML = '<option value="">أول ورقة تلقائياً</option>';
      return;
    }
    sel.innerHTML = '<option value="">أول ورقة تلقائياً</option>' + data.sheets.map(function(s) { return '<option value="' + (s.title || '').replace(/"/g, '&quot;') + '">' + (s.title || '') + '</option>'; }).join('');
  } catch (_) {
    sel.innerHTML = '<option value="">أول ورقة تلقائياً</option>';
  }
}

var currentManagementRows = [];
var currentAgentRows = [];

function showSavePanel(managementRows, agentRows) {
  currentManagementRows = managementRows || [];
  currentAgentRows = agentRows || [];
  document.getElementById('previewMgmtRows').textContent = currentManagementRows.length;
  document.getElementById('previewAgentRows').textContent = currentAgentRows.length;
  document.getElementById('panelSave').classList.remove('hidden');
  var footer = document.getElementById('cycleModalFooter');
  if (footer) footer.classList.remove('hidden');
}

async function fetchFromGoogle() {
  var mgmtId = (document.getElementById('mgmtSpreadsheetId').value || '').trim();
  var agentId = (document.getElementById('agentSpreadsheetId').value || '').trim();
  if (!mgmtId || !agentId) {
    if (typeof showToast === 'function') showToast('اختر جدول الإدارة وجدول الوكيل من القائمة', 'error');
    return;
  }
  var btn = document.getElementById('btnFetchGoogle');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري الجلب...';
  try {
    var res = await fetch('/api/sheet/import-google', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        managementSpreadsheetId: mgmtId,
        managementSheetName: (document.getElementById('mgmtSheetName').value || '').trim() || undefined,
        agentSpreadsheetId: agentId,
        agentSheetName: (document.getElementById('agentSheetName').value || '').trim() || undefined
      })
    });
    var data = await res.json();
    if (data.success) {
      showSavePanel(data.managementRows, data.agentRows);
      if (typeof showToast === 'function') showToast('تم جلب البيانات', 'success');
    } else {
      if (typeof showToast === 'function') showToast(data.message || 'فشل الاستيراد', 'error');
    }
  } catch (_) {
    if (typeof showToast === 'function') showToast('خطأ في الاتصال', 'error');
  }
  btn.disabled = false;
  btn.innerHTML = '<i class="fas fa-cloud-download-alt"></i> جلب البيانات من Google';
}

async function uploadFiles() {
  var fileMgmt = document.getElementById('fileManagement').files[0];
  var fileAgent = document.getElementById('fileAgent').files[0];
  if (!fileMgmt || !fileAgent) {
    if (typeof showToast === 'function') showToast('اختر ملف الإدارة وملف الوكيل', 'error');
    return;
  }
  var btn = document.getElementById('btnUploadFiles');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري القراءة...';
  var form = new FormData();
  form.append('managementFile', fileMgmt);
  form.append('agentFile', fileAgent);
  try {
    var res = await fetch('/api/sheet/upload', { method: 'POST', body: form });
    var data = await res.json();
    if (data.success) {
      showSavePanel(data.managementRows, data.agentRows);
      if (typeof showToast === 'function') showToast('تم قراءة الملفات', 'success');
    } else {
      if (typeof showToast === 'function') showToast(data.message || 'فشل قراءة الملفات', 'error');
    }
  } catch (_) {
    if (typeof showToast === 'function') showToast('خطأ في الاتصال', 'error');
  }
  btn.disabled = false;
  btn.innerHTML = '<i class="fas fa-upload"></i> تحميل وقراءة الملفات';
}

async function saveCycle() {
  var name = document.getElementById('cycleName').value.trim();
  if (!name) {
    if (typeof showToast === 'function') showToast('أدخل اسم الدورة', 'error');
    return;
  }
  var editId = document.getElementById('cycleEditId').value.trim();
  var btn = document.getElementById('btnSaveCycle');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري الحفظ...';
  try {
    var mgmtId = (document.getElementById('mgmtSpreadsheetId')?.value || '').trim();
    var agentId = (document.getElementById('agentSpreadsheetId')?.value || '').trim();
    var tdpRaw = document.getElementById('cycleTransferDiscountPct')?.value;
    var payload = {
      name: name,
      managementSpreadsheetId: mgmtId || null,
      managementSheetName: (document.getElementById('mgmtSheetName')?.value || '').trim() || null,
      agentSpreadsheetId: agentId || null,
      agentSheetName: (document.getElementById('agentSheetName')?.value || '').trim() || null,
      transferDiscountPct: tdpRaw !== undefined && tdpRaw !== '' ? Number(tdpRaw) : 0
    };
    if ((!mgmtId || !agentId) && (currentManagementRows.length || currentAgentRows.length)) {
      payload.managementData = currentManagementRows;
      payload.agentData = currentAgentRows;
      payload.managementSpreadsheetId = null;
      payload.agentSpreadsheetId = null;
    }
    var url = editId ? '/api/sheet/cycles/' + editId : '/api/sheet/cycles';
    var method = editId ? 'PUT' : 'POST';
    var res = await fetch(url, {
      method: method,
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    var data;
    try {
      data = await res.json();
    } catch (parseErr) {
      if (typeof showToast === 'function') showToast('خطأ في استجابة الخادم', 'error');
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-save"></i> حفظ الدورة';
      return;
    }
    if (res.status === 401) {
      if (typeof showToast === 'function') showToast(data.message || 'انتهت الجلسة. سجّل دخولك مجدداً.', 'error');
      setTimeout(function() { window.location.href = '/login'; }, 1500);
      return;
    }
    if (data.success) {
      if (typeof showToast === 'function') showToast(data.message || 'تم حفظ الدورة', 'success');
      closeCycleModal();
      loadCycles();
    } else {
      if (typeof showToast === 'function') showToast(data.message || 'فشل الحفظ', 'error');
    }
  } catch (err) {
    if (typeof showToast === 'function') showToast('خطأ في الاتصال: ' + (err.message || 'تحقق من الاتصال'), 'error');
  }
  btn.disabled = false;
  btn.innerHTML = '<i class="fas fa-save"></i> حفظ الدورة';
}

async function confirmDeleteCycle() {
  var id = window._deleteCycleId;
  if (!id) return;
  var btn = document.getElementById('btnConfirmDelete');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
  try {
    var res = await fetch('/api/sheet/cycles/' + id, { method: 'DELETE' });
    var data = await res.json();
    if (data.success) {
      if (typeof showToast === 'function') showToast(data.message || 'تم حذف الدورة', 'success');
      closeDeleteConfirm();
      loadCycles();
    } else {
      if (typeof showToast === 'function') showToast(data.message || 'فشل الحذف', 'error');
    }
  } catch (_) {
    if (typeof showToast === 'function') showToast('خطأ في الاتصال', 'error');
  }
  btn.disabled = false;
  btn.innerHTML = 'حذف';
}

function formatDate(d) {
  if (!d) return '—';
  try {
    return new Date(d).toLocaleDateString('ar-SA', { year: 'numeric', month: 'short', day: 'numeric' });
  } catch (_) { return d; }
}

async function loadCycles() {
  try {
    var res = await fetch('/api/sheet/cycles');
    var data = await res.json();
    var list = document.getElementById('cyclesList');
    var empty = document.getElementById('cyclesEmpty');
    if (!data.success || !data.cycles || data.cycles.length === 0) {
      if (list) list.innerHTML = '';
      if (empty) empty.classList.remove('hidden');
      return;
    }
    if (empty) empty.classList.add('hidden');
    if (list) {
      var colors = ['from-sky-500 to-violet-600', 'from-emerald-500 to-teal-600', 'from-amber-500 to-orange-600', 'from-rose-500 to-pink-600', 'from-cyan-500 to-blue-600'];
      list.innerHTML = data.cycles.map(function(c, i) {
        var color = colors[i % colors.length];
        var hasGoogle = !!(c.management_spreadsheet_id && c.agent_spreadsheet_id);
        return '<div class="bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition-all overflow-hidden group">' +
          '<div class="h-2 bg-gradient-to-r ' + color + '"></div>' +
          '<div class="p-5">' +
            '<div class="flex items-start justify-between gap-3 mb-3">' +
              '<h5 class="font-bold text-slate-800 text-lg">' + (c.name || 'دورة') + '</h5>' +
              '<div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">' +
                '<button type="button" onclick="event.stopPropagation(); openCycleModal(' + c.id + ')" class="w-9 h-9 rounded-lg text-slate-500 hover:bg-sky-50 hover:text-[#1e3a5f] flex items-center justify-center" title="تعديل"><i class="fas fa-edit"></i></button>' +
                '<button type="button" onclick="event.stopPropagation(); openDeleteConfirm(' + c.id + ', \'' + (c.name || '').replace(/'/g, "\\'") + '\')" class="w-9 h-9 rounded-lg text-slate-500 hover:bg-red-50 hover:text-red-600 flex items-center justify-center" title="حذف"><i class="fas fa-trash-alt"></i></button>' +
              '</div>' +
            '</div>' +
            '<div class="space-y-2 text-sm text-slate-600">' +
              '<p class="flex items-center gap-2"><i class="fas fa-calendar text-slate-400 w-4"></i>' + formatDate(c.created_at) + '</p>' +
              (hasGoogle ? '<p class="flex items-center gap-2 text-emerald-600"><i class="fas fa-link w-4"></i> مرتبطة بـ Google</p>' : '<p class="flex items-center gap-2 text-amber-600"><i class="fas fa-file w-4"></i> ملفات محلية</p>') +
              (c.transfer_discount_pct > 0 ? '<p class="flex items-center gap-2 text-slate-500"><i class="fas fa-percent w-4"></i> خصم تحويل: ' + c.transfer_discount_pct + '%</p>' : '') +
            '</div>' +
          '</div>' +
        '</div>';
      }).join('');
    }
  } catch (_) {}
}

(function initSheetPage() {
  loadCycles();
})();
</script>
