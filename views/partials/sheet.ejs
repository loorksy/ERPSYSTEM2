<div class="max-w-5xl" dir="rtl">
  <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
    <div class="flex items-center justify-between flex-wrap gap-3 py-5 px-6 border-b border-slate-100">
      <div class="flex items-center gap-3">
        <i class="fas fa-file-excel text-xl text-indigo-600"></i>
        <h3 class="text-lg font-bold">الدورات المالية</h3>
      </div>
      <button type="button" onclick="openCreateCycleModal()" class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl font-semibold text-sm transition-all duration-300 cursor-pointer active:scale-[0.97] bg-indigo-600 text-white hover:bg-indigo-700">
        <i class="fas fa-plus"></i>
        <span>إنشاء دورة مالية</span>
      </button>
    </div>
    <div class="p-6 md:p-10">
      <div class="mb-6">
        <h4 class="font-bold text-slate-800 mb-2 flex items-center gap-2"><i class="fas fa-history text-indigo-600"></i> الدورات المحفوظة</h4>
        <div id="cyclesList" class="flex flex-wrap gap-2"></div>
        <p id="cyclesEmpty" class="text-sm text-slate-500 py-4">لا توجد دورات محفوظة بعد.</p>
      </div>
    </div>
  </div>
</div>

<!-- Modal إنشاء دورة مالية -->
<div id="createCycleModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4" style="display: none;">
  <div class="bg-white rounded-2xl shadow-xl max-w-2xl w-full max-h-[90vh] overflow-y-auto">
    <div class="p-6 border-b border-slate-100 flex items-center justify-between sticky top-0 bg-white">
      <h4 class="text-lg font-bold text-slate-800 flex items-center gap-2"><i class="fas fa-file-excel text-indigo-600"></i> إنشاء دورة مالية</h4>
      <button type="button" onclick="closeCreateCycleModal()" class="w-9 h-9 rounded-lg text-slate-500 hover:bg-slate-100 flex items-center justify-center"><i class="fas fa-times"></i></button>
    </div>
    <div class="p-6">
      <div class="flex gap-2 mb-6">
        <button type="button" id="tabGoogle" onclick="setCycleTab('google')" class="px-4 py-2 rounded-xl font-semibold text-sm bg-indigo-600 text-white">استيراد من Google</button>
        <button type="button" id="tabUpload" onclick="setCycleTab('upload')" class="px-4 py-2 rounded-xl font-semibold text-sm bg-slate-100 text-slate-600 hover:bg-slate-200">رفع يدوي (Excel / CSV)</button>
      </div>

      <!-- استيراد من Google (مزامنة جداول حساب المستخدم) -->
      <div id="panelGoogle" class="space-y-4">
        <p class="text-sm text-slate-600">اختر من جداول البيانات في حسابك — يتم جلب القائمة تلقائياً من Google.</p>
        <div>
          <label class="block mb-2 font-semibold text-sm text-slate-800">جدول الإدارة</label>
          <select id="mgmtSpreadsheetId" class="w-full py-3 px-4 border-2 border-slate-200 rounded-xl text-sm bg-white text-slate-800 focus:outline-none focus:border-indigo-600">
            <option value="">— جاري التحميل... —</option>
          </select>
          <label class="block mt-2 mb-1 font-medium text-xs text-slate-600">ورقة الإدارة (اختياري)</label>
          <select id="mgmtSheetName" class="w-full py-2 px-4 border border-slate-200 rounded-lg text-sm bg-white">
            <option value="">أول ورقة تلقائياً</option>
          </select>
        </div>
        <div>
          <label class="block mb-2 font-semibold text-sm text-slate-800">جدول الوكيل</label>
          <select id="agentSpreadsheetId" class="w-full py-3 px-4 border-2 border-slate-200 rounded-xl text-sm bg-white text-slate-800 focus:outline-none focus:border-indigo-600">
            <option value="">— جاري التحميل... —</option>
          </select>
          <label class="block mt-2 mb-1 font-medium text-xs text-slate-600">ورقة الوكيل (اختياري)</label>
          <select id="agentSheetName" class="w-full py-2 px-4 border border-slate-200 rounded-lg text-sm bg-white">
            <option value="">أول ورقة تلقائياً</option>
          </select>
        </div>
        <button type="button" id="btnFetchGoogle" onclick="fetchFromGoogle()" class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl font-semibold text-sm bg-emerald-600 text-white hover:bg-emerald-700">
          <i class="fas fa-cloud-download-alt"></i> جلب البيانات من Google
        </button>
      </div>

      <!-- رفع يدوي -->
      <div id="panelUpload" class="space-y-4 hidden">
        <div>
          <label class="block mb-2 font-semibold text-sm text-slate-800">ملف الإدارة (Excel أو CSV)</label>
          <input type="file" id="fileManagement" accept=".xlsx,.xls,.csv" class="w-full py-2 px-4 border-2 border-slate-200 rounded-xl text-sm">
        </div>
        <div>
          <label class="block mb-2 font-semibold text-sm text-slate-800">ملف الوكيل (Excel أو CSV)</label>
          <input type="file" id="fileAgent" accept=".xlsx,.xls,.csv" class="w-full py-2 px-4 border-2 border-slate-200 rounded-xl text-sm">
        </div>
        <button type="button" id="btnUploadFiles" onclick="uploadFiles()" class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl font-semibold text-sm bg-sky-600 text-white hover:bg-sky-700">
          <i class="fas fa-upload"></i> تحميل وقراءة الملفات
        </button>
      </div>

      <!-- بعد تحميل البيانات: معاينة + اسم الدورة + حفظ -->
      <div id="panelSave" class="mt-6 pt-6 border-t border-slate-200 hidden">
        <div class="flex gap-4 mb-4 text-sm">
          <span class="text-slate-600">الإدارة: <strong id="previewMgmtRows">0</strong> صف</span>
          <span class="text-slate-600">الوكيل: <strong id="previewAgentRows">0</strong> صف</span>
        </div>
        <div class="mb-4">
          <label class="block mb-2 font-semibold text-sm text-slate-800">اسم الدورة المالية</label>
          <input type="text" id="cycleName" placeholder="مثال: دورة يناير 2025" class="w-full py-3 px-4 border-2 border-slate-200 rounded-xl text-sm bg-white text-slate-800 focus:outline-none focus:border-indigo-600">
        </div>
        <button type="button" id="btnSaveCycle" onclick="saveCycle()" class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl font-semibold text-sm bg-indigo-600 text-white hover:bg-indigo-700">
          <i class="fas fa-save"></i> حفظ الدورة
        </button>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  var modal = document.getElementById('createCycleModal');
  if (!modal) return;
  window.openCreateCycleModal = function() {
    modal.classList.remove('hidden');
    modal.style.display = 'flex';
    document.getElementById('panelSave').classList.add('hidden');
    document.getElementById('cycleName').value = '';
    document.getElementById('fileManagement').value = '';
    document.getElementById('fileAgent').value = '';
    loadSpreadsheetsList();
  };
  window.closeCreateCycleModal = function() {
    modal.classList.add('hidden');
    modal.style.display = 'none';
  };
  window.setCycleTab = function(tab) {
    var panelGoogle = document.getElementById('panelGoogle');
    var panelUpload = document.getElementById('panelUpload');
    var tabGoogle = document.getElementById('tabGoogle');
    var tabUpload = document.getElementById('tabUpload');
    if (tab === 'google') {
      panelGoogle.classList.remove('hidden');
      panelUpload.classList.add('hidden');
      tabGoogle.className = 'px-4 py-2 rounded-xl font-semibold text-sm bg-indigo-600 text-white';
      tabUpload.className = 'px-4 py-2 rounded-xl font-semibold text-sm bg-slate-100 text-slate-600 hover:bg-slate-200';
      loadSpreadsheetsList();
    } else {
      panelGoogle.classList.add('hidden');
      panelUpload.classList.remove('hidden');
      tabUpload.className = 'px-4 py-2 rounded-xl font-semibold text-sm bg-indigo-600 text-white';
      tabGoogle.className = 'px-4 py-2 rounded-xl font-semibold text-sm bg-slate-100 text-slate-600 hover:bg-slate-200';
    }
  };
})();

async function loadSpreadsheetsList() {
  var selMgmt = document.getElementById('mgmtSpreadsheetId');
  var selAgent = document.getElementById('agentSpreadsheetId');
  if (!selMgmt || !selAgent) return;
  selMgmt.innerHTML = '<option value="">— جاري التحميل... —</option>';
  selAgent.innerHTML = '<option value="">— جاري التحميل... —</option>';
  document.getElementById('mgmtSheetName').innerHTML = '<option value="">أول ورقة تلقائياً</option>';
  document.getElementById('agentSheetName').innerHTML = '<option value="">أول ورقة تلقائياً</option>';
  try {
    var res = await fetch('/api/sheet/spreadsheets-list');
    var data = await res.json();
    if (!data.success) {
      selMgmt.innerHTML = '<option value="">' + (data.message || 'لم يتم الربط بـ Google') + '</option>';
      selAgent.innerHTML = '<option value="">' + (data.message || 'لم يتم الربط بـ Google') + '</option>';
      return;
    }
    var list = data.spreadsheets || [];
    var opt = '<option value="">— اختر الجدول —</option>' + list.map(function(f) { return '<option value="' + (f.id || '').replace(/"/g, '&quot;') + '">' + (f.name || f.id) + '</option>'; }).join('');
    selMgmt.innerHTML = opt;
    selAgent.innerHTML = opt;
    if (!window._sheetSelectListenersAdded) {
      window._sheetSelectListenersAdded = true;
      selMgmt.addEventListener('change', function() { loadSheetsForSpreadsheet(this.value, 'mgmt'); });
      selAgent.addEventListener('change', function() { loadSheetsForSpreadsheet(this.value, 'agent'); });
    }
  } catch (_) {
    selMgmt.innerHTML = '<option value="">خطأ في التحميل</option>';
    selAgent.innerHTML = '<option value="">خطأ في التحميل</option>';
  }
}

async function loadSheetsForSpreadsheet(spreadsheetId, which) {
  var sel = document.getElementById(which === 'mgmt' ? 'mgmtSheetName' : 'agentSheetName');
  if (!sel) return;
  sel.innerHTML = '<option value="">جاري التحميل...</option>';
  if (!spreadsheetId) { sel.innerHTML = '<option value="">أول ورقة تلقائياً</option>'; return; }
  try {
    var res = await fetch('/api/sheet/spreadsheet-sheets?spreadsheetId=' + encodeURIComponent(spreadsheetId));
    var data = await res.json();
    if (!data.success || !data.sheets || !data.sheets.length) {
      sel.innerHTML = '<option value="">أول ورقة تلقائياً</option>';
      return;
    }
    sel.innerHTML = '<option value="">أول ورقة تلقائياً</option>' + data.sheets.map(function(s) { return '<option value="' + (s.title || '').replace(/"/g, '&quot;') + '">' + (s.title || '') + '</option>'; }).join('');
  } catch (_) {
    sel.innerHTML = '<option value="">أول ورقة تلقائياً</option>';
  }
}

var currentManagementRows = [];
var currentAgentRows = [];

function showSavePanel(managementRows, agentRows) {
  currentManagementRows = managementRows || [];
  currentAgentRows = agentRows || [];
  document.getElementById('previewMgmtRows').textContent = currentManagementRows.length;
  document.getElementById('previewAgentRows').textContent = currentAgentRows.length;
  document.getElementById('panelSave').classList.remove('hidden');
}

async function fetchFromGoogle() {
  var mgmtId = (document.getElementById('mgmtSpreadsheetId').value || '').trim();
  var agentId = (document.getElementById('agentSpreadsheetId').value || '').trim();
  if (!mgmtId || !agentId) {
    if (typeof showToast === 'function') showToast('اختر جدول الإدارة وجدول الوكيل من القائمة', 'error');
    return;
  }
  var btn = document.getElementById('btnFetchGoogle');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري الجلب...';
  try {
    var res = await fetch('/api/sheet/import-google', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        managementSpreadsheetId: mgmtId,
        managementSheetName: (document.getElementById('mgmtSheetName').value || '').trim() || undefined,
        agentSpreadsheetId: agentId,
        agentSheetName: (document.getElementById('agentSheetName').value || '').trim() || undefined
      })
    });
    var data = await res.json();
    if (data.success) {
      showSavePanel(data.managementRows, data.agentRows);
      if (typeof showToast === 'function') showToast('تم جلب البيانات', 'success');
    } else {
      if (typeof showToast === 'function') showToast(data.message || 'فشل الاستيراد', 'error');
    }
  } catch (_) {
    if (typeof showToast === 'function') showToast('خطأ في الاتصال', 'error');
  }
  btn.disabled = false;
  btn.innerHTML = '<i class="fas fa-cloud-download-alt"></i> جلب البيانات من Google';
}

async function uploadFiles() {
  var fileMgmt = document.getElementById('fileManagement').files[0];
  var fileAgent = document.getElementById('fileAgent').files[0];
  if (!fileMgmt || !fileAgent) {
    if (typeof showToast === 'function') showToast('اختر ملف الإدارة وملف الوكيل', 'error');
    return;
  }
  var btn = document.getElementById('btnUploadFiles');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري القراءة...';
  var form = new FormData();
  form.append('managementFile', fileMgmt);
  form.append('agentFile', fileAgent);
  try {
    var res = await fetch('/api/sheet/upload', { method: 'POST', body: form });
    var data = await res.json();
    if (data.success) {
      showSavePanel(data.managementRows, data.agentRows);
      if (typeof showToast === 'function') showToast('تم قراءة الملفات', 'success');
    } else {
      if (typeof showToast === 'function') showToast(data.message || 'فشل قراءة الملفات', 'error');
    }
  } catch (_) {
    if (typeof showToast === 'function') showToast('خطأ في الاتصال', 'error');
  }
  btn.disabled = false;
  btn.innerHTML = '<i class="fas fa-upload"></i> تحميل وقراءة الملفات';
}

async function saveCycle() {
  var name = document.getElementById('cycleName').value.trim();
  if (!name) {
    if (typeof showToast === 'function') showToast('أدخل اسم الدورة', 'error');
    return;
  }
  var btn = document.getElementById('btnSaveCycle');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري الحفظ...';
  try {
    var res = await fetch('/api/sheet/cycles', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        name: name,
        managementData: currentManagementRows,
        agentData: currentAgentRows,
        managementSpreadsheetId: document.getElementById('mgmtSpreadsheetId')?.value || undefined,
        managementSheetName: document.getElementById('mgmtSheetName')?.value || undefined,
        agentSpreadsheetId: document.getElementById('agentSpreadsheetId')?.value || undefined,
        agentSheetName: document.getElementById('agentSheetName')?.value || undefined
      })
    });
    var data;
    try {
      data = await res.json();
    } catch (parseErr) {
      if (typeof showToast === 'function') showToast('خطأ في استجابة الخادم (تحقق من السجلات)', 'error');
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-save"></i> حفظ الدورة';
      return;
    }
    if (res.status === 401) {
      if (typeof showToast === 'function') showToast(data.message || 'انتهت الجلسة. سجّل دخولك مجدداً.', 'error');
      setTimeout(function() { window.location.href = '/login'; }, 1500);
      return;
    }
    if (data.success) {
      if (typeof showToast === 'function') showToast(data.message || 'تم حفظ الدورة', 'success');
      closeCreateCycleModal();
      loadCycles();
    } else {
      if (typeof showToast === 'function') showToast(data.message || 'فشل الحفظ', 'error');
    }
  } catch (err) {
    if (typeof showToast === 'function') showToast('خطأ في الاتصال: ' + (err.message || 'تحقق من الاتصال'), 'error');
  }
  btn.disabled = false;
  btn.innerHTML = '<i class="fas fa-save"></i> حفظ الدورة';
}

async function loadCycles() {
  try {
    var res = await fetch('/api/sheet/cycles');
    var data = await res.json();
    var list = document.getElementById('cyclesList');
    var empty = document.getElementById('cyclesEmpty');
    if (!data.success || !data.cycles || data.cycles.length === 0) {
      if (list) list.innerHTML = '';
      if (empty) empty.classList.remove('hidden');
      return;
    }
    if (empty) empty.classList.add('hidden');
    if (list) {
      list.innerHTML = data.cycles.map(function(c) {
        var date = c.created_at ? new Date(c.created_at).toLocaleString('ar-SA') : '';
        return '<span class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-100 text-slate-700 text-sm">' +
          '<i class="fas fa-file-excel text-indigo-600"></i> ' + (c.name || 'دورة') + ' <span class="text-slate-500 text-xs">' + date + '</span></span>';
      }).join('');
    }
  } catch (_) {}
}

(function initSheetPage() {
  loadCycles();
})();
</script>
