  .shipping-actions-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }
  @media (min-width: 640px) {
    .shipping-actions-row {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.75rem;
    }
    .shipping-actions-record {
      grid-column: auto;
    }
  }
  .shipping-actions-record {
    grid-column: 1 / -1;
  }
</style>
