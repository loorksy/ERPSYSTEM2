    <div class="sticky top-0 bg-white border-b border-slate-100 px-6 py-4 flex items-center justify-between">
      <h4 class="text-lg font-bold text-slate-800">نموذج بيع</h4>
      <button type="button" onclick="shippingCloseSellModal()" class="w-10 h-10 rounded-xl text-slate-400 hover:bg-slate-100 flex items-center justify-center">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <form id="shippingSellForm" class="p-6 space-y-4">
