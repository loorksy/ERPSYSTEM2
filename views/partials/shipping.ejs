<style>
  /* يتجاوز preflight (background: transparent على كل button) حتى يظهر زر البيع بلون صلب */
  #shippingBtnSell {
    background-color: #4f46e5 !important;
    color: #ffffff !important;
    -webkit-tap-highlight-color: transparent;
  }
  #shippingBtnSell:hover {
    background-color: #4338ca !important;
  }
  #shippingBtnSell:active {
    background-color: #3730a3 !important;
  }
</style>
<div class="w-full max-w-5xl mx-auto" dir="rtl">
  <div class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden flex flex-col min-w-0" data-tabs-container="shipping">
    <!-- رأس: يتكيف مع العرض الضيق -->
    <header class="shrink-0 border-b border-slate-100 bg-white px-4 py-4 sm:px-5 sm:py-5 md:px-6">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-4">
        <div class="flex items-center gap-3 min-w-0">
          <div class="flex h-11 w-11 sm:h-12 sm:w-12 shrink-0 items-center justify-center rounded-xl bg-indigo-600 text-white shadow-md">
            <i class="fas fa-truck-fast text-lg sm:text-xl"></i>
          </div>
          <div class="min-w-0">
            <h3 class="text-base sm:text-lg md:text-xl font-bold text-slate-900 truncate">قسم الشحن</h3>
            <p class="mt-0.5 text-xs sm:text-sm text-slate-500 leading-snug">المخزون، البيع والشراء، ووكالات النقل</p>
          </div>
        </div>
      </div>
    </header>

    <!-- شريط تبويبات موحّد (segmented) — ثلاثة أعمدة متساوية على كل الشاشات -->
    <div class="shrink-0 border-b border-slate-100 bg-white px-3 pt-3 pb-2 sm:px-4 sm:pt-4 sm:pb-3 md:px-5">
      <nav class="rounded-xl bg-slate-100 p-1 grid grid-cols-3 gap-0 shadow-inner touch-manipulation" role="tablist" aria-label="أقسام الشحن">
        <button type="button" role="tab" onclick="switchShippingTab(this, 'shipping-carriers')" class="shipping-tab-link flex min-h-[44px] sm:min-h-[46px] items-center justify-center gap-1 sm:gap-1.5 px-1 py-2 rounded-lg text-[11px] sm:text-xs md:text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors">
          <i class="fas fa-truck-moving shrink-0 text-[0.85em] sm:text-[0.95em]"></i>
          <span class="leading-tight text-center">وكالات الشحن</span>
        </button>
        <button type="button" role="tab" onclick="switchShippingTab(this, 'shipping-main')" class="shipping-tab-link flex min-h-[44px] sm:min-h-[46px] items-center justify-center gap-1 sm:gap-1.5 px-1 py-2 rounded-lg text-[11px] sm:text-xs md:text-sm font-semibold text-indigo-700 bg-white shadow-sm ring-1 ring-slate-200/90 transition-colors">
          <i class="fas fa-right-left shrink-0 text-[0.85em] sm:text-[0.95em]"></i>
          <span class="leading-tight text-center">الشحن</span>
        </button>
        <button type="button" role="tab" onclick="switchShippingTab(this, 'shipping-packages')" class="shipping-tab-link flex min-h-[44px] sm:min-h-[46px] items-center justify-center gap-1 sm:gap-1.5 px-1 py-2 rounded-lg text-[11px] sm:text-xs md:text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors">
          <i class="fas fa-box-open shrink-0 text-[0.85em] sm:text-[0.95em]"></i>
          <span class="leading-tight text-center">الباقات</span>
        </button>
      </nav>
    </div>

    <!-- محتوى التبويبات -->
    <div class="relative bg-slate-50/70 px-3 py-4 sm:px-4 sm:py-5 md:px-6 md:py-6 pb-6 sm:pb-8 max-lg:pb-[max(1.5rem,env(safe-area-inset-bottom))]">
      <!-- وكالات الشحن -->
      <div id="shipping-carriers" class="tab-content hidden rounded-xl border border-slate-200 bg-white p-4 sm:p-5 shadow-sm">
        <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
          <div class="min-w-0">
            <h4 class="text-sm sm:text-base font-bold text-slate-900">وكالات الشحن</h4>
            <p class="mt-1 text-xs sm:text-sm text-slate-500 leading-relaxed">إضافة رصيد وعرض سجل الحركات لكل وكالة.</p>
          </div>
          <button type="button" onclick="shippingOpenCarrierAdd()" class="w-full sm:w-auto shrink-0 inline-flex h-11 items-center justify-center gap-2 rounded-xl bg-indigo-600 px-4 text-sm font-bold text-white shadow-md hover:bg-indigo-700 active:scale-[0.99] transition">
            <i class="fas fa-plus-circle"></i>
            إضافة وكالة
          </button>
        </div>
        <div id="shippingCarrierCards" class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <p class="text-slate-400 text-sm col-span-full py-6 text-center">جاري التحميل...</p>
        </div>
      </div>

      <!-- الشحن -->
      <div id="shipping-main" class="tab-content space-y-4 sm:space-y-5">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
          <div class="rounded-xl border border-amber-200 bg-amber-50 p-3.5 sm:p-4">
            <div class="flex items-center gap-3">
              <span class="flex h-9 w-9 sm:h-10 sm:w-10 shrink-0 items-center justify-center rounded-lg bg-amber-100 text-amber-700">
                <i class="fas fa-coins text-sm sm:text-base"></i>
              </span>
              <div class="min-w-0">
                <p class="text-[11px] sm:text-xs font-semibold text-amber-900">رصيد الذهب</p>
                <p id="shippingGoldBalance" class="text-base sm:text-lg md:text-xl font-bold tabular-nums text-amber-900 truncate">0</p>
              </div>
            </div>
          </div>
          <div class="rounded-xl border border-indigo-200 bg-indigo-50 p-3.5 sm:p-4">
            <div class="flex items-center gap-3">
              <span class="flex h-9 w-9 sm:h-10 sm:w-10 shrink-0 items-center justify-center rounded-lg bg-indigo-100 text-indigo-700">
                <i class="fas fa-gem text-sm sm:text-base"></i>
              </span>
              <div class="min-w-0">
                <p class="text-[11px] sm:text-xs font-semibold text-indigo-900">رصيد الكرستال</p>
                <p id="shippingCrystalBalance" class="text-base sm:text-lg md:text-xl font-bold tabular-nums text-indigo-900 truncate">0</p>
              </div>
            </div>
          </div>
        </div>

        <!-- أزرار متساوية: عمود واحد على الموبايل، ثلاثة أعمدة من sm فما فوق -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-2.5 sm:gap-3 touch-manipulation">
          <button type="button" id="shippingBtnSell" onclick="shippingOpenSellModal()" class="flex h-12 sm:h-[52px] w-full items-center justify-center gap-2 rounded-xl px-3 text-sm font-bold shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 transition-colors select-none">
            <i class="fas fa-hand-holding-usd shrink-0" aria-hidden="true"></i>
            <span>بيع</span>
          </button>
          <button type="button" onclick="shippingOpenBuyModal()" class="flex h-12 sm:h-[52px] w-full items-center justify-center gap-2 rounded-xl bg-cyan-600 px-3 text-sm font-bold text-white shadow-md hover:bg-cyan-700 active:bg-cyan-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500 focus-visible:ring-offset-2 transition-colors select-none">
            <i class="fas fa-shopping-cart shrink-0"></i>
            <span>شراء</span>
          </button>
          <button type="button" onclick="shippingOpenRecordModal()" class="flex h-12 sm:h-[52px] w-full items-center justify-center gap-2 rounded-xl border-2 border-slate-200 bg-white px-3 text-sm font-bold text-slate-800 shadow-sm hover:border-indigo-200 hover:bg-indigo-50/60 active:bg-slate-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-slate-300 focus-visible:ring-offset-2 transition-colors select-none">
            <i class="fas fa-history shrink-0 text-slate-600"></i>
            <span>السجل</span>
          </button>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-3.5 sm:p-4 shadow-sm">
          <div class="flex gap-3 sm:gap-4">
            <div class="flex h-9 w-9 sm:h-10 sm:w-10 shrink-0 items-center justify-center rounded-lg bg-indigo-100 text-indigo-600">
              <i class="fas fa-info-circle text-sm sm:text-base"></i>
            </div>
            <div class="min-w-0">
              <h4 class="text-sm sm:text-base font-bold text-slate-900">عن المبلغ والكمية</h4>
              <p class="mt-2 text-xs sm:text-sm leading-relaxed text-slate-600">
                المبلغ مع الكمية = <strong class="text-slate-900">إجمالي قيمة تلك الكمية</strong> (وليس سعر الوحدة). استخدم <span class="font-semibold text-indigo-700">بيع</span> و<span class="font-semibold text-cyan-700">شراء</span> ثم راجع <span class="font-semibold text-slate-800">السجل</span> عند الحاجة.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- الباقات -->
      <div id="shipping-packages" class="tab-content hidden rounded-xl border border-slate-200 bg-white p-6 sm:p-10 text-center shadow-sm">
        <div class="mx-auto mb-4 flex h-14 w-14 sm:h-16 sm:w-16 items-center justify-center rounded-2xl bg-indigo-100 text-indigo-600">
          <i class="fas fa-box-open text-2xl sm:text-3xl"></i>
        </div>
        <p class="text-sm sm:text-base font-bold text-slate-900">الباقات</p>
        <p class="mt-2 text-xs sm:text-sm text-slate-500 max-w-sm mx-auto leading-relaxed">سيتم إضافة محتوى الباقات هنا قريباً.</p>
      </div>
    </div>
  </div>
</div>

<!-- نافذة بيع -->
<div id="shippingSellModal" class="fixed inset-0 z-[2000] hidden items-center justify-center p-4 bg-black/50">
  <div class="bg-white rounded-2xl shadow-xl max-w-lg w-full max-h-[90vh] overflow-y-auto">
    <div class="sticky top-0 bg-white border-b border-slate-100 px-6 py-4 flex items-center justify-between">
      <h4 class="text-lg font-bold text-slate-800">نموذج بيع</h4>
      <button type="button" onclick="shippingCloseSellModal()" class="w-10 h-10 rounded-xl text-slate-400 hover:bg-slate-100 flex items-center justify-center">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <form id="shippingSellForm" class="p-6 space-y-4">
      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-2">نوع المشتري</label>
        <select id="sellBuyerType" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" onchange="shippingSellBuyerTypeChange()">
          <option value="user">مستخدم</option>
          <option value="approved">معتمد</option>
          <option value="sub_agent">وكيل فرعي</option>
          <option value="shipping_carrier">وكالة شحن</option>
        </select>
      </div>

      <!-- مستخدم -->
      <div id="sellUserFields" class="space-y-3">
        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-1">رقم المستخدم</label>
          <input type="text" id="sellUserNumber" class="w-full px-4 py-2.5 rounded-xl border border-slate-200" placeholder="رقم المستخدم">
        </div>
      </div>

      <!-- معتمد -->
      <div id="sellApprovedFields" class="hidden space-y-3">
        <div class="flex gap-2">
          <select id="sellApprovedId" class="flex-1 px-4 py-2.5 rounded-xl border border-slate-200">
            <option value="">-- اختر المعتمد --</option>
          </select>
          <button type="button" onclick="shippingQuickAdd('approved', 'sellApprovedId', 'اسم المعتمد')" class="px-3 py-2.5 rounded-xl bg-slate-100 text-slate-600 hover:bg-slate-200 text-sm" title="إضافة معتمد">+</button>
        </div>
      </div>

      <!-- وكيل فرعي -->
      <div id="sellSubAgentFields" class="hidden space-y-3">
        <div class="flex gap-2">
          <select id="sellSubAgencyId" class="flex-1 px-4 py-2.5 rounded-xl border border-slate-200">
            <option value="">-- اختر الوكالة --</option>
          </select>
          <button type="button" onclick="shippingQuickAdd('sub-agencies', 'sellSubAgencyId', 'اسم الوكالة')" class="px-3 py-2.5 rounded-xl bg-slate-100 text-slate-600 hover:bg-slate-200 text-sm" title="إضافة وكالة">+</button>
        </div>
      </div>

      <div id="sellCarrierFields" class="hidden space-y-3">
        <div class="flex gap-2">
          <select id="sellCarrierId" class="flex-1 px-4 py-2.5 rounded-xl border border-slate-200">
            <option value="">-- وكالة الشحن --</option>
          </select>
        </div>
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-2">نوع الشحن</label>
        <select id="sellItemType" name="itemType" class="w-full px-4 py-2.5 rounded-xl border border-slate-200" required>
          <option value="gold">ذهب</option>
          <option value="crystal">كرستال</option>
        </select>
      </div>

      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-1">الكمية</label>
          <input type="number" id="sellQuantity" name="quantity" step="0.01" min="0.01" class="w-full px-4 py-2.5 rounded-xl border border-slate-200" required>
        </div>
        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-1">إجمالي مبلغ البيع (للكمية)</label>
          <input type="number" id="sellUnitPrice" name="unitPrice" step="0.01" min="0" class="w-full px-4 py-2.5 rounded-xl border border-slate-200" required>
        </div>
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-2">طريقة الدفع</label>
        <select id="sellPaymentMethod" name="paymentMethod" class="w-full px-4 py-2.5 rounded-xl border border-slate-200" onchange="shippingSellPaymentChange()" required>
          <option value="cash">كاش</option>
          <option value="debt">دين</option>
          <option value="salary_deduction" id="sellSalaryOpt">خصم من راتب</option>
          <option value="agency_deduction" id="sellAgencyOpt" class="hidden">خصم من نسبة الوكالة</option>
        </select>
      </div>

      <div id="sellSalaryFields" class="hidden space-y-3">
        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-1">اختيار مستخدم (للخصم)</label>
          <select id="sellSalaryUserId" class="w-full px-4 py-2.5 rounded-xl border border-slate-200">
            <option value="">-- اختر المستخدم --</option>
          </select>
        </div>
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-1">ملاحظات</label>
        <textarea id="sellNotes" name="notes" rows="2" class="w-full px-4 py-2.5 rounded-xl border border-slate-200" placeholder="اختياري"></textarea>
      </div>

      <div class="flex gap-3 pt-2">
        <button type="submit" class="flex-1 py-3 rounded-xl font-semibold bg-emerald-600 text-white hover:bg-emerald-700">تسجيل البيع</button>
        <button type="button" onclick="shippingCloseSellModal()" class="px-5 py-3 rounded-xl font-semibold bg-slate-100 text-slate-600 hover:bg-slate-200">إلغاء</button>
      </div>
    </form>
  </div>
</div>

<!-- نافذة شراء -->
<div id="shippingBuyModal" class="fixed inset-0 z-[2000] hidden items-center justify-center p-4 bg-black/50">
  <div class="bg-white rounded-2xl shadow-xl max-w-lg w-full max-h-[90vh] overflow-y-auto">
    <div class="sticky top-0 bg-white border-b border-slate-100 px-6 py-4 flex items-center justify-between">
      <h4 class="text-lg font-bold text-slate-800">نموذج شراء</h4>
      <button type="button" onclick="shippingCloseBuyModal()" class="w-10 h-10 rounded-xl text-slate-400 hover:bg-slate-100 flex items-center justify-center">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <form id="shippingBuyForm" class="p-6 space-y-4">
      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-2">مصدر الشراء</label>
        <select id="buyPurchaseSource" name="purchaseSource" class="w-full px-4 py-2.5 rounded-xl border border-slate-200" onchange="shippingBuySourceChange()" required>
          <option value="administration">الإدارة</option>
          <option value="company">شركة</option>
        </select>
      </div>

      <div id="buyCompanyFields" class="hidden space-y-2">
        <div class="flex gap-2">
          <select id="buyCompanyId" class="flex-1 px-4 py-2.5 rounded-xl border border-slate-200">
            <option value="">-- اختر الشركة --</option>
          </select>
          <button type="button" onclick="shippingQuickAdd('companies', 'buyCompanyId', 'اسم الشركة')" class="px-3 py-2.5 rounded-xl bg-slate-100 text-slate-600 hover:bg-slate-200 text-sm" title="إضافة شركة">+</button>
        </div>
        <input type="text" id="buyCompanyName" class="w-full px-4 py-2.5 rounded-xl border border-slate-200" placeholder="أو اكتب اسم شركة جديدة">
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-2">نوع الشراء</label>
        <select id="buyItemType" name="itemType" class="w-full px-4 py-2.5 rounded-xl border border-slate-200" required>
          <option value="gold">ذهب</option>
          <option value="crystal">كرستال</option>
        </select>
      </div>

      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-1">الكمية</label>
          <input type="number" id="buyQuantity" name="quantity" step="0.01" min="0.01" class="w-full px-4 py-2.5 rounded-xl border border-slate-200" required>
        </div>
        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-1">إجمالي مبلغ الشراء (للكمية)</label>
          <input type="number" id="buyUnitPrice" name="unitPrice" step="0.01" min="0" class="w-full px-4 py-2.5 rounded-xl border border-slate-200" required>
        </div>
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-2">طريقة الدفع</label>
        <select id="buyPaymentMethod" name="paymentMethod" class="w-full px-4 py-2.5 rounded-xl border border-slate-200" required>
          <option value="cash">كاش</option>
          <option value="debt">دين</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-1">ملاحظات</label>
        <textarea id="buyNotes" name="notes" rows="2" class="w-full px-4 py-2.5 rounded-xl border border-slate-200" placeholder="اختياري"></textarea>
      </div>

      <div class="flex gap-3 pt-2">
        <button type="submit" class="flex-1 py-3 rounded-xl font-semibold bg-blue-600 text-white hover:bg-blue-700">تسجيل الشراء</button>
        <button type="button" onclick="shippingCloseBuyModal()" class="px-5 py-3 rounded-xl font-semibold bg-slate-100 text-slate-600 hover:bg-slate-200">إلغاء</button>
      </div>
    </form>
  </div>
</div>

<!-- نافذة السجل -->
<div id="shippingRecordModal" class="fixed inset-0 z-[2000] hidden items-center justify-center p-4 bg-black/50">
  <div class="bg-white rounded-2xl shadow-xl max-w-4xl w-full max-h-[90vh] overflow-hidden flex flex-col">
    <div class="flex-shrink-0 px-6 py-4 border-b border-slate-100 flex items-center justify-between">
      <h4 class="text-lg font-bold text-slate-800">سجل عمليات الشحن</h4>
      <button type="button" onclick="shippingCloseRecordModal()" class="w-10 h-10 rounded-xl text-slate-400 hover:bg-slate-100 flex items-center justify-center">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div class="p-4 border-b border-slate-100 flex flex-wrap gap-2">
      <select id="recordFilterType" class="px-3 py-2 rounded-lg border border-slate-200 text-sm">
        <option value="">كل الأنواع</option>
        <option value="sell">بيع</option>
        <option value="buy">شراء</option>
      </select>
      <select id="recordFilterStatus" class="px-3 py-2 rounded-lg border border-slate-200 text-sm">
        <option value="">كل الحالات</option>
        <option value="completed">مكتملة</option>
        <option value="debt">دين</option>
      </select>
      <input type="date" id="recordFilterFrom" class="px-3 py-2 rounded-lg border border-slate-200 text-sm">
      <input type="date" id="recordFilterTo" class="px-3 py-2 rounded-lg border border-slate-200 text-sm">
      <button type="button" onclick="shippingLoadRecord()" class="px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700">تطبيق</button>
    </div>
    <div class="flex-1 overflow-y-auto p-4">
      <div id="shippingRecordList" class="space-y-2">
        <p class="text-slate-400 text-center py-8">جاري التحميل...</p>
      </div>
    </div>
  </div>
</div>

<div id="shippingCarrierAddModal" class="fixed inset-0 z-[2000] hidden items-center justify-center p-4 bg-black/50">
  <div class="bg-white rounded-2xl p-6 max-w-md w-full shadow-xl">
    <h4 class="font-bold text-lg mb-4">إضافة وكالة شحن</h4>
    <form id="shippingCarrierAddForm" class="space-y-3">
      <input type="text" id="carrierAddName" placeholder="الاسم" class="w-full px-4 py-2.5 rounded-xl border border-slate-200" required>
      <div class="grid grid-cols-2 gap-2">
        <input type="number" id="carrierAddAmt" step="0.01" placeholder="المبلغ (اختياري)" class="px-4 py-2.5 rounded-xl border border-slate-200">
        <input type="number" id="carrierAddQty" step="0.01" placeholder="الكمية (اختياري)" class="px-4 py-2.5 rounded-xl border border-slate-200">
      </div>
      <div class="flex gap-2">
