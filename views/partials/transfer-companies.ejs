<div class="max-w-6xl mx-auto px-4 sm:px-0 pb-10" dir="rtl">
  <div class="erp-module-shell rounded-2xl border border-slate-200/90 bg-white shadow-sm overflow-hidden mb-6">
    <div class="relative overflow-hidden border-b border-slate-200/80 bg-gradient-to-br from-cyan-50/90 via-white to-slate-50 px-4 py-5 sm:px-7 sm:py-6">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_50%_at_100%_100%,rgba(6,182,212,0.1),transparent)] pointer-events-none"></div>
      <div class="relative flex items-start gap-3 sm:gap-4">
        <div class="flex h-11 w-11 sm:h-12 sm:w-12 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-cyan-600 to-blue-700 text-white shadow-md">
          <i class="fas fa-building text-lg sm:text-xl"></i>
        </div>
        <div class="min-w-0">
          <p class="text-xs font-semibold text-cyan-800 mb-0.5">شركاء التحويل</p>
          <h2 class="text-lg sm:text-2xl font-bold text-slate-900 tracking-tight">شركات التحويل</h2>
          <p class="text-sm text-slate-600 mt-1 leading-relaxed">إدارة الشركات، الأرصدة، والدفاتر والمرتجعات.</p>
        </div>
      </div>
    </div>
    <div class="border-b border-slate-100 bg-slate-50/95 px-4 py-4 sm:px-6 sm:py-4">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-end">
        <button type="button" onclick="tcOpenAdd()" class="inline-flex w-full sm:w-auto items-center justify-center gap-2 px-5 py-2.5 rounded-xl bg-sky-600 text-white text-sm font-bold shadow-md shadow-sky-600/20 hover:bg-sky-700 active:scale-[0.99] transition">
          <i class="fas fa-plus"></i> إضافة شركة
        </button>
      </div>
    </div>
  </div>
  <div id="tcCards" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <p class="text-slate-400 col-span-full text-center py-12">جاري التحميل...</p>
  </div>
</div>

<div id="tcAddModal" class="fixed inset-0 z-[2000] hidden items-center justify-center p-4 bg-black/50">
  <div class="bg-white rounded-2xl shadow-xl max-w-lg w-full p-6 max-h-[90vh] overflow-y-auto">
    <h4 class="text-lg font-bold mb-4">إضافة شركة تحويل</h4>
    <form id="tcAddForm" class="space-y-3">
      <div>
        <label class="text-sm font-semibold">اسم الشركة</label>
        <input type="text" id="tcName" class="w-full mt-1 px-4 py-2.5 rounded-xl border border-slate-200" required>
      </div>
      <div>
        <label class="text-sm font-semibold">الدولة</label>
        <select id="tcCountry" class="w-full mt-1 px-4 py-2.5 rounded-xl border border-slate-200"></select>
      </div>
      <div>
        <label class="text-sm font-semibold">الرصيد (موجب لنا / سالب علينا)</label>
        <div class="flex gap-2 mt-1">
          <input type="number" id="tcBal" step="0.01" class="flex-1 px-4 py-2.5 rounded-xl border border-slate-200" value="0">
          <select id="tcBalCur" class="w-28 rounded-xl border border-slate-200"><option value="USD">USD</option><option value="TRY">TRY</option><option value="SYP">SYP</option></select>
        </div>
      </div>
      <div>
        <label class="text-sm font-semibold">أنواع التحويل (اختر عدة)</label>
        <div id="tcTypesWrap" class="mt-2 flex flex-wrap gap-2"></div>
      </div>
      <div class="flex gap-2 pt-2">
        <button type="submit" class="flex-1 py-3 rounded-xl bg-sky-600 text-white font-semibold">حفظ</button>
        <button type="button" onclick="tcCloseAdd()" class="px-5 py-3 rounded-xl bg-slate-100">إلغاء</button>
      </div>
    </form>
  </div>
</div>

<div id="tcDetailModal" class="fixed inset-0 z-[2000] hidden items-center justify-center p-4 bg-black/50">
  <div class="bg-white rounded-2xl shadow-xl max-w-2xl w-full max-h-[90vh] overflow-hidden flex flex-col">
    <div class="px-6 py-4 border-b flex justify-between">
      <h4 id="tcDetailTitle" class="text-lg font-bold">الشركة</h4>
      <button type="button" onclick="tcCloseDetail()" class="w-10 h-10 rounded-xl hover:bg-slate-100 text-slate-400"><i class="fas fa-times"></i></button>
    </div>
    <div class="p-4 overflow-y-auto flex-1">
      <div class="flex flex-wrap items-center justify-between gap-2 mb-3">
        <p id="tcDetailBal" class="text-sky-600 font-bold"></p>
        <button type="button" onclick="tcDownloadLedgerPdf()" class="px-3 py-2 rounded-xl bg-slate-100 text-slate-700 text-sm font-semibold hover:bg-slate-200">
          <i class="fas fa-file-pdf ml-1"></i> تنزيل PDF
        </button>
      </div>
      <div class="border border-slate-100 rounded-xl p-4 mb-4 bg-slate-50/50">
        <h5 class="font-bold text-slate-800 mb-2 text-sm">إضافة دين لنا</h5>
        <div class="flex flex-wrap gap-2 items-end">
          <input type="number" id="tcRecvAmt" step="0.01" min="0" class="px-3 py-2 rounded-lg border border-slate-200 w-32 text-sm" placeholder="المبلغ">
          <select id="tcRecvCur" class="px-3 py-2 rounded-lg border border-slate-200 text-sm">
            <option value="USD">USD</option>
            <option value="TRY">TRY</option>
            <option value="SYP">SYP</option>
          </select>
          <input type="text" id="tcRecvNotes" class="flex-1 min-w-[140px] px-3 py-2 rounded-lg border border-slate-200 text-sm" placeholder="ملاحظات (اختياري)">
          <button type="button" onclick="tcSubmitReceivable()" class="px-4 py-2 rounded-lg bg-sky-600 text-white text-sm font-semibold">تسجيل</button>
        </div>
      </div>
      <div id="tcDetailLedger" class="space-y-2 text-sm"></div>
      <div class="border-t border-slate-200 pt-4 mt-4">
        <h5 class="font-bold text-slate-800 mb-2">تسجيل مرتجع</h5>
        <input type="hidden" id="tcReturnCompanyId">
        <div class="flex flex-wrap gap-2 items-end mb-2">
          <input type="number" id="tcReturnAmt" step="0.01" min="0" placeholder="المبلغ" class="px-3 py-2 rounded-lg border border-slate-200 w-32 text-sm">
          <select id="tcReturnCur" class="px-3 py-2 rounded-lg border border-slate-200 text-sm">
            <option value="USD">USD</option>
            <option value="TRY">TRY</option>
            <option value="SYP">SYP</option>
          </select>
          <select id="tcReturnDisposition" class="px-3 py-2 rounded-lg border border-slate-200 text-sm">
            <option value="remain_at_entity">يبقى لدى الشركة</option>
            <option value="transfer_to_fund">ترحيل لصندوق</option>
          </select>
          <select id="tcReturnFundId" class="px-3 py-2 rounded-lg border border-slate-200 text-sm hidden"></select>
        </div>
        <input type="text" id="tcReturnNotes" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm mb-2" placeholder="ملاحظات (اختياري)">
        <button type="button" onclick="tcSubmitReturn()" class="px-4 py-2 rounded-lg bg-sky-600 text-white text-sm font-semibold">تسجيل المرتجع</button>
      </div>
    </div>
  </div>
</div>
<script>
  window.FUNDS_COUNTRIES = ['سوريا','تركيا','مصر','العراق','الجزائر','الأردن','المغرب','فلسطين','لبنان','السعودية','الإمارات','الكويت','قطر','البحرين','عُمان','اليمن','السودان','تونس','ليبيا','موريتانيا'];
</script>
