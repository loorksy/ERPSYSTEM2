</div>

<div id="accBulkModal" class="fixed inset-0 z-[9990] hidden items-end sm:items-center justify-center p-0 sm:p-4 bg-slate-900/60 backdrop-blur-sm transition-opacity" dir="rtl" data-acc-step="import">
