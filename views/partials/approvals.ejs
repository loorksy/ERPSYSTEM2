            <option value="paste">لصق نص أو CSV</option>
            <option value="sheet">رابط Google Sheet</option>
          </select>
        </div>

        <div class="mt-4 sm:mt-5 pt-4 sm:pt-5 border-t border-slate-100 space-y-4 min-h-[6rem]">
          <div id="accBulkPanelFile" class="acc-bulk-source-panel space-y-4">
            <p class="text-xs text-slate-500 leading-relaxed">ملف يحتوي الأعمدة: كود، اسم، رصيد، (اختياري) معتمد رئيسي.</p>
            <input type="file" id="accBulkFile" accept=".csv,.xlsx,.xls" class="sr-only" tabindex="-1" aria-label="اختيار ملف">
            <label for="accBulkFile" id="accBulkDropzone" class="acc-bulk-dropzone flex cursor-pointer flex-col items-center justify-center gap-2 rounded-2xl border-2 border-dashed border-indigo-200 bg-indigo-50/50 px-4 py-7 sm:py-8 text-center transition-colors hover:border-indigo-300 hover:bg-indigo-50/80 focus-within:outline focus-within:outline-2 focus-within:outline-offset-2 focus-within:outline-indigo-500/40 min-h-[140px] sm:min-h-[156px] sm:gap-3">
              <span class="flex h-14 w-14 items-center justify-center rounded-2xl border border-indigo-100 bg-white text-indigo-600 shadow-sm">
                <i class="fas fa-cloud-arrow-up text-2xl"></i>
              </span>
              <span class="text-sm font-semibold text-slate-800">اسحب الملف هنا أو اضغط للاختيار</span>
              <span class="text-xs text-slate-500">Excel أو CSV</span>
              <span id="accBulkFileName" class="hidden max-w-full truncate rounded-lg bg-white/80 px-2 py-1 text-xs font-mono text-indigo-700 ring-1 ring-indigo-100"></span>
            </label>
