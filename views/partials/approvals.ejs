    </div>
    <div class="flex flex-wrap gap-2">
      <button type="button" onclick="accOpenBulk()" class="px-4 py-2.5 rounded-xl bg-slate-600 text-white text-sm font-semibold shadow-md hover:bg-slate-700 active:scale-[0.99] transition">رفع أرصدة</button>
      <button type="button" onclick="accOpenDelivery()" class="px-4 py-2.5 rounded-xl bg-emerald-600 text-white text-sm font-semibold shadow-md hover:bg-emerald-700 active:scale-[0.99] transition">تسليم</button>
      <button type="button" onclick="accOpenAdd()" class="px-5 py-2.5 rounded-xl bg-indigo-600 text-white text-sm font-semibold shadow-md hover:bg-indigo-700 active:scale-[0.99] transition">
        <i class="fas fa-plus ml-2"></i> إضافة معتمد
      </button>
    </div>
  </div>
  <div class="acc-approvals-list-shell rounded-2xl border border-slate-100 bg-white shadow-sm w-full flex flex-col overflow-hidden">
    <div id="accCards" class="grid flex-1 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 p-4 sm:p-6 min-h-0 content-start">
      <div class="col-span-full acc-approvals-empty text-slate-400">
