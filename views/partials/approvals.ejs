    background-color: rgb(16 185 129);
    color: white;
    border-color: rgb(16 185 129);
  }
  #accBulkModal[data-acc-step="review"] .acc-bulk-step-label-1 {
    color: rgb(71 85 105);
  }
  #accBulkModal[data-acc-step="review"] .acc-bulk-step-dot-2 {
    background-color: rgb(79 70 229);
    color: white;
    border-color: rgb(79 70 229);
    box-shadow: 0 0 0 4px rgb(99 102 241 / 0.2);
  }
  #accBulkModal[data-acc-step="review"] .acc-bulk-step-label-2 {
    color: rgb(30 41 59);
    font-weight: 700;
  }
  #accBulkModal[data-acc-step="import"] .acc-bulk-step-dot-1 {
    background-color: rgb(79 70 229);
    color: white;
    border-color: rgb(79 70 229);
    box-shadow: 0 0 0 4px rgb(99 102 241 / 0.2);
  }
  #accBulkModal[data-acc-step="import"] .acc-bulk-step-label-1 {
    color: rgb(30 41 59);
    font-weight: 700;
  }
  #accBulkModal[data-acc-step="import"] .acc-bulk-step-dot-2 {
    background-color: white;
    color: rgb(100 116 139);
    border-color: rgb(226 232 240);
    box-shadow: none;
  }
  #accBulkModal[data-acc-step="import"] .acc-bulk-step-label-2 {
    color: rgb(100 116 139);
    font-weight: 600;
  }
  /* معاينة الجدول (موبايل) + عمود نموذج مريح على الشاشات العريضة */
  .acc-bulk-form-narrow {
    max-width: 28rem;
    margin-left: auto;
    margin-right: auto;
    width: 100%;
  }
  @media (min-width: 640px) {
    .acc-bulk-form-narrow {
      max-width: 32rem;
    }
  }
  #accBulkModal select,
  #accBulkModal input[type="number"]:not(.acc-bulk-bp),
  #accBulkModal input[type="url"],
  #accBulkModal input[type="text"] {
    min-height: 2.75rem;
  }
  @media (max-width: 767px) {
    .acc-bulk-scroll { overflow-x: hidden !important; }
    .acc-bulk-review { min-width: 0 !important; width: 100% !important; }
    .acc-bulk-review thead.acc-bulk-thead { display: none !important; }
    .acc-bulk-review tbody tr.acc-bulk-tr {
      display: block;
      border: 1px solid rgb(241 245 249);
      border-radius: 0.75rem;
      margin-bottom: 0.75rem;
      background: #fff;
      box-shadow: 0 1px 2px 0 rgb(15 23 42 / 0.04);
      overflow: hidden;
    }
    .acc-bulk-review tbody td.acc-bulk-td {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 0.75rem;
      padding: 0.65rem 0.85rem !important;
      border-bottom: 1px solid rgb(241 245 249);
      width: 100%;
      box-sizing: border-box;
    }
    .acc-bulk-review tbody td.acc-bulk-td:last-child { border-bottom: none; }
    .acc-bulk-review tbody td.acc-bulk-td::before {
      content: attr(data-label);
      flex-shrink: 0;
      font-size: 0.75rem;
      font-weight: 600;
      color: rgb(100 116 139);
      max-width: 40%;
    }
    .acc-bulk-review tbody td.acc-bulk-td > *:last-child {
      flex: 1 1 auto;
      min-width: 0;
      text-align: end;
    }
  }
</style>
<div class="w-full max-w-6xl mx-auto" dir="rtl">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between mb-8">
    <div class="flex items-center gap-3 min-w-0">
      <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-indigo-600 text-white shadow-md">
        <i class="fas fa-stamp text-xl"></i>
      </div>
      <div>
        <h2 class="text-xl sm:text-2xl font-bold text-slate-900">الاعتمادات</h2>
        <p class="text-sm text-slate-500 mt-0.5">المعتمدون، الأرصدة، والتسليم</p>
      </div>
    </div>
    <div class="flex flex-wrap gap-2">
      <button type="button" onclick="accOpenBulk()" class="px-4 py-2.5 rounded-xl bg-slate-600 text-white text-sm font-semibold shadow-md hover:bg-slate-700 active:scale-[0.99] transition">رفع أرصدة</button>
      <button type="button" onclick="accOpenDelivery()" class="px-4 py-2.5 rounded-xl bg-emerald-600 text-white text-sm font-semibold shadow-md hover:bg-emerald-700 active:scale-[0.99] transition">تسليم</button>
      <button type="button" onclick="accOpenAdd()" class="px-5 py-2.5 rounded-xl bg-indigo-600 text-white text-sm font-semibold shadow-md hover:bg-indigo-700 active:scale-[0.99] transition">
        <i class="fas fa-plus ml-2"></i> إضافة معتمد
      </button>
    </div>
  </div>
  <div id="accCards" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <p class="text-slate-400 col-span-full text-center py-12">جاري التحميل...</p>
  </div>
</div>

<div id="accBulkModal" class="fixed inset-0 z-[2000] hidden items-start sm:items-center justify-center px-3 sm:px-4 bg-slate-900/50 backdrop-blur-[2px] overflow-y-auto overscroll-y-contain" dir="rtl" data-acc-step="import">
  <div class="bg-white rounded-2xl shadow-xl border border-slate-100 w-full max-w-[min(100vw-1.5rem,52rem)] my-3 sm:my-8 overflow-hidden flex flex-col min-h-0 max-h-[100dvh] sm:max-h-[calc(100dvh-2.5rem)]">
    <div class="px-5 sm:px-6 py-4 sm:py-5 border-b border-slate-100 shrink-0 bg-white">
      <div class="flex items-start gap-3">
        <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-indigo-500/10 text-indigo-600 border border-slate-100 shadow-sm">
          <i class="fas fa-file-circle-plus text-lg"></i>
        </div>
        <div class="min-w-0 flex-1">
          <h4 class="text-lg font-bold text-slate-900 tracking-tight">إضافة أرصدة (دفعة)</h4>
          <p class="text-xs text-slate-500 mt-1.5 leading-relaxed">أعمدة الملف: A كود، B اسم، C رصيد، D معتمد رئيسي — تُعرض المعاينة قبل الحفظ.</p>
        </div>
      </div>
    </div>
    <div id="accBulkStepper" class="flex items-center justify-center gap-2 sm:gap-4 px-4 py-3 border-b border-slate-100 bg-slate-50/90 shrink-0" aria-hidden="true">
      <div class="flex items-center gap-2 min-w-0">
        <span class="acc-bulk-step-dot-1 flex h-9 w-9 shrink-0 items-center justify-center rounded-full border-2 border-indigo-200 bg-white text-sm font-bold text-indigo-600">1</span>
        <span class="acc-bulk-step-label-1 text-xs sm:text-sm font-semibold text-slate-800 truncate">استيراد</span>
      </div>
      <div class="h-px w-8 sm:w-14 shrink bg-gradient-to-l from-slate-200 to-slate-300" role="presentation"></div>
      <div class="flex items-center gap-2 min-w-0">
        <span class="acc-bulk-step-dot-2 flex h-9 w-9 shrink-0 items-center justify-center rounded-full border-2 border-slate-200 bg-white text-sm font-bold text-slate-500">2</span>
        <span class="acc-bulk-step-label-2 text-xs sm:text-sm font-semibold text-slate-500 truncate">مراجعة وحفظ</span>
      </div>
    </div>
    <div class="p-5 sm:p-6 space-y-4 sm:space-y-5 overflow-y-auto flex-1 min-h-0 overscroll-contain bg-slate-50/40">
      <div class="rounded-2xl border border-slate-100 bg-white p-4 sm:p-5 shadow-sm acc-bulk-form-narrow">
        <div class="flex flex-wrap items-center gap-3 mb-3 sm:mb-4">
