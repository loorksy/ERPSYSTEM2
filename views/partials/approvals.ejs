            <label class="block text-xs font-semibold text-slate-600 mb-1.5">الدورة المالية</label>
            <select id="accBulkCycle" class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white text-slate-800 text-sm focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400 transition-shadow"><option value="">— دورة مالية —</option></select>
          </div>
          <div>
