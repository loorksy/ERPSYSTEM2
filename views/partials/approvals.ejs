            <textarea id="accBulkPaste" rows="6" class="w-full min-h-[140px] px-4 py-3 rounded-xl border border-slate-200 bg-white text-xs sm:text-sm font-mono text-slate-800 focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400" placeholder="الصق الصفوف من Excel أو CSV…"></textarea>
            <button type="button" onclick="accSubmitBulkText()" class="w-full min-h-[46px] py-3 rounded-xl bg-indigo-600 text-white text-sm font-bold shadow-sm hover:bg-indigo-700 active:scale-[0.99] transition-all">
              <i class="fas fa-eye ml-2 opacity-90"></i>
