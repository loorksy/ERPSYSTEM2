      <button type="button" onclick="accCloseBulk()" class="text-slate-400 hover:text-slate-600 hover:bg-slate-100 p-2 rounded-xl transition-colors shrink-0" aria-label="إغلاق"><i class="fas fa-times text-lg"></i></button>
    </div>

    <div id="accBulkStepper" class="flex items-center justify-center px-4 py-3 bg-slate-50/80 border-b border-slate-100 shrink-0 gap-2 sm:gap-4 relative z-0">
      <div class="flex items-center gap-2">
        <span class="acc-bulk-step-dot-1 flex h-7 w-7 sm:h-8 sm:w-8 items-center justify-center rounded-full border-2 text-xs sm:text-sm font-bold transition-all duration-300">1</span>
        <span class="acc-bulk-step-label-1 text-xs sm:text-sm transition-all duration-300">استيراد</span>
      </div>
      <div class="w-8 sm:w-16 h-px bg-slate-200"></div>
      <div class="flex items-center gap-2">
        <span class="acc-bulk-step-dot-2 flex h-7 w-7 sm:h-8 sm:w-8 items-center justify-center rounded-full border-2 text-xs sm:text-sm font-bold transition-all duration-300">2</span>
        <span class="acc-bulk-step-label-2 text-xs sm:text-sm transition-all duration-300">مراجعة</span>
      </div>
