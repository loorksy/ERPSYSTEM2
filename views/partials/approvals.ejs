<style>
  /* ثيم LorkERP: slate + indigo + emerald — يبقى CSS للحالات التي لا تغطيها Tailwind (جدول موبايل، sticky) */
  #accBulkModal {
    overscroll-behavior: contain;
    padding-top: max(0.75rem, env(safe-area-inset-top, 0px));
    padding-bottom: max(0.75rem, env(safe-area-inset-bottom, 0px));
    touch-action: manipulation;
    isolation: isolate;
  }
  .acc-bulk-dropzone.acc-bulk-dropzone-drag {
    border-color: rgb(99 102 241);
    background-color: rgb(238 242 255);
    transform: scale(1.02);
  }
  #accBulkModal[data-acc-step="review"] #accBulkSourceWrap {
    display: none;
  }
  #accBulkModal[data-acc-step="review"] .acc-bulk-step-dot-1 {
    background-color: rgb(16 185 129);
    color: white;
    border-color: rgb(16 185 129);
  }
  #accBulkModal[data-acc-step="review"] .acc-bulk-step-label-1 {
    color: rgb(100 116 139);
  }
  #accBulkModal[data-acc-step="review"] .acc-bulk-step-dot-2 {
    background-color: rgb(79 70 229);
    color: white;
    border-color: rgb(79 70 229);
    box-shadow: 0 0 0 4px rgb(99 102 241 / 0.2);
  }
  #accBulkModal[data-acc-step="review"] .acc-bulk-step-label-2 {
    color: rgb(30 41 59);
    font-weight: 700;
  }
  #accBulkModal[data-acc-step="import"] .acc-bulk-step-dot-1 {
    background-color: rgb(79 70 229);
    color: white;
    border-color: rgb(79 70 229);
    box-shadow: 0 0 0 4px rgb(99 102 241 / 0.2);
  }
  #accBulkModal[data-acc-step="import"] .acc-bulk-step-label-1 {
    color: rgb(30 41 59);
    font-weight: 700;
  }
  #accBulkModal[data-acc-step="import"] .acc-bulk-step-dot-2 {
    background-color: rgb(241 245 249);
    color: rgb(148 163 184);
    border-color: rgb(241 245 249);
    box-shadow: none;
  }
  #accBulkModal[data-acc-step="import"] .acc-bulk-step-label-2 {
    color: rgb(148 163 184);
    font-weight: 600;
  }
  /* معاينة الجدول (موبايل) + عمود نموذج مريح على الشاشات العريضة */
  .acc-bulk-form-narrow {
    max-width: min(100%, 26rem);
    margin-left: auto;
    margin-right: auto;
    width: 100%;
  }
  @media (min-width: 640px) {
    .acc-bulk-form-narrow {
      max-width: min(100%, 36rem);
    }
  }
  #accBulkModal select,
  #accBulkModal input[type="number"]:not(.acc-bulk-bp),
  #accBulkModal input[type="url"],
  #accBulkModal input[type="text"] {
    min-height: 2.75rem;
  }
  /* ارتفاع النافذة: vh للمتصفحات القديمة، dvh عند التوفر (Safari iOS 15.4+، Chrome) */
  .acc-bulk-modal-shell {
    max-height: min(92vh, calc(100vh - 1.25rem - env(safe-area-inset-top, 0px) - env(safe-area-inset-bottom, 0px)));
    transition: max-width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  @supports (height: 100dvh) {
    .acc-bulk-modal-shell {
      max-height: min(92dvh, calc(100dvh - 1.25rem - env(safe-area-inset-top, 0px) - env(safe-area-inset-bottom, 0px)));
    }
  }
  /* استيراد: نمط لوحة الإجراء السريع (ضيق) — مراجعة: نمط بطاقة العملاء (عرض max-w-5xl) */
  #accBulkModal[data-acc-step="import"] .acc-bulk-modal-shell {
    max-width: min(100vw - 1.25rem, 30rem);
  }
  #accBulkModal[data-acc-step="review"] .acc-bulk-modal-shell {
    max-width: min(100vw - 1.5rem, 64rem);
  }
  .acc-bulk-src-btn {
    transition: all 0.2s ease;
  }
  .acc-bulk-src-btn--active {
    background-color: white !important;
    color: rgb(79 70 229) !important;
    font-weight: 700 !important;
    box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1) !important;
  }
  .acc-bulk-modal-body {
    -webkit-overflow-scrolling: touch;
  }
  .acc-bulk-scroll {
    overscroll-behavior: contain;
  }
  @media (max-width: 767px) {
    .acc-bulk-scroll {
      touch-action: pan-y;
    }
  }
  /* iOS Safari: تجنّب تكبير الصفحة عند التركيز على حقول أصغر من 16px */
  @media (max-width: 639px) {
    #accBulkModal input:not(.sr-only),
    #accBulkModal select,
    #accBulkModal textarea {
      font-size: 1rem;
      line-height: 1.5;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    #accBulkModal .acc-bulk-src-btn {
      transition: none;
    }
  }
  /* رأس الجدول ثابت داخل منطقة التمرير الأفقية */
  .acc-bulk-scroll .acc-bulk-thead th {
    position: sticky;
    top: 0;
    z-index: 30;
    background-color: rgb(248 250 252); /* slate-50 */
    box-shadow: 0 1px 0 0 rgb(241 245 249); /* slate-100 */
  }
  .acc-bulk-review {
    table-layout: fixed;
  }
  @media (max-width: 767px) {
    .acc-bulk-scroll {
      overflow-x: hidden !important;
      width: 100%;
      max-width: 100%;
    }
    .acc-bulk-review {
      min-width: 0 !important;
      width: 100% !important;
      max-width: 100% !important;
      table-layout: auto !important;
      display: block;
    }
    .acc-bulk-review thead.acc-bulk-thead { display: none !important; }
    .acc-bulk-review tbody {
      display: block;
      width: 100%;
    }
    .acc-bulk-review tbody tr.acc-bulk-tr {
      display: block;
      width: 100%;
      max-width: 100%;
      border: 1px solid rgb(241 245 249);
      border-radius: 0.75rem;
      margin-bottom: 0.75rem;
      background: #fff;
      box-shadow: 0 1px 2px 0 rgb(15 23 42 / 0.04);
      overflow: hidden;
    }
    /* عمودي: تسمية ثم قيمة بعرض كامل يتناسب مع RTL */
    .acc-bulk-review tbody td.acc-bulk-td {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      justify-content: flex-start;
      gap: 0.25rem;
      padding: 0.5rem 0.75rem !important;
      border-bottom: 1px solid rgb(241 245 249);
      width: 100%;
      max-width: 100%;
      box-sizing: border-box;
    }
    .acc-bulk-review tbody td.acc-bulk-td:last-child { border-bottom: none; }
    .acc-bulk-review tbody td.acc-bulk-td::before {
      content: attr(data-label);
      flex-shrink: 0;
      font-size: 0.7rem;
      font-weight: 600;
      color: rgb(100 116 139);
      max-width: none;
      width: 100%;
      text-align: start;
    }
    .acc-bulk-review tbody td.acc-bulk-td > *:last-child {
      flex: 0 0 auto;
      width: 100%;
      min-width: 0;
      text-align: start;
    }
    .acc-bulk-review tbody td.acc-bulk-td .acc-bulk-val {
      text-align: start;
    }
  }
  /* مسافة فوق شريط التنقل الثابت + زر + العائم (~72px) */
  @media (max-width: 1023px) {
    #accBulkModalBody {
      padding-bottom: max(6.5rem, calc(5.25rem + env(safe-area-inset-bottom, 0px)));
    }
  }
  /* مساحة قائمة المعتمدين: تعبئة عرض المحتوى وارتفاع يشبه بطاقة لوحة التحكم */
  .acc-approvals-list-shell {
    min-height: min(72vh, calc(100vh - 11rem));
  }
  @supports (height: 100dvh) {
    .acc-approvals-list-shell {
      min-height: min(72dvh, calc(100dvh - 11rem));
    }
  }
  @media (max-width: 1023px) {
    .acc-approvals-list-shell {
      min-height: min(58vh, calc(100vh - 13rem));
    }
    @supports (height: 100dvh) {
      .acc-approvals-list-shell {
        min-height: min(58dvh, calc(100dvh - 13rem));
      }
    }
  }
  /* حالة فارغة / تحميل داخل البطاقة — يعمل دون الاعتماد على فئات Tailwind في JS */
  .acc-approvals-empty {
    min-height: min(58vh, 24rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding-left: 1rem;
    padding-right: 1rem;
    text-align: center;
  }
  @supports (height: 100dvh) {
    .acc-approvals-empty {
      min-height: min(58dvh, 24rem);
    }
  }
  @media (min-width: 640px) {
    .acc-approvals-empty {
      min-height: min(64vh, 28rem);
    }
    @supports (height: 100dvh) {
      .acc-approvals-empty {
        min-height: min(64dvh, 28rem);
      }
    }
  }
</style>
<div class="w-full min-w-0 flex flex-col" dir="rtl">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between mb-5 sm:mb-6 shrink-0">
    <div class="flex items-center gap-3 min-w-0">
      <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-indigo-600 text-white shadow-md">
        <i class="fas fa-stamp text-xl"></i>
      </div>
      <div>
