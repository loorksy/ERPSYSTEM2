<div class="max-w-4xl mx-auto space-y-6 pb-8 pb-[max(2rem,env(safe-area-inset-bottom))]" dir="rtl">
  <div class="flex items-center gap-3">
    <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-[#1e3a5f] to-[#1e3a5f] text-white shadow-md shadow-[#1e3a5f]/25">
      <i class="fas fa-search text-lg"></i>
    </span>
    <div>
      <h2 class="text-lg font-bold text-slate-900 tracking-tight">البحث والتدقيق</h2>
      <p class="text-xs text-slate-500 mt-0.5">استعلام عن مستخدم في الدورة أو عبر كل الدورات — بنفس أسلوب واجهة النظام</p>
    </div>
  </div>

  <!-- بطاقة مدخلات البحث -->
  <section class="rounded-2xl border border-slate-200/90 bg-white shadow-sm shadow-slate-200/40 overflow-hidden ring-1 ring-slate-100">
    <div class="border-b border-slate-100 bg-gradient-to-l from-slate-50/80 to-white px-4 py-3 sm:px-6">
      <h3 class="text-sm font-bold text-slate-800 flex items-center gap-2">
        <i class="fas fa-sliders-h text-[#1e3a5f] text-xs"></i>
        معايير البحث
      </h3>
    </div>
    <div class="p-4 sm:p-6 space-y-4">
      <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1.2fr)_minmax(0,1.8fr)] gap-4 items-end">
        <div class="space-y-2">
          <label for="searchCycleSelect" class="block text-xs font-bold text-slate-700">الدورة المالية</label>
          <select id="searchCycleSelect"
            class="w-full py-3 px-3 border-2 border-slate-200 rounded-xl text-sm bg-slate-50/80 text-slate-900 focus:outline-none focus:border-[#1e3a5f] focus:ring-2 focus:ring-[#1e3a5f]/20 transition-all">
            <option value="">— اختر الدورة —</option>
          </select>
        </div>

        <div class="space-y-2">
          <label class="block text-xs font-bold text-slate-700">بيانات البحث</label>
          <div class="flex flex-col sm:flex-row gap-2">
            <div class="flex-1 min-w-0">
              <input id="searchUserIdInput" type="text" inputmode="numeric" placeholder="أدخل رقم المستخدم"
                class="w-full py-3 px-3 border-2 border-slate-200 rounded-xl text-sm bg-white text-slate-900 placeholder:text-slate-400 focus:outline-none focus:border-[#1e3a5f] focus:ring-2 focus:ring-[#1e3a5f]/20 transition-all">
            </div>
            <button type="button" id="searchPasteBtn"
              class="inline-flex items-center justify-center px-4 py-3 rounded-xl border-2 border-slate-200 bg-white text-slate-700 text-xs font-semibold hover:bg-slate-50 hover:border-sky-200 active:scale-[0.98] shrink-0">
              <i class="fas fa-paste ml-1.5 text-slate-500"></i>
              لصق
            </button>
          </div>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row flex-wrap items-stretch sm:items-center justify-between gap-3 pt-2 border-t border-slate-100">
        <div class="flex items-center gap-2">
          <label for="searchDiscountRate" class="text-xs font-bold text-slate-600 shrink-0">خصم %</label>
          <input type="number" id="searchDiscountRate" min="0" max="100" step="0.01" value=""
            placeholder="0"
            class="w-full max-w-[7rem] py-2.5 px-3 border-2 border-slate-200 rounded-xl text-sm bg-white text-slate-900 placeholder:text-slate-400 focus:outline-none focus:border-[#1e3a5f] focus:ring-2 focus:ring-[#1e3a5f]/20 transition-all">
        </div>

        <label class="inline-flex items-center justify-between gap-3 sm:gap-4 text-xs sm:text-sm font-bold text-slate-700 cursor-pointer shrink-0 rounded-xl border border-slate-200 bg-slate-50/80 px-3 py-2.5 sm:py-2">
          <span>البحث الشامل (كل الدورات)</span>
          <div class="relative inline-flex items-center flex-none shrink-0 min-w-[3.5rem]">
            <input id="searchGlobalToggle" type="checkbox" class="sr-only peer">
            <div class="ring-0 bg-gradient-to-bl from-slate-700 via-slate-600 to-slate-700 rounded-full outline-none duration-300 after:duration-300 w-14 h-7 shadow-inner peer-focus-visible:ring-2 peer-focus-visible:ring-[#1e3a5f] after:content-[''] after:rounded-full after:absolute after:bg-white after:shadow after:h-5 after:w-5 after:top-1 after:left-1 peer-checked:after:translate-x-7 peer-checked:bg-gradient-to-r peer-checked:from-[#1e3a5f] peer-checked:to-sky-700 peer-hover:after:scale-95"></div>
          </div>
        </label>
      </div>
    </div>
  </section>

  <section id="searchResultSection" class="rounded-2xl border border-slate-200/90 bg-white shadow-sm shadow-slate-200/40 overflow-hidden ring-1 ring-slate-100 hidden">
    <div class="border-b border-slate-100 bg-gradient-to-l from-sky-50/50 to-white px-4 py-3 sm:px-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <h3 class="text-base font-bold text-slate-900 flex items-center gap-2">
        <i class="fas fa-user-tag text-[#1e3a5f]"></i>
        نتيجة البحث
      </h3>
      <div class="flex flex-col sm:flex-row gap-2 w-full sm:w-auto">
        <button type="button" id="searchCopyCardBtn"
          class="inline-flex items-center justify-center gap-2 px-3 py-2.5 sm:py-2 rounded-xl border border-slate-200 bg-white text-xs font-semibold text-slate-800 hover:bg-slate-50 hover:border-slate-300 active:scale-[0.98]">
          <i class="fas fa-copy text-slate-500"></i>
          <span>نسخ كبطاقة</span>
        </button>
        <button type="button" id="searchDownloadImageBtn"
          class="inline-flex items-center justify-center gap-2 px-3 py-2.5 sm:py-2 rounded-xl border border-sky-200 bg-sky-50 text-xs font-semibold text-sky-800 hover:bg-sky-100 active:scale-[0.98]">
          <i class="fas fa-image"></i>
          <span>تنزيل كصورة</span>
        </button>
      </div>
    </div>
    <div class="p-4 sm:p-6 space-y-4">
      <div id="searchResultContent" class="text-sm text-slate-700 space-y-2"></div>
      <div id="searchAuditActions" class="mt-4 hidden">
        <div class="space-y-3">
          <div class="p-3 rounded-xl border border-sky-100 bg-sky-50/60 space-y-2">
            <p class="text-sm font-medium text-slate-800 mb-1">خيارات التدقيق الانتقائي</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div>
                <label class="block mb-1 text-xs font-semibold text-slate-700">ورقة الهدف في جدول الإدارة</label>
                <select id="searchTargetSheetSelect"
                  class="w-full py-2 px-3 border-2 border-slate-200 rounded-xl text-xs bg-white text-slate-800 focus:outline-none focus:border-[#1e3a5f] focus:ring-2 focus:ring-[#1e3a5f]/20">
                  <option value="">— اختر ورقة أو أنشئ جديدة —</option>
                </select>
                <div class="mt-1 flex items-center gap-2">
                  <input type="text" id="searchNewSheetTitle" placeholder="اسم ورقة جديدة (اختياري)"
                    class="flex-1 py-1.5 px-2 border border-slate-200 rounded-lg text-[0.7rem] bg-white text-slate-700 focus:outline-none focus:border-[#1e3a5f] focus:ring-1 focus:ring-[#1e3a5f]/20">
                </div>
              </div>
              <div id="searchAgentColorWrap">
                <label class="block mb-1 text-xs font-semibold text-slate-700">لون سحب الوكيل</label>
                <input type="color" id="searchAgentColor"
                  class="w-16 h-9 p-1 border border-slate-200 rounded-lg align-middle">
              </div>
              <div id="searchManagementColorWrap">
                <label class="block mb-1 text-xs font-semibold text-slate-700">لون سحب الإدارة</label>
                <input type="color" id="searchManagementColor"
                  class="w-16 h-9 p-1 border border-slate-200 rounded-lg align-middle">
              </div>
            </div>
            <div class="mt-3 flex flex-col sm:flex-row flex-wrap gap-2 items-stretch sm:items-center">
              <button type="button" id="searchExecuteAuditAdvancedBtn"
                class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-4 py-3 sm:py-2 rounded-xl text-xs font-bold bg-[#1e3a5f] text-white hover:bg-sky-700 active:scale-[0.97] shadow-md shadow-[#1e3a5f]/15">
                <i class="fas fa-check-circle"></i>
                <span>تنفيذ التدقيق الانتقائي</span>
              </button>
              <span id="searchAuditHint" class="text-[0.7rem] text-slate-500">اختر ورقة في جدول الإدارة أو اكتب اسماً لإنشاء ورقة جديدة في الدورة الحالية.</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>

<script>
(function initSearchPage() {
  async function loadCyclesForSearch() {
    var sel = document.getElementById('searchCycleSelect');
    if (!sel) return;
    sel.innerHTML = '<option value="">— جاري التحميل... —</option>';
    try {
      var res = await fetch('/api/search/cycles');
      var data = await res.json();
      if (!data.success || !data.cycles || !data.cycles.length) {
        sel.innerHTML = '<option value="">— لا توجد دورات —</option>';
        return;
      }
      sel.innerHTML = '<option value="">— اختر الدورة —</option>' + data.cycles.map(function(c) {
        return '<option value="' + c.id + '">' + (c.name || ('دورة #' + c.id)) + '</option>';
      }).join('');
      // اختيار أحدث دورة تلقائياً (أول عنصر في القائمة المرتبة تنازلياً)
      if (data.cycles[0] && data.cycles[0].id != null) {
        sel.value = String(data.cycles[0].id);
      }
    } catch (e) {
      sel.innerHTML = '<option value="">— خطأ في التحميل —</option>';
    }
  }

  function pasteFromClipboard() {
    var input = document.getElementById('searchUserIdInput');
    if (!navigator.clipboard || !input) return;
    navigator.clipboard.readText().then(function(text) {
      if (text) {
        input.value = text.trim();
        debouncedSearch();
      }
    }).catch(function() {});
  }

  async function runSearch() {
    var userId = (document.getElementById('searchUserIdInput').value || '').trim();
    var discountRate = Number(document.getElementById('searchDiscountRate').value) || 0;
    var globalToggle = document.getElementById('searchGlobalToggle');
    var isGlobal = !!(globalToggle && globalToggle.checked);
    var cycleId = document.getElementById('searchCycleSelect').value;
    if ((!cycleId && !isGlobal) || !userId) {
      return;
    }
    try {
      var url;
      if (isGlobal) {
        url = '/api/search/user-across-cycles?userId=' + encodeURIComponent(userId) +
          '&discountRate=' + encodeURIComponent(discountRate);
      } else {
        url = '/api/search/search-user?cycleId=' + encodeURIComponent(cycleId) +
          '&userId=' + encodeURIComponent(userId) +
          '&discountRate=' + encodeURIComponent(discountRate);
      }
      var res = await fetch(url);
      var data = await res.json();
      var container = document.getElementById('searchResultContent');
      var section = document.getElementById('searchResultSection');
      var actions = document.getElementById('searchAuditActions');
      if (!data.success) {
        if (container && section) {
          container.innerHTML = '<p class="text-amber-700 font-medium">' + (data.message || 'لم يتم العثور على بيانات.') + '</p>';
          section.classList.remove('hidden');
        }
        if (actions) {
          actions.classList.add('hidden');
        }
        if (typeof showToast === 'function') {
          var msg = data.message || 'فشل البحث';
          var level = (msg.indexOf('غير موجود') !== -1) ? 'info' : 'error';
          showToast(msg, level);
        }
        return;
      }
      var parts = [];
      if (isGlobal) {
        var cycles = data.cycles || [];
        parts.push('<p><span class="font-medium text-slate-600">رقم المستخدم:</span> <code class="bg-slate-100 px-1 rounded">' + (data.userId || userId) + '</code></p>');
        if (data.name) {
          parts.push('<p><span class="font-medium text-slate-600">الاسم:</span> ' + data.name + '</p>');
        }
        parts.push('<p class="text-xs text-slate-500">عدد الدورات التي ظهر بها هذا المستخدم: <span class="font-semibold">' + cycles.length + '</span></p>');
        if (cycles.length) {
          parts.push('<div class="mt-3 border-t border-slate-100 pt-3 space-y-2">');
          cycles.forEach(function(c) {
            var canAudit = c.logicalStatus && c.logicalStatus !== 'غير موجود' && (!c.auditStatus || c.auditStatus === 'غير مدقق');
            parts.push(
              '<div class="rounded-2xl border border-slate-200/90 bg-gradient-to-br from-slate-50/90 to-white p-4 shadow-sm overflow-visible">' +
                '<div class="space-y-1.5 text-xs sm:text-sm text-slate-800">' +
                  '<p><span class="font-bold text-slate-700">الدورة:</span> ' + (c.cycleName || ('دورة #' + c.cycleId)) + '</p>' +
                  '<p><span class="font-bold text-slate-700">الحالة المنطقية:</span> ' + (c.logicalStatus || 'غير موجود') + '</p>' +
                  '<p><span class="font-bold text-slate-700">الراتب قبل الخصم:</span> ' + (c.salaryBeforeDiscount || 0) + '</p>' +
                  '<p><span class="font-bold text-slate-700">الراتب بعد الخصم:</span> ' + (c.salaryAfterDiscount || 0) + '</p>' +
                  '<p><span class="font-bold text-slate-700">حالة التدقيق:</span> ' + (c.auditStatus || 'غير مدقق') + (c.auditSource ? ' — <span class="text-sky-700 font-semibold">' + c.auditSource + '</span>' : '') + '</p>' +
                '</div>' +
                (canAudit
                  ? '<button type="button" class="mt-3 w-full sm:w-auto sm:min-w-[11rem] inline-flex items-center justify-center gap-2 px-4 py-3 sm:py-2 rounded-xl text-sm sm:text-[0.7rem] font-bold bg-[#1e3a5f] text-white hover:bg-sky-700 active:scale-[0.98] shadow-md shadow-[#1e3a5f]/20" data-search-cycle-id="' + c.cycleId + '" data-logical-status="' + (c.logicalStatus || '') + '"><i class="fas fa-magic"></i><span>تدقيق هذه الدورة</span></button>'
                  : '') +
              '</div>'
            );
          });
          parts.push('</div>');
        }
      } else {
        parts.push('<p><span class="font-medium text-slate-600">رقم المستخدم:</span> <code class="bg-slate-100 px-1 rounded">' + (data.memberId || userId) + '</code></p>');
        if (data.name) {
          parts.push('<p><span class="font-medium text-slate-600">الاسم:</span> ' + data.name + '</p>');
        }
        parts.push('<p><span class="font-medium text-slate-600">الحالة المنطقية:</span> ' + (data.logicalStatus || 'غير موجود') + '</p>');
        parts.push('<p><span class="font-medium text-slate-600">الراتب قبل الخصم:</span> ' + (data.salaryBeforeDiscount || 0) + '</p>');
        parts.push('<p><span class="font-medium text-slate-600">الراتب بعد الخصم:</span> ' + (data.salaryAfterDiscount || 0) + '</p>');
        parts.push('<p><span class="font-medium text-slate-600">حالة التدقيق:</span> ' + (data.auditStatus || 'غير مدقق') + (data.auditSource ? ' — <span class="text-sky-700">' + data.auditSource + '</span>' : '') + '</p>');
      }

      container.innerHTML = parts.join('');
      section.classList.remove('hidden');

      if (actions) {
        if (!isGlobal && (data.logicalStatus && data.logicalStatus !== 'غير موجود') && (!data.auditStatus || data.auditStatus === 'غير مدقق')) {
          actions.classList.remove('hidden');
          initAuditOptions(data.memberId || userId, data.logicalStatus || '');
        } else {
          actions.classList.add('hidden');
        }
      }

      // ربط أزرار "تدقيق هذه الدورة" في وضع البحث العام
      if (isGlobal && Array.isArray(data.cycles)) {
        var buttons = container.querySelectorAll('[data-search-cycle-id]');
        buttons.forEach(function(btn) {
          btn.addEventListener('click', function() {
            var cid = this.getAttribute('data-search-cycle-id');
            var logical = this.getAttribute('data-logical-status') || '';
            var cycleSelect = document.getElementById('searchCycleSelect');
            if (cycleSelect && cid) {
              cycleSelect.value = String(cid);
            }
            if (actions) {
              actions.classList.remove('hidden');
            }
            initAuditOptions(data.userId || userId, logical);
          });
        });
      }
      if (typeof showToast === 'function') showToast('تم جلب نتيجة البحث', 'success');
    } catch (_) {
      if (typeof showToast === 'function') showToast('تعذر إكمال البحث، تحقق من الاتصال وحاول مرة أخرى', 'error');
    }
  }

  var searchTimeout = null;
  function debouncedSearch() {
    if (searchTimeout) clearTimeout(searchTimeout);
    searchTimeout = setTimeout(runSearch, 300);
  }

  loadCyclesForSearch();

  var pasteBtn = document.getElementById('searchPasteBtn');
  if (pasteBtn) pasteBtn.addEventListener('click', pasteFromClipboard);
  var input = document.getElementById('searchUserIdInput');
  if (input) input.addEventListener('input', debouncedSearch);
  var cycleSel = document.getElementById('searchCycleSelect');
  if (cycleSel) cycleSel.addEventListener('change', debouncedSearch);
  var discountInput = document.getElementById('searchDiscountRate');
  if (discountInput) discountInput.addEventListener('input', debouncedSearch);
  var globalToggle = document.getElementById('searchGlobalToggle');
  if (globalToggle) globalToggle.addEventListener('change', debouncedSearch);

  var copyBtn = document.getElementById('searchCopyCardBtn');
  if (copyBtn) copyBtn.addEventListener('click', copySearchResultCard);
  var downloadBtn = document.getElementById('searchDownloadImageBtn');
  if (downloadBtn) downloadBtn.addEventListener('click', downloadSearchResultImage);
})();

async function executeAuditFromSearch(cycleId, memberId, options) {
  try {
    var btn = document.getElementById('searchExecuteAuditAdvancedBtn');
    if (btn) {
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i><span>جاري التنفيذ...</span>';
    }
    var body = Object.assign({}, options || {}, {
      targetCycleId: options && options.targetCycleId ? options.targetCycleId : cycleId,
      memberId: memberId
    });
    var res = await fetch('/api/search/execute-audit-advanced', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    var data = await res.json();
    if (typeof showToast === 'function') {
      showToast(data.message || (data.success ? 'تم التنفيذ' : 'فشل التنفيذ'), data.success ? 'success' : 'error');
    }
    if (data.success) {
      var actions = document.getElementById('searchAuditActions');
      if (actions) {
        actions.classList.add('hidden');
      }
      if (typeof debouncedSearch === 'function') {
        debouncedSearch();
      }
    }
  } catch (e) {
    if (typeof showToast === 'function') showToast('خطأ في الاتصال أثناء تنفيذ التدقيق', 'error');
  } finally {
    var btn2 = document.getElementById('searchExecuteAuditAdvancedBtn');
    if (btn2) {
      btn2.disabled = false;
      btn2.innerHTML = '<i class="fas fa-check-circle"></i><span>تنفيذ التدقيق الانتقائي في الدورة المختارة</span>';
    }
  }
}

async function loadSheetsForCycle(cycleId) {
  try {
    var sel = document.getElementById('searchTargetSheetSelect');
    if (!sel) return;
    if (!cycleId) {
      sel.innerHTML = '<option value="">— اختر ورقة أو اكتب اسماً جديداً —</option>';
      return;
    }
    sel.innerHTML = '<option value="">— جاري جلب الأوراق —</option>';
    var res = await fetch('/api/search/cycle-sheets?cycleId=' + encodeURIComponent(cycleId));
    var data = await res.json();
    if (!data.success || !data.sheets || !data.sheets.length) {
      sel.innerHTML = '<option value="">لا توجد أوراق في جدول الإدارة لهذه الدورة</option>';
      return;
    }
    sel.innerHTML = '<option value="">— اختر ورقة أو اكتب اسماً جديداً —</option>' + data.sheets.map(function(s) {
      return '<option value="' + (s.title || '') + '">' + (s.title || '') + '</option>';
    }).join('');
  } catch (_) {}
}

function initAuditOptions(memberId, logicalStatus) {
  // تخزين رقم المستخدم الحالي لاستخدامه عند النقر على زر التنفيذ
  window._searchCurrentMemberId = memberId;

  // تحميل أوراق جدول الإدارة للدورة الحالية المختارة في أعلى الصفحة
  var baseCycleId = document.getElementById('searchCycleSelect')?.value || '';
  if (baseCycleId) {
    loadSheetsForCycle(baseCycleId);
  }
  var agentColor = document.getElementById('searchAgentColor');
  var mgmtColor = document.getElementById('searchManagementColor');
  // تعيين الألوان الافتراضية دائماً بدلاً من اللون الأسود الافتراضي للمتصفح
  if (agentColor) agentColor.value = '#8b5cf6';
  if (mgmtColor) mgmtColor.value = '#facc15';

  // إظهار/إخفاء حقول الألوان بناءً على نوع السحب
  var agentWrap = document.getElementById('searchAgentColorWrap');
  var mgmtWrap = document.getElementById('searchManagementColorWrap');
  var status = String(logicalStatus || '').trim();
  var isAgent = status.indexOf('سحب وكيل') === 0;
  var isMgmt = status.indexOf('سحب ادارة') === 0;
  if (agentWrap && mgmtWrap) {
    if (isAgent && !isMgmt) {
      agentWrap.classList.remove('hidden');
      mgmtWrap.classList.add('hidden');
    } else if (isMgmt && !isAgent) {
      mgmtWrap.classList.remove('hidden');
      agentWrap.classList.add('hidden');
    } else {
      agentWrap.classList.remove('hidden');
      mgmtWrap.classList.remove('hidden');
    }
  }

  var btn = document.getElementById('searchExecuteAuditAdvancedBtn');
  if (btn && !btn._lorkerpBound) {
    btn._lorkerpBound = true;
    btn.addEventListener('click', function() {
      var cycleId = document.getElementById('searchCycleSelect')?.value || '';
      var sheetSel = document.getElementById('searchTargetSheetSelect');
      var newSheetTitle = document.getElementById('searchNewSheetTitle')?.value.trim();
      var targetTitle = newSheetTitle || (sheetSel && sheetSel.value ? sheetSel.value : '');
      var aColor = document.getElementById('searchAgentColor')?.value || '#8b5cf6';
      var mColor = document.getElementById('searchManagementColor')?.value || '#facc15';
      if (!cycleId) {
        if (typeof showToast === 'function') showToast('اختر الدورة التي تريد تدقيق المستخدم بها', 'error');
        return;
      }
      if (!targetTitle) {
        if (typeof showToast === 'function') showToast('اختر ورقة هدف أو اكتب اسماً لورقة جديدة', 'error');
        return;
      }
      executeAuditFromSearch(cycleId, window._searchCurrentMemberId || memberId, {
        targetCycleId: cycleId,
        targetSheetTitle: targetTitle,
        createIfMissing: !!newSheetTitle,
        discountRate: 0,
        agentColor: aColor,
        managementColor: mColor
      });
    });
  }
}

function copySearchResultCard() {
  var container = document.getElementById('searchResultContent');
  if (!container) return;
  var text = (container.innerText || '').trim();
  if (!text) return;
  if (!navigator.clipboard) {
    if (typeof showToast === 'function') {
      showToast('نسخ غير مدعوم في هذا المتصفح، يمكنك تحديد النص ونسخه يدوياً', 'info');
    }
    return;
  }
  navigator.clipboard.writeText(text).then(function() {
    if (typeof showToast === 'function') showToast('تم نسخ النتائج كبطاقة نصية', 'success');
  }).catch(function() {
    if (typeof showToast === 'function') showToast('تعذر نسخ النتائج، حاول مرة أخرى', 'error');
  });
}

function drawSearchResultAsImage() {
  var contentEl = document.getElementById('searchResultContent');
  if (!contentEl) return null;
  var text = (contentEl.innerText || '').trim();
  if (!text) return null;

  var padding = 32;
  var lineHeight = 22;
  var fontSize = 14;
  var titleSize = 18;
  var maxWidth = 520;
  var canvas = document.createElement('canvas');
  var ctx = canvas.getContext('2d');
  if (!ctx) return null;

  ctx.font = fontSize + 'px Arial, Tahoma, sans-serif';
  var lines = [];
  var rawLines = text.split(/\n/);
  rawLines.forEach(function(line) {
    line = line.trim();
    if (!line) return;
    var words = line.split(/\s+/);
    var current = '';
    for (var i = 0; i < words.length; i++) {
      var test = current ? current + ' ' + words[i] : words[i];
      var m = ctx.measureText(test);
      if (m.width > maxWidth && current) {
        lines.push(current);
        current = words[i];
      } else {
        current = test;
      }
    }
    if (current) lines.push(current);
  });

  var title = 'نتيجة البحث';
  ctx.font = 'bold ' + titleSize + 'px Arial, Tahoma, sans-serif';
  var titleW = ctx.measureText(title).width;
  ctx.font = fontSize + 'px Arial, Tahoma, sans-serif';

  var contentH = lines.length * lineHeight;
  var titleH = titleSize + 14;
  var w = maxWidth + padding * 2;
  var h = padding + titleH + 12 + contentH + padding;
  canvas.width = w;
  canvas.height = h;

  ctx.fillStyle = '#f8fafc';
  ctx.fillRect(0, 0, w, h);
  ctx.strokeStyle = '#e2e8f0';
  ctx.lineWidth = 1;
  ctx.strokeRect(1, 1, w - 2, h - 2);

  ctx.direction = 'rtl';
  ctx.textAlign = 'right';
  ctx.fillStyle = '#1e293b';
  ctx.font = 'bold ' + titleSize + 'px Arial, Tahoma, sans-serif';
  ctx.fillText(title, w - padding, padding + titleSize);

  ctx.font = fontSize + 'px Arial, Tahoma, sans-serif';
  ctx.fillStyle = '#475569';
  var y = padding + titleH + 12;
  lines.forEach(function(line) {
    ctx.fillText(line, w - padding, y);
    y += lineHeight;
  });

  return canvas;
}

async function downloadSearchResultImage() {
  var section = document.getElementById('searchResultSection');
  if (!section || section.classList.contains('hidden')) {
    if (typeof showToast === 'function') showToast('لا توجد نتائج حالية لتنزيلها', 'info');
    return;
  }
  var btn = document.getElementById('searchDownloadImageBtn');
  if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i><span>جاري التحميل...</span>'; }
  try {
    var canvas = drawSearchResultAsImage();
    if (!canvas) {
      if (typeof showToast === 'function') showToast('لا يوجد محتوى لتحويله إلى صورة', 'info');
      return;
    }
    var link = document.createElement('a');
    link.href = canvas.toDataURL('image/png');
    link.download = 'lorkerp-search-result.png';
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    if (typeof showToast === 'function') showToast('تم تنزيل صورة النتائج بنجاح', 'success');
  } catch (e) {
    if (typeof showToast === 'function') showToast('حدث خطأ أثناء إنشاء الصورة', 'error');
  } finally {
    if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fas fa-image"></i><span>تنزيل كصورة</span>'; }
  }
}
</script>
