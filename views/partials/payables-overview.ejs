        <div>
          <h3 class="text-base font-bold text-slate-900">صناديق (رصيد سالب USD)</h3>
          <p class="text-xs text-slate-500">التزامات بالدولار</p>
        </div>
      </div>
      <div id="payablesNegFunds" class="min-h-[4rem] divide-y divide-slate-100"></div>
    </div>
  </section>

  <!-- سجل الديون المسجّلة -->
  <section class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 border-b border-slate-100 bg-slate-50/80 px-5 py-4">
      <div class="flex items-center gap-3">
        <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-violet-100 text-violet-800"><i class="fas fa-list-check"></i></span>
        <div>
          <h3 class="text-base font-bold text-slate-900">ديون مسجّلة يدوياً</h3>
