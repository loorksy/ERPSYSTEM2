  <!-- صف KPIs: موبايل عمودي، لابتوب شبكة -->
  <section class="grid grid-cols-1 lg:grid-cols-12 gap-4 lg:gap-6">
    <div class="lg:col-span-5 rounded-2xl border border-rose-200/90 bg-gradient-to-br from-rose-600 to-rose-800 p-6 sm:p-8 text-white shadow-lg shadow-rose-900/20">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-white/15 backdrop-blur-sm"><i class="fas fa-scale-balanced text-xl"></i></span>
        <div>
          <p class="text-sm text-rose-100">إجمالي التزامات (من الحاسبة)</p>
          <p class="text-xs text-rose-200/90">يشمل شحن، اعتمادات، يدوي، أرصدة سالبة…</p>
        </div>
      </div>
      <p class="font-mono text-4xl sm:text-5xl font-bold tabular-nums tracking-tight" id="payablesHeroTotal">—</p>
    </div>
    <div class="lg:col-span-7 grid grid-cols-2 sm:grid-cols-3 gap-3">
      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm flex flex-col justify-between min-h-[5.5rem]">
        <p class="text-xs font-semibold text-slate-500 flex items-center gap-1.5"><i class="fas fa-truck-fast text-sky-500"></i> شحن</p>
        <p class="font-mono text-lg font-bold tabular-nums text-slate-900 text-left" dir="ltr" id="payablesKpiShipping">—</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm flex flex-col justify-between min-h-[5.5rem]">
        <p class="text-xs font-semibold text-slate-500 flex items-center gap-1.5"><i class="fas fa-certificate text-violet-500"></i> اعتمادات</p>
        <p class="font-mono text-lg font-bold tabular-nums text-slate-900 text-left" dir="ltr" id="payablesKpiAcc">—</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm flex flex-col justify-between min-h-[5.5rem] col-span-2 sm:col-span-1">
        <p class="text-xs font-semibold text-slate-500 flex items-center gap-1.5"><i class="fas fa-pen text-slate-500"></i> مسجّل يدوي</p>
        <p class="font-mono text-lg font-bold tabular-nums text-slate-900 text-left" dir="ltr" id="payablesKpiManual">—</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm flex flex-col justify-between min-h-[5.5rem]">
        <p class="text-xs font-semibold text-slate-500 flex items-center gap-1.5"><i class="fas fa-building text-red-500"></i> شركات</p>
        <p class="font-mono text-lg font-bold tabular-nums text-slate-900 text-left" dir="ltr" id="payablesKpiCo">—</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm flex flex-col justify-between min-h-[5.5rem]">
        <p class="text-xs font-semibold text-slate-500 flex items-center gap-1.5"><i class="fas fa-piggy-bank text-amber-500"></i> صناديق</p>
        <p class="font-mono text-lg font-bold tabular-nums text-slate-900 text-left" dir="ltr" id="payablesKpiFund">—</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm flex flex-col justify-between min-h-[5.5rem]">
        <p class="text-xs font-semibold text-slate-500 flex items-center gap-1.5"><i class="fas fa-chart-line text-teal-500"></i> فرق تصريف</p>
        <p class="font-mono text-lg font-bold tabular-nums text-slate-900 text-left" dir="ltr" id="payablesKpiFx">—</p>
      </div>
    </div>
  </section>

  <!-- شركات وصناديق سالبة — شبكة لابتوب -->
  <section class="grid grid-cols-1 md:grid-cols-2 gap-4 lg:gap-6">
    <div class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
      <div class="flex items-center gap-3 border-b border-slate-100 bg-red-50/50 px-5 py-4">
        <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-red-100 text-red-700"><i class="fas fa-building"></i></span>
        <div>
          <h3 class="text-base font-bold text-slate-900">شركات تحويل (رصيد سالب)</h3>
          <p class="text-xs text-slate-500">مديونية علينا تجاه الشركة</p>
        </div>
      </div>
      <div id="payablesNegCompanies" class="min-h-[4rem] divide-y divide-slate-100"></div>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
