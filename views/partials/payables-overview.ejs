<div class="max-w-6xl mx-auto px-4 sm:px-0 pb-10 space-y-6 lg:space-y-8" dir="rtl" id="payablesPageRoot">
  <!-- رأس -->
  <header class="relative overflow-hidden rounded-2xl border border-rose-200/80 bg-gradient-to-br from-rose-50/90 via-white to-slate-50 shadow-sm">
