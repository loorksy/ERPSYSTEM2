    <div class="relative p-5 sm:p-7 lg:p-8">
      <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-5">
        <div class="min-w-0 flex-1">
          <p class="text-xs font-semibold uppercase tracking-wider text-rose-600 mb-1">التزامات</p>
          <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight">دين علينا</h2>
          <p class="text-sm text-slate-600 mt-2 max-w-2xl leading-relaxed">ملخص التزاماتنا المحسوبة من الأرصدة والسجلات، مع تفصيل يدوي من <span class="font-semibold text-slate-800">entity_payables</span>.</p>
        </div>
        <div class="flex flex-wrap gap-2 shrink-0">
          <a href="/receivables-to-us" class="inline-flex items-center gap-2 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-2.5 text-sm font-semibold text-emerald-900 shadow-sm transition hover:bg-emerald-100">
            <i class="fas fa-hand-holding-heart text-emerald-600 text-xs"></i>
            ديين لنا
          </a>
          <a href="/payment-due" class="inline-flex items-center gap-2 rounded-xl border border-amber-200 bg-amber-50 px-4 py-2.5 text-sm font-semibold text-amber-900 shadow-sm transition hover:bg-amber-100">
            <i class="fas fa-money-bill-wave text-amber-600 text-xs"></i>
            مطلوب دفع
          </a>
          <a href="/debts" class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 shadow-sm transition hover:border-rose-200 hover:bg-rose-50">
            <i class="fas fa-file-invoice-dollar text-rose-600 text-xs"></i>
            صفحة الديون
          </a>
          <a href="/dashboard" class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 shadow-sm transition hover:border-indigo-200 hover:bg-indigo-50">
            <i class="fas fa-arrow-right text-xs opacity-70"></i>
            لوحة التحكم
          </a>
        </div>
      </div>
    </div>
