<div class="max-w-3xl">
  <div class="section-card">
    <!-- Header -->
    <div class="flex items-center justify-between flex-wrap gap-3 py-5 px-4 md:px-6 border-b border-slate-100">
      <div class="flex items-center gap-2.5">
        <i class="fas fa-table text-xl text-[#0f9d58]"></i>
        <h3 class="text-lg font-bold">مزامنة Google Sheets</h3>
      </div>
      <div class="flex items-center gap-2 py-1.5 px-3.5 rounded-full bg-slate-50 text-sm font-medium" id="sheetsStatusBadge">
        <span class="status-dot <%= (typeof sheetsConfig !== 'undefined' && sheetsConfig && sheetsConfig.sync_enabled) ? 'connected' : 'disconnected' %>"></span>
        <span><%= (typeof sheetsConfig !== 'undefined' && sheetsConfig && sheetsConfig.sync_enabled) ? 'مفعل' : 'غير مفعل' %></span>
      </div>
    </div>

    <!-- Body -->
    <div class="p-4 md:p-6">
      <!-- Config Form -->
      <div class="mb-7">
        <h4 class="flex items-center gap-2 mb-5 text-base font-semibold text-slate-800">
          <i class="fas fa-cogs text-indigo-600"></i> إعدادات الربط
        </h4>
        <form id="sheetsConfigForm" onsubmit="saveSheetsConfig(event)">
          <div class="mb-5">
            <label for="spreadsheetId" class="block mb-2 font-semibold text-sm text-slate-800">معرّف جدول البيانات (Spreadsheet ID)</label>
            <input type="text" id="spreadsheetId" name="spreadsheet_id" class="form-control" dir="ltr"
              placeholder="أدخل معرّف جدول البيانات"
              value="<%= (typeof sheetsConfig !== 'undefined' && sheetsConfig) ? (sheetsConfig.spreadsheet_id || '') : '' %>">
            <small class="block mt-1.5 text-xs text-slate-500">يمكنك إيجاده في رابط الجدول بعد /d/ وقبل /edit</small>
          </div>

          <div class="mb-5">
            <label for="clientId" class="block mb-2 font-semibold text-sm text-slate-800">Client ID</label>
            <input type="text" id="clientId" name="client_id" class="form-control" dir="ltr"
              placeholder="أدخل Client ID من Google Cloud Console">
          </div>

          <div class="mb-5">
            <label for="clientSecret" class="block mb-2 font-semibold text-sm text-slate-800">Client Secret</label>
            <input type="password" id="clientSecret" name="client_secret" class="form-control" dir="ltr"
              placeholder="أدخل Client Secret">
          </div>

          <div class="flex flex-wrap gap-3 mt-6">
            <button type="submit" class="btn btn-primary">
              <i class="fas fa-save"></i>
              <span>حفظ الإعدادات</span>
            </button>
            <% if (typeof sheetsConfig !== 'undefined' && sheetsConfig && sheetsConfig.credentials) { %>
              <a href="/sheets/auth" class="btn btn-success">
                <i class="fas fa-link"></i>
                <span>تفويض الوصول</span>
              </a>
            <% } %>
          </div>
        </form>
      </div>

      <!-- Sync Toggle -->
      <div class="mb-6">
        <div class="flex items-center justify-between p-5 bg-slate-50 rounded-xl border border-slate-200">
          <div>
            <h4 class="text-[0.95rem] font-semibold mb-1">المزامنة التلقائية</h4>
            <p class="text-sm text-slate-500">تفعيل أو إيقاف المزامنة التلقائية مع Google Sheets</p>
          </div>
          <label class="switch">
            <input type="checkbox" id="syncToggle" onchange="toggleSync()"
              <%= (typeof sheetsConfig !== 'undefined' && sheetsConfig && sheetsConfig.sync_enabled) ? 'checked' : '' %>>
            <span class="slider"></span>
          </label>
        </div>
      </div>

      <!-- Instructions -->
      <div class="p-5 bg-sky-50 border border-sky-200 rounded-xl text-right">
        <h4 class="flex items-center gap-2 mb-3 text-sky-700 text-[0.95rem] font-semibold">
          <i class="fas fa-lightbulb"></i> كيفية الإعداد
        </h4>
        <ol class="pr-6 list-decimal space-y-1">
          <li class="text-sm text-slate-500 leading-7">اذهب إلى <a href="https://console.cloud.google.com" target="_blank" class="text-sky-600 hover:underline">Google Cloud Console</a></li>
          <li class="text-sm text-slate-500 leading-7">أنشئ مشروعاً جديداً أو اختر مشروعاً موجوداً</li>
          <li class="text-sm text-slate-500 leading-7">فعّل Google Sheets API</li>
          <li class="text-sm text-slate-500 leading-7">أنشئ بيانات اعتماد OAuth 2.0</li>
          <li class="text-sm text-slate-500 leading-7">أدخل Client ID و Client Secret هنا</li>
          <li class="text-sm text-slate-500 leading-7">اضغط على "تفويض الوصول" للربط</li>
        </ol>
      </div>
    </div>
  </div>
</div>
