<div class="max-w-lg mx-auto space-y-6 pb-8" dir="rtl">
  <section class="bg-white rounded-2xl shadow-sm border border-slate-100 p-4 sm:p-6 space-y-4">
    <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2">
      <i class="fas fa-balance-scale text-indigo-600"></i>
      إضافات وخصومات ومكافآت
    </h2>
    <p class="text-xs text-slate-500">أدخل رقم المستخدم، المبلغ، والنوع. الخصم يستهلك المؤجل ثم الرصيد المسجّل ثم يُسجَّل الدين.</p>

    <div class="space-y-2">
      <label class="block text-xs font-semibold text-slate-600">رقم المستخدم</label>
      <div class="flex gap-2">
        <input type="text" id="maMemberId" placeholder="مثال: 12345"
          class="flex-1 py-2.5 px-3 border-2 border-slate-200 rounded-xl text-sm focus:outline-none focus:border-indigo-500">
        <button type="button" id="maPasteBtn"
          class="px-3 py-2 rounded-xl border border-slate-200 bg-slate-50 text-xs font-medium text-slate-700">لصق</button>
      </div>
    </div>

    <div class="space-y-2">
      <label class="block text-xs font-semibold text-slate-600">النوع</label>
      <select id="maKind"
        class="w-full py-2.5 px-3 border-2 border-slate-200 rounded-xl text-sm bg-white focus:outline-none focus:border-indigo-500">
        <option value="deduct">خصم</option>
        <option value="add">إضافة</option>
        <option value="reward">مكافأة</option>
      </select>
    </div>

    <div class="space-y-2">
      <label class="block text-xs font-semibold text-slate-600">المبلغ (USD)</label>
      <input type="number" id="maAmount" min="0" step="0.01" placeholder="0.00"
        class="w-full py-2.5 px-3 border-2 border-slate-200 rounded-xl text-sm focus:outline-none focus:border-indigo-500">
    </div>

    <div class="space-y-2">
      <label class="block text-xs font-semibold text-slate-600">دورة مالية (اختياري)</label>
      <input type="number" id="maCycleId" placeholder="رقم الدورة"
        class="w-full py-2.5 px-3 border-2 border-slate-200 rounded-xl text-sm focus:outline-none focus:border-indigo-500">
    </div>

    <div class="space-y-2">
      <label class="block text-xs font-semibold text-slate-600">ملاحظات</label>
      <textarea id="maNotes" rows="2" placeholder="اختياري"
        class="w-full py-2.5 px-3 border-2 border-slate-200 rounded-xl text-sm focus:outline-none focus:border-indigo-500 resize-y min-h-[4rem]"></textarea>
    </div>

    <button type="button" id="maSubmitBtn"
      class="w-full py-3 rounded-xl bg-indigo-600 text-white text-sm font-bold hover:bg-indigo-700">
      تسجيل
    </button>
    <p id="maMsg" class="text-sm text-center min-h-[1.25rem]"></p>
  </section>
</div>
