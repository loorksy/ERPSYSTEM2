<div class="max-w-lg lg:max-w-5xl mx-auto px-4 sm:px-0 space-y-6 pb-8" dir="rtl">
  <section class="bg-white rounded-2xl shadow-sm border border-slate-100 p-4 sm:p-6 lg:p-8">
    <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2 mb-4 lg:mb-6">
      <i class="fas fa-balance-scale text-sky-600"></i>
      إضافات وخصومات ومكافآت
    </h2>

    <!-- موبايل: عمود واحد كما كان | لابتوب: عمودان -->
    <div class="flex flex-col gap-5 lg:grid lg:grid-cols-2 lg:gap-x-10 lg:gap-y-4 lg:items-start">
      <div class="space-y-4 min-w-0">
        <div class="space-y-2">
          <label class="block text-xs font-semibold text-slate-600">رقم المستخدم</label>
          <div class="flex gap-2">
            <input type="text" id="maMemberId" placeholder="مثال: 12345"
              class="flex-1 min-w-0 py-2.5 px-3 border-2 border-slate-200 rounded-xl text-sm focus:outline-none focus:border-sky-500">
            <button type="button" id="maPasteBtn"
              class="shrink-0 px-3 py-2 rounded-xl border border-slate-200 bg-slate-50 text-xs font-medium text-slate-700">لصق</button>
          </div>
        </div>

        <div class="space-y-2">
          <label class="block text-xs font-semibold text-slate-600">النوع</label>
          <select id="maKind"
            class="w-full py-2.5 px-3 border-2 border-slate-200 rounded-xl text-sm bg-white focus:outline-none focus:border-sky-500">
            <option value="deduct">خصم</option>
            <option value="add">إضافة</option>
            <option value="reward">مكافأة</option>
          </select>
        </div>

        <div class="space-y-2">
          <label class="block text-xs font-semibold text-slate-600">المبلغ (USD)</label>
          <input type="number" id="maAmount" min="0" step="0.01" placeholder="0.00"
            class="w-full py-2.5 px-3 border-2 border-slate-200 rounded-xl text-sm focus:outline-none focus:border-sky-500">
        </div>
      </div>

      <div class="space-y-4 min-w-0 lg:border-l lg:border-slate-200 lg:pl-10">
        <div class="space-y-2">
          <label class="block text-xs font-semibold text-slate-600">دورة مالية (مُستحسَن لتحديث Google)</label>
          <select id="maCycleId"
            class="w-full py-2.5 px-3 border-2 border-slate-200 rounded-xl text-sm bg-white focus:outline-none focus:border-sky-500">
            <option value="">— اختر الدورة —</option>
          </select>
        </div>

        <label class="flex items-start gap-2 sm:gap-3 cursor-pointer text-sm text-slate-700">
          <input type="checkbox" id="maSyncSheet" class="mt-0.5 rounded border-slate-300 text-sky-600 focus:ring-sky-500 shrink-0" checked>
          <span>تحديث عمود الراتب في جدول معلومات المستخدمين (Google Sheet)</span>
        </label>

        <div class="grid grid-cols-2 gap-3 max-w-md lg:max-w-none">
          <div class="space-y-1">
            <label class="block text-[0.65rem] font-semibold text-slate-500">عمود رقم المستخدم</label>
            <input type="text" id="maUiUidCol" value="C" maxlength="3"
              class="w-full py-2 px-2 border-2 border-slate-200 rounded-lg text-sm text-center uppercase">
          </div>
          <div class="space-y-1">
            <label class="block text-[0.65rem] font-semibold text-slate-500">عمود الراتب</label>
            <input type="text" id="maUiSalCol" value="L" maxlength="3"
              class="w-full py-2 px-2 border-2 border-slate-200 rounded-lg text-sm text-center uppercase">
          </div>
        </div>

        <div class="space-y-2">
          <label class="block text-xs font-semibold text-slate-600">ملاحظات</label>
          <textarea id="maNotes" rows="2" placeholder="اختياري"
            class="w-full py-2.5 px-3 border-2 border-slate-200 rounded-xl text-sm focus:outline-none focus:border-sky-500 resize-y min-h-[4rem] lg:min-h-[5.5rem]"></textarea>
        </div>
      </div>
    </div>

    <div class="mt-6 lg:mt-8 pt-5 border-t border-slate-100">
      <button type="button" id="maSubmitBtn"
        class="w-full lg:w-auto lg:min-w-[12rem] lg:px-10 py-3 rounded-xl bg-sky-600 text-white text-sm font-bold hover:bg-sky-700">
        تسجيل
      </button>
      <p id="maMsg" class="text-sm text-center lg:text-right mt-3 min-h-[1.25rem]"></p>
    </div>
  </section>
</div>
