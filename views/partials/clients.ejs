<div class="max-w-5xl" dir="rtl">
  <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
    <div class="flex items-center gap-3 py-5 px-6 border-b border-slate-100">
      <i class="fas fa-users text-xl text-sky-600"></i>
      <h3 class="text-lg font-bold">بيانات العملاء</h3>
    </div>
    <div class="p-6 md:p-10">
      <div class="flex gap-2 mb-6 flex-wrap">
        <button onclick="switchTab(this, 'clients-list')" class="tab-btn px-5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-300 bg-sky-600 text-white shadow-md">العملاء</button>
        <button onclick="switchTab(this, 'clients-discounts')" class="tab-btn px-5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-300 bg-slate-100 text-slate-600 hover:bg-slate-200">خصومات وإضافات</button>
      </div>
      <div id="clients-list" class="tab-content">
        <div class="flex flex-col items-center justify-center py-16 text-slate-400">
          <i class="fas fa-users text-5xl mb-4 opacity-40"></i>
          <p class="text-lg font-medium">سيتم إضافة قائمة العملاء هنا</p>
          <p class="text-sm mt-2">سيتم بناء هذا القسم قريباً</p>
        </div>
      </div>
      <div id="clients-discounts" class="tab-content hidden">
        <div class="flex flex-col items-center justify-center py-16 text-slate-400">
          <i class="fas fa-users text-5xl mb-4 opacity-40"></i>
          <p class="text-lg font-medium">سيتم إضافة الخصومات والإضافات هنا</p>
          <p class="text-sm mt-2">سيتم بناء هذا القسم قريباً</p>
        </div>
      </div>
    </div>
  </div>
</div>
