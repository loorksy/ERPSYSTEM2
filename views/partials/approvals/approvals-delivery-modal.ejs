<div id="accDeliveryModal" class="fixed inset-0 z-[9990] hidden items-center justify-center p-4 bg-slate-900/50 backdrop-blur-[2px]" dir="rtl">
  <div class="bg-white rounded-2xl border border-slate-100 shadow-xl p-6 max-w-md w-full max-h-[85vh] overflow-y-auto">
    <div class="flex items-start gap-3 mb-4">
      <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-700 border border-emerald-100">
        <i class="fas fa-hand-holding-dollar"></i>
      </span>
      <div>
        <h4 class="text-lg font-bold text-slate-900">تسليم معتمدين</h4>
        <p class="text-xs text-slate-500 mt-0.5">حدّد الدورة والمعتمدين ثم نفّذ التسليم</p>
      </div>
    </div>
    <label class="block text-xs font-semibold text-slate-600 mb-1.5">دورة مالية</label>
    <select id="accDelCycle" class="w-full mb-3 px-4 py-2.5 rounded-xl border border-slate-200 bg-white text-slate-800 text-sm focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400"><option value="">— دورة —</option></select>
    <div id="accDelList" class="text-sm space-y-2 mb-4 max-h-48 overflow-y-auto rounded-xl border border-slate-100 bg-slate-50/50 p-2"></div>
    <div class="flex flex-col-reverse sm:flex-row gap-2">
      <button type="button" onclick="accCloseDelivery()" class="w-full sm:w-auto px-5 py-2.5 rounded-xl border border-slate-200 bg-white text-slate-700 text-sm font-semibold hover:bg-slate-50">إلغاء</button>
      <button type="button" onclick="accSubmitDelivery()" class="w-full sm:flex-1 py-2.5 rounded-xl bg-emerald-600 text-white text-sm font-bold shadow-sm hover:bg-emerald-700">تسليم</button>
    </div>
  </div>
</div>
