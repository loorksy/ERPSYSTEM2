<div id="accBulkModal" class="fixed inset-0 z-[9990] hidden items-start sm:items-center justify-center px-2.5 sm:px-4 py-3 sm:py-6 bg-slate-900/50 backdrop-blur-[2px] overscroll-y-contain overflow-hidden" dir="rtl" data-acc-step="import">
  <div class="acc-bulk-modal-shell bg-white rounded-2xl shadow-xl border border-slate-100 w-full max-w-[min(100vw-1.25rem,52rem)] overflow-hidden flex flex-col min-h-0 min-w-0">
    <div class="px-4 sm:px-6 py-3.5 sm:py-5 border-b border-slate-100 shrink-0 bg-white">
      <div class="flex items-start gap-3">
        <div class="flex h-10 w-10 sm:h-11 sm:w-11 shrink-0 items-center justify-center rounded-xl bg-indigo-500/10 text-indigo-600 border border-slate-100 shadow-sm">
          <i class="fas fa-file-circle-plus text-base sm:text-lg"></i>
        </div>
        <div class="min-w-0 flex-1">
          <h4 class="text-base sm:text-lg font-bold text-slate-900 tracking-tight">إضافة أرصدة (دفعة)</h4>
          <p class="text-[0.7rem] sm:text-xs text-slate-500 mt-1 sm:mt-1.5 leading-relaxed break-words">أعمدة الملف: A كود، B اسم، C رصيد، D معتمد رئيسي — تُعرض المعاينة قبل الحفظ.</p>
        </div>
      </div>
    </div>
    <div id="accBulkStepper" class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-x-4 sm:gap-y-2 px-4 py-3 border-b border-slate-100 bg-slate-50/90 shrink-0" aria-hidden="true">
      <div class="flex w-full sm:w-auto items-center justify-center gap-2.5 min-w-0">
        <span class="acc-bulk-step-dot-1 flex h-8 w-8 sm:h-9 sm:w-9 shrink-0 items-center justify-center rounded-full border-2 border-indigo-200 bg-white text-xs sm:text-sm font-bold text-indigo-600">1</span>
        <span class="acc-bulk-step-label-1 text-xs sm:text-sm font-semibold text-slate-800">استيراد</span>
      </div>
      <div class="hidden sm:block h-px w-12 md:w-14 shrink-0 bg-gradient-to-l from-slate-200 to-slate-300" role="presentation"></div>
      <div class="flex w-full sm:w-auto items-center justify-center gap-2.5 min-w-0">
        <span class="acc-bulk-step-dot-2 flex h-8 w-8 sm:h-9 sm:w-9 shrink-0 items-center justify-center rounded-full border-2 border-slate-200 bg-white text-xs sm:text-sm font-bold text-slate-500">2</span>
        <span class="acc-bulk-step-label-2 text-xs sm:text-sm font-semibold text-slate-500">مراجعة وحفظ</span>
      </div>
    </div>
    <div id="accBulkModalBody" class="acc-bulk-modal-body p-3.5 sm:p-6 space-y-3 sm:space-y-5 overflow-y-auto flex-1 min-h-0 overscroll-contain bg-slate-50/40">
      <div class="rounded-2xl border border-slate-100 bg-white p-4 sm:p-5 shadow-sm acc-bulk-form-narrow">
        <div class="flex flex-wrap items-center gap-3 mb-3 sm:mb-4">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-slate-100 text-slate-600">
            <i class="fas fa-sliders text-sm"></i>
          </span>
          <div class="min-w-0">
            <p class="text-sm font-bold text-slate-800">إعدادات الدفعة</p>
            <p class="text-xs text-slate-500">الدورة والوساطة الافتراضية</p>
          </div>
        </div>
        <div class="grid gap-3 sm:gap-4">
          <div>
            <label class="block text-xs font-semibold text-slate-600 mb-1.5">الدورة المالية</label>
            <select id="accBulkCycle" class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white text-slate-800 text-sm focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400 transition-shadow"><option value="">— دورة مالية —</option></select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-600 mb-1.5">نسبة وساطة افتراضية (0–100)</label>
            <input type="number" id="accBulkBroker" min="0" max="100" step="0.01" class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white text-slate-800 text-sm focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400 transition-shadow" placeholder="0">
          </div>
        </div>
      </div>

      <div id="accBulkStaging" class="hidden rounded-2xl border border-slate-100 bg-white shadow-sm ring-1 ring-slate-100/80 min-w-0">
        <div class="h-1 w-full bg-gradient-to-l from-emerald-400 via-teal-400 to-indigo-500" aria-hidden="true"></div>
        <div class="p-4 sm:p-6">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between mb-4">
          <div class="flex items-start gap-3 min-w-0">
            <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-700 border border-emerald-100 shadow-sm">
              <i class="fas fa-clipboard-check text-lg"></i>
            </span>
            <div class="min-w-0">
              <p class="text-base font-bold text-slate-800">مراجعة الصفوف</p>
              <p class="text-xs text-slate-500 mt-0.5 leading-relaxed">اضبط الوساطة والاتجاه والنوع لكل معتمد، أو احذف الصف قبل الحفظ.</p>
            </div>
          </div>
          <span id="accBulkStagingBadge" class="inline-flex shrink-0 w-auto self-start sm:self-center items-center gap-1.5 justify-center rounded-full bg-emerald-600 text-white text-xs font-bold px-3 py-1.5 shadow-sm"><i class="fas fa-clipboard-list text-[0.7rem] opacity-90" aria-hidden="true"></i><span class="acc-bulk-badge-text">0 صف</span></span>
        </div>
        <div id="accBulkStagingTable" class="rounded-xl border border-slate-100 bg-slate-50/50 overflow-hidden min-w-0"></div>
        <div class="flex flex-col-reverse gap-2 sm:flex-row sm:justify-end sm:gap-3 mt-4 pt-4 border-t border-slate-100">
          <button type="button" onclick="accClearBulkStaging()" class="w-full sm:w-auto px-5 py-3 sm:py-2.5 rounded-xl border border-slate-200 bg-white text-slate-700 text-sm font-semibold hover:bg-slate-50 transition">إلغاء المعاينة</button>
          <button type="button" onclick="accCommitBulk()" class="w-full sm:w-auto px-6 py-3 sm:py-2.5 rounded-xl bg-emerald-600 text-white text-sm font-bold shadow-sm hover:bg-emerald-700 active:scale-[0.99] transition"><i class="fas fa-save ml-2 opacity-90"></i> حفظ الكل</button>
        </div>
        </div>
      </div>

      <div id="accBulkSourceWrap" class="rounded-2xl border border-slate-100 bg-white p-5 sm:p-6 shadow-sm acc-bulk-form-narrow">
        <div class="flex flex-wrap items-center gap-3 mb-3 sm:mb-4">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-500/10 text-indigo-600 border border-slate-100">
            <i class="fas fa-file-import"></i>
          </span>
          <div class="min-w-0">
            <h3 class="text-base font-bold text-slate-800">استيراد بيانات المعتمدين</h3>
            <p class="text-xs text-slate-500 mt-0.5">اختر المصدر ثم أكمل الحقول واضغط معاينة</p>
          </div>
        </div>
        <div>
          <label for="accBulkSourceMethod" class="block text-xs font-semibold text-slate-600 mb-1.5">طريقة الاستيراد</label>
          <select id="accBulkSourceMethod" class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white text-slate-800 text-sm font-medium focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400 transition-shadow">
            <option value="file">ملف من الجهاز (Excel / CSV)</option>
            <option value="paste">لصق نص أو CSV</option>
            <option value="sheet">رابط Google Sheet</option>
          </select>
        </div>

        <div class="mt-4 sm:mt-5 pt-4 sm:pt-5 border-t border-slate-100 space-y-4 min-h-[6rem]">
          <div id="accBulkPanelFile" class="acc-bulk-source-panel space-y-4">
            <p class="text-xs text-slate-500 leading-relaxed">ملف يحتوي الأعمدة: كود، اسم، رصيد، (اختياري) معتمد رئيسي.</p>
            <input type="file" id="accBulkFile" accept=".csv,.xlsx,.xls" class="sr-only" tabindex="-1" aria-label="اختيار ملف">
            <label for="accBulkFile" id="accBulkDropzone" class="acc-bulk-dropzone flex cursor-pointer flex-col items-center justify-center gap-2 rounded-2xl border-2 border-dashed border-indigo-200 bg-indigo-50/50 px-4 py-7 sm:py-8 text-center transition-colors hover:border-indigo-300 hover:bg-indigo-50/80 focus-within:outline focus-within:outline-2 focus-within:outline-offset-2 focus-within:outline-indigo-500/40 min-h-[140px] sm:min-h-[156px] sm:gap-3">
              <span class="flex h-14 w-14 items-center justify-center rounded-2xl border border-indigo-100 bg-white text-indigo-600 shadow-sm">
                <i class="fas fa-cloud-arrow-up text-2xl"></i>
              </span>
              <span class="text-sm font-semibold text-slate-800">اسحب الملف هنا أو اضغط للاختيار</span>
              <span class="text-xs text-slate-500">Excel أو CSV</span>
              <span id="accBulkFileName" class="hidden max-w-full truncate rounded-lg bg-white/80 px-2 py-1 text-xs font-mono text-indigo-700 ring-1 ring-indigo-100"></span>
            </label>
            <button type="button" onclick="accSubmitBulk()" class="w-full min-h-[46px] py-3 rounded-xl bg-indigo-600 text-white text-sm font-bold shadow-sm hover:bg-indigo-700 active:scale-[0.99] transition-all">
              <i class="fas fa-search ml-2 opacity-90"></i>
              تحميل ومعاينة
            </button>
          </div>
          <div id="accBulkPanelPaste" class="acc-bulk-source-panel hidden space-y-3">
            <p class="text-xs text-slate-500">الصق الصفوف من Excel أو CSV بنفس ترتيب الأعمدة.</p>
            <textarea id="accBulkPaste" rows="6" class="w-full min-h-[140px] px-4 py-3 rounded-xl border border-slate-200 bg-white text-xs sm:text-sm font-mono text-slate-800 focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400" placeholder="الصق الصفوف من Excel أو CSV…"></textarea>
            <button type="button" onclick="accSubmitBulkText()" class="w-full min-h-[46px] py-3 rounded-xl bg-indigo-600 text-white text-sm font-bold shadow-sm hover:bg-indigo-700 active:scale-[0.99] transition-all">
              <i class="fas fa-eye ml-2 opacity-90"></i>
              معاينة من النص
            </button>
          </div>
          <div id="accBulkPanelSheet" class="acc-bulk-source-panel hidden space-y-3">
            <p class="text-xs text-indigo-800 bg-indigo-50/80 border border-indigo-100 rounded-xl px-3 py-2.5 leading-relaxed">يتطلب ربط Google من إعدادات الجداول (Sheet).</p>
            <input type="url" id="accBulkSheetUrl" class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white text-sm text-slate-800 focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400" placeholder="https://docs.google.com/spreadsheets/d/...">
            <input type="text" id="accBulkSheetName" class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white text-sm text-slate-800 focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400" placeholder="اسم الورقة (اختياري)">
            <button type="button" onclick="accSubmitBulkSheetUrl()" class="w-full min-h-[46px] py-3 rounded-xl bg-indigo-600 text-white text-sm font-bold shadow-sm hover:bg-indigo-700 active:scale-[0.99] transition-all">
              <i class="fas fa-link ml-2 opacity-90"></i>
              معاينة من الرابط
            </button>
          </div>
        </div>
      </div>

      <div class="flex justify-center pt-1">
        <button type="button" onclick="accCloseBulk()" class="min-w-[10rem] px-8 py-2.5 rounded-xl border border-slate-200 bg-white text-slate-700 text-sm font-semibold hover:bg-slate-50 transition-colors shadow-sm">إغلاق</button>
      </div>
    </div>
  </div>
</div>
