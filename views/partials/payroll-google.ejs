<div class="payroll-audit-page w-full min-w-0 px-3 sm:px-4 pb-24 sm:pb-10" dir="rtl">
  <article class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm ring-1 ring-slate-100">

    <!-- مزامنة الدورة -->
    <div class="p-5 sm:p-6">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:gap-3">
        <div class="min-w-0 flex-1">
          <label for="payrollCycleSelect" class="mb-2 block text-sm font-medium text-slate-700">الدورة المالية</label>
          <select id="payrollCycleSelect" class="w-full min-h-[44px] rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20">
            <option value="">— اختر الدورة —</option>
          </select>
        </div>
        <button type="button" id="payrollLoadCycleBtn" onclick="payrollLoadCycle()" class="inline-flex h-11 w-full shrink-0 items-center justify-center gap-2 rounded-lg bg-indigo-600 px-5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700 active:scale-[0.99] sm:w-auto sm:min-w-[11rem]">
          <i class="fas fa-cloud-download-alt text-xs opacity-90"></i>
