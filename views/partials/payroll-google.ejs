              <button type="button" id="payrollReopenAuditBtn" onclick="payrollReopenAuditSession()" class="hidden inline-flex h-10 items-center justify-center rounded-lg bg-slate-700 px-3 text-xs font-semibold text-white hover:bg-slate-800 sm:min-w-[11rem]">
