              <button type="button" id="payrollCloseAuditBtn" onclick="payrollCloseAuditSession()" class="hidden inline-flex h-10 items-center justify-center rounded-lg bg-amber-600 px-3 text-xs font-semibold text-white shadow-sm hover:bg-amber-700 sm:min-w-[11rem]">
                إغلاق التدقيق
