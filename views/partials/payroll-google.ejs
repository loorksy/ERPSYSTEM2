          <button type="button" id="payrollAuditBtn" onclick="payrollRunAudit()" class="inline-flex h-11 w-full shrink-0 items-center justify-center gap-2 rounded-lg bg-emerald-600 px-5 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 active:scale-[0.99] sm:w-auto sm:min-w-[11rem]" title="مزامنة اللقطات ثم كتابة النتائج والألوان في Google">
            <i class="fas fa-clipboard-check text-xs opacity-90"></i>
            تدقيق
          </button>
        </div>

        <div id="payrollCycleColumnsBlock" class="space-y-3">
          <p class="text-xs font-medium text-slate-500">أعمدة الدورة (الإدارة والوكيل)</p>
          <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
            <div class="min-w-0">
              <label for="payrollCycleMgmtUserIdCol" class="mb-2 block text-xs text-slate-600">رقم المستخدم — الإدارة</label>
              <select id="payrollCycleMgmtUserIdCol" class="w-full min-h-[44px] rounded-lg border border-slate-300 bg-slate-50/50 px-2 py-2 text-sm text-slate-900 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500/30">
                <option value="A">A</option>
              </select>
            </div>
            <div class="min-w-0">
              <label for="payrollCycleAgentUserIdCol" class="mb-2 block text-xs text-slate-600">رقم المستخدم — الوكيل</label>
              <select id="payrollCycleAgentUserIdCol" class="w-full min-h-[44px] rounded-lg border border-slate-300 bg-slate-50/50 px-2 py-2 text-sm text-slate-900 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500/30">
                <option value="A">A</option>
              </select>
            </div>
            <div class="min-w-0">
              <label for="payrollCycleAgentSalaryCol" class="mb-2 block text-xs text-slate-600">الراتب — الوكيل</label>
              <select id="payrollCycleAgentSalaryCol" class="w-full min-h-[44px] rounded-lg border border-slate-300 bg-slate-50/50 px-2 py-2 text-sm text-slate-900 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500/30">
                <option value="D">D</option>
              </select>
            </div>
          </div>
        </div>

        <div id="payrollUserInfoColumnsBlock" class="space-y-3 border-t border-slate-100 pt-6">
          <p class="text-xs font-medium text-slate-500">ورقة وجدول معلومات المستخدمين</p>
          <div class="min-w-0">
            <label for="payrollUserInfoSheetSelect" class="mb-2 block text-xs text-slate-600">الورقة</label>
            <select id="payrollUserInfoSheetSelect" class="w-full min-h-[44px] rounded-lg border border-slate-300 bg-slate-50/50 px-2 py-2 text-sm text-slate-900 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500/30">
              <option value="">أول ورقة</option>
            </select>
          </div>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
            <div class="min-w-0">
              <label for="payrollUserInfoUserIdCol" class="mb-2 block text-xs text-slate-600">رقم المستخدم</label>
              <select id="payrollUserInfoUserIdCol" class="w-full min-h-[44px] rounded-lg border border-slate-300 bg-slate-50/50 px-2 py-2 text-sm text-slate-900 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500/30">
                <option value="C">C</option>
              </select>
            </div>
            <div class="min-w-0">
              <label for="payrollUserInfoTitleCol" class="mb-2 block text-xs text-slate-600">اسم الورقة</label>
              <select id="payrollUserInfoTitleCol" class="w-full min-h-[44px] rounded-lg border border-slate-300 bg-slate-50/50 px-2 py-2 text-sm text-slate-900 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500/30">
                <option value="D">D</option>
              </select>
            </div>
            <div class="min-w-0">
              <label for="payrollUserInfoSalaryCol" class="mb-2 block text-xs text-slate-600">كتابة الراتب</label>
              <select id="payrollUserInfoSalaryCol" class="w-full min-h-[44px] rounded-lg border border-slate-300 bg-slate-50/50 px-2 py-2 text-sm text-slate-900 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500/30">
                <option value="L">L</option>
              </select>
            </div>
            <div class="min-w-0 col-span-2 sm:col-span-1">
              <label for="payrollUserInfoStatusCol" class="mb-2 block text-xs text-slate-600">الحالة (محاذي)</label>
              <select id="payrollUserInfoStatusCol" class="w-full min-h-[44px] rounded-lg border border-slate-300 bg-slate-50/50 px-2 py-2 text-sm text-slate-900 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500/30">
                <option value="">تلقائي (العمود التالي)</option>
              </select>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- إعدادات التدقيق -->
    <div class="border-t border-slate-200 p-5 sm:p-6">
      <p class="mb-4 text-xs font-medium text-slate-500">الخصم والألوان</p>
      <div class="space-y-4">
        <div>
          <label for="payrollDiscountRate" class="mb-2 block text-sm font-medium text-slate-700">نسبة الخصم (%)</label>
          <input type="number" id="payrollDiscountRate" min="0" max="100" step="0.01" value="0"
            class="w-full max-w-xs min-h-[44px] rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20">
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div>
            <label for="payrollAgentColor" class="mb-2 block text-sm font-medium text-slate-700">لون الوكيل</label>
            <div class="flex items-center gap-2">
              <input type="color" id="payrollAgentColor" value="#3b82f6" class="h-10 w-10 shrink-0 cursor-pointer rounded-lg border border-slate-300 bg-white p-1">
              <input type="text" id="payrollAgentColorText" value="#3b82f6" maxlength="7" dir="ltr" class="min-h-[44px] min-w-0 flex-1 rounded-lg border border-slate-300 px-2 font-mono text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500/30">
            </div>
          </div>
          <div>
            <label for="payrollMgmtColor" class="mb-2 block text-sm font-medium text-slate-700">لون الإدارة</label>
            <div class="flex items-center gap-2">
              <input type="color" id="payrollMgmtColor" value="#10b981" class="h-10 w-10 shrink-0 cursor-pointer rounded-lg border border-slate-300 bg-white p-1">
              <input type="text" id="payrollMgmtColorText" value="#10b981" maxlength="7" dir="ltr" class="min-h-[44px] min-w-0 flex-1 rounded-lg border border-slate-300 px-2 font-mono text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500/30">
            </div>
          </div>
        </div>
        <button type="button" onclick="payrollSaveSettings()" class="inline-flex h-10 w-full items-center justify-center gap-2 rounded-lg border border-slate-300 bg-white px-4 text-sm font-semibold text-slate-800 shadow-sm hover:bg-slate-50 sm:w-auto sm:min-w-[11rem]">
          <i class="fas fa-save text-xs text-slate-500"></i>
          حفظ الإعدادات
        </button>
      </div>
    </div>

    <!-- النتائج -->
    <div id="payrollResultsSection" class="hidden border-t border-slate-200">
      <div class="border-b border-slate-100 bg-slate-50 px-5 py-3 sm:px-6">
        <span class="text-sm font-semibold text-slate-800">نتيجة التدقيق</span>
      </div>
      <div class="max-h-96 overflow-y-auto overscroll-contain p-5 sm:p-6">
        <div id="payrollResultsContent" class="break-words text-sm leading-relaxed text-slate-600">
          سيظهر هنا نتيجة التدقيق بعد التنفيذ.
        </div>
      </div>
    </div>
  </article>
