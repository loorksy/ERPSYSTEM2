<div class="w-full max-w-5xl mx-auto" dir="rtl">
  <header class="mb-8 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex items-center gap-3 min-w-0">
      <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-indigo-600 text-white shadow-md">
        <i class="fas fa-receipt text-xl"></i>
      </div>
      <div class="min-w-0">
        <h2 class="text-xl sm:text-2xl font-bold text-slate-900 truncate">المصاريف</h2>
        <p class="mt-0.5 text-sm text-slate-500">تسجيل يدوي وسجل مصاريف موحّد من الدفتر</p>
      </div>
    </div>
  </header>

  <div class="space-y-8">
    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h3 class="text-base font-bold text-slate-900 mb-1">مصروف يدوي</h3>
      <p class="text-xs text-slate-500 mb-4">يُسجَّل في الدفتر كمصروف (مع قيد موحّد).</p>
      <form id="expForm" class="max-w-md space-y-3">
        <input type="number" name="amount" step="0.01" required placeholder="المبلغ" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400">
        <input type="text" name="category" placeholder="التصنيف (اختياري)" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400">
        <textarea name="notes" placeholder="ملاحظات" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400" rows="2"></textarea>
        <button type="submit" class="w-full py-3 rounded-xl bg-indigo-600 text-white font-semibold shadow-md hover:bg-indigo-700 active:scale-[0.99] transition">تسجيل مصروف</button>
      </form>
      <p id="expMsg" class="mt-3 text-sm"></p>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between mb-4">
        <div>
          <h3 class="text-base font-bold text-slate-900">سجل المصاريف الموحّد</h3>
          <p class="text-xs text-slate-500 mt-1">خصومات تبديل الراتب، مكافآت الوكالات، ومصاريف الدفتر.</p>
        </div>
        <div class="flex flex-wrap items-center gap-2">
          <label class="text-xs font-medium text-slate-600 sr-only sm:not-sr-only sm:inline">تصفية</label>
          <input type="text" id="expUnifiedFilter" list="expSourceHints" placeholder="مثال: salary_swap_discount" class="min-w-[10rem] flex-1 sm:flex-none px-3 py-2 rounded-xl border border-slate-200 text-sm focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400">
          <datalist id="expSourceHints">
            <option value="manual_expense"></option>
            <option value="salary_swap_discount"></option>
            <option value="sub_agency_reward"></option>
          </datalist>
          <button type="button" onclick="expensesLoadUnified()" class="inline-flex items-center justify-center gap-1.5 px-4 py-2 rounded-xl bg-slate-100 text-slate-800 text-sm font-semibold hover:bg-slate-200 transition">تحديث</button>
        </div>
      </div>
      <div class="rounded-xl border border-slate-200 overflow-hidden bg-slate-50/50">
        <div class="overflow-x-auto">
          <table class="w-full text-right text-sm">
            <thead>
              <tr class="bg-slate-100/90 text-slate-700 border-b border-slate-200">
                <th class="px-3 py-2.5 font-semibold text-xs">التاريخ</th>
                <th class="px-3 py-2.5 font-semibold text-xs">المبلغ</th>
                <th class="px-3 py-2.5 font-semibold text-xs">المصدر</th>
                <th class="px-3 py-2.5 font-semibold text-xs">النوع</th>
                <th class="px-3 py-2.5 font-semibold text-xs">ملاحظات</th>
              </tr>
            </thead>
            <tbody id="expUnifiedBody" class="bg-white">
              <tr><td colspan="5" class="px-3 py-8 text-center text-slate-400 text-sm">جاري التحميل…</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>
  </div>
</div>
