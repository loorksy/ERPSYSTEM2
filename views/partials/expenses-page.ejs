<div class="max-w-6xl mx-auto px-4 sm:px-0 pb-10 space-y-6 lg:space-y-8" dir="rtl" id="expensesPageRoot">
  <!-- رأس -->
  <header class="relative overflow-hidden rounded-2xl border border-rose-200/70 bg-gradient-to-br from-rose-50/90 via-white to-slate-50 shadow-sm">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_50%_at_100%_0%,rgba(244,63,94,0.08),transparent)] pointer-events-none"></div>
    <div class="relative flex flex-col lg:flex-row lg:items-center lg:justify-between gap-5 p-6 sm:p-8">
      <div class="flex items-start gap-4 min-w-0">
        <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-rose-600 to-rose-800 text-white shadow-lg shadow-rose-900/20">
          <i class="fas fa-receipt text-2xl"></i>
        </div>
        <div class="min-w-0">
          <p class="text-xs font-semibold uppercase tracking-wider text-rose-600 mb-1">المحاسبة</p>
          <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight">المصاريف</h2>
          <p class="text-sm text-slate-600 mt-2 max-w-xl leading-relaxed">تسجيل مصروف يدوي، وعرض السجل الموحّد من الدفتر (تبديل راتب، مكافآت وكالات، قيود مصروف).</p>
        </div>
      </div>
      <a href="/dashboard" class="inline-flex shrink-0 items-center justify-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 shadow-sm transition hover:border-sky-300 hover:bg-sky-50/80 hover:text-sky-800">
        <i class="fas fa-arrow-right text-xs opacity-70"></i>
        لوحة التحكم
      </a>
    </div>
  </header>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8">
    <!-- نموذج يدوي -->
    <section class="lg:col-span-5">
      <div class="rounded-2xl border border-slate-200/90 bg-white shadow-sm overflow-hidden h-full flex flex-col">
        <div class="border-b border-slate-100 bg-gradient-to-l from-slate-50/90 to-white px-5 py-4">
          <h3 class="text-base font-bold text-slate-900 flex items-center gap-2">
            <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-rose-100 text-rose-700"><i class="fas fa-plus-circle text-sm"></i></span>
            مصروف يدوي
          </h3>
          <p class="text-xs text-slate-500 mt-1">يُسجَّل في الدفتر الموحّد كمصروف.</p>
        </div>
        <form id="expForm" class="p-5 sm:p-6 space-y-4 flex-1 flex flex-col">
          <div class="space-y-1.5">
            <label class="text-xs font-semibold text-slate-600">المبلغ</label>
            <input type="number" name="amount" step="0.01" required placeholder="0.00" class="w-full rounded-xl border-2 border-slate-200 bg-slate-50/50 px-4 py-3 text-sm font-mono tabular-nums transition focus:border-sky-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-sky-500/15">
          </div>
          <div class="space-y-1.5">
            <label class="text-xs font-semibold text-slate-600">التصنيف <span class="text-slate-400 font-normal">(اختياري)</span></label>
            <input type="text" name="category" placeholder="مثال: تشغيل، إيجار" class="w-full rounded-xl border-2 border-slate-200 bg-slate-50/50 px-4 py-3 text-sm transition focus:border-sky-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-sky-500/15">
          </div>
          <div class="space-y-1.5 flex-1 flex flex-col min-h-0">
            <label class="text-xs font-semibold text-slate-600">ملاحظات</label>
            <textarea name="notes" placeholder="تفاصيل إضافية" class="w-full min-h-[5rem] flex-1 rounded-xl border-2 border-slate-200 bg-slate-50/50 px-4 py-3 text-sm resize-y transition focus:border-sky-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-sky-500/15"></textarea>
          </div>
          <button type="submit" class="w-full inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-l from-sky-600 to-sky-700 py-3.5 text-sm font-bold text-white shadow-lg shadow-sky-600/25 transition hover:from-sky-700 hover:to-sky-800 active:scale-[0.99]">
            <i class="fas fa-check"></i>
            تسجيل مصروف
          </button>
          <p id="expMsg" class="text-sm min-h-[1.25rem]"></p>
        </form>
      </div>
    </section>

    <!-- سجل موحّد -->
    <section class="lg:col-span-7">
      <div class="rounded-2xl border border-slate-200/90 bg-white shadow-sm overflow-hidden flex flex-col min-h-[28rem] lg:min-h-[36rem]">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 border-b border-slate-100 bg-slate-50/80 px-5 py-4">
          <div class="min-w-0">
            <h3 class="text-base font-bold text-slate-900 flex items-center gap-2">
              <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-slate-200/80 text-slate-700"><i class="fas fa-table-list text-sm"></i></span>
              السجل الموحّد
            </h3>
            <p class="text-xs text-slate-500 mt-1">خصومات تبديل الراتب، مكافآت الوكالات، ومصاريف الدفتر.</p>
          </div>
          <div class="flex flex-wrap items-center gap-2">
            <label class="sr-only" for="expUnifiedFilter">تصفية المصدر</label>
            <input type="text" id="expUnifiedFilter" list="expSourceHints" placeholder="تصفية المصدر…" class="min-w-0 flex-1 sm:w-44 rounded-xl border-2 border-slate-200 bg-white px-3 py-2 text-sm transition focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/15">
            <datalist id="expSourceHints">
              <option value="manual_expense"></option>
              <option value="salary_swap_discount"></option>
              <option value="sub_agency_reward"></option>
            </datalist>
            <button type="button" onclick="expensesLoadUnified()" class="inline-flex items-center justify-center gap-1.5 rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-800 shadow-sm transition hover:bg-slate-50 hover:border-slate-300">
              <i class="fas fa-sync-alt text-xs"></i>
              تحديث
            </button>
          </div>
        </div>
        <div class="flex-1 overflow-hidden flex flex-col min-h-0">
          <div class="overflow-x-auto flex-1">
            <table class="w-full text-right text-sm min-w-[640px]">
              <thead>
                <tr class="border-b border-slate-200 bg-white sticky top-0 z-10">
                  <th class="px-4 py-3 font-semibold text-xs text-slate-600">التاريخ</th>
                  <th class="px-4 py-3 font-semibold text-xs text-slate-600 text-left" dir="ltr">المبلغ</th>
                  <th class="px-4 py-3 font-semibold text-xs text-slate-600">المصدر</th>
                  <th class="px-4 py-3 font-semibold text-xs text-slate-600">النوع</th>
                  <th class="px-4 py-3 font-semibold text-xs text-slate-600">ملاحظات</th>
                </tr>
              </thead>
              <tbody id="expUnifiedBody" class="divide-y divide-slate-100 bg-white">
                <tr><td colspan="5" class="px-4 py-12 text-center text-slate-400"><i class="fas fa-circle-notch fa-spin text-sky-500 ml-2"></i> جاري التحميل…</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>
  </div>
</div>
