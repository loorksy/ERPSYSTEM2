<div class="max-w-7xl mx-auto space-y-6 pb-8" dir="rtl">
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
    <div class="flex items-center gap-3">
      <div class="w-12 h-12 rounded-2xl bg-slate-700 flex items-center justify-center shrink-0">
        <i class="fas fa-table text-xl text-white"></i>
      </div>
      <div>
        <h2 class="text-xl font-bold text-slate-800">تدقيق محلي ومعاينة الجداول</h2>
        <p class="text-sm text-slate-500">معاينة لقطات الإدارة والوكيل ومعلومات المستخدمين على الخادم، ثم تدقيق محلي وتصدير — دون كتابة على الجداول السحابية إلا عند المزامنة أدناه.</p>
      </div>
    </div>
    <a href="/payroll" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-semibold bg-indigo-50 text-indigo-700 border border-indigo-100 hover:bg-indigo-100 shrink-0">
      <i class="fas fa-cloud"></i> تدقيق الرواتب (مزامنة وتطبيق سحابي)
    </a>
  </div>

  <section class="bg-white rounded-2xl shadow-sm border border-slate-100 p-4 sm:p-6">
    <h3 class="text-base font-bold text-slate-800 mb-3"><i class="fas fa-database text-slate-600 ml-1"></i> الدورة والمعاينة</h3>
    <div class="flex flex-col lg:flex-row gap-3 flex-wrap items-end">
      <div class="flex-1 min-w-[200px]">
        <label for="plpCycleSelect" class="block mb-1 font-semibold text-sm text-slate-700">الدورة المالية</label>
        <select id="plpCycleSelect" class="w-full py-2.5 px-3 border-2 border-slate-200 rounded-xl text-sm bg-white"></select>
      </div>
      <button type="button" id="plpRefreshPreviewBtn" class="px-4 py-2.5 rounded-xl font-semibold text-sm bg-slate-700 text-white hover:bg-slate-800">
        <i class="fas fa-eye"></i> تحديث المعاينة
      </button>
      <button type="button" id="plpSyncCycleBtn" class="px-4 py-2.5 rounded-xl font-semibold text-sm bg-indigo-600 text-white hover:bg-indigo-700" title="جلب أحدث إدارة ووكيل من Google">
        <i class="fas fa-sync"></i> مزامنة الإدارة والوكيل
      </button>
    </div>
    <p id="plpSnapshotMeta" class="mt-2 text-xs text-slate-500 hidden"></p>
  </section>

  <section class="bg-white rounded-2xl shadow-sm border border-slate-100 p-4 sm:p-6">
    <h3 class="text-base font-bold text-slate-800 mb-2"><i class="fas fa-user-friends text-emerald-600 ml-1"></i> مزامنة معلومات المستخدمين (للصفوف الجديدة)</h3>
    <p class="text-sm text-slate-600 mb-4">بعد إضافة أرقام في ملف معلومات المستخدمين على Google، اختر الجدول والورقة ثم نفّذ المزامنة قبل التدقيق المحلي.</p>
    <div class="flex flex-col xl:flex-row gap-3 flex-wrap items-end">
      <div class="flex-1 min-w-[200px]">
        <label class="block mb-1 text-xs font-medium text-slate-600">جدول معلومات المستخدمين</label>
        <select id="plpSpreadsheetSelect" class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm bg-white"></select>
      </div>
      <div class="min-w-[140px]">
        <label class="block mb-1 text-xs font-medium text-slate-600">الورقة</label>
        <select id="plpUserInfoSheetSelect" class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm bg-white">
          <option value="">أول ورقة</option>
        </select>
      </div>
      <button type="button" id="plpSyncUserInfoBtn" class="px-4 py-2.5 rounded-xl font-semibold text-sm bg-emerald-600 text-white hover:bg-emerald-700">
        <i class="fas fa-cloud-download-alt"></i> مزامنة معلومات المستخدمين
      </button>
    </div>
  </section>

  <section class="bg-white rounded-2xl shadow-sm border border-slate-100 p-4 sm:p-6">
    <h3 class="text-base font-bold text-slate-800 mb-3"><i class="fas fa-columns text-amber-600 ml-1"></i> أعمدة التدقيق (كما في تدقيق الرواتب)</h3>
    <div id="plpCycleColumnsBlock" class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-4 pb-4 border-b border-slate-100">
      <div>
        <label class="block mb-1 text-xs font-medium text-slate-600">عمود رقم المستخدم — الإدارة</label>
        <select id="plpCycleMgmtUserIdCol" class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm bg-white"></select>
      </div>
      <div>
        <label class="block mb-1 text-xs font-medium text-slate-600">عمود رقم المستخدم — الوكيل</label>
        <select id="plpCycleAgentUserIdCol" class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm bg-white"></select>
      </div>
      <div>
        <label class="block mb-1 text-xs font-medium text-slate-600">عمود الراتب — الوكيل</label>
        <select id="plpCycleAgentSalaryCol" class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm bg-white"></select>
      </div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
      <div>
        <label class="block mb-1 text-xs font-medium text-slate-600">عمود رقم المستخدم (معلومات المستخدمين)</label>
        <select id="plpUserInfoUserIdCol" class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm bg-white"></select>
      </div>
      <div>
        <label class="block mb-1 text-xs font-medium text-slate-600">عمود اسم الورقة</label>
        <select id="plpUserInfoTitleCol" class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm bg-white"></select>
      </div>
      <div>
        <label class="block mb-1 text-xs font-medium text-slate-600">عمود كتابة الراتب</label>
        <select id="plpUserInfoSalaryCol" class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm bg-white"></select>
      </div>
      <div>
        <label class="block mb-1 text-xs font-medium text-slate-600">عمود كتابة الحالة (اختياري)</label>
        <select id="plpUserInfoStatusCol" class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm bg-white">
          <option value="">تلقائي</option>
        </select>
      </div>
    </div>
  </section>

  <section class="bg-white rounded-2xl shadow-sm border border-slate-100 p-4 sm:p-6">
    <h3 class="text-base font-bold text-slate-800 mb-3"><i class="fas fa-sliders-h text-amber-600 ml-1"></i> إعدادات التدقيق</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <div>
        <label for="plpDiscountRate" class="block mb-1 font-semibold text-sm text-slate-700">نسبة الخصم (%)</label>
        <input type="number" id="plpDiscountRate" min="0" max="100" step="0.01" value="0" class="w-full py-2.5 px-3 border-2 border-slate-200 rounded-xl text-sm">
      </div>
      <div>
        <label class="block mb-1 font-semibold text-sm text-slate-700">لون الوكيل</label>
        <div class="flex gap-2">
          <input type="color" id="plpAgentColor" value="#3b82f6" class="w-11 h-10 rounded-lg border border-slate-200 cursor-pointer">
          <input type="text" id="plpAgentColorText" value="#3b82f6" maxlength="7" dir="ltr" class="flex-1 py-2 px-2 border-2 border-slate-200 rounded-xl text-sm font-mono">
        </div>
      </div>
      <div>
        <label class="block mb-1 font-semibold text-sm text-slate-700">لون الإدارة</label>
        <div class="flex gap-2">
          <input type="color" id="plpMgmtColor" value="#10b981" class="w-11 h-10 rounded-lg border border-slate-200 cursor-pointer">
          <input type="text" id="plpMgmtColorText" value="#10b981" maxlength="7" dir="ltr" class="flex-1 py-2 px-2 border-2 border-slate-200 rounded-xl text-sm font-mono">
        </div>
      </div>
      <div class="flex items-end">
        <button type="button" id="plpSaveSettingsBtn" class="w-full py-2.5 rounded-xl font-semibold text-sm bg-amber-500 text-white hover:bg-amber-600">حفظ الإعدادات</button>
      </div>
    </div>
  </section>

  <section class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
    <div class="flex flex-wrap gap-1 border-b border-slate-100 p-2 bg-slate-50">
      <button type="button" class="plp-tab px-4 py-2 rounded-lg text-sm font-semibold bg-white shadow text-indigo-700" data-plp-tab="agent">جدول الوكيل</button>
      <button type="button" class="plp-tab px-4 py-2 rounded-lg text-sm font-medium text-slate-600 hover:bg-white/80" data-plp-tab="mgmt">جدول الإدارة</button>
      <button type="button" class="plp-tab px-4 py-2 rounded-lg text-sm font-medium text-slate-600 hover:bg-white/80" data-plp-tab="userinfo">معلومات المستخدمين</button>
    </div>
    <div id="plpGridAgent" class="plp-grid-panel p-3 max-h-[min(70vh,520px)] overflow-auto"></div>
    <div id="plpGridMgmt" class="plp-grid-panel p-3 max-h-[min(70vh,520px)] overflow-auto hidden"></div>
    <div id="plpGridUserInfo" class="plp-grid-panel p-3 max-h-[min(70vh,520px)] overflow-auto hidden"></div>
    <p id="plpGridEmpty" class="p-6 text-sm text-slate-500 text-center hidden">لا توجد بيانات. اختر دورة واضغط «تحديث المعاينة» أو «مزامنة».</p>
  </section>

  <section class="bg-white rounded-2xl shadow-sm border border-slate-100 p-4 sm:p-6">
    <h3 class="text-base font-bold text-slate-800 mb-3">تدقيق وتصدير</h3>
    <div class="flex flex-wrap gap-2">
      <button type="button" id="plpAuditLocalBtn" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl font-semibold text-sm bg-slate-800 text-white hover:bg-slate-900">
        <i class="fas fa-server"></i> تدقيق محلي
      </button>
      <button type="button" id="plpExportBothBtn" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl font-semibold text-sm bg-white border-2 border-slate-200 text-slate-800 hover:bg-slate-50">
        <i class="fas fa-file-excel text-emerald-600"></i> تصدير وكيل + إدارة
      </button>
      <button type="button" id="plpExportAgentBtn" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl font-semibold text-sm bg-white border-2 border-slate-200 text-slate-800 hover:bg-slate-50">تصدير الوكيل فقط</button>
      <button type="button" id="plpExportMgmtBtn" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl font-semibold text-sm bg-white border-2 border-slate-200 text-slate-800 hover:bg-slate-50">تصدير الإدارة فقط</button>
    </div>
  </section>

  <section id="plpResultsSection" class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hidden">
    <div class="p-4 sm:p-6">
      <h3 class="text-base font-bold text-slate-800 mb-3"><i class="fas fa-list-alt text-slate-600"></i> نتيجة التدقيق</h3>
      <div id="plpResultsContent" class="text-sm text-slate-600"></div>
    </div>
  </section>
</div>

<script>
(function() {
  var MAX_ROWS = 600;

  function esc(s) {
    if (s == null) return '';
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function renderGrid(container, rows) {
    if (!container) return;
    if (!rows || !rows.length) {
      container.innerHTML = '<p class="text-sm text-slate-400 py-4 text-center">لا صفوف.</p>';
      return;
    }
    var slice = rows.length > MAX_ROWS ? rows.slice(0, MAX_ROWS) : rows;
    var html = '';
    if (rows.length > MAX_ROWS) {
      html += '<p class="text-xs text-amber-700 mb-2">عرض أول ' + MAX_ROWS + ' صف من ' + rows.length + '.</p>';
    }
    html += '<div class="inline-block min-w-full align-middle"><table class="min-w-full text-xs border-collapse border border-slate-200">';
    for (var r = 0; r < slice.length; r++) {
      html += '<tr class="' + (r === 0 ? 'bg-slate-100 font-semibold' : 'hover:bg-slate-50') + '">';
      var row = slice[r] || [];
      var maxC = Math.min(40, Math.max(row.length, 1));
      for (var c = 0; c < maxC; c++) {
        html += '<td class="border border-slate-200 px-1.5 py-1 whitespace-nowrap max-w-[12rem] truncate" title="' + esc(row[c]) + '">' + esc(row[c]) + '</td>';
      }
      html += '</tr>';
    }
    html += '</table></div>';
    container.innerHTML = html;
  }

  function columnLetter(i) {
    var s = '';
    var n = i + 1;
    while (n > 0) {
      var r = (n - 1) % 26;
      s = String.fromCharCode(65 + r) + s;
      n = Math.floor((n - 1) / 26);
    }
    return s || 'A';
  }

  function showToast(msg, type) {
    if (typeof window.showToast === 'function') window.showToast(msg, type || 'success');
    else alert(msg);
  }

  async function plpLoadCycles() {
    var sel = document.getElementById('plpCycleSelect');
    if (!sel) return;
    try {
      var res = await fetch('/api/sheet/cycles');
      var data = await res.json();
      if (!data.success || !data.cycles || !data.cycles.length) {
        sel.innerHTML = '<option value="">— لا توجد دورات —</option>';
        return;
      }
      sel.innerHTML = '<option value="">— اختر الدورة —</option>' + data.cycles.map(function(c) {
        return '<option value="' + c.id + '">' + esc(c.name || ('دورة #' + c.id)) + '</option>';
      }).join('');
    } catch (_) {
      sel.innerHTML = '<option value="">خطأ تحميل</option>';
    }
  }

  async function plpLoadCycleColumns(cycleId) {
    if (!cycleId) return;
    var res = await fetch('/api/sheet/cycles/' + cycleId + '/structure');
    var data = await res.json();
    if (!data.success) return;
    var mgmtSel = document.getElementById('plpCycleMgmtUserIdCol');
    var agentSel = document.getElementById('plpCycleAgentUserIdCol');
    var salarySel = document.getElementById('plpCycleAgentSalaryCol');
    var maxCols = Math.max(data.managementColumns || 26, data.agentColumns || 26, 26);
    var fallbackOpts = '';
    for (var i = 0; i < maxCols; i++) fallbackOpts += '<option value="' + columnLetter(i) + '">' + columnLetter(i) + '</option>';
    if (mgmtSel) { mgmtSel.innerHTML = fallbackOpts; mgmtSel.value = 'A'; }
    if (agentSel) { agentSel.innerHTML = fallbackOpts; agentSel.value = 'A'; }
    if (salarySel) { salarySel.innerHTML = fallbackOpts; salarySel.value = 'D'; }
    function fillFromColumns(sel, columns, defaultLetter) {
      if (!sel || !columns || !columns.length) return;
      var opts = columns.map(function(c) {
        var label = c.header ? (c.letter + ' - ' + c.header) : c.letter;
        return '<option value="' + c.letter + '">' + esc(label) + '</option>';
      }).join('');
      sel.innerHTML = opts;
      if (columns.some(function(c) { return c.letter === defaultLetter; })) sel.value = defaultLetter;
      else if (columns[0]) sel.value = columns[0].letter;
    }
    if (data.managementSpreadsheetId) {
      var mr = await fetch('/api/sheet/spreadsheet-columns?spreadsheetId=' + encodeURIComponent(data.managementSpreadsheetId) + (data.managementSheetName ? '&sheetName=' + encodeURIComponent(data.managementSheetName) : ''));
      var md = await mr.json();
      if (md.success && md.columns && md.columns.length) fillFromColumns(mgmtSel, md.columns, 'A');
    }
    if (data.agentSpreadsheetId) {
      var ar = await fetch('/api/sheet/spreadsheet-columns?spreadsheetId=' + encodeURIComponent(data.agentSpreadsheetId) + (data.agentSheetName ? '&sheetName=' + encodeURIComponent(data.agentSheetName) : ''));
      var ad = await ar.json();
      if (ad.success && ad.columns && ad.columns.length) {
        fillFromColumns(agentSel, ad.columns, 'A');
        fillFromColumns(salarySel, ad.columns, 'D');
      }
    }
  }

  async function plpLoadSpreadsheetsList() {
    var sel = document.getElementById('plpSpreadsheetSelect');
    if (!sel) return;
    sel.innerHTML = '<option value="">— جاري التحميل... —</option>';
    try {
      var res = await fetch('/api/sheet/spreadsheets-list');
      var data = await res.json();
      if (!data.success) {
        sel.innerHTML = '<option value="">' + esc(data.message || 'غير مربوط') + '</option>';
        return;
      }
      var list = data.spreadsheets || [];
      sel.innerHTML = '<option value="">— اختر الجدول —</option>' + list.map(function(f) {
        return '<option value="' + esc(f.id || '') + '">' + esc(f.name || f.id) + '</option>';
      }).join('');
    } catch (_) {
      sel.innerHTML = '<option value="">خطأ</option>';
    }
  }

  async function plpLoadUserInfoSheetsAndColumns(spreadsheetId, sheetName) {
    var sheetSel = document.getElementById('plpUserInfoSheetSelect');
    var userIdCol = document.getElementById('plpUserInfoUserIdCol');
    var titleCol = document.getElementById('plpUserInfoTitleCol');
    var salaryCol = document.getElementById('plpUserInfoSalaryCol');
    var statusCol = document.getElementById('plpUserInfoStatusCol');
    if (!spreadsheetId || !userIdCol || !titleCol || !salaryCol) return;
    if (sheetSel) sheetSel.innerHTML = '<option value="">أول ورقة</option>';
    if (statusCol) statusCol.innerHTML = '<option value="">تلقائي</option>';
    try {
      var sheetsRes = await fetch('/api/sheet/spreadsheet-sheets?spreadsheetId=' + encodeURIComponent(spreadsheetId));
      var sheetsData = await sheetsRes.json();
      if (sheetsData.success && sheetsData.sheets && sheetsData.sheets.length && sheetSel) {
        sheetSel.innerHTML = '<option value="">أول ورقة</option>' + sheetsData.sheets.map(function(s) {
          return '<option value="' + esc(s.title || '') + '">' + esc(s.title || s.id) + '</option>';
        }).join('');
      }
      var colRes = await fetch('/api/sheet/spreadsheet-columns?spreadsheetId=' + encodeURIComponent(spreadsheetId) + (sheetName ? '&sheetName=' + encodeURIComponent(sheetName) : ''));
      var colData = await colRes.json();
      if (colData.success && colData.columns && colData.columns.length) {
        var opts = colData.columns.map(function(c) {
          var label = c.header ? (c.letter + ' - ' + c.header) : c.letter;
          return '<option value="' + c.letter + '">' + esc(label) + '</option>';
        }).join('');
        userIdCol.innerHTML = opts;
        titleCol.innerHTML = opts;
        salaryCol.innerHTML = opts;
        if (statusCol) statusCol.innerHTML = '<option value="">تلقائي</option>' + opts;
        if (colData.columns.some(function(c) { return c.letter === 'C'; })) userIdCol.value = 'C';
        if (colData.columns.some(function(c) { return c.letter === 'D'; })) titleCol.value = 'D';
        if (colData.columns.some(function(c) { return c.letter === 'L'; })) salaryCol.value = 'L';
      }
    } catch (_) {}
  }

  async function plpRefreshPreview() {
    var sel = document.getElementById('plpCycleSelect');
    var cid = sel && sel.value;
    var meta = document.getElementById('plpSnapshotMeta');
    var empty = document.getElementById('plpGridEmpty');
    if (!cid) {
      showToast('اختر دورة مالية', 'error');
      return;
    }
    try {
      var res = await fetch('/api/sheet/cycles/' + cid + '/preview-snapshot');
      var data = await res.json();
      if (!data.success) {
        showToast(data.message || 'فشل', 'error');
        return;
      }
      var hasAny = (data.rowCounts && (data.rowCounts.management > 0 || data.rowCounts.agent > 0 || data.rowCounts.userInfo > 0));
      if (meta) {
        meta.classList.remove('hidden');
        var u = data.updatedAt ? new Date(data.updatedAt).toLocaleString('ar-SY') : '—';
        meta.textContent = 'صفوف: إدارة ' + (data.rowCounts.management || 0) + '، وكيل ' + (data.rowCounts.agent || 0) + '، معلومات المستخدمين ' + (data.rowCounts.userInfo || 0) + ' — آخر تحديث مخزّن: ' + u;
      }
      if (empty) empty.classList.toggle('hidden', !!hasAny);
      renderGrid(document.getElementById('plpGridAgent'), data.agentRows || []);
      renderGrid(document.getElementById('plpGridMgmt'), data.managementRows || []);
      renderGrid(document.getElementById('plpGridUserInfo'), data.userInfoRows || []);
    } catch (_) {
      showToast('خطأ في الاتصال', 'error');
    }
  }

  async function plpSyncCycleOnly() {
    var cid = document.getElementById('plpCycleSelect') && document.getElementById('plpCycleSelect').value;
    if (!cid) { showToast('اختر دورة', 'error'); return; }
    var btn = document.getElementById('plpSyncCycleBtn');
    if (btn) { btn.disabled = true; }
    try {
      var res = await fetch('/api/sheet/cycles/' + cid + '/sync', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' });
      var data = await res.json();
      if (data.success) {
        showToast((data.message || '') + (data.detail ? ' — ' + data.detail : ''), 'success');
        await plpLoadCycleColumns(cid);
        await plpRefreshPreview();
      } else showToast(data.message || 'فشل', 'error');
    } catch (_) { showToast('خطأ في الاتصال', 'error'); }
    if (btn) { btn.disabled = false; }
  }

  async function plpSyncUserInfo() {
    var cid = document.getElementById('plpCycleSelect') && document.getElementById('plpCycleSelect').value;
    var ss = document.getElementById('plpSpreadsheetSelect') && document.getElementById('plpSpreadsheetSelect').value;
    var sheetName = document.getElementById('plpUserInfoSheetSelect') && document.getElementById('plpUserInfoSheetSelect').value;
    if (!cid || !ss) { showToast('اختر الدورة وجدول معلومات المستخدمين', 'error'); return; }
    var btn = document.getElementById('plpSyncUserInfoBtn');
    if (btn) btn.disabled = true;
    try {
      var res = await fetch('/api/sheet/cycles/' + cid + '/sync', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userInfoSpreadsheetId: ss, userInfoSheetName: sheetName || undefined })
      });
      var data = await res.json();
      if (data.success) {
        showToast((data.message || 'تم') + (data.detail ? ' — ' + data.detail : ''), 'success');
        await plpRefreshPreview();
      } else showToast(data.message || 'فشل', 'error');
    } catch (_) { showToast('خطأ في الاتصال', 'error'); }
    if (btn) btn.disabled = false;
  }

  function plpBuildResultHtml(data) {
    var s = data.summary || {};
    var msg = data.message || 'تم';
    var html = '';
    if (data.localOnly) html += '<p class="text-xs text-slate-500 mb-2"><i class="fas fa-server ml-1"></i> تدقيق على الخادم فقط — لم تُكتب بيانات على Google.</p>';
    html += '<p class="font-semibold mb-2">' + esc(msg) + '</p>';
    html += '<ul class="space-y-1 text-slate-600">';
    html += '<li>إجمالي الصفوف: <strong>' + (s.total || 0) + '</strong></li>';
    html += '<li>سحب وكالة: <strong>' + (s.agent || 0) + '</strong></li>';
    html += '<li>سحب إدارة: <strong>' + (s.management || 0) + '</strong></li>';
    html += '<li>غير موجود: <strong>' + (s.notFound || 0) + '</strong></li></ul>';
    if (data.diagnostic) {
      var d = data.diagnostic;
      html += '<div class="mt-3 p-3 bg-amber-50 border border-amber-200 rounded-xl text-sm"><p class="font-semibold text-amber-900 mb-1">تشخيص</p>';
      html += '<ul class="text-slate-700 text-xs space-y-1">';
      html += '<li>مستخدمون (معلومات): ' + (d.userInfoUniqueCount != null ? d.userInfoUniqueCount : '—') + '</li>';
      html += '<li>إدارة: ' + (d.managementUniqueCount != null ? d.managementUniqueCount : '—') + '</li>';
      html += '<li>وكيل: ' + (d.agentUniqueCount != null ? d.agentUniqueCount : '—') + '</li></ul></div>';
    }
    return html;
  }

  async function plpAuditLocal() {
    var cid = document.getElementById('plpCycleSelect') && document.getElementById('plpCycleSelect').value;
    if (!cid) { showToast('اختر الدورة', 'error'); return; }
    var btn = document.getElementById('plpAuditLocalBtn');
    if (btn) { btn.disabled = true; }
    var discountRate = document.getElementById('plpDiscountRate').value;
    var agentColor = document.getElementById('plpAgentColor').value;
    var managementColor = document.getElementById('plpMgmtColor').value;
    var body = {
      cycleId: Number(cid),
      discountRate: Number(discountRate) || 0,
      agentColor: agentColor || '#3b82f6',
      managementColor: managementColor || '#10b981',
      userInfoUserIdCol: (document.getElementById('plpUserInfoUserIdCol') || {}).value || 'C',
      userInfoTitleCol: (document.getElementById('plpUserInfoTitleCol') || {}).value || 'D',
      userInfoSalaryCol: (document.getElementById('plpUserInfoSalaryCol') || {}).value || 'L',
      cycleMgmtUserIdCol: (document.getElementById('plpCycleMgmtUserIdCol') || {}).value || 'A',
      cycleAgentUserIdCol: (document.getElementById('plpCycleAgentUserIdCol') || {}).value || 'A',
      cycleAgentSalaryCol: (document.getElementById('plpCycleAgentSalaryCol') || {}).value || 'D'
    };
    try {
      var res = await fetch('/api/sheet/payroll-audit-local', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });
      var data = await res.json();
      if (data.success) {
        document.getElementById('plpResultsContent').innerHTML = plpBuildResultHtml(data);
        document.getElementById('plpResultsSection').classList.remove('hidden');
        showToast(data.message || 'تم', data.applied ? 'success' : 'warning');
      } else showToast(data.message || 'فشل', 'error');
    } catch (_) { showToast('خطأ في الاتصال', 'error'); }
    if (btn) btn.disabled = false;
  }

  function plpExport(which) {
    var cid = document.getElementById('plpCycleSelect') && document.getElementById('plpCycleSelect').value;
    if (!cid) { showToast('اختر الدورة', 'error'); return; }
    window.open('/api/sheet/cycles/' + cid + '/export-tables?which=' + encodeURIComponent(which), '_blank');
  }

  async function plpLoadSettings() {
    try {
      var res = await fetch('/api/sheet/payroll-settings');
      var data = await res.json();
      if (!data.success) return;
      document.getElementById('plpDiscountRate').value = data.discountRate != null ? data.discountRate : 0;
      var ac = data.agentColor || '#3b82f6';
      var mc = data.managementColor || '#10b981';
      document.getElementById('plpAgentColor').value = ac;
      document.getElementById('plpAgentColorText').value = ac;
      document.getElementById('plpMgmtColor').value = mc;
      document.getElementById('plpMgmtColorText').value = mc;
    } catch (_) {}
  }

  async function plpSaveSettings() {
    try {
      var res = await fetch('/api/sheet/payroll-settings', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          discountRate: Number(document.getElementById('plpDiscountRate').value) || 0,
          agentColor: document.getElementById('plpAgentColor').value,
          managementColor: document.getElementById('plpMgmtColor').value
        })
      });
      var data = await res.json();
      showToast(data.message || (data.success ? 'تم الحفظ' : 'فشل'), data.success ? 'success' : 'error');
    } catch (_) { showToast('خطأ', 'error'); }
  }

  document.querySelectorAll('.plp-tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      var id = tab.getAttribute('data-plp-tab');
      document.querySelectorAll('.plp-tab').forEach(function(t) {
        t.classList.remove('bg-white', 'shadow', 'text-indigo-700', 'font-semibold');
        t.classList.add('text-slate-600', 'font-medium');
      });
      tab.classList.add('bg-white', 'shadow', 'text-indigo-700', 'font-semibold');
      tab.classList.remove('text-slate-600', 'font-medium');
      document.getElementById('plpGridAgent').classList.toggle('hidden', id !== 'agent');
      document.getElementById('plpGridMgmt').classList.toggle('hidden', id !== 'mgmt');
      document.getElementById('plpGridUserInfo').classList.toggle('hidden', id !== 'userinfo');
    });
  });

  document.getElementById('plpCycleSelect').addEventListener('change', function() {
    var cid = this.value;
    if (cid) plpLoadCycleColumns(cid);
  });

  document.getElementById('plpRefreshPreviewBtn').addEventListener('click', plpRefreshPreview);
  document.getElementById('plpSyncCycleBtn').addEventListener('click', plpSyncCycleOnly);
  document.getElementById('plpSyncUserInfoBtn').addEventListener('click', plpSyncUserInfo);
  document.getElementById('plpAuditLocalBtn').addEventListener('click', plpAuditLocal);
  document.getElementById('plpExportBothBtn').addEventListener('click', function() { plpExport('both'); });
  document.getElementById('plpExportAgentBtn').addEventListener('click', function() { plpExport('agent'); });
  document.getElementById('plpExportMgmtBtn').addEventListener('click', function() { plpExport('management'); });
  document.getElementById('plpSaveSettingsBtn').addEventListener('click', plpSaveSettings);

  document.getElementById('plpAgentColor').addEventListener('input', function() {
    document.getElementById('plpAgentColorText').value = this.value;
  });
  document.getElementById('plpAgentColorText').addEventListener('input', function() {
    var v = this.value;
    if (/^#[0-9A-Fa-f]{6}$/.test(v)) document.getElementById('plpAgentColor').value = v;
  });
  document.getElementById('plpMgmtColor').addEventListener('input', function() {
    document.getElementById('plpMgmtColorText').value = this.value;
  });
  document.getElementById('plpMgmtColorText').addEventListener('input', function() {
    var v = this.value;
    if (/^#[0-9A-Fa-f]{6}$/.test(v)) document.getElementById('plpMgmtColor').value = v;
  });

  var plpSs = document.getElementById('plpSpreadsheetSelect');
  var plpSheet = document.getElementById('plpUserInfoSheetSelect');
  if (plpSs) plpSs.addEventListener('change', function() {
    var id = (this.value || '').trim();
    if (id) plpLoadUserInfoSheetsAndColumns(id, null);
  });
  if (plpSheet) plpSheet.addEventListener('change', function() {
    var ssId = (document.getElementById('plpSpreadsheetSelect').value || '').trim();
    if (ssId) plpLoadUserInfoSheetsAndColumns(ssId, this.value || null);
  });

  plpLoadCycles();
  plpLoadSpreadsheetsList();
  plpLoadSettings();
})();
</script>
