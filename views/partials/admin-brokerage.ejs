<div class="w-full max-w-6xl mx-auto px-4 sm:px-0 pb-10" dir="rtl">
  <div class="erp-module-shell rounded-2xl border border-slate-200/90 bg-white shadow-sm overflow-hidden">
    <div class="relative overflow-hidden border-b border-slate-200/80 bg-gradient-to-br from-amber-50/90 via-white to-slate-50 px-4 py-5 sm:px-7 sm:py-6">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_50%_at_0%_100%,rgba(245,158,11,0.1),transparent)] pointer-events-none"></div>
      <div class="relative flex items-start gap-3 sm:gap-4">
        <div class="flex h-11 w-11 sm:h-12 sm:w-12 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-amber-500 to-orange-600 text-white shadow-md">
          <i class="fas fa-percent text-lg sm:text-xl"></i>
        </div>
        <div class="min-w-0">
          <p class="text-xs font-semibold text-amber-800 mb-0.5">توزيع الربح والصندوق</p>
          <h2 class="text-lg sm:text-2xl font-bold text-slate-900 tracking-tight">وساطة إدارية</h2>
          <p class="text-sm text-slate-600 mt-1 leading-relaxed">نسبة الوساطة تُسجّل ربحاً، والباقي يُضاف للصندوق الرئيسي.</p>
        </div>
      </div>
    </div>

    <div class="border-b border-slate-100 bg-slate-50/95 px-4 py-4 sm:px-6 sm:py-5">
      <p class="text-xs font-semibold text-slate-500 mb-3">تسجيل عملية جديدة</p>
      <form id="abForm" class="space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4">
          <div class="space-y-1.5">
            <label class="text-xs font-semibold text-slate-600">الدورة (اختياري)</label>
            <select id="abCycle" name="cycleId" class="w-full px-4 py-2.5 rounded-xl border-2 border-slate-200 bg-white text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/15"><option value="">— دورة (اختياري) —</option></select>
          </div>
          <div class="space-y-1.5">
            <label class="text-xs font-semibold text-slate-600">المبلغ</label>
            <input type="number" name="amount" step="0.01" required placeholder="المبلغ" class="w-full px-4 py-2.5 rounded-xl border-2 border-slate-200 bg-white text-sm font-mono tabular-nums focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/15">
          </div>
          <div class="space-y-1.5 sm:col-span-2 lg:col-span-1">
            <label class="text-xs font-semibold text-slate-600">نسبة الوساطة %</label>
            <input type="number" name="brokeragePct" step="0.1" required placeholder="نسبة الوساطة %" class="w-full px-4 py-2.5 rounded-xl border-2 border-slate-200 bg-white text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/15">
          </div>
        </div>
        <div class="space-y-1.5">
          <label class="text-xs font-semibold text-slate-600">ملاحظات</label>
          <textarea name="notes" placeholder="ملاحظات" class="w-full px-4 py-2.5 rounded-xl border-2 border-slate-200 bg-white text-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/15" rows="2"></textarea>
        </div>
        <button type="submit" class="w-full sm:w-auto sm:min-w-[200px] py-3 rounded-xl bg-sky-600 text-white font-bold shadow-md shadow-sky-600/20 hover:bg-sky-700 active:scale-[0.99] transition">تسجيل</button>
      </form>
      <p id="abMsg" class="text-sm min-h-[1.25rem] mt-3"></p>
    </div>

    <div class="px-4 py-5 sm:px-7 sm:py-6">
      <h3 class="text-base font-bold text-slate-900 mb-1 flex items-center gap-2">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-slate-100 text-slate-600"><i class="fas fa-book text-sm"></i></span>
        سجل حركات
      </h3>
      <p class="text-xs text-slate-500 mb-4">إدخالات الوساطة الإدارية والقيود المرتبطة في الدفتر.</p>
      <div id="abLedgerBox" class="text-sm text-slate-500 min-h-[80px] rounded-xl border border-slate-200/80 bg-slate-50/40 p-4">جاري التحميل…</div>
    </div>
  </div>
</div>
<script>
fetch('/api/sheet/cycles', { credentials: 'same-origin' }).then(function(r) { return r.json(); }).then(function(res) {
  var sel = document.getElementById('abCycle');
  if (!sel || !res.success) return;
  (res.cycles || []).forEach(function(c) {
    sel.innerHTML += '<option value="' + c.id + '">' + (c.name || c.id) + '</option>';
  });
});
function abLoadLedger() {
  var box = document.getElementById('abLedgerBox');
  if (!box) return;
  fetch('/api/admin-brokerage/ledger', { credentials: 'same-origin' }).then(function(r) { return r.json(); }).then(function(res) {
    if (!res.success) {
      box.innerHTML = '<p class="text-red-600">' + (res.message || 'فشل') + '</p>';
      return;
    }
    var ent = res.entries || [];
    var led = res.ledgerEntries || [];
    if (!ent.length) {
      box.innerHTML = '<p class="text-slate-400">لا إدخالات بعد.</p>';
      return;
    }
    var html = '<div class="space-y-4">';
    ent.forEach(function(e) {
      html += '<div class="rounded-xl border border-slate-100 p-3 bg-slate-50/80">';
      html += '<div class="flex flex-wrap justify-between gap-2 text-xs text-slate-500"><span>#' + e.id + '</span><span>' + (e.created_at || '') + '</span></div>';
      html += '<p class="font-semibold text-slate-800 mt-1">مبلغ: ' + (e.amount != null ? e.amount : '') + ' — وساطة %' + (e.brokerage_pct != null ? e.brokerage_pct : '') + '</p>';
      html += '<p class="text-xs">ربح: ' + (e.profit_amount != null ? e.profit_amount : '') + ' | صندوق: ' + (e.main_fund_amount != null ? e.main_fund_amount : '') + '</p>';
      if (e.notes) html += '<p class="text-xs text-slate-600 mt-1">' + String(e.notes).replace(/</g, '&lt;') + '</p>';
      var related = led.filter(function(l) { return l.ref_id === e.id; });
      if (related.length) {
        html += '<ul class="mt-2 space-y-1 text-xs border-t border-slate-200 pt-2">';
        related.forEach(function(l) {
          html += '<li class="flex justify-between gap-2"><span>' + (l.source_type || l.bucket || '') + '</span><span class="tabular-nums">' + (l.amount != null ? l.amount : '') + ' ' + (l.currency || '') + '</span></li>';
        });
        html += '</ul>';
      }
      html += '</div>';
    });
    html += '</div>';
    box.innerHTML = html;
  }).catch(function() {
    box.innerHTML = '<p class="text-red-600">فشل التحميل</p>';
  });
}
document.getElementById('abForm').addEventListener('submit', function(e) {
  e.preventDefault();
  var fd = new FormData(e.target);
  fetch('/api/admin-brokerage/add', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    credentials: 'same-origin',
    body: JSON.stringify({
      cycleId: fd.get('cycleId') || null,
      amount: fd.get('amount'),
      brokeragePct: fd.get('brokeragePct'),
      notes: fd.get('notes')
    })
  }).then(function(r) { return r.json(); }).then(function(res) {
    var p = document.getElementById('abMsg');
    p.textContent = res.message || '';
    p.className = 'text-sm mt-3 ' + (res.success ? 'text-emerald-600' : 'text-red-600');
    if (res.success) abLoadLedger();
  });
});
abLoadLedger();
</script>
