<div class="w-full max-w-2xl mx-auto space-y-8" dir="rtl">
  <header class="flex items-center gap-3">
    <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-indigo-600 text-white shadow-md">
      <i class="fas fa-percent text-xl"></i>
    </div>
    <div>
      <h2 class="text-xl sm:text-2xl font-bold text-slate-900">وساطة إدارية</h2>
      <p class="text-sm text-slate-500 mt-0.5">نسبة الوساطة تُسجّل ربحاً، والباقي يُضاف للصندوق الرئيسي.</p>
    </div>
  </header>
  <form id="abForm" class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm space-y-3">
    <select id="abCycle" name="cycleId" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400"><option value="">— دورة (اختياري) —</option></select>
    <input type="number" name="amount" step="0.01" required placeholder="المبلغ" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400">
    <input type="number" name="brokeragePct" step="0.1" required placeholder="نسبة الوساطة %" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400">
    <textarea name="notes" placeholder="ملاحظات" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400" rows="2"></textarea>
    <button type="submit" class="w-full py-3 rounded-xl bg-indigo-600 text-white font-semibold shadow-md hover:bg-indigo-700 active:scale-[0.99] transition">تسجيل</button>
  </form>
  <p id="abMsg" class="text-sm"></p>

  <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <h3 class="text-lg font-bold text-slate-800 mb-1">سجل حركات</h3>
    <p class="text-xs text-slate-500 mb-4">إدخالات الوساطة الإدارية والقيود المرتبطة في الدفتر.</p>
    <div id="abLedgerBox" class="text-sm text-slate-500 min-h-[80px]">جاري التحميل…</div>
  </section>
</div>
<script>
fetch('/api/sheet/cycles', { credentials: 'same-origin' }).then(function(r) { return r.json(); }).then(function(res) {
  var sel = document.getElementById('abCycle');
  if (!sel || !res.success) return;
  (res.cycles || []).forEach(function(c) {
    sel.innerHTML += '<option value="' + c.id + '">' + (c.name || c.id) + '</option>';
  });
});
function abLoadLedger() {
  var box = document.getElementById('abLedgerBox');
  if (!box) return;
  fetch('/api/admin-brokerage/ledger', { credentials: 'same-origin' }).then(function(r) { return r.json(); }).then(function(res) {
    if (!res.success) {
      box.innerHTML = '<p class="text-red-600">' + (res.message || 'فشل') + '</p>';
      return;
    }
    var ent = res.entries || [];
    var led = res.ledgerEntries || [];
    if (!ent.length) {
      box.innerHTML = '<p class="text-slate-400">لا إدخالات بعد.</p>';
      return;
    }
    var html = '<div class="space-y-4">';
    ent.forEach(function(e) {
      html += '<div class="rounded-xl border border-slate-100 p-3 bg-slate-50/80">';
      html += '<div class="flex flex-wrap justify-between gap-2 text-xs text-slate-500"><span>#' + e.id + '</span><span>' + (e.created_at || '') + '</span></div>';
      html += '<p class="font-semibold text-slate-800 mt-1">مبلغ: ' + (e.amount != null ? e.amount : '') + ' — وساطة %' + (e.brokerage_pct != null ? e.brokerage_pct : '') + '</p>';
      html += '<p class="text-xs">ربح: ' + (e.profit_amount != null ? e.profit_amount : '') + ' | صندوق: ' + (e.main_fund_amount != null ? e.main_fund_amount : '') + '</p>';
      if (e.notes) html += '<p class="text-xs text-slate-600 mt-1">' + String(e.notes).replace(/</g, '&lt;') + '</p>';
      var related = led.filter(function(l) { return l.ref_id === e.id; });
      if (related.length) {
        html += '<ul class="mt-2 space-y-1 text-xs border-t border-slate-200 pt-2">';
        related.forEach(function(l) {
          html += '<li class="flex justify-between gap-2"><span>' + (l.source_type || l.bucket || '') + '</span><span class="tabular-nums">' + (l.amount != null ? l.amount : '') + ' ' + (l.currency || '') + '</span></li>';
        });
        html += '</ul>';
      }
      html += '</div>';
    });
    html += '</div>';
    box.innerHTML = html;
  }).catch(function() {
    box.innerHTML = '<p class="text-red-600">فشل التحميل</p>';
  });
}
document.getElementById('abForm').addEventListener('submit', function(e) {
  e.preventDefault();
  var fd = new FormData(e.target);
  fetch('/api/admin-brokerage/add', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    credentials: 'same-origin',
    body: JSON.stringify({
      cycleId: fd.get('cycleId') || null,
      amount: fd.get('amount'),
      brokeragePct: fd.get('brokeragePct'),
      notes: fd.get('notes')
    })
  }).then(function(r) { return r.json(); }).then(function(res) {
    var p = document.getElementById('abMsg');
    p.textContent = res.message || '';
    p.className = 'text-sm ' + (res.success ? 'text-emerald-600' : 'text-red-600');
    if (res.success) abLoadLedger();
  });
});
abLoadLedger();
</script>
