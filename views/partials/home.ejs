<!-- Welcome -->
<div class="mb-6">
  <div class="bg-gradient-to-br from-indigo-600 to-indigo-700 rounded-2xl p-6 md:p-8 flex flex-col md:flex-row items-center gap-5 text-white shadow-[0_8px_32px_rgba(79,70,229,0.3)]">
    <div class="w-14 h-14 md:w-16 md:h-16 bg-white/20 rounded-2xl flex items-center justify-center text-2xl md:text-3xl shrink-0">
      <i class="fas fa-hand-wave"></i>
    </div>
    <div class="text-center md:text-right">
      <h2 class="text-lg md:text-xl font-bold mb-1">مرحباً، <%= user.displayName %></h2>
      <p class="opacity-85 text-sm leading-7">مرحباً بك في نظام LorkERP للمحاسبة. النظام جاهز لإضافة الأقسام والصفحات حسب احتياجاتك.</p>
    </div>
  </div>
</div>

<!-- Cycle selector for stats -->
<div class="mb-4 flex flex-wrap items-center gap-3">
  <label class="text-sm font-medium text-slate-600">الدورة المالية:</label>
  <select id="homeCycleSelect" class="px-3 py-2 rounded-lg border border-slate-200 text-sm bg-white" onchange="homeLoadStats()">
    <option value="">-- اختر الدورة --</option>
  </select>
  <button type="button" onclick="homeLoadStats()" class="px-3 py-2 rounded-lg bg-indigo-100 text-indigo-700 text-sm font-medium hover:bg-indigo-200">
    <i class="fas fa-sync-alt ml-1"></i> تحديث
  </button>
</div>

<!-- تقارير PDF -->
<div class="mb-6 flex flex-wrap items-center gap-2 p-4 rounded-xl bg-slate-50 border border-slate-100">
  <span class="text-sm font-semibold text-slate-700"><i class="fas fa-file-pdf text-red-600 ml-1"></i> تقرير PDF:</span>
  <select id="homeReportType" class="px-3 py-2 rounded-lg border border-slate-200 text-sm bg-white max-w-[min(100%,14rem)]" aria-label="نوع التقرير">
    <option value="comprehensive">تقرير شامل</option>
    <option value="accreditations">الاعتمادات</option>
    <option value="transfer-companies">شركات التحويل</option>
    <option value="movements">الحركات (كل الدفاتر)</option>
  </select>
  <button type="button" onclick="homeDownloadReportPdf()" class="px-4 py-2 rounded-lg bg-red-600 text-white text-sm font-semibold hover:bg-red-700">
    تنزيل
  </button>
  <span class="text-xs text-slate-500 w-full sm:w-auto">يُطبَّق اختيار الدورة على التقارير التي تدعم التصفية.</span>
</div>

<!-- Financial Reports -->
<div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-8 gap-4 mb-6">
  <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 hover:shadow-md transition-all duration-300 group">
    <div class="w-11 h-11 rounded-xl bg-emerald-500/10 flex items-center justify-center mb-3 group-hover:scale-110 transition-transform duration-300">
      <i class="fas fa-arrow-trend-up text-lg text-emerald-500"></i>
    </div>
    <p class="text-slate-400 text-xs font-medium mb-1">إجمالي الإيرادات</p>
    <p class="text-xl font-bold text-slate-800" id="totalRevenue">0.00</p>
  </div>

  <a href="/profit-sources" class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 hover:shadow-md transition-all duration-300 group block" title="مصادر الربح">
    <div class="w-11 h-11 rounded-xl bg-indigo-500/10 flex items-center justify-center mb-3 group-hover:scale-110 transition-transform duration-300">
      <i class="fas fa-coins text-lg text-indigo-500"></i>
    </div>
    <p class="text-slate-400 text-xs font-medium mb-1">الربح الصافي</p>
    <p class="text-xl font-bold text-slate-800" id="netProfit">0.00</p>
  </a>

  <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 hover:shadow-md transition-all duration-300 group">
    <div class="w-11 h-11 rounded-xl bg-rose-500/10 flex items-center justify-center mb-3 group-hover:scale-110 transition-transform duration-300">
      <i class="fas fa-receipt text-lg text-rose-500"></i>
    </div>
    <p class="text-slate-400 text-xs font-medium mb-1">المصاريف (مجمّع)</p>
    <p class="text-xl font-bold text-slate-800" id="totalExpenses">0.00</p>
  </div>

  <a href="/debts" class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 hover:shadow-md transition-all duration-300 group block" id="homeCardDebt" title="صفحة الديون والملفات">
    <div class="w-11 h-11 rounded-xl bg-red-500/10 flex items-center justify-center mb-3 group-hover:scale-110 transition-transform duration-300">
      <i class="fas fa-file-invoice-dollar text-lg text-red-500"></i>
    </div>
    <p class="text-slate-400 text-xs font-medium mb-1">إجمالي الديون</p>
    <p class="text-xl font-bold text-slate-800" id="totalDebts">0.00</p>
  </a>

  <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 hover:shadow-md transition-all duration-300 group cursor-pointer" id="homeCardCash" onclick="homeOpenFundModal()" title="مصادر الأموال والصناديق">
    <div class="w-11 h-11 rounded-xl bg-amber-500/10 flex items-center justify-center mb-3 group-hover:scale-110 transition-transform duration-300">
      <i class="fas fa-vault text-lg text-amber-500"></i>
    </div>
    <p class="text-slate-400 text-xs font-medium mb-1">رصيد الصندوق</p>
    <p class="text-xl font-bold text-slate-800" id="cashBalance">0.00</p>
    <p class="text-[0.65rem] text-slate-400 mt-1" id="cashBalanceSub"></p>
  </div>

  <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 hover:shadow-md transition-all duration-300 group cursor-pointer" onclick="homeOpenCapitalModal()" title="ترحيل الأرباح">
    <div class="w-11 h-11 rounded-xl bg-emerald-500/10 flex items-center justify-center mb-3 group-hover:scale-110 transition-transform duration-300">
      <i class="fas fa-landmark text-lg text-emerald-600"></i>
    </div>
    <p class="text-slate-400 text-xs font-medium mb-1">رأس المال (مسترد)</p>
    <p class="text-xl font-bold text-slate-800" id="capitalRecovery">0.00</p>
  </div>

  <a href="/deferred-balance" id="deferredBalanceLink" class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 hover:shadow-md transition-all duration-300 group block">
    <div class="w-11 h-11 rounded-xl bg-sky-500/10 flex items-center justify-center mb-3 group-hover:scale-110 transition-transform duration-300">
      <i class="fas fa-clock-rotate-left text-lg text-sky-500"></i>
    </div>
    <p class="text-slate-400 text-xs font-medium mb-1">رصيد المؤجل</p>
    <p class="text-xl font-bold text-slate-800" id="deferredBalance">0.00</p>
  </a>

  <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 hover:shadow-md transition-all duration-300 group">
    <div class="w-11 h-11 rounded-xl bg-violet-500/10 flex items-center justify-center mb-3 group-hover:scale-110 transition-transform duration-300">
      <i class="fas fa-truck-fast text-lg text-violet-500"></i>
    </div>
    <p class="text-slate-400 text-xs font-medium mb-1">رصيد الشحن (كمية)</p>
    <p class="text-xl font-bold text-slate-800" id="shippingBalance">0.00</p>
  </div>
</div>

<!-- نوافذ تفاصيل لوحة التحكم -->
<div id="homeFundModal" class="fixed inset-0 z-[3000] hidden items-center justify-center p-4 bg-black/50">
  <div class="bg-white rounded-2xl max-w-lg w-full max-h-[85vh] overflow-y-auto p-6 shadow-xl">
    <div class="flex justify-between items-center mb-4">
      <h4 class="text-lg font-bold">مصادر الأموال والصناديق</h4>
      <button type="button" onclick="homeCloseFundModal()" class="text-slate-400 hover:text-slate-600"><i class="fas fa-times text-xl"></i></button>
    </div>
    <div id="homeFundModalBody" class="text-sm text-slate-600 space-y-3"></div>
  </div>
</div>
<div id="homeCapitalModal" class="fixed inset-0 z-[3000] hidden items-center justify-center p-4 bg-black/50">
  <div class="bg-white rounded-2xl max-w-md w-full p-6 shadow-xl">
    <div class="flex justify-between items-center mb-4">
      <h4 class="text-lg font-bold">ترحيل أرباح إلى صندوق</h4>
      <button type="button" onclick="homeCloseCapitalModal()" class="text-slate-400"><i class="fas fa-times text-xl"></i></button>
    </div>
    <p class="text-xs text-slate-500 mb-3">يمكنك إرسال عدة دفعات بإضافة صفوف (صندوق + مبلغ).</p>
    <div id="homeProfitRows" class="space-y-2 mb-3"></div>
    <button type="button" onclick="homeAddProfitRow()" class="text-sm text-indigo-600 font-semibold mb-3">+ دفعة</button>
    <select id="homeProfitCycle" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm mb-3"><option value="">— دورة مالية (اختياري) —</option></select>
    <button type="button" onclick="homeSubmitProfitTransfer()" class="w-full py-3 rounded-xl bg-indigo-600 text-white font-semibold">ترحيل</button>
  </div>
</div>

<!-- Quick Status -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
  <div class="bg-white rounded-xl p-5 flex items-center gap-4 shadow-sm border border-slate-100 transition-all duration-300 hover:shadow-md">
    <div class="w-12 h-12 rounded-xl bg-[#0f9d58]/10 text-[#0f9d58] flex items-center justify-center text-xl shrink-0">
      <i class="fas fa-table"></i>
    </div>
    <div class="flex-1">
      <h4 class="text-[0.95rem] font-semibold mb-1">Google Sheets</h4>
      <span class="text-xs font-medium py-0.5 px-2.5 rounded-full bg-red-50 text-red-500" id="homeSheetsStatus">جاري التحقق...</span>
    </div>
    <a href="/settings" class="w-9 h-9 rounded-full bg-slate-50 flex items-center justify-center text-slate-500 transition-all duration-300 hover:bg-indigo-600/10 hover:text-indigo-600">
      <i class="fas fa-arrow-left"></i>
    </a>
  </div>
</div>

<!-- System Info -->
<div class="mb-6">
  <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
    <div class="flex items-center gap-2.5 py-4 px-5 border-b border-slate-100">
      <i class="fas fa-info-circle text-indigo-600"></i>
      <h3 class="text-base font-semibold">معلومات النظام</h3>
    </div>
    <div class="py-2">
      <div class="flex items-center justify-between py-3 px-5 border-b border-slate-100">
        <span class="text-slate-500 text-sm">إصدار النظام</span>
        <span class="font-semibold text-sm">1.0.0</span>
      </div>
      <div class="flex items-center justify-between py-3 px-5 border-b border-slate-100">
        <span class="text-slate-500 text-sm">اسم المستخدم</span>
        <span class="font-semibold text-sm"><%= user.username %></span>
      </div>
      <div class="flex items-center justify-between py-3 px-5">
        <span class="text-slate-500 text-sm">الصلاحية</span>
        <span class="font-semibold text-sm"><%= user.role === 'admin' ? 'مدير النظام' : 'مستخدم' %></span>
      </div>
    </div>
  </div>
</div>
