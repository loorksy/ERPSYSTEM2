<div class="max-w-6xl mx-auto px-4 sm:px-0 pb-10 space-y-6 lg:space-y-8" dir="rtl" id="homeDashboardRoot">
  <!-- ترحيب -->
  <section class="relative overflow-hidden rounded-2xl border border-indigo-200/60 bg-gradient-to-br from-indigo-600 via-indigo-700 to-slate-900 text-white shadow-xl shadow-indigo-900/25">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_100%_0%,rgba(255,255,255,0.12),transparent)] pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 h-32 w-32 rounded-full bg-white/5 blur-2xl"></div>
    <div class="relative flex flex-col md:flex-row md:items-center gap-5 md:gap-8 p-6 md:p-8">
      <div class="flex h-16 w-16 md:h-20 md:w-20 shrink-0 items-center justify-center rounded-2xl bg-white/15 backdrop-blur-sm shadow-inner ring-1 ring-white/20">
        <i class="fas fa-hand-wave text-3xl md:text-4xl text-white/95"></i>
      </div>
      <div class="min-w-0 flex-1 text-center md:text-right">
        <p class="text-xs font-semibold uppercase tracking-wider text-indigo-200/90 mb-1">LorkERP</p>
        <h2 class="text-xl md:text-2xl font-bold tracking-tight">مرحباً، <%= user.displayName %></h2>
        <p class="mt-2 text-sm text-indigo-100/90 leading-relaxed max-w-2xl mx-auto md:mx-0 md:ml-auto">
          نظرة سريعة على الأرقام المهمة، الدورة المالية، والتقارير. استخدم البطاقات أدناه للانتقال إلى التفاصيل.
        </p>
      </div>
    </div>
  </section>

  <!-- أدوات: دورة + تقرير PDF -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
    <div class="lg:col-span-7 rounded-2xl border border-slate-200/90 bg-white p-4 sm:p-5 shadow-sm">
      <div class="flex flex-col sm:flex-row sm:items-end gap-4">
        <div class="flex-1 min-w-0">
          <label class="block text-xs font-semibold text-slate-500 mb-2">الدورة المالية</label>
          <select id="homeCycleSelect" class="w-full rounded-xl border-2 border-slate-200 bg-slate-50/50 px-4 py-3 text-sm font-medium text-slate-800 transition focus:border-indigo-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/15" onchange="homeLoadStats()">
            <option value="">-- اختر الدورة --</option>
          </select>
        </div>
        <button type="button" onclick="homeLoadStats()" class="inline-flex items-center justify-center gap-2 rounded-xl bg-indigo-600 px-5 py-3 text-sm font-bold text-white shadow-md shadow-indigo-600/25 transition hover:bg-indigo-700 active:scale-[0.99] shrink-0">
          <i class="fas fa-sync-alt"></i>
          تحديث الأرقام
        </button>
      </div>
    </div>
    <div class="lg:col-span-5 rounded-2xl border border-slate-200/90 bg-gradient-to-br from-slate-50 to-white p-4 sm:p-5 shadow-sm">
      <p class="text-xs font-semibold text-slate-500 mb-3 flex items-center gap-2">
        <i class="fas fa-file-pdf text-red-500"></i>
        تقرير PDF
      </p>
      <div class="flex flex-col sm:flex-row gap-2 sm:items-stretch">
        <select id="homeReportType" class="flex-1 min-w-0 rounded-xl border-2 border-slate-200 bg-white px-3 py-2.5 text-sm font-medium text-slate-800 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/15" aria-label="نوع التقرير">
          <option value="comprehensive">تقرير شامل</option>
          <option value="accreditations">الاعتمادات</option>
          <option value="transfer-companies">شركات التحويل</option>
          <option value="movements">الحركات (كل الدفاتر)</option>
        </select>
        <button type="button" onclick="homeDownloadReportPdf()" class="inline-flex items-center justify-center gap-2 rounded-xl bg-red-600 px-4 py-2.5 text-sm font-bold text-white shadow-sm transition hover:bg-red-700 shrink-0">
          <i class="fas fa-download text-xs"></i>
          تنزيل
        </button>
      </div>
      <p class="text-[0.7rem] text-slate-500 mt-2 leading-snug">يُطبَّق اختيار الدورة على التقارير التي تدعم التصفية.</p>
    </div>
  </div>

  <!-- مؤشرات مالية -->
  <section>
    <h3 class="text-sm font-bold text-slate-800 mb-3 flex items-center gap-2">
      <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-indigo-100 text-indigo-700"><i class="fas fa-chart-pie text-sm"></i></span>
      مؤشرات مالية
    </h3>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
      <a href="/profit-sources" class="group rounded-2xl border border-slate-200/90 bg-white p-4 sm:p-5 shadow-sm transition hover:border-indigo-200 hover:shadow-md" title="مصادر الربح">
        <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-indigo-50 text-indigo-600 mb-3 transition group-hover:bg-indigo-600 group-hover:text-white">
          <i class="fas fa-coins text-lg"></i>
        </div>
        <p class="text-xs font-semibold text-slate-500 mb-1">الربح الصافي</p>
        <p class="font-mono text-lg sm:text-xl font-bold tabular-nums text-slate-900 tracking-tight" id="netProfit">0.00</p>
      </a>

      <div class="rounded-2xl border border-slate-200/90 bg-white p-4 sm:p-5 shadow-sm">
        <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-rose-50 text-rose-600 mb-3">
          <i class="fas fa-receipt text-lg"></i>
        </div>
        <p class="text-xs font-semibold text-slate-500 mb-1">المصاريف (مجمّع)</p>
        <p class="font-mono text-lg sm:text-xl font-bold tabular-nums text-slate-900" id="totalExpenses">0.00</p>
      </div>

      <a href="/debts" class="group rounded-2xl border border-slate-200/90 bg-white p-4 sm:p-5 shadow-sm transition hover:border-red-200 hover:shadow-md" id="homeCardDebt" title="صفحة الديون والملفات">
        <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-red-50 text-red-600 mb-3 transition group-hover:bg-red-600 group-hover:text-white">
          <i class="fas fa-file-invoice-dollar text-lg"></i>
        </div>
        <p class="text-xs font-semibold text-slate-500 mb-1">إجمالي الديون</p>
        <p class="font-mono text-lg sm:text-xl font-bold tabular-nums text-slate-900" id="totalDebts">0.00</p>
      </a>

      <a href="/receivables-to-us" class="group rounded-2xl border border-slate-200/90 bg-white p-4 sm:p-5 shadow-sm transition hover:border-emerald-200 hover:shadow-md" title="ديين لنا">
        <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-50 text-emerald-700 mb-3 transition group-hover:bg-emerald-600 group-hover:text-white">
          <i class="fas fa-hand-holding-heart text-lg"></i>
        </div>
        <p class="text-xs font-semibold text-slate-500 mb-1">ديين لنا</p>
        <p class="font-mono text-lg sm:text-xl font-bold tabular-nums text-slate-900" id="receivablesToUsHome">—</p>
      </a>
    </div>
  </section>

  <!-- سيولة ومستحقات -->
  <section>
    <h3 class="text-sm font-bold text-slate-800 mb-3 flex items-center gap-2">
      <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-100 text-amber-800"><i class="fas fa-wallet text-sm"></i></span>
      سيولة ومستحقات
    </h3>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
      <a href="/payment-due" class="group rounded-2xl border border-slate-200/90 bg-white p-4 sm:p-5 shadow-sm transition hover:border-amber-200 hover:shadow-md" title="مطلوب دفع">
        <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-amber-50 text-amber-700 mb-3 transition group-hover:bg-amber-500 group-hover:text-white">
          <i class="fas fa-money-bill-wave text-lg"></i>
        </div>
        <p class="text-xs font-semibold text-slate-500 mb-1">مطلوب دفع</p>
        <p class="font-mono text-lg sm:text-xl font-bold tabular-nums text-slate-900" id="paymentDueHome">—</p>
      </a>

      <div class="rounded-2xl border border-slate-200/90 bg-white p-4 sm:p-5 shadow-sm cursor-pointer transition hover:border-amber-200 hover:shadow-md" id="homeCardCash" onclick="homeOpenFundModal()" title="مصادر الأموال والصناديق">
        <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-amber-50 text-amber-600 mb-3">
          <i class="fas fa-vault text-lg"></i>
        </div>
        <p class="text-xs font-semibold text-slate-500 mb-1">رصيد الصندوق الرئيسي</p>
        <p class="text-[0.65rem] text-slate-400 mb-1">(محاسبي)</p>
        <p class="font-mono text-lg sm:text-xl font-bold tabular-nums text-slate-900" id="cashBalance">0.00</p>
        <p class="text-[0.65rem] text-slate-400 mt-1.5 leading-snug min-h-[1.25rem]" id="cashBalanceSub"></p>
      </div>

      <a href="/deferred-balance" id="deferredBalanceLink" class="group rounded-2xl border border-slate-200/90 bg-white p-4 sm:p-5 shadow-sm transition hover:border-sky-200 hover:shadow-md">
        <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-sky-50 text-sky-600 mb-3 transition group-hover:bg-sky-600 group-hover:text-white">
          <i class="fas fa-clock-rotate-left text-lg"></i>
        </div>
        <p class="text-xs font-semibold text-slate-500 mb-1">رصيد المؤجل</p>
        <p class="font-mono text-lg sm:text-xl font-bold tabular-nums text-slate-900" id="deferredBalance">0.00</p>
      </a>

      <div class="rounded-2xl border border-slate-200/90 bg-white p-4 sm:p-5 shadow-sm">
        <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-violet-50 text-violet-600 mb-3">
          <i class="fas fa-truck-fast text-lg"></i>
        </div>
        <p class="text-xs font-semibold text-slate-500 mb-1">رصيد الشحن (كمية)</p>
        <p class="font-mono text-lg sm:text-xl font-bold tabular-nums text-slate-900" id="shippingBalance">0.00</p>
      </div>
    </div>
  </section>

  <!-- حالة الربط + معلومات -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <div class="rounded-2xl border border-slate-200/90 bg-white p-5 shadow-sm flex flex-col sm:flex-row sm:items-center gap-4">
      <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-emerald-50 text-emerald-600 text-2xl">
        <i class="fas fa-table"></i>
      </div>
      <div class="flex-1 min-w-0">
        <h4 class="font-bold text-slate-900 mb-1">Google Sheets</h4>
        <span class="inline-flex text-xs font-semibold py-1 px-3 rounded-full bg-red-50 text-red-500" id="homeSheetsStatus">جاري التحقق...</span>
      </div>
      <a href="/settings" class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-slate-200 text-slate-500 transition hover:border-indigo-300 hover:bg-indigo-50 hover:text-indigo-700" aria-label="الإعدادات">
        <i class="fas fa-arrow-left"></i>
      </a>
    </div>

    <div class="rounded-2xl border border-slate-200/90 bg-white shadow-sm overflow-hidden">
      <div class="flex items-center gap-2 border-b border-slate-100 bg-slate-50/80 px-5 py-3.5">
        <i class="fas fa-info-circle text-indigo-600"></i>
        <h3 class="text-sm font-bold text-slate-800">معلومات النظام</h3>
      </div>
      <dl class="divide-y divide-slate-100 text-sm">
        <div class="flex items-center justify-between gap-4 px-5 py-3">
          <dt class="text-slate-500">إصدار النظام</dt>
          <dd class="font-semibold text-slate-900 tabular-nums">1.0.0</dd>
        </div>
        <div class="flex items-center justify-between gap-4 px-5 py-3">
          <dt class="text-slate-500">اسم المستخدم</dt>
          <dd class="font-semibold text-slate-800 truncate max-w-[55%] text-left" dir="ltr"><%= user.username %></dd>
        </div>
        <div class="flex items-center justify-between gap-4 px-5 py-3">
          <dt class="text-slate-500">الصلاحية</dt>
          <dd class="font-semibold text-slate-800"><%= user.role === 'admin' ? 'مدير النظام' : 'مستخدم' %></dd>
        </div>
      </dl>
    </div>
  </div>
</div>

<!-- نافذة مصادر الصناديق -->
<div id="homeFundModal" class="fixed inset-0 z-[3000] hidden items-center justify-center p-4 bg-slate-900/50 backdrop-blur-[2px]">
  <div class="bg-white rounded-2xl max-w-lg w-full max-h-[85vh] overflow-hidden shadow-2xl border border-slate-200/80 flex flex-col">
    <div class="flex justify-between items-center gap-3 px-6 py-4 border-b border-slate-100 bg-slate-50/80">
      <h4 class="text-lg font-bold text-slate-900">مصادر الأموال والصناديق</h4>
      <button type="button" onclick="homeCloseFundModal()" class="flex h-9 w-9 items-center justify-center rounded-lg text-slate-400 hover:bg-slate-200 hover:text-slate-700 transition" aria-label="إغلاق">
        <i class="fas fa-times text-lg"></i>
      </button>
    </div>
    <div id="homeFundModalBody" class="text-sm text-slate-600 space-y-3 p-6 overflow-y-auto"></div>
  </div>
</div>
