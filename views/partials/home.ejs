<div class="max-w-7xl mx-auto px-4 lg:px-6 pb-12" dir="rtl" id="homeDashboardRoot">
  <!-- Page Header -->
  <div class="mb-8">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold mb-1" style="color: #1e293b;">لوحة التحكم</h1>
        <p class="text-sm" style="color: #64748b;">نظرة عامة على الأداء المالي والعمليات</p>
      </div>
      
      <!-- Controls -->
      <div class="flex flex-wrap items-center gap-3">
        <!-- Cycle Selector -->
        <div class="flex items-center gap-2 bg-white rounded-xl border border-slate-200 px-3 py-2 shadow-sm">
          <i class="fas fa-calendar-alt text-[#1e3a5f] text-sm"></i>
          <select id="homeCycleSelect" class="text-sm bg-transparent border-none focus:outline-none text-slate-700 min-w-[120px]" onchange="homeLoadStats()">
            <option value="">— الدورة المالية —</option>
          </select>
          <button type="button" onclick="homeLoadStats()" class="w-8 h-8 flex items-center justify-center rounded-lg bg-[#1e3a5f] text-white hover:bg-[#2d5a87] transition-all" title="تحديث">
            <i class="fas fa-sync-alt text-xs"></i>
          </button>
        </div>
        
        <!-- PDF Report -->
        <div class="flex items-center gap-2 bg-white rounded-xl border border-slate-200 px-3 py-2 shadow-sm">
          <i class="fas fa-file-pdf text-red-500 text-sm"></i>
          <select id="homeReportType" class="text-sm bg-transparent border-none focus:outline-none text-slate-700 min-w-[100px]">
            <option value="comprehensive">تقرير شامل</option>
            <option value="accreditations">اعتمادات</option>
            <option value="transfer-companies">تحويل</option>
            <option value="movements">حركات</option>
          </select>
          <button type="button" onclick="homeDownloadReportPdf()" class="w-8 h-8 flex items-center justify-center rounded-lg bg-red-500 text-white hover:bg-red-600 transition-all" title="تنزيل PDF">
            <i class="fas fa-download text-xs"></i>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Financial Overview Section -->
  <section class="mb-8">
    <div class="flex items-center gap-3 mb-5">
      <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: rgba(30, 58, 95, 0.1);">
        <i class="fas fa-chart-pie" style="color: #1e3a5f;"></i>
      </div>
      <h2 class="text-lg font-bold" style="color: #1e293b;">المؤشرات المالية</h2>
    </div>
    
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      <!-- Net Profit -->
      <a href="/profit-sources" class="group rounded-2xl p-5 shadow-sm hover:shadow-lg transition-all duration-200" style="background: #ffffff; border: 1px solid #e2e8f0;">
        <div class="flex items-start justify-between mb-4">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center transition-all" style="background: rgba(5, 150, 105, 0.1); color: #059669;">
            <i class="fas fa-coins text-xl"></i>
          </div>
          <span class="text-xs font-medium px-2 py-1 rounded-full" style="background: rgba(5, 150, 105, 0.1); color: #059669;">
            <i class="fas fa-arrow-up text-[10px] mr-1"></i>
            ربح
          </span>
        </div>
        <p class="text-xs font-medium mb-1" style="color: #64748b;">الربح الصافي</p>
        <p class="text-2xl font-bold" style="color: #1e293b;" id="netProfit">0.00</p>
      </a>

      <!-- Expenses -->
      <a href="/expenses-manual" class="group rounded-2xl p-5 shadow-sm hover:shadow-lg transition-all duration-200" style="background: #ffffff; border: 1px solid #e2e8f0;">
        <div class="flex items-start justify-between mb-4">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center transition-all" style="background: rgba(220, 38, 38, 0.08); color: #dc2626;">
            <i class="fas fa-receipt text-xl"></i>
          </div>
          <span class="text-xs font-medium px-2 py-1 rounded-full" style="background: rgba(220, 38, 38, 0.08); color: #dc2626;">مصاريف</span>
        </div>
        <p class="text-xs font-medium mb-1" style="color: #64748b;">المصاريف (مجمّع)</p>
        <p class="text-2xl font-bold" style="color: #1e293b;" id="totalExpenses">0.00</p>
      </a>

      <!-- Debts -->
      <a href="/debts" class="group rounded-2xl p-5 shadow-sm hover:shadow-lg transition-all duration-200" style="background: #ffffff; border: 1px solid #e2e8f0;" id="homeCardDebt">
        <div class="flex items-start justify-between mb-4">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center transition-all" style="background: rgba(194, 65, 12, 0.08); color: #c2410c;">
            <i class="fas fa-file-invoice-dollar text-xl"></i>
          </div>
          <span class="text-xs font-medium px-2 py-1 rounded-full" style="background: rgba(194, 65, 12, 0.08); color: #c2410c;">ديون</span>
        </div>
        <p class="text-xs font-medium mb-1" style="color: #64748b;">إجمالي الديون</p>
        <p class="text-2xl font-bold" style="color: #1e293b;" id="totalDebts">0.00</p>
      </a>

      <!-- Receivables -->
      <a href="/receivables-to-us" class="group rounded-2xl p-5 shadow-sm hover:shadow-lg transition-all duration-200" style="background: #ffffff; border: 1px solid #e2e8f0;">
        <div class="flex items-start justify-between mb-4">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center transition-all" style="background: rgba(30, 58, 95, 0.08); color: #1e3a5f;">
            <i class="fas fa-hand-holding-usd text-xl"></i>
          </div>
          <span class="text-xs font-medium px-2 py-1 rounded-full" style="background: rgba(30, 58, 95, 0.08); color: #1e3a5f;">مستحقات</span>
        </div>
        <p class="text-xs font-medium mb-1" style="color: #64748b;">ديين لنا</p>
        <p class="text-2xl font-bold" style="color: #1e293b;" id="receivablesToUsHome">—</p>
      </a>
    </div>
  </section>

  <!-- Liquidity Section -->
  <section class="mb-8">
    <div class="flex items-center gap-3 mb-5">
      <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: rgba(201, 162, 39, 0.1);">
        <i class="fas fa-wallet" style="color: #c9a227;"></i>
      </div>
      <h2 class="text-lg font-bold" style="color: #1e293b;">السيولة والمستحقات</h2>
    </div>
    
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      <!-- Payment Due -->
      <a href="/payment-due" class="group rounded-2xl p-5 shadow-sm hover:shadow-lg transition-all duration-200" style="background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); border: 1px solid #fcd34d;">
        <div class="flex items-start justify-between mb-4">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center transition-all" style="background: rgba(217, 119, 6, 0.15); color: #d97706;">
            <i class="fas fa-money-bill-wave text-xl"></i>
          </div>
        </div>
        <p class="text-xs font-medium mb-1" style="color: #92400e;">مطلوب دفع</p>
        <p class="text-2xl font-bold" style="color: #78350f;" id="paymentDueHome">—</p>
      </a>

      <!-- Cash Balance -->
      <div class="group rounded-2xl p-5 shadow-sm hover:shadow-lg transition-all duration-200 cursor-pointer" style="background: #ffffff; border: 1px solid #e2e8f0;" id="homeCardCash" onclick="homeOpenFundModal()">
        <div class="flex items-start justify-between mb-4">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center transition-all" style="background: rgba(201, 162, 39, 0.1); color: #c9a227;">
            <i class="fas fa-vault text-xl"></i>
          </div>
          <i class="fas fa-external-link-alt text-xs" style="color: #94a3b8;"></i>
        </div>
        <p class="text-xs font-medium mb-0.5" style="color: #64748b;">رصيد الصندوق الرئيسي</p>
        <p class="text-[10px] mb-1" style="color: #94a3b8;">(محاسبي)</p>
        <p class="text-2xl font-bold" style="color: #1e293b;" id="cashBalance">0.00</p>
      </div>

      <!-- Deferred Balance -->
      <a href="/deferred-balance" id="deferredBalanceLink" class="group rounded-2xl p-5 shadow-sm hover:shadow-lg transition-all duration-200" style="background: #ffffff; border: 1px solid #e2e8f0;">
        <div class="flex items-start justify-between mb-4">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center transition-all" style="background: rgba(2, 132, 199, 0.08); color: #0284c7;">
            <i class="fas fa-clock-rotate-left text-xl"></i>
          </div>
        </div>
        <p class="text-xs font-medium mb-1" style="color: #64748b;">رصيد المؤجل</p>
        <p class="text-2xl font-bold" style="color: #1e293b;" id="deferredBalance">0.00</p>
      </a>

      <!-- Shipping Balance -->
      <div class="rounded-2xl p-5 shadow-sm" style="background: #ffffff; border: 1px solid #e2e8f0;">
        <div class="flex items-start justify-between mb-4">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background: rgba(124, 58, 237, 0.08); color: #7c3aed;">
            <i class="fas fa-truck-fast text-xl"></i>
          </div>
        </div>
        <p class="text-xs font-medium mb-1" style="color: #64748b;">رصيد الشحن (كمية)</p>
        <p class="text-2xl font-bold" style="color: #1e293b;" id="shippingBalance">0.00</p>
      </div>
    </div>
  </section>

  <!-- Google Sheets Status -->
  <div class="flex justify-center md:justify-end">
    <div class="inline-flex items-center gap-3 bg-white rounded-xl border border-slate-200 px-4 py-3 shadow-sm">
      <div class="flex items-center gap-2 text-sm text-slate-600">
        <i class="fab fa-google-drive text-emerald-600"></i>
        <span>Google Sheets</span>
      </div>
      <div class="w-px h-5 bg-slate-200"></div>
      <span id="homeSheetsStatus" class="text-xs font-semibold px-3 py-1 rounded-full bg-slate-100 text-slate-500">جاري التحقق...</span>
      <a href="/settings" class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:bg-slate-100 hover:text-[#1e3a5f] transition-all" title="الإعدادات">
        <i class="fas fa-cog text-sm"></i>
      </a>
    </div>
  </div>
</div>

<!-- Fund Sources Modal -->
<div id="homeFundModal" class="fixed inset-0 z-[3000] hidden items-center justify-center p-4 bg-slate-900/50 backdrop-blur-sm">
  <div class="bg-white rounded-2xl max-w-lg w-full max-h-[85vh] overflow-hidden shadow-2xl border border-slate-200 flex flex-col">
    <div class="flex justify-between items-center gap-3 px-6 py-5 border-b border-slate-100 bg-gradient-to-br from-slate-50 to-white">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-[#c9a227]/10 flex items-center justify-center">
          <i class="fas fa-vault text-[#c9a227]"></i>
        </div>
        <h4 class="text-lg font-bold text-slate-900">مصادر الأموال والصناديق</h4>
      </div>
      <button type="button" onclick="homeCloseFundModal()" class="w-10 h-10 flex items-center justify-center rounded-xl text-slate-400 hover:bg-slate-100 hover:text-slate-700 transition-all" aria-label="إغلاق">
        <i class="fas fa-times text-lg"></i>
      </button>
    </div>
    <div id="homeFundModalBody" class="text-sm text-slate-600 space-y-3 p-6 overflow-y-auto"></div>
  </div>
</div>
