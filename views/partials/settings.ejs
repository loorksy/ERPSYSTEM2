<div class="max-w-5xl">
  <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
    <div class="flex items-center gap-3 py-5 px-6 border-b border-slate-100">
      <i class="fas fa-cog text-xl text-indigo-600"></i>
      <h3 class="text-lg font-bold">الإعدادات</h3>
    </div>
    <div class="p-6 md:p-10">
      <!-- Tabs -->
      <div class="flex gap-2 mb-6 flex-wrap">
        <button onclick="switchTab(this, 'settings-profile')" class="tab-btn px-5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-300 bg-indigo-600 text-white shadow-md">الملف الشخصي</button>
        <button onclick="switchTab(this, 'settings-ai')" class="tab-btn px-5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-300 bg-slate-100 text-slate-600 hover:bg-slate-200">الذكاء الاصطناعي</button>
        <button onclick="switchTab(this, 'settings-whatsapp')" class="tab-btn px-5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-300 bg-slate-100 text-slate-600 hover:bg-slate-200">واتساب</button>
        <button onclick="switchTab(this, 'settings-sheets')" class="tab-btn px-5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-300 bg-slate-100 text-slate-600 hover:bg-slate-200">Google Sheets</button>
      </div>

      <!-- Profile Tab -->
      <div id="settings-profile" class="tab-content">
        <div class="space-y-8">
          <!-- Profile Form -->
          <div>
            <h4 class="text-base font-bold text-slate-800 mb-4 flex items-center gap-2"><i class="fas fa-user-circle text-indigo-600"></i> الملف الشخصي</h4>
            <form id="profileForm" onsubmit="updateProfile(event)">
              <div class="mb-5">
                <label for="displayName" class="block mb-2 font-semibold text-sm text-slate-800">الاسم المعروض</label>
                <input type="text" id="displayName" name="displayName"
                  class="w-full py-3 px-4 border-2 border-slate-200 rounded-xl text-[0.95rem] bg-slate-50 text-slate-800 transition-all duration-300 focus:outline-none focus:border-indigo-600 focus:bg-white focus:ring-2 focus:ring-indigo-600/10 placeholder:text-slate-400"
                  value="<%= user.displayName %>" required>
              </div>
              <button type="submit" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-semibold text-[0.95rem] transition-all duration-300 cursor-pointer whitespace-nowrap active:scale-[0.97] bg-indigo-600 text-white hover:bg-indigo-700 hover:shadow-[0_4px_12px_rgba(79,70,229,0.4)]">
                <i class="fas fa-save"></i>
                <span>حفظ التغييرات</span>
              </button>
            </form>
          </div>

          <hr class="border-slate-100">

          <!-- Password Form -->
          <div>
            <h4 class="text-base font-bold text-slate-800 mb-4 flex items-center gap-2"><i class="fas fa-key text-indigo-600"></i> تغيير كلمة المرور</h4>
            <form id="passwordForm" onsubmit="changePassword(event)">
              <div class="mb-5">
                <label for="currentPassword" class="block mb-2 font-semibold text-sm text-slate-800">كلمة المرور الحالية</label>
                <input type="password" id="currentPassword" name="currentPassword"
                  class="w-full py-3 px-4 border-2 border-slate-200 rounded-xl text-[0.95rem] bg-slate-50 text-slate-800 transition-all duration-300 focus:outline-none focus:border-indigo-600 focus:bg-white focus:ring-2 focus:ring-indigo-600/10 placeholder:text-slate-400"
                  required>
              </div>
              <div class="mb-5">
                <label for="newPassword" class="block mb-2 font-semibold text-sm text-slate-800">كلمة المرور الجديدة</label>
                <input type="password" id="newPassword" name="newPassword"
                  class="w-full py-3 px-4 border-2 border-slate-200 rounded-xl text-[0.95rem] bg-slate-50 text-slate-800 transition-all duration-300 focus:outline-none focus:border-indigo-600 focus:bg-white focus:ring-2 focus:ring-indigo-600/10 placeholder:text-slate-400"
                  required minlength="6">
              </div>
              <div class="mb-5">
                <label for="confirmPassword" class="block mb-2 font-semibold text-sm text-slate-800">تأكيد كلمة المرور</label>
                <input type="password" id="confirmPassword" name="confirmPassword"
                  class="w-full py-3 px-4 border-2 border-slate-200 rounded-xl text-[0.95rem] bg-slate-50 text-slate-800 transition-all duration-300 focus:outline-none focus:border-indigo-600 focus:bg-white focus:ring-2 focus:ring-indigo-600/10 placeholder:text-slate-400"
                  required minlength="6">
              </div>
              <button type="submit" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-semibold text-[0.95rem] transition-all duration-300 cursor-pointer whitespace-nowrap active:scale-[0.97] bg-indigo-600 text-white hover:bg-indigo-700 hover:shadow-[0_4px_12px_rgba(79,70,229,0.4)]">
                <i class="fas fa-lock"></i>
                <span>تغيير كلمة المرور</span>
              </button>
            </form>
          </div>
        </div>
      </div>

      <!-- AI Tab -->
      <div id="settings-ai" class="tab-content hidden">
        <div class="space-y-8">
          <!-- OpenAI -->
          <div class="p-5 bg-slate-50 rounded-xl border border-slate-200">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center shrink-0">
                <i class="fas fa-robot text-emerald-600"></i>
              </div>
              <div>
                <h4 class="font-bold text-slate-800">OpenAI</h4>
                <p class="text-xs text-slate-500">GPT-4o, GPT-4, GPT-3.5</p>
              </div>
              <span class="mr-auto text-xs font-medium py-1 px-3 rounded-full" id="openaiStatusBadge"></span>
            </div>
            <div class="flex gap-3 max-md:flex-col">
              <input type="password" id="openaiKey" placeholder="sk-..." dir="ltr"
                class="flex-1 py-3 px-4 border-2 border-slate-200 rounded-xl text-sm bg-white text-slate-800 transition-all duration-300 focus:outline-none focus:border-indigo-600 focus:ring-2 focus:ring-indigo-600/10 placeholder:text-slate-400">
              <button onclick="saveAIKey('openai')" class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl font-semibold text-sm transition-all duration-300 cursor-pointer active:scale-[0.97] bg-indigo-600 text-white hover:bg-indigo-700 whitespace-nowrap">
                <i class="fas fa-save"></i> حفظ
              </button>
            </div>
            <div class="mt-4 hidden" id="openaiModelsSection">
              <label class="block mb-2 font-semibold text-xs text-slate-600">اختر الموديل:</label>
              <div class="flex gap-3 max-md:flex-col">
                <select id="openaiModelSelect" onchange="selectModel('openai', this.value)"
                  class="flex-1 py-3 px-4 border-2 border-slate-200 rounded-xl text-sm bg-white text-slate-800 focus:outline-none focus:border-indigo-600">
                </select>
                <button onclick="refreshModels('openai')" class="inline-flex items-center justify-center gap-2 px-4 py-3 rounded-xl font-semibold text-sm transition-all duration-300 cursor-pointer active:scale-[0.97] bg-slate-200 text-slate-700 hover:bg-slate-300 whitespace-nowrap">
                  <i class="fas fa-sync-alt"></i> تحديث
                </button>
              </div>
            </div>
          </div>

          <!-- Gemini -->
          <div class="p-5 bg-slate-50 rounded-xl border border-slate-200">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-xl bg-blue-500/10 flex items-center justify-center shrink-0">
                <i class="fas fa-brain text-blue-600"></i>
              </div>
              <div>
                <h4 class="font-bold text-slate-800">Google Gemini</h4>
                <p class="text-xs text-slate-500">Gemini Pro, Gemini Flash</p>
              </div>
              <span class="mr-auto text-xs font-medium py-1 px-3 rounded-full" id="geminiStatusBadge"></span>
            </div>
            <div class="flex gap-3 max-md:flex-col">
              <input type="password" id="geminiKey" placeholder="AIza..." dir="ltr"
                class="flex-1 py-3 px-4 border-2 border-slate-200 rounded-xl text-sm bg-white text-slate-800 transition-all duration-300 focus:outline-none focus:border-indigo-600 focus:ring-2 focus:ring-indigo-600/10 placeholder:text-slate-400">
              <button onclick="saveAIKey('gemini')" class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl font-semibold text-sm transition-all duration-300 cursor-pointer active:scale-[0.97] bg-indigo-600 text-white hover:bg-indigo-700 whitespace-nowrap">
                <i class="fas fa-save"></i> حفظ
              </button>
            </div>
            <div class="mt-4 hidden" id="geminiModelsSection">
              <label class="block mb-2 font-semibold text-xs text-slate-600">اختر الموديل:</label>
              <div class="flex gap-3 max-md:flex-col">
                <select id="geminiModelSelect" onchange="selectModel('gemini', this.value)"
                  class="flex-1 py-3 px-4 border-2 border-slate-200 rounded-xl text-sm bg-white text-slate-800 focus:outline-none focus:border-indigo-600">
                </select>
                <button onclick="refreshModels('gemini')" class="inline-flex items-center justify-center gap-2 px-4 py-3 rounded-xl font-semibold text-sm transition-all duration-300 cursor-pointer active:scale-[0.97] bg-slate-200 text-slate-700 hover:bg-slate-300 whitespace-nowrap">
                  <i class="fas fa-sync-alt"></i> تحديث
                </button>
              </div>
            </div>
          </div>

          <div class="p-4 bg-amber-50 border border-amber-200 rounded-xl">
            <p class="text-sm text-amber-700"><i class="fas fa-shield-halved ml-1"></i> مفاتيح API تُحفظ مشفّرة بالكامل على الخادم ولا يمكن قراءتها أو تسريبها.</p>
          </div>
        </div>
      </div>

      <!-- WhatsApp Tab -->
      <div id="settings-whatsapp" class="tab-content hidden">
        <div class="flex flex-col items-center justify-center py-16 text-slate-400">
          <i class="fab fa-whatsapp text-5xl mb-4 opacity-40"></i>
          <p class="text-lg font-medium">إعدادات واتساب</p>
          <p class="text-sm mt-2">سيتم بناء هذا القسم قريباً</p>
        </div>
      </div>

      <!-- Google Sheets Tab -->
      <div id="settings-sheets" class="tab-content hidden">
        <div class="flex flex-col items-center justify-center py-16 text-slate-400">
          <i class="fas fa-table text-5xl mb-4 opacity-40"></i>
          <p class="text-lg font-medium">إعدادات Google Sheets</p>
          <p class="text-sm mt-2">سيتم بناء هذا القسم قريباً</p>
        </div>
      </div>
    </div>
  </div>
</div>
