<style>
  /* نافذة حذف البيانات — نفس منطق نافذة تسليم الاعتمادات */
  #resetDataModal {
    overscroll-behavior: contain;
    padding-top: max(0.75rem, env(safe-area-inset-top, 0px));
    padding-bottom: max(0.75rem, env(safe-area-inset-bottom, 0px));
    isolation: isolate;
  }
  .reset-data-modal-shell {
    max-height: min(92vh, calc(100vh - 1.25rem - env(safe-area-inset-top, 0px) - env(safe-area-inset-bottom, 0px)));
    max-width: min(100%, 28rem);
  }
  @supports (height: 100dvh) {
    .reset-data-modal-shell {
      max-height: min(92dvh, calc(100dvh - 1.25rem - env(safe-area-inset-top, 0px) - env(safe-area-inset-bottom, 0px)));
    }
  }
  #resetDataModalBody {
    -webkit-overflow-scrolling: touch;
    touch-action: pan-y;
    overscroll-behavior: contain;
  }
  @media (max-width: 1023px) {
    #resetDataModal {
      top: calc(60px + env(safe-area-inset-top, 0px));
      right: 0;
      bottom: calc(65px + env(safe-area-inset-bottom, 0px));
      left: 0;
      width: 100%;
      height: auto;
      max-height: none;
      align-items: stretch;
      justify-content: flex-start;
      padding: 0.5rem;
      padding-left: max(0.5rem, env(safe-area-inset-left, 0px));
      padding-right: max(0.5rem, env(safe-area-inset-right, 0px));
      box-sizing: border-box;
    }
    #resetDataModal .reset-data-modal-shell {
      width: 100%;
      max-width: 100% !important;
      margin-left: 0 !important;
      margin-right: 0 !important;
      min-height: 0 !important;
      max-height: 100% !important;
      flex: 1 1 auto;
      border-radius: 1rem;
    }
  }
  @media (max-width: 639px) {
    #resetDataCategories .reset-cat-row {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0.75rem;
      position: relative;
      padding-top: 2.25rem;
    }
    #resetDataCategories .reset-cat-row .reset-cat-cb {
      position: absolute;
      top: 0.75rem;
      right: 0.75rem;
    }
    #resetDataCategories .reset-cat-row > span.flex-1 {
      width: 100%;
    }
  }
</style>
<div class="max-w-5xl">
  <div id="settingsCard" class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden flex flex-col min-w-0" data-tabs-container="settings">
    <header class="shrink-0 flex items-center gap-3 py-5 px-4 sm:px-6 border-b border-slate-100 bg-white">
      <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-indigo-600 text-white shadow-md">
        <i class="fas fa-cog text-xl"></i>
      </div>
      <div class="min-w-0">
        <h3 class="text-lg font-bold text-slate-900 truncate">الإعدادات</h3>
        <p class="mt-0.5 text-sm text-slate-500 leading-snug">العملة، الحساب، الذكاء، وربط Google</p>
      </div>
    </header>

    <div class="shrink-0 border-b border-slate-100 bg-white px-4 py-3 md:px-6 min-w-0">
      <nav id="settingsTabsBar" class="rounded-xl bg-slate-100 p-1 flex flex-nowrap gap-0 shadow-inner touch-manipulation w-full min-w-0 overflow-x-auto" role="tablist" aria-label="أقسام الإعدادات">
        <button type="button" role="tab" class="settings-tab-btn flex flex-1 min-w-0 basis-0 h-11 sm:h-12 flex-row items-center justify-center gap-1 px-1 sm:px-2 rounded-lg text-[0.62rem] sm:text-xs sm:text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors" data-settings-tab="settings-general">
          <i class="fas fa-sliders-h shrink-0 text-[0.9em] sm:text-[0.95em]"></i>
          <span class="leading-tight text-center">عام</span>
        </button>
        <button type="button" role="tab" class="settings-tab-btn flex flex-1 min-w-0 basis-0 h-11 sm:h-12 flex-row items-center justify-center gap-1 px-1 sm:px-2 rounded-lg text-[0.62rem] sm:text-xs sm:text-sm font-semibold text-indigo-700 bg-white shadow-sm ring-1 ring-slate-200/90 transition-colors" data-settings-tab="settings-profile">
          <i class="fas fa-user-circle shrink-0 text-[0.9em] sm:text-[0.95em]"></i>
          <span class="leading-tight text-center line-clamp-2">الملف الشخصي</span>
        </button>
        <button type="button" role="tab" class="settings-tab-btn flex flex-1 min-w-0 basis-0 h-11 sm:h-12 flex-row items-center justify-center gap-1 px-1 sm:px-2 rounded-lg text-[0.62rem] sm:text-xs sm:text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors" data-settings-tab="settings-ai">
          <i class="fas fa-robot shrink-0 text-[0.9em] sm:text-[0.95em]"></i>
          <span class="leading-tight text-center line-clamp-2">الذكاء الاصطناعي</span>
        </button>
        <button type="button" role="tab" class="settings-tab-btn flex flex-1 min-w-0 basis-0 h-11 sm:h-12 flex-row items-center justify-center gap-1 px-1 sm:px-2 rounded-lg text-[0.62rem] sm:text-xs sm:text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors" data-settings-tab="settings-sheets">
          <i class="fas fa-table shrink-0 text-[0.9em] sm:text-[0.95em] text-emerald-600"></i>
          <span class="leading-tight text-center line-clamp-2">Google Sheets</span>
        </button>
      </nav>
    </div>

    <div class="p-6 md:p-10">
      <!-- General Tab -->
      <div id="settings-general" class="settings-tab-panel hidden" data-settings-panel="settings-general">
        <div class="space-y-8">
          <div>
            <h4 class="text-base font-bold text-slate-800 mb-4 flex items-center gap-2"><i class="fas fa-coins text-amber-500"></i> نوع العملة</h4>
            <p class="text-sm text-slate-600 mb-4">يتم عرض جميع المبالغ في النظام بأرقام غربية مع رمز العملة المحدد.</p>
            <form id="currencyForm" onsubmit="saveCurrency(event)">
              <div class="mb-5">
                <label for="currencySelect" class="block mb-2 font-semibold text-sm text-slate-800">العملة</label>
                <select id="currencySelect" name="currency" class="w-full max-w-xs py-3 px-4 border-2 border-slate-200 rounded-xl text-[0.95rem] bg-slate-50 text-slate-800">
                  <% (typeof currencyOptions !== 'undefined' ? currencyOptions : []).forEach(function(opt) { %>
                    <option value="<%= opt.code %>" <%= (typeof currency !== 'undefined' && currency === opt.code) ? 'selected' : '' %>><%= opt.label %></option>
                  <% }); %>
                </select>
              </div>
              <button type="submit" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-semibold text-[0.95rem] transition-all duration-300 cursor-pointer whitespace-nowrap active:scale-[0.97] bg-indigo-600 text-white hover:bg-indigo-700 hover:shadow-[0_4px_12px_rgba(79,70,229,0.4)]">
                <i class="fas fa-save"></i>
                <span>حفظ</span>
              </button>
            </form>
          </div>
        </div>
      </div>

      <!-- Profile Tab -->
      <div id="settings-profile" class="settings-tab-panel" data-settings-panel="settings-profile">
        <div class="space-y-8">
          <!-- Profile Form -->
          <div>
            <h4 class="text-base font-bold text-slate-800 mb-4 flex items-center gap-2"><i class="fas fa-user-circle text-indigo-600"></i> الملف الشخصي</h4>
            <form id="profileForm" onsubmit="updateProfile(event)">
              <div class="mb-5">
                <label for="displayName" class="block mb-2 font-semibold text-sm text-slate-800">الاسم المعروض</label>
                <input type="text" id="displayName" name="displayName"
                  class="w-full py-3 px-4 border-2 border-slate-200 rounded-xl text-[0.95rem] bg-slate-50 text-slate-800 transition-all duration-300 focus:outline-none focus:border-indigo-600 focus:bg-white focus:ring-2 focus:ring-indigo-600/10 placeholder:text-slate-400"
                  value="<%= user.displayName %>" required>
              </div>
              <button type="submit" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-semibold text-[0.95rem] transition-all duration-300 cursor-pointer whitespace-nowrap active:scale-[0.97] bg-indigo-600 text-white hover:bg-indigo-700 hover:shadow-[0_4px_12px_rgba(79,70,229,0.4)]">
                <i class="fas fa-save"></i>
                <span>حفظ التغييرات</span>
              </button>
            </form>
          </div>

          <hr class="border-slate-100">

          <!-- Password Form -->
          <div>
            <h4 class="text-base font-bold text-slate-800 mb-4 flex items-center gap-2"><i class="fas fa-key text-indigo-600"></i> تغيير كلمة المرور</h4>
            <form id="passwordForm" onsubmit="changePassword(event)">
              <div class="mb-5">
                <label for="currentPassword" class="block mb-2 font-semibold text-sm text-slate-800">كلمة المرور الحالية</label>
                <input type="password" id="currentPassword" name="currentPassword"
                  class="w-full py-3 px-4 border-2 border-slate-200 rounded-xl text-[0.95rem] bg-slate-50 text-slate-800 transition-all duration-300 focus:outline-none focus:border-indigo-600 focus:bg-white focus:ring-2 focus:ring-indigo-600/10 placeholder:text-slate-400"
                  required>
              </div>
              <div class="mb-5">
                <label for="newPassword" class="block mb-2 font-semibold text-sm text-slate-800">كلمة المرور الجديدة</label>
                <input type="password" id="newPassword" name="newPassword"
                  class="w-full py-3 px-4 border-2 border-slate-200 rounded-xl text-[0.95rem] bg-slate-50 text-slate-800 transition-all duration-300 focus:outline-none focus:border-indigo-600 focus:bg-white focus:ring-2 focus:ring-indigo-600/10 placeholder:text-slate-400"
                  required minlength="6">
              </div>
              <div class="mb-5">
                <label for="confirmPassword" class="block mb-2 font-semibold text-sm text-slate-800">تأكيد كلمة المرور</label>
                <input type="password" id="confirmPassword" name="confirmPassword"
                  class="w-full py-3 px-4 border-2 border-slate-200 rounded-xl text-[0.95rem] bg-slate-50 text-slate-800 transition-all duration-300 focus:outline-none focus:border-indigo-600 focus:bg-white focus:ring-2 focus:ring-indigo-600/10 placeholder:text-slate-400"
                  required minlength="6">
              </div>
              <button type="submit" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-semibold text-[0.95rem] transition-all duration-300 cursor-pointer whitespace-nowrap active:scale-[0.97] bg-indigo-600 text-white hover:bg-indigo-700 hover:shadow-[0_4px_12px_rgba(79,70,229,0.4)]">
                <i class="fas fa-lock"></i>
                <span>تغيير كلمة المرور</span>
              </button>
            </form>
          </div>

          <hr class="border-slate-100">

          <div class="p-4 rounded-xl border border-red-100 bg-red-50/60">
            <h4 class="text-base font-bold text-red-700 mb-2 flex items-center gap-2">
              <i class="fas fa-triangle-exclamation"></i>
              حذف البيانات من الخادم
            </h4>
            <p class="text-sm text-red-700 mb-3">
              اختر فئات البيانات المراد حذفها من الخادم، أو فعّل «حذف كل شيء» لمسح كل البيانات التشغيلية دفعة واحدة مع <strong>الإبقاء تلقائياً</strong> على ربط Google ومفاتيح الذكاء المخزّنة محلياً (لا تظهر في هذه القائمة).
            </p>
            <button type="button" onclick="openResetDataModal()" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl font-semibold text-sm bg-red-600 text-white hover:bg-red-700 active:scale-[0.97]">
              <i class="fas fa-trash"></i>
              فتح قائمة الحذف والتأكيد
            </button>
          </div>
        </div>
      </div>

      <!-- AI Tab -->
      <div id="settings-ai" class="settings-tab-panel hidden" data-settings-panel="settings-ai">
        <div class="space-y-8">
          <div class="p-5 bg-slate-50 rounded-xl border border-slate-200">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center shrink-0">
                <i class="fas fa-robot text-emerald-600"></i>
              </div>
              <div>
                <h4 class="font-bold text-slate-800">OpenAI</h4>
                <p class="text-xs text-slate-500">GPT-4o, GPT-4, GPT-3.5</p>
              </div>
              <span class="mr-auto text-xs font-medium py-1 px-3 rounded-full" id="openaiStatusBadge"></span>
            </div>
            <div class="flex gap-3 max-md:flex-col">
              <input type="password" id="openaiKey" placeholder="sk-..." dir="ltr"
                class="flex-1 py-3 px-4 border-2 border-slate-200 rounded-xl text-sm bg-white text-slate-800 transition-all duration-300 focus:outline-none focus:border-indigo-600 focus:ring-2 focus:ring-indigo-600/10 placeholder:text-slate-400">
              <button type="button" id="openaiSaveBtn" onclick="saveAIKey('openai')" class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl font-semibold text-sm transition-all duration-300 cursor-pointer active:scale-[0.97] bg-indigo-600 text-white hover:bg-indigo-700 whitespace-nowrap">
                <i class="fas fa-save"></i> حفظ
              </button>
            </div>
            <div class="mt-4 hidden" id="openaiModelsSection">
              <label class="block mb-2 font-semibold text-xs text-slate-600">اختر الموديل:</label>
              <div class="flex gap-3 max-md:flex-col">
                <select id="openaiModelSelect" onchange="selectModel('openai', this.value)"
                  class="flex-1 py-3 px-4 border-2 border-slate-200 rounded-xl text-sm bg-white text-slate-800 focus:outline-none focus:border-indigo-600">
                </select>
                <button type="button" onclick="refreshModels('openai')" class="inline-flex items-center justify-center gap-2 px-4 py-3 rounded-xl font-semibold text-sm transition-all duration-300 cursor-pointer active:scale-[0.97] bg-slate-200 text-slate-700 hover:bg-slate-300 whitespace-nowrap">
                  <i class="fas fa-sync-alt"></i> تحديث
                </button>
              </div>
            </div>
          </div>

          <div class="p-5 bg-slate-50 rounded-xl border border-slate-200">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-xl bg-blue-500/10 flex items-center justify-center shrink-0">
                <i class="fas fa-brain text-blue-600"></i>
              </div>
              <div>
                <h4 class="font-bold text-slate-800">Google Gemini</h4>
                <p class="text-xs text-slate-500">Gemini Pro, Gemini Flash</p>
              </div>
              <span class="mr-auto text-xs font-medium py-1 px-3 rounded-full" id="geminiStatusBadge"></span>
            </div>
            <div class="flex gap-3 max-md:flex-col">
              <input type="password" id="geminiKey" placeholder="AIza..." dir="ltr"
                class="flex-1 py-3 px-4 border-2 border-slate-200 rounded-xl text-sm bg-white text-slate-800 transition-all duration-300 focus:outline-none focus:border-indigo-600 focus:ring-2 focus:ring-indigo-600/10 placeholder:text-slate-400">
              <button type="button" id="geminiSaveBtn" onclick="saveAIKey('gemini')" class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl font-semibold text-sm transition-all duration-300 cursor-pointer active:scale-[0.97] bg-indigo-600 text-white hover:bg-indigo-700 whitespace-nowrap">
                <i class="fas fa-save"></i> حفظ
              </button>
            </div>
            <div class="mt-4 hidden" id="geminiModelsSection">
              <label class="block mb-2 font-semibold text-xs text-slate-600">اختر الموديل:</label>
              <div class="flex gap-3 max-md:flex-col">
                <select id="geminiModelSelect" onchange="selectModel('gemini', this.value)"
                  class="flex-1 py-3 px-4 border-2 border-slate-200 rounded-xl text-sm bg-white text-slate-800 focus:outline-none focus:border-indigo-600">
                </select>
                <button type="button" onclick="refreshModels('gemini')" class="inline-flex items-center justify-center gap-2 px-4 py-3 rounded-xl font-semibold text-sm transition-all duration-300 cursor-pointer active:scale-[0.97] bg-slate-200 text-slate-700 hover:bg-slate-300 whitespace-nowrap">
                  <i class="fas fa-sync-alt"></i> تحديث
                </button>
              </div>
            </div>
          </div>

          <div class="p-4 bg-amber-50 border border-amber-200 rounded-xl">
            <p class="text-sm text-amber-700"><i class="fas fa-shield-halved ml-1"></i> مفاتيح API تُحفظ مشفّرة بالكامل على الخادم ولا يمكن قراءتها أو تسريبها.</p>
          </div>
          <div class="p-4 bg-indigo-50 border border-indigo-200 rounded-xl">
            <p class="text-sm text-indigo-700"><i class="fas fa-link ml-1"></i> يتم ربط المفتاح والموديل تلقائياً بأداة <strong>ترتيب الرسائل</strong> — بعد الحفظ يمكنك الذهاب إلى ترتيب الرسائل واستخدام التحليل مباشرة.</p>
          </div>
        </div>
      </div>

      <!-- Google Sheets Tab -->
      <div id="settings-sheets" class="settings-tab-panel hidden" data-settings-panel="settings-sheets">
        <div class="space-y-6">
          <div class="p-5 bg-slate-50 rounded-xl border border-slate-200">
            <h4 class="text-base font-bold text-slate-800 mb-3 flex items-center gap-2"><i class="fas fa-table text-[#0f9d58]"></i> الربط مع Google Sheets</h4>
            <p class="text-sm text-slate-600 mb-4">اربط حسابك بـ Google لتصدير نتائج ترتيب الرسائل مباشرة إلى جدول بيانات. يمكنك إنشاء ورقة جديدة لكل تحليل أو إلحاق النتائج بورقة موجودة.</p>
            <div id="sheetsStatusMessage" class="mb-4 hidden"></div>
            <div id="sheetsAuthBlock">
              <a href="/sheets/auth" id="sheetsGoogleBtn" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-semibold text-[0.95rem] transition-all duration-300 cursor-pointer whitespace-nowrap active:scale-[0.97] bg-white border-2 border-slate-200 text-slate-700 hover:bg-slate-50 hover:border-slate-300">
                <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                <span>تسجيل الدخول باستخدام Google</span>
              </a>
              <p id="sheetsNoEnvHint" class="mt-3 text-xs text-amber-600 hidden">أضف GOOGLE_CLIENT_ID و GOOGLE_CLIENT_SECRET في ملف .env ثم أعد تحميل الصفحة.</p>
            </div>
            <div id="sheetsAfterConnect" class="hidden">
              <p class="text-sm text-emerald-600 font-medium mb-3"><i class="fas fa-check-circle ml-1"></i> متصل بحساب Google</p>
              <div class="mb-4">
                <label for="sheetsSpreadsheetId" class="block mb-2 font-semibold text-sm text-slate-800">معرّف جدول البيانات (Spreadsheet ID)</label>
                <input type="text" id="sheetsSpreadsheetId" dir="ltr" placeholder="من رابط الجدول بعد /d/"
                  class="w-full py-3 px-4 border-2 border-slate-200 rounded-xl text-sm bg-white text-slate-800 focus:outline-none focus:border-indigo-600 focus:ring-2 focus:ring-indigo-600/10">
                <small class="block mt-1 text-xs text-slate-500">يمكنك إيجاده في رابط الجدول بعد /d/ وقبل /edit</small>
              </div>
              <div class="flex flex-wrap gap-2">
                <button type="button" id="sheetsSaveSpreadsheetBtn" onclick="saveSheetsSpreadsheet()" class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl font-semibold text-sm transition-all duration-300 cursor-pointer active:scale-[0.97] bg-indigo-600 text-white hover:bg-indigo-700">
                  <i class="fas fa-save"></i> حفظ الجدول المختار
                </button>
                <button type="button" id="sheetsDisconnectBtn" onclick="disconnectSheets()" class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl font-semibold text-sm transition-all duration-300 cursor-pointer active:scale-[0.97] bg-slate-200 text-slate-700 hover:bg-slate-300">
                  <i class="fas fa-unlink"></i> قطع الاتصال
                </button>
              </div>
              <p class="mt-2 text-xs text-slate-500">قطع الاتصال يسمح لك بإعادة تسجيل الدخول بحساب آخر أو بتحديث الصلاحيات.</p>
            </div>
          </div>
          <div class="p-4 bg-indigo-50 border border-indigo-200 rounded-xl">
            <p class="text-sm text-indigo-700"><i class="fas fa-link ml-1"></i> بعد الربط واختيار جدول البيانات، ستظهر في صفحة <strong>ترتيب الرسائل</strong> زر «تصدير إلى Google Sheets» عند كل تحليل ناجح — يمكنك إنشاء ورقة جديدة باسم تختاره أو إلحاق النتائج بورقة موجودة.</p>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Modal: حذف البيانات — نفس نمط نافذة «تسليم» في الاعتمادات -->
  <div id="resetDataModal" class="fixed inset-0 z-[10050] hidden items-center justify-center p-4 sm:p-6 md:p-8 max-lg:p-2 max-lg:items-stretch max-lg:justify-start bg-slate-900/60 backdrop-blur-sm transition-opacity" dir="rtl" role="dialog" aria-modal="true" aria-labelledby="resetDataModalTitle">
    <div class="reset-data-modal-shell bg-white rounded-2xl sm:rounded-[2rem] max-lg:rounded-xl shadow-2xl w-full flex flex-col min-h-0 overflow-hidden mx-auto">
      <div class="px-5 py-4 border-b border-slate-100 flex justify-between items-start sm:items-center bg-white/80 backdrop-blur-md z-10 shrink-0">
        <div class="flex items-center gap-3 min-w-0">
          <div class="h-10 w-10 flex items-center justify-center rounded-xl bg-red-50 text-red-600 shrink-0 border border-red-100">
            <i class="fas fa-trash-alt text-lg"></i>
          </div>
          <div class="min-w-0">
            <h3 id="resetDataModalTitle" class="text-base sm:text-lg font-bold text-slate-800 leading-tight">حذف البيانات من الخادم</h3>
            <p class="text-xs text-slate-500 mt-0.5 leading-relaxed">اختر الفئات أو «حذف كل شيء»، ثم أكّد بعبارة الحذف</p>
          </div>
        </div>
        <button type="button" onclick="closeResetDataModal()" class="text-slate-400 hover:text-slate-600 hover:bg-slate-100 p-2 rounded-xl transition-colors shrink-0" aria-label="إغلاق"><i class="fas fa-times text-lg"></i></button>
      </div>

      <div id="resetDataModalBody" class="p-4 sm:p-6 overflow-y-auto flex-1 min-h-0 overscroll-contain bg-slate-50/30">
        <div class="bg-white border border-slate-200 rounded-2xl p-4 sm:p-5 shadow-sm mb-4">
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" id="resetWipeAll" class="mt-1 rounded border-slate-300 text-red-600 focus:ring-red-500" onchange="onResetWipeAllChange()">
            <span>
              <span class="font-bold text-red-900 block text-sm">حذف كل شيء (البيانات التشغيلية)</span>
              <span class="text-xs text-red-800/90 leading-relaxed mt-1 block">يشمل جميع الفئات أدناه دفعة واحدة، ما عدا ربط Google Sheets والذكاء الاصطناعي (يُحفظان). لحذفهما اختر الفئتين من القائمة يدوياً.</span>
            </span>
          </label>
        </div>

        <div class="flex flex-wrap items-center justify-between gap-3 mb-2 px-1">
          <span class="text-xs font-semibold text-slate-600">فئات البيانات</span>
          <label class="flex items-center gap-2 text-xs font-medium text-slate-600 cursor-pointer select-none">
            <input type="checkbox" id="resetCatSelectAll" class="h-4 w-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" checked>
            <span>تحديد الكل</span>
          </label>
        </div>
        <div id="resetDataCategories" class="space-y-2 rounded-2xl border border-slate-200 bg-white p-3 shadow-sm max-h-[min(42vh,22rem)] sm:max-h-[min(48vh,26rem)] overflow-y-auto">
          <p class="text-slate-500 text-xs py-8 text-center">جاري التحميل…</p>
        </div>

        <div class="bg-white border border-slate-200 rounded-2xl p-4 sm:p-5 shadow-sm mt-4">
          <label for="resetConfirmPhrase" class="block text-xs font-semibold text-slate-600 mb-2 flex items-center gap-2">
            <i class="fas fa-key text-red-500"></i> تأكيد نهائي
          </label>
          <p class="text-xs text-slate-500 mb-2">اكتب بالضبط: <strong dir="ltr">حذف نهائي</strong> أو <strong dir="ltr">DELETE</strong></p>
          <input type="text" id="resetConfirmPhrase" dir="ltr" autocomplete="off"
            class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 text-sm focus:bg-white focus:ring-2 focus:ring-red-500/20 focus:border-red-500 transition-all outline-none"
            placeholder="حذف نهائي">
        </div>
      </div>

      <div class="px-4 sm:px-6 py-4 border-t border-slate-100 bg-white sm:bg-slate-50/50 flex flex-col-reverse sm:flex-row justify-end gap-3 shrink-0">
        <button type="button" onclick="closeResetDataModal()" class="w-full sm:w-auto px-6 py-3 sm:py-2.5 rounded-xl border border-slate-300 text-slate-700 font-bold hover:bg-slate-100 transition-colors text-sm flex items-center justify-center gap-2">إلغاء</button>
        <button type="button" id="resetDataSubmitBtn" onclick="submitResetData()" class="w-full sm:flex-1 px-8 py-3 sm:py-2.5 rounded-xl bg-red-600 text-white font-bold shadow-md shadow-red-200 hover:bg-red-700 hover:shadow-lg hover:-translate-y-0.5 transition-all text-sm flex items-center justify-center gap-2 max-w-md sm:max-w-none"><i class="fas fa-exclamation-triangle"></i> تنفيذ الحذف على الخادم</button>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  var card = document.getElementById('settingsCard');
  if (!card) return;
  var SETTINGS_TAB_BASE =
    'settings-tab-btn flex flex-1 min-w-0 basis-0 h-11 sm:h-12 flex-row items-center justify-center gap-1 px-1 sm:px-2 rounded-lg text-[0.62rem] sm:text-xs sm:text-sm transition-colors touch-manipulation';
  var SETTINGS_TAB_INACTIVE = SETTINGS_TAB_BASE + ' font-medium text-slate-600 hover:text-slate-900';
  var SETTINGS_TAB_ACTIVE =
    SETTINGS_TAB_BASE + ' font-semibold text-indigo-700 bg-white shadow-sm ring-1 ring-slate-200/90';
  function showTab(tabId) {
    var panels = card.querySelectorAll('.settings-tab-panel');
    var targetPanel = card.querySelector('[data-settings-panel="' + tabId + '"]');
    panels.forEach(function(p) {
      p.classList.add('hidden');
      p.style.setProperty('display', 'none');
    });
    if (targetPanel) {
      targetPanel.classList.remove('hidden');
      targetPanel.style.removeProperty('display');
      if (tabId === 'settings-sheets' && typeof loadSheetsStatus === 'function') loadSheetsStatus();
    }
    card.querySelectorAll('.settings-tab-btn').forEach(function(b) {
      b.className = SETTINGS_TAB_INACTIVE;
    });
    var btn = card.querySelector('[data-settings-tab="' + tabId + '"]');
    if (btn) btn.className = SETTINGS_TAB_ACTIVE;
  }
  card.addEventListener('click', function(e) {
    var btn = e.target.closest('.settings-tab-btn');
    if (!btn) return;
    var tabId = btn.getAttribute('data-settings-tab');
    if (!tabId) return;
    showTab(tabId);
  });
  var search = window.location.search || '';
  if (search.indexOf('sheets=') !== -1) {
    showTab('settings-sheets');
    var msg = document.getElementById('sheetsStatusMessage');
    if (msg) {
      msg.classList.remove('hidden');
      if (search.indexOf('sheets=connected') !== -1) {
        msg.className = 'mb-4 p-3 rounded-lg bg-emerald-100 text-emerald-700 text-sm';
        msg.textContent = 'تم الربط بحساب Google بنجاح. اختر جدول البيانات أدناه.';
      } else if (search.indexOf('sheets=no_credentials') !== -1) {
        msg.className = 'mb-4 p-3 rounded-lg bg-amber-100 text-amber-700 text-sm';
        msg.textContent = 'لم يتم إعداد بيانات الاعتماد. أضف GOOGLE_CLIENT_ID و GOOGLE_CLIENT_SECRET في .env';
      } else if (search.indexOf('sheets=callback_failed') !== -1 || search.indexOf('sheets=auth_failed') !== -1) {
        msg.className = 'mb-4 p-3 rounded-lg bg-red-100 text-red-700 text-sm';
        msg.textContent = 'فشل الربط. حاول مرة أخرى.';
      }
    }
    if (window.history && window.history.replaceState) window.history.replaceState({}, '', window.location.pathname);
  }
})();

async function loadSheetsStatus() {
  try {
    var res = await fetch('/sheets/status');
    var data = await res.json();
    if (!data.success) return;
    var authBlock = document.getElementById('sheetsAuthBlock');
    var afterConnect = document.getElementById('sheetsAfterConnect');
    var googleBtn = document.getElementById('sheetsGoogleBtn');
    var noEnv = document.getElementById('sheetsNoEnvHint');
    if (!data.canAuth) {
      if (noEnv) {
        noEnv.classList.remove('hidden');
        noEnv.textContent = 'أضف GOOGLE_CLIENT_ID و GOOGLE_CLIENT_SECRET في ملف .env في مجلد المشروع ثم أعد تشغيل السيرفر (npm run dev).';
      }
      if (googleBtn) googleBtn.style.display = '';
    } else {
      if (noEnv) noEnv.classList.add('hidden');
      if (googleBtn) googleBtn.style.display = '';
    }
    if (data.connected) {
      if (authBlock) authBlock.classList.add('hidden');
      if (afterConnect) {
        afterConnect.classList.remove('hidden');
        var inp = document.getElementById('sheetsSpreadsheetId');
        if (inp && data.spreadsheet_id) inp.value = data.spreadsheet_id;
      }
    } else {
      if (authBlock) authBlock.classList.remove('hidden');
      if (afterConnect) afterConnect.classList.add('hidden');
    }
  } catch (_) {}
}
function saveSheetsSpreadsheet() {
  var inp = document.getElementById('sheetsSpreadsheetId');
  var btn = document.getElementById('sheetsSaveSpreadsheetBtn');
  var id = inp && inp.value ? inp.value.trim() : '';
  if (!id) {
    if (typeof showToast === 'function') showToast('أدخل معرّف جدول البيانات', 'error');
    return;
  }
  if (btn) {
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري الحفظ...';
  }
  fetch('/sheets/save-spreadsheet', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ spreadsheet_id: id }),
  })
    .then(function (r) {
      return r.json();
    })
    .then(function (d) {
      if (btn) {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save"></i> حفظ الجدول المختار';
      }
      if (typeof showToast === 'function')
        showToast(d.message || (d.success ? 'تم الحفظ' : 'فشل'), d.success ? 'success' : 'error');
    })
    .catch(function () {
      if (btn) {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save"></i> حفظ الجدول المختار';
      }
      if (typeof showToast === 'function') showToast('خطأ في الاتصال', 'error');
    });
}
function disconnectSheets() {
  var btn = document.getElementById('sheetsDisconnectBtn');
  if (btn) {
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري...';
  }
  fetch('/sheets/disconnect', { method: 'POST', headers: { 'Content-Type': 'application/json' } })
    .then(function (r) {
      return r.json();
    })
    .then(function (d) {
      if (typeof showToast === 'function')
        showToast(d.message || (d.success ? 'تم قطع الاتصال' : 'فشل'), d.success ? 'success' : 'error');
      if (d.success) loadSheetsStatus();
    })
    .catch(function () {
      if (typeof showToast === 'function') showToast('خطأ في الاتصال', 'error');
    })
    .finally(function () {
      if (btn) {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-unlink"></i> قطع الاتصال';
      }
    });
}

async function saveCurrency(e) {
  e.preventDefault();
  var sel = document.getElementById('currencySelect');
  if (!sel) return;
  var currency = sel.value;
  try {
    var res = await fetch('/settings/currency', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ currency: currency })
    });
    var data = await res.json();
    if (typeof showToast === 'function') showToast(data.message || (data.success ? 'تم حفظ العملة' : 'فشل'), data.success ? 'success' : 'error');
    if (data.success && data.symbol) window.currencySymbol = data.symbol;
  } catch (_) {
    if (typeof showToast === 'function') showToast('خطأ في الاتصال', 'error');
  }
}

var resetDataCategoriesCache = null;

function resetSyncCatSelectAll() {
  var boxes = document.querySelectorAll('#resetDataCategories [data-reset-cat]');
  var sa = document.getElementById('resetCatSelectAll');
  if (!sa) return;
  var wipe = document.getElementById('resetWipeAll');
  if (wipe && wipe.checked) {
    sa.checked = true;
    sa.indeterminate = false;
    sa.disabled = true;
    return;
  }
  if (!boxes.length) {
    sa.checked = false;
    sa.indeterminate = false;
    sa.disabled = true;
    return;
  }
  sa.disabled = false;
  var n = boxes.length;
  var c = document.querySelectorAll('#resetDataCategories [data-reset-cat]:checked').length;
  sa.checked = c === n && n > 0;
  sa.indeterminate = c > 0 && c < n;
}

function wireResetCatSelectAll() {
  var sa = document.getElementById('resetCatSelectAll');
  if (!sa || sa.dataset.resetSaBound) return;
  sa.dataset.resetSaBound = '1';
  sa.addEventListener('change', function () {
    var wipe = document.getElementById('resetWipeAll');
    if (wipe && wipe.checked) return;
    if (sa.disabled) return;
    document.querySelectorAll('#resetDataCategories [data-reset-cat]').forEach(function (cb) {
      cb.checked = sa.checked;
    });
  });
}

function wireResetCategoriesDelegation() {
  var box = document.getElementById('resetDataCategories');
  if (!box || box.dataset.resetDelegBound) return;
  box.dataset.resetDelegBound = '1';
  box.addEventListener('change', function (e) {
    if (!e.target || !e.target.getAttribute || !e.target.getAttribute('data-reset-cat')) return;
    resetSyncCatSelectAll();
  });
}

function renderResetCategories() {
  var box = document.getElementById('resetDataCategories');
  if (!box || !resetDataCategoriesCache) return;
  var wipe = document.getElementById('resetWipeAll');
  var wipeOn = wipe && wipe.checked;
  box.innerHTML = '';
  resetDataCategoriesCache.forEach(function (cat) {
    var id = 'resetCat_' + cat.id;
    var wrap = document.createElement('label');
    wrap.className =
      'reset-cat-row flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 sm:gap-3 p-3 rounded-xl border border-slate-100 bg-white cursor-pointer hover:border-indigo-100 hover:bg-indigo-50/40 transition-colors shadow-sm text-center sm:text-right';
    var cb = document.createElement('input');
    cb.type = 'checkbox';
    cb.id = id;
    cb.setAttribute('data-reset-cat', cat.id);
    cb.className = 'reset-cat-cb h-4 w-4 shrink-0 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500';
    cb.disabled = wipeOn;
    cb.checked = true;
    var span = document.createElement('span');
    span.className = 'flex-1 min-w-0 text-sm text-slate-800';
    var title = document.createElement('span');
    title.className = 'font-bold block';
    title.textContent = cat.label || '';
    var desc = document.createElement('span');
    desc.className = 'text-slate-500 text-xs block mt-1 leading-relaxed';
    desc.textContent = cat.description || '';
    span.appendChild(title);
    span.appendChild(desc);
    wrap.appendChild(cb);
    wrap.appendChild(span);
    box.appendChild(wrap);
  });
  resetSyncCatSelectAll();
}

function onResetWipeAllChange() {
  renderResetCategories();
}

function closeResetDataModal() {
  var modal = document.getElementById('resetDataModal');
  if (modal) {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }
  var phrase = document.getElementById('resetConfirmPhrase');
  if (phrase) phrase.value = '';
}

async function openResetDataModal() {
  var modal = document.getElementById('resetDataModal');
  if (!modal) return;
  modal.classList.remove('hidden');
  modal.classList.add('flex');
  wireResetCatSelectAll();
  wireResetCategoriesDelegation();
  var box = document.getElementById('resetDataCategories');
  resetDataCategoriesCache = null;
  if (box) {
    box.innerHTML = '<p class="py-10 text-center text-sm text-slate-500">جاري التحميل…</p>';
    try {
      var res = await fetch('/settings/reset-data-options', { credentials: 'same-origin' });
      var data = await res.json();
      if (data.success && data.categories) resetDataCategoriesCache = data.categories;
      else box.innerHTML = '<p class="py-10 text-center text-sm text-red-600">تعذر تحميل القائمة.</p>';
    } catch (e) {
      if (box) box.innerHTML = '<p class="py-10 text-center text-sm text-red-600">خطأ في الاتصال.</p>';
      resetSyncCatSelectAll();
      return;
    }
  }
  renderResetCategories();
}

document.addEventListener('click', function (e) {
  var modal = document.getElementById('resetDataModal');
  if (!modal || modal.classList.contains('hidden')) return;
  if (e.target === modal) closeResetDataModal();
});

async function submitResetData() {
  var wipeEl = document.getElementById('resetWipeAll');
  var phraseEl = document.getElementById('resetConfirmPhrase');
  var btn = document.getElementById('resetDataSubmitBtn');
  var wipeAll = !!(wipeEl && wipeEl.checked);
  var confirmPhrase = phraseEl ? phraseEl.value : '';
  var categories = [];
  if (!wipeAll) {
    document.querySelectorAll('[data-reset-cat]:checked').forEach(function (cb) {
      categories.push(cb.getAttribute('data-reset-cat'));
    });
  }
  if (!wipeAll && categories.length === 0) {
    if (typeof showToast === 'function') showToast('اختر فئة أو فعّل حذف كل شيء.', 'error');
    else alert('اختر فئة أو فعّل حذف كل شيء.');
    return;
  }
  try {
    if (btn) {
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري الحذف…';
    }
    var res = await fetch('/settings/reset-data', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ wipeAll: wipeAll, categories: categories, confirmPhrase: confirmPhrase })
    });
    var data = await res.json();
    if (typeof showToast === 'function') {
      showToast(data.message || (data.success ? 'تم' : 'فشل'), data.success ? 'success' : 'error');
    } else {
      alert(data.message || (data.success ? 'تم' : 'فشل'));
    }
    if (data.success) closeResetDataModal();
  } catch (e) {
    if (typeof showToast === 'function') showToast('خطأ في الاتصال', 'error');
  } finally {
    if (btn) {
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-exclamation-triangle"></i> تنفيذ الحذف على الخادم';
    }
  }
}
</script>
