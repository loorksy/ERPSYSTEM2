<div class="max-w-5xl">
  <div id="settingsCard" class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden" data-tabs-container="settings">
    <div class="flex items-center gap-3 py-5 px-6 border-b border-slate-100">
      <i class="fas fa-cog text-xl text-indigo-600"></i>
      <h3 class="text-lg font-bold">الإعدادات</h3>
    </div>
    <div class="p-6 md:p-10">
      <!-- Tabs -->
      <div class="flex gap-2 mb-6 flex-wrap" id="settingsTabsBar" role="tablist" aria-label="أقسام الإعدادات">
        <button type="button" role="tab" class="settings-tab-btn px-5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-300 bg-slate-100 text-slate-600 hover:bg-slate-200" data-settings-tab="settings-general">عام</button>
        <button type="button" role="tab" class="settings-tab-btn px-5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-300 bg-indigo-600 text-white shadow-md" data-settings-tab="settings-profile">الملف الشخصي</button>
      </div>

      <!-- General Tab -->
      <div id="settings-general" class="settings-tab-panel hidden" data-settings-panel="settings-general">
        <div class="space-y-8">
          <div id="settingsSheetsRedirectBanner" class="hidden rounded-2xl border border-emerald-200/80 bg-gradient-to-br from-emerald-50 to-white p-4 shadow-sm">
            <p class="text-sm font-medium text-emerald-800 flex items-start gap-2">
              <i class="fas fa-check-circle mt-0.5 text-emerald-600"></i>
              <span id="settingsSheetsRedirectBannerText"></span>
            </p>
          </div>
          <div>
            <h4 class="text-base font-bold text-slate-800 mb-4 flex items-center gap-2"><i class="fas fa-coins text-amber-500"></i> نوع العملة</h4>
            <p class="text-sm text-slate-600 mb-4">يتم عرض جميع المبالغ في النظام بأرقام غربية مع رمز العملة المحدد.</p>
            <form id="currencyForm" onsubmit="saveCurrency(event)">
              <div class="mb-5">
                <label for="currencySelect" class="block mb-2 font-semibold text-sm text-slate-800">العملة</label>
                <select id="currencySelect" name="currency" class="w-full max-w-xs py-3 px-4 border-2 border-slate-200 rounded-xl text-[0.95rem] bg-slate-50 text-slate-800">
                  <% (typeof currencyOptions !== 'undefined' ? currencyOptions : []).forEach(function(opt) { %>
                    <option value="<%= opt.code %>" <%= (typeof currency !== 'undefined' && currency === opt.code) ? 'selected' : '' %>><%= opt.label %></option>
                  <% }); %>
                </select>
              </div>
              <button type="submit" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-semibold text-[0.95rem] transition-all duration-300 cursor-pointer whitespace-nowrap active:scale-[0.97] bg-indigo-600 text-white hover:bg-indigo-700 hover:shadow-[0_4px_12px_rgba(79,70,229,0.4)]">
                <i class="fas fa-save"></i>
                <span>حفظ</span>
              </button>
            </form>
          </div>
        </div>
      </div>

      <!-- Profile Tab -->
      <div id="settings-profile" class="settings-tab-panel" data-settings-panel="settings-profile">
        <div class="space-y-8">
          <!-- Profile Form -->
          <div>
            <h4 class="text-base font-bold text-slate-800 mb-4 flex items-center gap-2"><i class="fas fa-user-circle text-indigo-600"></i> الملف الشخصي</h4>
            <form id="profileForm" onsubmit="updateProfile(event)">
              <div class="mb-5">
                <label for="displayName" class="block mb-2 font-semibold text-sm text-slate-800">الاسم المعروض</label>
                <input type="text" id="displayName" name="displayName"
                  class="w-full py-3 px-4 border-2 border-slate-200 rounded-xl text-[0.95rem] bg-slate-50 text-slate-800 transition-all duration-300 focus:outline-none focus:border-indigo-600 focus:bg-white focus:ring-2 focus:ring-indigo-600/10 placeholder:text-slate-400"
                  value="<%= user.displayName %>" required>
              </div>
              <button type="submit" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-semibold text-[0.95rem] transition-all duration-300 cursor-pointer whitespace-nowrap active:scale-[0.97] bg-indigo-600 text-white hover:bg-indigo-700 hover:shadow-[0_4px_12px_rgba(79,70,229,0.4)]">
                <i class="fas fa-save"></i>
                <span>حفظ التغييرات</span>
              </button>
            </form>
          </div>

          <hr class="border-slate-100">

          <!-- Password Form -->
          <div>
            <h4 class="text-base font-bold text-slate-800 mb-4 flex items-center gap-2"><i class="fas fa-key text-indigo-600"></i> تغيير كلمة المرور</h4>
            <form id="passwordForm" onsubmit="changePassword(event)">
              <div class="mb-5">
                <label for="currentPassword" class="block mb-2 font-semibold text-sm text-slate-800">كلمة المرور الحالية</label>
                <input type="password" id="currentPassword" name="currentPassword"
                  class="w-full py-3 px-4 border-2 border-slate-200 rounded-xl text-[0.95rem] bg-slate-50 text-slate-800 transition-all duration-300 focus:outline-none focus:border-indigo-600 focus:bg-white focus:ring-2 focus:ring-indigo-600/10 placeholder:text-slate-400"
                  required>
              </div>
              <div class="mb-5">
                <label for="newPassword" class="block mb-2 font-semibold text-sm text-slate-800">كلمة المرور الجديدة</label>
                <input type="password" id="newPassword" name="newPassword"
                  class="w-full py-3 px-4 border-2 border-slate-200 rounded-xl text-[0.95rem] bg-slate-50 text-slate-800 transition-all duration-300 focus:outline-none focus:border-indigo-600 focus:bg-white focus:ring-2 focus:ring-indigo-600/10 placeholder:text-slate-400"
                  required minlength="6">
              </div>
              <div class="mb-5">
                <label for="confirmPassword" class="block mb-2 font-semibold text-sm text-slate-800">تأكيد كلمة المرور</label>
                <input type="password" id="confirmPassword" name="confirmPassword"
                  class="w-full py-3 px-4 border-2 border-slate-200 rounded-xl text-[0.95rem] bg-slate-50 text-slate-800 transition-all duration-300 focus:outline-none focus:border-indigo-600 focus:bg-white focus:ring-2 focus:ring-indigo-600/10 placeholder:text-slate-400"
                  required minlength="6">
              </div>
              <button type="submit" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-semibold text-[0.95rem] transition-all duration-300 cursor-pointer whitespace-nowrap active:scale-[0.97] bg-indigo-600 text-white hover:bg-indigo-700 hover:shadow-[0_4px_12px_rgba(79,70,229,0.4)]">
                <i class="fas fa-lock"></i>
                <span>تغيير كلمة المرور</span>
              </button>
            </form>
          </div>

          <hr class="border-slate-100">

          <div class="p-4 rounded-xl border border-red-100 bg-red-50/60">
            <h4 class="text-base font-bold text-red-700 mb-2 flex items-center gap-2">
              <i class="fas fa-triangle-exclamation"></i>
              حذف البيانات من الخادم
            </h4>
            <p class="text-sm text-red-700 mb-3">
              اختر فئات البيانات المراد حذفها من الخادم، أو فعّل «حذف كل شيء» لمسح كل البيانات التشغيلية دفعة واحدة مع <strong>الإبقاء تلقائياً</strong> على ربط Google ومفاتيح الذكاء المخزّنة محلياً (لا تظهر في هذه القائمة).
            </p>
            <button type="button" onclick="openResetDataModal()" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl font-semibold text-sm bg-red-600 text-white hover:bg-red-700 active:scale-[0.97]">
              <i class="fas fa-trash"></i>
              فتح قائمة الحذف والتأكيد
            </button>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Modal: حذف البيانات — تذييل ثابت يظهر على الموبايل فوق الشريط السفلي -->
  <!-- z أعلى من الشريط السفلي (z-[999]) وأقل من التوست (z-[9999]) -->
  <div id="resetDataModal" class="fixed inset-0 z-[5000] hidden flex items-end sm:items-center justify-center p-0 sm:p-4 bg-slate-900/60 backdrop-blur-[2px]" role="dialog" aria-modal="true" aria-labelledby="resetDataModalTitle">
    <div class="bg-white rounded-t-[1.25rem] sm:rounded-2xl shadow-2xl border border-slate-200/90 max-w-lg w-full max-h-[min(92dvh,100vh)] flex flex-col min-h-0 sm:max-h-[90vh]">
      <div class="shrink-0 px-5 py-4 border-b border-slate-100 flex items-center justify-between gap-3 bg-gradient-to-l from-white to-slate-50/90">
        <div class="flex items-center gap-3 min-w-0">
          <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-red-100 text-red-600">
            <i class="fas fa-database"></i>
          </span>
          <h3 id="resetDataModalTitle" class="text-lg font-bold text-slate-900 truncate">حذف البيانات من الخادم</h3>
        </div>
        <button type="button" onclick="closeResetDataModal()" class="p-2 rounded-xl text-slate-500 hover:bg-slate-100 shrink-0" aria-label="إغلاق">
          <i class="fas fa-times"></i>
        </button>
      </div>
      <div class="flex-1 min-h-0 overflow-y-auto overscroll-contain px-5 py-4 space-y-4">
        <label class="flex items-start gap-3 p-4 rounded-2xl border-2 border-red-200/90 bg-gradient-to-br from-red-50/95 to-white cursor-pointer shadow-sm">
          <input type="checkbox" id="resetWipeAll" class="mt-1 rounded border-slate-300 text-red-600 focus:ring-red-500" onchange="onResetWipeAllChange()">
          <span>
            <span class="font-bold text-red-900 block">حذف كل شيء (البيانات التشغيلية)</span>
            <span class="text-sm text-red-800/90 leading-relaxed">يشمل كل الفئات أدناه دفعة واحدة، مع الإبقاء على ربط Google ومفاتيح الذكاء المخزّنة على الخادم.</span>
          </span>
        </label>
        <div>
          <p class="text-xs font-bold text-slate-500 uppercase tracking-wide mb-2">فئات يمكن اختيارها</p>
          <div id="resetDataCategories" class="space-y-2 text-sm text-slate-700 rounded-2xl border border-slate-200/90 bg-slate-50/50 p-2 max-h-[38vh] sm:max-h-[40vh] overflow-y-auto">
            <p class="text-slate-500 text-xs px-2 py-2">جاري التحميل…</p>
          </div>
        </div>
        <div class="flex flex-wrap gap-2">
          <button type="button" onclick="resetSelectAllCats(true)" class="text-xs font-semibold px-3 py-2 rounded-xl bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 hover:border-indigo-200">تحديد الكل</button>
          <button type="button" onclick="resetSelectAllCats(false)" class="text-xs font-semibold px-3 py-2 rounded-xl bg-white border border-slate-200 text-slate-700 hover:bg-slate-50">إلغاء التحديد</button>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
          <label for="resetConfirmPhrase" class="block text-sm font-semibold text-slate-800 mb-1">تأكيد نهائي</label>
          <p class="text-xs text-slate-500 mb-2">اكتب بالضبط: <strong dir="ltr">حذف نهائي</strong> أو <strong dir="ltr">DELETE</strong></p>
          <input type="text" id="resetConfirmPhrase" dir="ltr" autocomplete="off"
            class="w-full py-3 px-3 border-2 border-slate-200 rounded-xl text-sm bg-slate-50/50 focus:outline-none focus:border-red-500 focus:ring-2 focus:ring-red-500/15"
            placeholder="حذف نهائي">
        </div>
      </div>
      <div class="shrink-0 px-4 sm:px-5 pt-3 pb-[max(1rem,env(safe-area-inset-bottom))] border-t border-slate-200 bg-white flex flex-col-reverse sm:flex-row sm:justify-end gap-2 sm:gap-3 shadow-[0_-8px_24px_rgba(15,23,42,0.06)]">
        <button type="button" onclick="closeResetDataModal()" class="w-full sm:w-auto px-4 py-3.5 sm:py-2.5 rounded-xl font-semibold text-sm bg-slate-100 text-slate-800 hover:bg-slate-200">إلغاء</button>
        <button type="button" id="resetDataSubmitBtn" onclick="submitResetData()" class="w-full sm:w-auto px-4 py-3.5 sm:py-2.5 rounded-xl font-semibold text-sm bg-red-600 text-white hover:bg-red-700 shadow-md shadow-red-600/20">تنفيذ الحذف على الخادم</button>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  var card = document.getElementById('settingsCard');
  if (!card) return;
  function showTab(tabId) {
    var panels = card.querySelectorAll('.settings-tab-panel');
    var targetPanel = card.querySelector('[data-settings-panel="' + tabId + '"]');
    panels.forEach(function(p) {
      p.classList.add('hidden');
      p.style.setProperty('display', 'none');
    });
    if (targetPanel) {
      targetPanel.classList.remove('hidden');
      targetPanel.style.removeProperty('display');
    }
    card.querySelectorAll('.settings-tab-btn').forEach(function(b) {
      b.classList.remove('bg-indigo-600', 'text-white', 'shadow-md');
      b.classList.add('bg-slate-100', 'text-slate-600');
    });
    var btn = card.querySelector('[data-settings-tab="' + tabId + '"]');
    if (btn) {
      btn.classList.remove('bg-slate-100', 'text-slate-600');
      btn.classList.add('bg-indigo-600', 'text-white', 'shadow-md');
    }
  }
  card.addEventListener('click', function(e) {
    var btn = e.target.closest('.settings-tab-btn');
    if (!btn) return;
    var tabId = btn.getAttribute('data-settings-tab');
    if (!tabId) return;
    showTab(tabId);
  });
  var search = window.location.search || '';
  if (search.indexOf('sheets=') !== -1) {
    showTab('settings-general');
    var banner = document.getElementById('settingsSheetsRedirectBanner');
    var bannerText = document.getElementById('settingsSheetsRedirectBannerText');
    var bannerRow = banner && banner.querySelector('p');
    var bannerIcon = banner && banner.querySelector('i');
    if (banner && bannerText) {
      banner.classList.remove('hidden');
      if (search.indexOf('sheets=connected') !== -1) {
        banner.className = 'mb-4 rounded-2xl border border-emerald-200/80 bg-gradient-to-br from-emerald-50 to-white p-4 shadow-sm';
        if (bannerRow) bannerRow.className = 'text-sm font-medium text-emerald-800 flex items-start gap-2';
        if (bannerIcon) bannerIcon.className = 'fas fa-check-circle mt-0.5 text-emerald-600';
        bannerText.textContent = 'تم الربط بحساب Google بنجاح. يمكنك استخدام التصدير من صفحة ترتيب الرسائل عند الحاجة.';
      } else if (search.indexOf('sheets=no_credentials') !== -1) {
        banner.className = 'mb-4 rounded-2xl border border-amber-200 bg-amber-50 p-4 shadow-sm';
        if (bannerRow) bannerRow.className = 'text-sm font-medium text-amber-900 flex items-start gap-2';
        if (bannerIcon) bannerIcon.className = 'fas fa-triangle-exclamation mt-0.5 text-amber-600';
        bannerText.textContent = 'لم يتم إعداد بيانات الاعتماد. أضف GOOGLE_CLIENT_ID و GOOGLE_CLIENT_SECRET في ملف .env ثم أعد تشغيل السيرفر.';
      } else if (search.indexOf('sheets=callback_failed') !== -1 || search.indexOf('sheets=auth_failed') !== -1) {
        banner.className = 'mb-4 rounded-2xl border border-red-200 bg-red-50 p-4 shadow-sm';
        if (bannerRow) bannerRow.className = 'text-sm font-medium text-red-900 flex items-start gap-2';
        if (bannerIcon) bannerIcon.className = 'fas fa-times-circle mt-0.5 text-red-600';
        bannerText.textContent = 'فشل الربط بـ Google. حاول مرة أخرى.';
      }
    }
    if (window.history && window.history.replaceState) window.history.replaceState({}, '', window.location.pathname);
  }
})();

async function saveCurrency(e) {
  e.preventDefault();
  var sel = document.getElementById('currencySelect');
  if (!sel) return;
  var currency = sel.value;
  try {
    var res = await fetch('/settings/currency', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ currency: currency })
    });
    var data = await res.json();
    if (typeof showToast === 'function') showToast(data.message || (data.success ? 'تم حفظ العملة' : 'فشل'), data.success ? 'success' : 'error');
    if (data.success && data.symbol) window.currencySymbol = data.symbol;
  } catch (_) {
    if (typeof showToast === 'function') showToast('خطأ في الاتصال', 'error');
  }
}

var resetDataCategoriesCache = null;

function renderResetCategories() {
  var box = document.getElementById('resetDataCategories');
  if (!box || !resetDataCategoriesCache) return;
  var wipe = document.getElementById('resetWipeAll');
  var wipeOn = wipe && wipe.checked;
  box.innerHTML = '';
  resetDataCategoriesCache.forEach(function (cat) {
    var id = 'resetCat_' + cat.id;
    var wrap = document.createElement('label');
    wrap.className = 'flex items-start gap-3 p-3 rounded-xl cursor-pointer border border-slate-200/80 bg-white shadow-sm hover:border-indigo-300/80 hover:bg-indigo-50/30 transition-colors';
    var cb = document.createElement('input');
    cb.type = 'checkbox';
    cb.id = id;
    cb.setAttribute('data-reset-cat', cat.id);
    cb.className = 'mt-1 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500';
    cb.disabled = wipeOn;
    cb.checked = wipeOn;
    var span = document.createElement('span');
    var title = document.createElement('span');
    title.className = 'font-bold text-slate-900 block text-[0.9rem]';
    title.textContent = cat.label || '';
    var desc = document.createElement('span');
    desc.className = 'text-slate-600 text-xs block mt-1 leading-relaxed';
    desc.textContent = cat.description || '';
    span.appendChild(title);
    span.appendChild(desc);
    wrap.appendChild(cb);
    wrap.appendChild(span);
    box.appendChild(wrap);
  });
}

function onResetWipeAllChange() {
  renderResetCategories();
}

function resetSelectAllCats(val) {
  var wipe = document.getElementById('resetWipeAll');
  if (wipe && wipe.checked) return;
  document.querySelectorAll('[data-reset-cat]').forEach(function (cb) {
    cb.checked = !!val;
  });
}

function closeResetDataModal() {
  var modal = document.getElementById('resetDataModal');
  if (modal) modal.classList.add('hidden');
  var phrase = document.getElementById('resetConfirmPhrase');
  if (phrase) phrase.value = '';
}

async function openResetDataModal() {
  var modal = document.getElementById('resetDataModal');
  if (!modal) return;
  modal.classList.remove('hidden');
  var box = document.getElementById('resetDataCategories');
  resetDataCategoriesCache = null;
  if (box) {
    box.innerHTML = '<p class="text-slate-500 text-xs">جاري التحميل…</p>';
    try {
      var res = await fetch('/settings/reset-data-options', { credentials: 'same-origin' });
      var data = await res.json();
      if (data.success && data.categories) resetDataCategoriesCache = data.categories;
      else box.innerHTML = '<p class="text-red-600 text-sm">تعذر تحميل القائمة.</p>';
    } catch (e) {
      if (box) box.innerHTML = '<p class="text-red-600 text-sm">خطأ في الاتصال.</p>';
      return;
    }
  }
  renderResetCategories();
}

document.addEventListener('click', function (e) {
  var modal = document.getElementById('resetDataModal');
  if (!modal || modal.classList.contains('hidden')) return;
  if (e.target === modal) closeResetDataModal();
});

async function submitResetData() {
  var wipeEl = document.getElementById('resetWipeAll');
  var phraseEl = document.getElementById('resetConfirmPhrase');
  var btn = document.getElementById('resetDataSubmitBtn');
  var wipeAll = !!(wipeEl && wipeEl.checked);
  var confirmPhrase = phraseEl ? phraseEl.value : '';
  var categories = [];
  if (!wipeAll) {
    document.querySelectorAll('[data-reset-cat]:checked').forEach(function (cb) {
      categories.push(cb.getAttribute('data-reset-cat'));
    });
  }
  if (!wipeAll && categories.length === 0) {
    if (typeof showToast === 'function') showToast('اختر فئة أو فعّل حذف كل شيء.', 'error');
    else alert('اختر فئة أو فعّل حذف كل شيء.');
    return;
  }
  try {
    if (btn) { btn.disabled = true; btn.textContent = 'جاري الحذف…'; }
    var res = await fetch('/settings/reset-data', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ wipeAll: wipeAll, categories: categories, confirmPhrase: confirmPhrase })
    });
    var data = await res.json();
    if (typeof showToast === 'function') {
      showToast(data.message || (data.success ? 'تم' : 'فشل'), data.success ? 'success' : 'error');
    } else {
      alert(data.message || (data.success ? 'تم' : 'فشل'));
    }
    if (data.success) closeResetDataModal();
  } catch (e) {
    if (typeof showToast === 'function') showToast('خطأ في الاتصال', 'error');
  } finally {
    if (btn) { btn.disabled = false; btn.textContent = 'تنفيذ الحذف على الخادم'; }
  }
}
</script>
