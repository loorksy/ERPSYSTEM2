<div class="max-w-3xl space-y-6">
  <!-- Profile -->
  <div class="section-card">
    <div class="flex items-center gap-2.5 py-5 px-4 md:px-6 border-b border-slate-100">
      <i class="fas fa-user-circle text-xl text-indigo-600"></i>
      <h3 class="text-lg font-bold">الملف الشخصي</h3>
    </div>
    <div class="p-4 md:p-6">
      <form id="profileForm" onsubmit="updateProfile(event)">
        <div class="mb-5">
          <label for="displayName" class="block mb-2 font-semibold text-sm text-slate-800">الاسم المعروض</label>
          <input type="text" id="displayName" name="displayName" class="form-control"
            value="<%= user.displayName %>" required>
        </div>
        <div class="flex flex-wrap gap-3 mt-6">
          <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i>
            <span>حفظ التغييرات</span>
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Password -->
  <div class="section-card">
    <div class="flex items-center gap-2.5 py-5 px-4 md:px-6 border-b border-slate-100">
      <i class="fas fa-key text-xl text-indigo-600"></i>
      <h3 class="text-lg font-bold">تغيير كلمة المرور</h3>
    </div>
    <div class="p-4 md:p-6">
      <form id="passwordForm" onsubmit="changePassword(event)">
        <div class="mb-5">
          <label for="currentPassword" class="block mb-2 font-semibold text-sm text-slate-800">كلمة المرور الحالية</label>
          <input type="password" id="currentPassword" name="currentPassword" class="form-control" required>
        </div>
        <div class="mb-5">
          <label for="newPassword" class="block mb-2 font-semibold text-sm text-slate-800">كلمة المرور الجديدة</label>
          <input type="password" id="newPassword" name="newPassword" class="form-control" required minlength="6">
        </div>
        <div class="mb-5">
          <label for="confirmPassword" class="block mb-2 font-semibold text-sm text-slate-800">تأكيد كلمة المرور</label>
          <input type="password" id="confirmPassword" name="confirmPassword" class="form-control" required minlength="6">
        </div>
        <div class="flex flex-wrap gap-3 mt-6">
          <button type="submit" class="btn btn-primary">
            <i class="fas fa-lock"></i>
            <span>تغيير كلمة المرور</span>
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
