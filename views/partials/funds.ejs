<div class="funds-page w-full max-w-6xl mx-auto px-4 sm:px-0 pb-10" dir="rtl">
  <div class="erp-module-shell rounded-2xl border border-slate-200/90 bg-white shadow-sm overflow-hidden mb-6">
    <div class="relative overflow-hidden border-b border-slate-200/80 bg-gradient-to-br from-teal-50/90 via-white to-slate-50 px-4 py-5 sm:px-7 sm:py-6">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_50%_at_0%_0%,rgba(20,184,166,0.1),transparent)] pointer-events-none"></div>
      <div class="relative flex items-start gap-3 sm:gap-4">
        <div class="flex h-11 w-11 sm:h-12 sm:w-12 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-teal-600 to-emerald-700 text-white shadow-md">
          <i class="fas fa-wallet text-lg sm:text-xl"></i>
        </div>
        <div class="min-w-0">
          <p class="text-xs font-semibold text-teal-700 mb-0.5">أرصدة وصناديق</p>
          <h2 class="text-lg sm:text-2xl font-bold text-slate-900 tracking-tight">الصناديق</h2>
          <p class="text-sm text-slate-600 mt-1 leading-relaxed">عرض وتعديل الصناديق والصندوق الرئيسي.</p>
        </div>
      </div>
    </div>
    <div class="border-b border-slate-100 bg-slate-50/95 px-4 py-4 sm:px-6 sm:py-4 funds-page-toolbar">
      <p class="text-xs font-semibold text-slate-500 mb-3 sm:mb-0 sm:hidden">إجراءات سريعة</p>
      <div class="flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-center sm:justify-end">
        <button type="button" onclick="fundsEditMain()" class="w-full sm:w-auto px-4 py-2.5 rounded-xl bg-amber-100 text-amber-900 text-sm font-semibold shadow-sm border border-amber-200/80 hover:bg-amber-200 active:scale-[0.99] transition text-center">
          <i class="fas fa-edit ml-1"></i> تعديل الصندوق الرئيسي
        </button>
        <button type="button" onclick="fundsOpenAdd()" class="btn-add inline-flex w-full sm:w-auto items-center justify-center">
          <i class="fas fa-plus ml-2"></i>
          إضافة صندوق
        </button>
      </div>
    </div>
  </div>

  <!-- تعديل الصندوق الرئيسي -->
  <div id="fundEditMainModal" class="fixed inset-0 z-[2000] hidden items-center justify-center p-4 bg-black/50">
    <div class="bg-white rounded-2xl shadow-xl max-w-md w-full p-6">
      <h4 class="text-lg font-bold mb-4">تعديل الصندوق الرئيسي</h4>
      <div class="space-y-3">
        <div>
          <label class="text-sm font-semibold text-slate-700">اسم الصندوق</label>
          <input type="text" id="fundMainEditName" class="w-full mt-1 px-4 py-2.5 rounded-xl border border-slate-200">
        </div>
        <div>
          <label class="text-sm font-semibold text-slate-700">رقم الصندوق</label>
          <input type="text" id="fundMainEditNumber" class="w-full mt-1 px-4 py-2.5 rounded-xl border border-slate-200">
        </div>
        <div class="flex gap-2 pt-2">
          <button type="button" onclick="fundsSubmitEditMain()" class="flex-1 py-3 rounded-xl bg-amber-600 text-white font-semibold">حفظ</button>
          <button type="button" onclick="fundsCloseEditMain()" class="px-5 py-3 rounded-xl bg-slate-100 text-slate-600">إلغاء</button>
        </div>
      </div>
    </div>
  </div>
  <div id="fundsCards" class="agencies-grid">
    <p class="text-slate-400 col-span-full text-center py-12">جاري التحميل...</p>
  </div>
</div>

<style>
/* نفس شبكة وبطاقات الوكالات الفرعية — محاذاة وسط على الموبايل */
.agencies-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.25rem; }
.btn-add { padding: 0.75rem 1.25rem; border-radius: 0.75rem; font-weight: 600; font-size: 0.875rem; background: linear-gradient(135deg, #4f46e5, #6366f1); color: white; transition: all 0.2s; }
.btn-add:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(79, 70, 229, 0.4); }
.agency-card { padding: 1.25rem; border-radius: 1rem; cursor: pointer; transition: all 0.2s; border: none; }
.agency-card:hover { transform: translateY(-2px); box-shadow: 0 12px 24px -8px rgba(0,0,0,0.15); }
.agency-card h5 { font-weight: 700; font-size: 1rem; margin-bottom: 0.5rem; }
.agency-card .agency-meta { font-size: 0.8125rem; opacity: 0.9; margin-bottom: 0.25rem; }
.agency-card .agency-balance { font-size: 0.875rem; font-weight: 600; }
@media (max-width: 639px) {
  .funds-page .agency-card { text-align: center; }
  .funds-page .agency-card h5 { text-align: center; }
  .funds-page .agency-card .agency-meta,
  .funds-page .agency-card .agency-balance { text-align: center; }
}
</style>

<div id="fundAddModal" class="fixed inset-0 z-[2000] hidden items-center justify-center p-4 bg-black/50">
  <div class="bg-white rounded-2xl shadow-xl max-w-lg w-full max-h-[90vh] overflow-y-auto p-6">
    <h4 class="text-lg font-bold mb-4">إضافة صندوق</h4>
    <form id="fundAddForm" class="space-y-3">
      <div>
        <label class="text-sm font-semibold text-slate-700">اسم الصندوق</label>
        <input type="text" id="fundAddName" class="w-full mt-1 px-4 py-2.5 rounded-xl border border-slate-200" required>
      </div>
      <div>
        <label class="text-sm font-semibold text-slate-700">رقم الصندوق</label>
        <input type="text" id="fundAddNumber" class="w-full mt-1 px-4 py-2.5 rounded-xl border border-slate-200">
      </div>
      <div>
        <label class="text-sm font-semibold text-slate-700">شركة التحويل (اختياري)</label>
        <select id="fundAddTc" class="w-full mt-1 px-4 py-2.5 rounded-xl border border-slate-200">
          <option value="">— لا يوجد —</option>
        </select>
      </div>
      <div>
        <label class="text-sm font-semibold text-slate-700">الدولة</label>
        <select id="fundAddCountry" class="w-full mt-1 px-4 py-2.5 rounded-xl border border-slate-200" onchange="fundsSyriaGov(this.value)"></select>
      </div>
      <div id="fundSyriaGovWrap" class="hidden">
        <label class="text-sm font-semibold text-slate-700">المحافظة (سوريا)</label>
        <select id="fundAddSyriaGov" class="w-full mt-1 px-4 py-2.5 rounded-xl border border-slate-200"></select>
      </div>
      <div>
        <label class="text-sm font-semibold text-slate-700">رصيد مرجعي — أول عملة</label>
        <div class="flex gap-2 mt-1">
          <input type="number" id="fundRefAmt1" step="0.01" class="flex-1 px-4 py-2.5 rounded-xl border border-slate-200" placeholder="المبلغ">
          <select id="fundRefCur1" class="w-32 px-2 rounded-xl border border-slate-200">
            <option value="USD">USD</option>
            <option value="TRY">TRY</option>
            <option value="SYP">SYP</option>
            <option value="EUR">EUR</option>
            <option value="EGP">EGP</option>
          </select>
        </div>
      </div>
      <div>
        <label class="text-sm font-semibold text-slate-700">رصيد مرجعي — عملة ثانية (اختياري)</label>
        <div class="flex gap-2 mt-1">
          <input type="number" id="fundRefAmt2" step="0.01" class="flex-1 px-4 py-2.5 rounded-xl border border-slate-200" placeholder="0">
          <select id="fundRefCur2" class="w-32 px-2 rounded-xl border border-slate-200">
            <option value="">—</option>
            <option value="TRY">TRY</option>
            <option value="SYP">SYP</option>
            <option value="USD">USD</option>
            <option value="EUR">EUR</option>
            <option value="EGP">EGP</option>
          </select>
        </div>
      </div>
      <div class="flex gap-2 pt-2">
        <button type="submit" class="flex-1 py-3 rounded-xl bg-sky-600 text-white font-semibold">حفظ</button>
        <button type="button" onclick="fundsCloseAdd()" class="px-5 py-3 rounded-xl bg-slate-100 text-slate-600">إلغاء</button>
      </div>
    </form>
  </div>
</div>

<div id="fundDetailModal" class="fixed inset-0 z-[2000] hidden items-center justify-center p-4 bg-black/50">
  <div class="bg-white rounded-2xl shadow-xl max-w-2xl w-full max-h-[90vh] overflow-hidden flex flex-col">
    <div class="px-6 py-4 border-b flex justify-between items-center flex-wrap gap-2">
      <h4 id="fundDetailTitle" class="text-lg font-bold">الصندوق</h4>
      <div class="flex items-center gap-2">
        <button type="button" onclick="fundsDownloadLedgerPdf()" class="px-3 py-2 rounded-xl bg-slate-100 text-slate-700 text-sm font-semibold hover:bg-slate-200">
          <i class="fas fa-file-pdf ml-1"></i> تنزيل PDF
        </button>
        <button type="button" onclick="fundsCloseDetail()" class="text-slate-400 hover:bg-slate-100 w-10 h-10 rounded-xl"><i class="fas fa-times"></i></button>
      </div>
    </div>
    <div class="p-4 overflow-y-auto flex-1">
      <div id="fundDetailMeta" class="text-sm text-slate-600 mb-4"></div>
      <div id="fundDetailPayables" class="hidden mb-3 text-sm font-semibold text-red-600"></div>
      <div id="fundDetailBalances" class="flex flex-wrap gap-2 mb-4"></div>
      <div class="flex flex-wrap gap-2 mb-4">
        <button type="button" onclick="fundsSetMain()" class="px-3 py-2 rounded-lg bg-amber-100 text-amber-800 text-sm font-semibold">تعيين كصندوق رئيسي</button>
      </div>
      <h5 class="font-bold text-slate-800 mb-2">ترحيل إلى صندوق آخر</h5>
      <div class="flex flex-wrap gap-2 items-end mb-6">
        <select id="fundTransferTo" class="px-3 py-2 rounded-lg border border-slate-200 text-sm"></select>
        <input type="number" id="fundTransferAmt" step="0.01" placeholder="المبلغ" class="px-3 py-2 rounded-lg border border-slate-200 w-32">
        <button type="button" onclick="fundsDoTransfer()" class="px-4 py-2 rounded-lg bg-sky-600 text-white text-sm">ترحيل</button>
      </div>
      <h5 class="font-bold text-slate-800 mb-2">تسجيل مرتجع</h5>
      <div class="flex flex-wrap gap-2 items-end mb-2">
        <input type="number" id="fundReturnAmt" step="0.01" min="0" placeholder="المبلغ" class="px-3 py-2 rounded-lg border border-slate-200 w-32 text-sm">
        <select id="fundReturnCur" class="px-3 py-2 rounded-lg border border-slate-200 text-sm">
          <option value="USD">USD</option>
          <option value="TRY">TRY</option>
          <option value="SYP">SYP</option>
        </select>
        <select id="fundReturnDisposition" class="px-3 py-2 rounded-lg border border-slate-200 text-sm">
          <option value="remain_at_entity">يبقى بالصندوق</option>
          <option value="transfer_to_fund">ترحيل لصندوق آخر</option>
        </select>
        <select id="fundReturnTarget" class="px-3 py-2 rounded-lg border border-slate-200 text-sm hidden"></select>
        <button type="button" onclick="fundsSubmitReturn()" class="px-4 py-2 rounded-lg bg-emerald-600 text-white text-sm font-semibold hover:bg-emerald-700">تسجيل</button>
      </div>
      <input type="text" id="fundReturnNotes" class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm mb-6" placeholder="ملاحظات (اختياري)">
      <h5 class="font-bold text-slate-800 mb-2">السجل</h5>
      <div id="fundDetailLedger" class="space-y-2 text-sm"></div>
    </div>
  </div>
</div>

<script>
  window.FUNDS_COUNTRIES = [
    'سوريا','تركيا','مصر','العراق','الجزائر','الأردن','المغرب','فلسطين','لبنان','السعودية','الإمارات','الكويت','قطر','البحرين','عُمان','اليمن','السودان','تونس','ليبيا','موريتانيا','الصومال','جيبوتي'
  ];
  window.FUNDS_SYRIA_GOV = ['دمشق','ريف دمشق','حلب','حمص','حماة','اللاذقية','طرطوس','درعا','السويداء','القنيطرة','الرقة','دير الزور','الحسكة','إدلب'];
</script>
