<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="theme-color" content="#1a1a2e">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>LorkERP - <%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/tailwind.css">
</head>
<body class="min-h-screen bg-slate-100 font-[Tajawal] text-slate-800">

  <!-- Mobile Header -->
  <header class="hidden lg:hidden fixed top-0 left-0 right-0 h-[60px] bg-white border-b border-slate-200 px-4 items-center justify-between z-[1000] shadow-sm max-lg:flex" id="mobileHeader">
    <button class="w-[42px] h-[42px] flex items-center justify-center rounded-xl text-slate-800 text-xl active:bg-slate-50" id="menuToggle" aria-label="القائمة">
      <i class="fas fa-bars"></i>
    </button>
    <div class="flex items-center gap-2 font-bold text-lg text-indigo-600">
      <i class="fas fa-chart-line text-xl"></i>
      <span>LorkERP</span>
    </div>
    <div class="cursor-pointer" id="mobileUserBtn">
      <div class="w-9 h-9 rounded-full bg-gradient-to-br from-indigo-600 to-indigo-400 text-white flex items-center justify-center font-bold text-sm">
        <%= user.displayName.charAt(0) %>
      </div>
    </div>
  </header>

  <!-- Sidebar Overlay -->
  <div class="hidden fixed inset-0 bg-black/50 z-[1000] backdrop-blur-sm" id="sidebarOverlay"></div>

  <!-- Sidebar -->
  <aside class="fixed top-0 right-0 w-[260px] h-screen bg-[#1a1a2e] z-[1001] flex flex-col transition-all duration-300 overflow-y-auto overflow-x-hidden max-lg:translate-x-full" id="sidebar">
    <div class="p-5 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-gradient-to-br from-indigo-600 to-indigo-400 rounded-xl flex items-center justify-center shrink-0">
          <i class="fas fa-chart-line text-white text-lg"></i>
        </div>
        <div>
          <h2 class="text-white text-xl font-bold leading-tight">LorkERP</h2>
          <span class="text-slate-400 text-xs">نظام المحاسبة</span>
        </div>
      </div>
      <button class="hidden max-lg:flex w-9 h-9 rounded-xl text-slate-400 items-center justify-center text-lg hover:bg-white/[0.08]" id="sidebarClose">
        <i class="fas fa-times"></i>
      </button>
    </div>

    <div class="py-4 px-5 mx-3 bg-white/[0.08] rounded-xl flex items-center gap-3">
      <div class="w-11 h-11 rounded-full bg-gradient-to-br from-indigo-600 to-cyan-500 text-white flex items-center justify-center font-bold text-lg shrink-0">
        <%= user.displayName.charAt(0) %>
      </div>
      <div>
        <h4 class="text-white text-[0.95rem] font-semibold"><%= user.displayName %></h4>
        <span class="text-slate-400 text-xs"><%= user.role === 'admin' ? 'مدير النظام' : 'مستخدم' %></span>
      </div>
    </div>

    <nav class="flex-1 py-4">
      <ul class="px-3">
        <li class="pt-4 pb-2 px-4 text-[0.7rem] font-bold uppercase text-white/35 tracking-wider">الرئيسية</li>
        <li>
          <a href="/dashboard" class="sidebar-link <%= page === 'home' ? 'active' : '' %>">
            <i class="fas fa-home w-5 text-center"></i>
            <span>لوحة التحكم</span>
          </a>
        </li>

        <li class="pt-4 pb-2 px-4 text-[0.7rem] font-bold uppercase text-white/35 tracking-wider">الربط والمزامنة</li>
        <li>
          <a href="/whatsapp" class="sidebar-link <%= page === 'whatsapp' ? 'active' : '' %>">
            <i class="fab fa-whatsapp w-5 text-center"></i>
            <span>ربط واتساب</span>
          </a>
        </li>
        <li>
          <a href="/sheets" class="sidebar-link <%= page === 'sheets' ? 'active' : '' %>">
            <i class="fas fa-table w-5 text-center"></i>
            <span>Google Sheets</span>
          </a>
        </li>

        <li class="pt-4 pb-2 px-4 text-[0.7rem] font-bold uppercase text-white/35 tracking-wider">النظام</li>
        <li>
          <a href="/settings" class="sidebar-link <%= page === 'settings' ? 'active' : '' %>">
            <i class="fas fa-cog w-5 text-center"></i>
            <span>الإعدادات</span>
          </a>
        </li>
        <li>
          <a href="/logout" class="sidebar-link !text-red-400 hover:!bg-red-400/10">
            <i class="fas fa-sign-out-alt w-5 text-center"></i>
            <span>تسجيل الخروج</span>
          </a>
        </li>
      </ul>
    </nav>

    <div class="py-4 px-5 border-t border-white/[0.08] text-center">
      <p class="text-white/30 text-xs">LorkERP v1.0</p>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="lg:mr-[260px] min-h-screen transition-all duration-300 max-lg:pt-[60px] max-lg:pb-[65px]" id="mainContent">
    <div class="bg-white py-5 px-4 lg:px-8 border-b border-slate-200 flex items-center justify-between sticky top-0 z-[100] max-lg:relative max-lg:top-auto">
      <div>
        <h1 class="text-xl lg:text-2xl font-bold text-slate-800"><%= title %></h1>
      </div>
      <div class="flex items-center gap-4">
        <div class="hidden md:flex items-center gap-2 text-slate-500 text-sm">
          <i class="fas fa-calendar-alt"></i>
          <span id="currentDate"></span>
        </div>
      </div>
    </div>

    <div class="p-4 lg:p-8 2xl:px-12">
      <% if (page === 'home') { %>
        <%- include('partials/home') %>
      <% } else if (page === 'whatsapp') { %>
        <%- include('partials/whatsapp') %>
      <% } else if (page === 'sheets') { %>
        <%- include('partials/sheets') %>
      <% } else if (page === 'settings') { %>
        <%- include('partials/settings') %>
      <% } %>
    </div>
  </main>

  <!-- Toast -->
  <div class="fixed top-5 left-5 z-[9999] flex flex-col gap-2 max-md:left-3 max-md:right-3 max-md:top-[72px]" id="toastContainer"></div>

  <!-- Mobile Bottom Nav -->
  <nav class="hidden max-lg:flex fixed bottom-0 left-0 right-0 h-[65px] bg-white border-t border-slate-200 justify-around items-center z-[999] shadow-[0_-2px_10px_rgba(0,0,0,0.05)] pb-[env(safe-area-inset-bottom,0)]">
    <a href="/dashboard" class="flex flex-col items-center gap-1 text-[0.7rem] font-medium py-2 px-3 rounded-xl transition-all duration-300 <%= page === 'home' ? 'text-indigo-600' : 'text-slate-400' %> active:bg-indigo-600/10">
      <i class="fas fa-home text-xl"></i>
      <span>الرئيسية</span>
    </a>
    <a href="/whatsapp" class="flex flex-col items-center gap-1 text-[0.7rem] font-medium py-2 px-3 rounded-xl transition-all duration-300 <%= page === 'whatsapp' ? 'text-indigo-600' : 'text-slate-400' %> active:bg-indigo-600/10">
      <i class="fab fa-whatsapp text-xl"></i>
      <span>واتساب</span>
    </a>
    <a href="/sheets" class="flex flex-col items-center gap-1 text-[0.7rem] font-medium py-2 px-3 rounded-xl transition-all duration-300 <%= page === 'sheets' ? 'text-indigo-600' : 'text-slate-400' %> active:bg-indigo-600/10">
      <i class="fas fa-table text-xl"></i>
      <span>الجداول</span>
    </a>
    <a href="/settings" class="flex flex-col items-center gap-1 text-[0.7rem] font-medium py-2 px-3 rounded-xl transition-all duration-300 <%= page === 'settings' ? 'text-indigo-600' : 'text-slate-400' %> active:bg-indigo-600/10">
      <i class="fas fa-cog text-xl"></i>
      <span>الإعدادات</span>
    </a>
  </nav>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/socket.io/4.7.5/socket.io.min.js"></script>
  <script src="/js/app.js"></script>
  <% if (page === 'whatsapp') { %>
    <script src="/js/whatsapp.js"></script>
  <% } %>
  <% if (page === 'sheets') { %>
    <script src="/js/sheets.js"></script>
  <% } %>
</body>
</html>
