            </span>
          </a>
        </li>
        <li>
          <a href="/search" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'search' ? 'bg-[#c9a227]/10 text-white' : 'text-slate-400 hover:bg-white/[0.06] hover:text-white' %>">
            <i class="fas fa-search w-5 text-center <%= page === 'search' ? 'text-[#c9a227]' : '' %>"></i>
            <span>البحث</span>
          </a>
        </li>
        <li>
          <a href="/clients" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'clients' ? 'bg-[#c9a227]/10 text-white' : 'text-slate-400 hover:bg-white/[0.06] hover:text-white' %>">
            <i class="fas fa-users w-5 text-center <%= page === 'clients' ? 'text-[#c9a227]' : '' %>"></i>
            <span>بيانات العملاء</span>
          </a>
        </li>
        <li>
          <a href="/member-directory" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'member-directory' || page === 'member-directory-detail' ? 'bg-[#c9a227]/10 text-white' : 'text-slate-400 hover:bg-white/[0.06] hover:text-white' %>">
