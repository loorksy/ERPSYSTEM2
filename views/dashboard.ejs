          </a>
        </li>
        <li>
          <a href="/member-adjustments" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'member-adjustments' ? 'bg-[#c9a227]/10 text-white' : 'text-slate-400 hover:bg-white/[0.06] hover:text-white' %>">
