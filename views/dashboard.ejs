<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="theme-color" content="#1a1a2e">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>LorkERP - <%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/tailwind.css">
</head>
<body class="min-h-screen bg-slate-100 font-[Tajawal] text-slate-800">

  <!-- Mobile Header (يُخفى عند فتح نافذة إنشاء/تعديل الدورة) -->
  <header id="mobileHeader" class="hidden lg:hidden fixed top-0 left-0 right-0 h-[60px] bg-white border-b border-slate-200 px-4 items-center justify-between z-[1000] shadow-sm max-lg:flex">
    <button class="w-[42px] h-[42px] flex items-center justify-center rounded-xl text-slate-800 text-xl active:bg-slate-50" id="menuToggle" aria-label="القائمة">
      <i class="fas fa-bars"></i>
    </button>
    <div class="flex items-center gap-2 font-bold text-lg text-indigo-600">
      <i class="fas fa-chart-line text-xl"></i>
      <span>LorkERP</span>
    </div>
    <div class="cursor-pointer" id="mobileUserBtn">
      <div class="w-9 h-9 rounded-full bg-gradient-to-br from-indigo-600 to-indigo-400 text-white flex items-center justify-center font-bold text-sm">
        <%= user.displayName.charAt(0) %>
      </div>
    </div>
  </header>

  <!-- Sidebar Overlay -->
  <div class="hidden fixed inset-0 bg-black/50 z-[1000] backdrop-blur-sm" id="sidebarOverlay"></div>

  <!-- Sidebar -->
  <aside class="fixed top-0 right-0 w-[260px] h-screen bg-[#1a1a2e] z-[1001] flex flex-col transition-all duration-300 overflow-y-auto overflow-x-hidden max-lg:translate-x-full" id="sidebar">
    <!-- Logo -->
    <div class="p-5 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-gradient-to-br from-indigo-600 to-indigo-400 rounded-xl flex items-center justify-center shrink-0">
          <i class="fas fa-chart-line text-white text-lg"></i>
        </div>
        <div>
          <h2 class="text-white text-xl font-bold leading-tight">LorkERP</h2>
          <span class="text-slate-400 text-xs">نظام المحاسبة</span>
        </div>
      </div>
      <button class="hidden max-lg:flex w-9 h-9 rounded-xl text-slate-400 items-center justify-center text-lg hover:bg-white/[0.08]" id="sidebarClose">
        <i class="fas fa-times"></i>
      </button>
    </div>

    <!-- User -->
    <div class="py-4 px-5 mx-3 bg-white/[0.08] rounded-xl flex items-center gap-3">
      <div class="w-11 h-11 rounded-full bg-gradient-to-br from-indigo-600 to-cyan-500 text-white flex items-center justify-center font-bold text-lg shrink-0">
        <%= user.displayName.charAt(0) %>
      </div>
      <div>
        <h4 class="text-white text-[0.95rem] font-semibold"><%= user.displayName %></h4>
        <span class="text-slate-400 text-xs"><%= user.role === 'admin' ? 'مدير النظام' : 'مستخدم' %></span>
      </div>
    </div>

    <!-- Navigation -->
    <nav class="flex-1 py-4">
      <ul class="px-3">
        <li class="pt-4 pb-2 px-4 text-[0.7rem] font-bold uppercase text-white/35 tracking-wider">الرئيسية</li>
        <li>
          <a href="/dashboard" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'home' ? 'bg-indigo-600/30 text-white' : 'text-slate-300 hover:bg-white/[0.08] hover:text-white' %>">
            <i class="fas fa-home w-5 text-center <%= page === 'home' ? 'text-indigo-400' : '' %>"></i>
            <span>لوحة التحكم</span>
          </a>
        </li>
        <li>
          <a href="/sheet" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'sheet' ? 'bg-indigo-600/30 text-white' : 'text-slate-300 hover:bg-white/[0.08] hover:text-white' %>">
            <i class="fas fa-file-excel w-5 text-center <%= page === 'sheet' ? 'text-indigo-400' : '' %>"></i>
            <span>Sheet</span>
          </a>
        </li>

        <li class="pt-4 pb-2 px-4 text-[0.7rem] font-bold uppercase text-white/35 tracking-wider">العمليات</li>
        <li>
          <a href="/payroll" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'payroll' ? 'bg-indigo-600/30 text-white' : 'text-slate-300 hover:bg-white/[0.08] hover:text-white' %>">
            <i class="fas fa-money-check-alt w-5 text-center <%= page === 'payroll' ? 'text-indigo-400' : '' %>"></i>
            <span>تدقيق الرواتب</span>
          </a>
        </li>
        <li>
          <a href="/search" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'search' ? 'bg-indigo-600/30 text-white' : 'text-slate-300 hover:bg-white/[0.08] hover:text-white' %>">
            <i class="fas fa-search w-5 text-center <%= page === 'search' ? 'text-indigo-400' : '' %>"></i>
            <span>البحث</span>
          </a>
        </li>
        <li>
          <a href="/clients" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'clients' ? 'bg-indigo-600/30 text-white' : 'text-slate-300 hover:bg-white/[0.08] hover:text-white' %>">
            <i class="fas fa-users w-5 text-center <%= page === 'clients' ? 'text-indigo-400' : '' %>"></i>
            <span>بيانات العملاء</span>
          </a>
        </li>
        <li>
          <a href="/messages" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'messages' ? 'bg-indigo-600/30 text-white' : 'text-slate-300 hover:bg-white/[0.08] hover:text-white' %>">
            <i class="fas fa-envelope-open-text w-5 text-center <%= page === 'messages' ? 'text-indigo-400' : '' %>"></i>
            <span>ترتيب الرسائل</span>
          </a>
        </li>
        <li>
          <a href="/approvals" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'approvals' ? 'bg-indigo-600/30 text-white' : 'text-slate-300 hover:bg-white/[0.08] hover:text-white' %>">
            <i class="fas fa-clipboard-check w-5 text-center <%= page === 'approvals' ? 'text-indigo-400' : '' %>"></i>
            <span>الاعتمادات</span>
          </a>
        </li>

        <li class="pt-4 pb-2 px-4 text-[0.7rem] font-bold uppercase text-white/35 tracking-wider">الوكالات والتحويل</li>
        <li>
          <a href="/sub-agencies" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'sub-agencies' ? 'bg-indigo-600/30 text-white' : 'text-slate-300 hover:bg-white/[0.08] hover:text-white' %>">
            <i class="fas fa-code-branch w-5 text-center <%= page === 'sub-agencies' ? 'text-indigo-400' : '' %>"></i>
            <span>الوكالات الفرعية</span>
          </a>
        </li>
        <li>
          <a href="/main-agency" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'main-agency' ? 'bg-indigo-600/30 text-white' : 'text-slate-300 hover:bg-white/[0.08] hover:text-white' %>">
            <i class="fas fa-building w-5 text-center <%= page === 'main-agency' ? 'text-indigo-400' : '' %>"></i>
            <span>الوكالة الرئيسية</span>
          </a>
        </li>
        <li>
          <a href="/transfer-companies" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'transfer-companies' ? 'bg-indigo-600/30 text-white' : 'text-slate-300 hover:bg-white/[0.08] hover:text-white' %>">
            <i class="fas fa-exchange-alt w-5 text-center <%= page === 'transfer-companies' ? 'text-indigo-400' : '' %>"></i>
            <span>شركات التحويل</span>
          </a>
        </li>
        <li>
          <a href="/funds" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'funds' ? 'bg-indigo-600/30 text-white' : 'text-slate-300 hover:bg-white/[0.08] hover:text-white' %>">
            <i class="fas fa-vault w-5 text-center <%= page === 'funds' ? 'text-indigo-400' : '' %>"></i>
            <span>الصناديع</span>
          </a>
        </li>
        <li>
          <a href="/shipping" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'shipping' ? 'bg-indigo-600/30 text-white' : 'text-slate-300 hover:bg-white/[0.08] hover:text-white' %>">
            <i class="fas fa-truck w-5 text-center <%= page === 'shipping' ? 'text-indigo-400' : '' %>"></i>
            <span>الشحن</span>
          </a>
        </li>

        <li class="pt-4 pb-2 px-4 text-[0.7rem] font-bold uppercase text-white/35 tracking-wider">التواصل والعملاء</li>
        <li>
          <a href="/client-portal" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'client-portal' ? 'bg-indigo-600/30 text-white' : 'text-slate-300 hover:bg-white/[0.08] hover:text-white' %>">
            <i class="fas fa-headset w-5 text-center <%= page === 'client-portal' ? 'text-indigo-400' : '' %>"></i>
            <span>واجهة العملاء</span>
          </a>
        </li>

        <li class="pt-4 pb-2 px-4 text-[0.7rem] font-bold uppercase text-white/35 tracking-wider">النظام</li>
        <li>
          <a href="/settings" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'settings' ? 'bg-indigo-600/30 text-white' : 'text-slate-300 hover:bg-white/[0.08] hover:text-white' %>">
            <i class="fas fa-cog w-5 text-center <%= page === 'settings' ? 'text-indigo-400' : '' %>"></i>
            <span>الإعدادات</span>
          </a>
        </li>
        <li>
          <a href="/logout" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 text-red-400 hover:bg-red-400/10">
            <i class="fas fa-sign-out-alt w-5 text-center"></i>
            <span>تسجيل الخروج</span>
          </a>
        </li>
      </ul>
    </nav>

    <div class="py-4 px-5 border-t border-white/[0.08] text-center">
      <p class="text-white/30 text-xs">LorkERP v1.0</p>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="lg:mr-[260px] min-h-screen transition-all duration-300 max-lg:pt-[60px] max-lg:pb-[65px]" id="mainContent">
    <div class="p-4 lg:p-8 2xl:px-12">
      <% if (page === 'home') { %>
        <%- include('partials/home') %>
      <% } else if (page === 'sheet') { %>
        <%- include('partials/sheet') %>
      <% } else if (page === 'payroll') { %>
        <%- include('partials/payroll') %>
      <% } else if (page === 'deferred-balance') { %>
        <%- include('partials/deferred-balance') %>
      <% } else if (page === 'search') { %>
        <%- include('partials/search') %>
          <% } else if (page === 'clients') { %>
        <%- include('partials/clients') %>
      <% } else if (page === 'messages') { %>
        <%- include('partials/messages') %>
      <% } else if (page === 'approvals') { %>
        <%- include('partials/approvals') %>
      <% } else if (page === 'sub-agencies') { %>
        <%- include('partials/sub-agencies') %>
      <% } else if (page === 'main-agency') { %>
        <%- include('partials/main-agency') %>
      <% } else if (page === 'transfer-companies') { %>
        <%- include('partials/transfer-companies') %>
      <% } else if (page === 'funds') { %>
        <%- include('partials/funds') %>
      <% } else if (page === 'shipping') { %>
        <%- include('partials/shipping') %>
      <% } else if (page === 'client-portal') { %>
        <%- include('partials/client-portal') %>
      <% } else if (page === 'settings') { %>
        <%- include('partials/settings') %>
      <% } %>
    </div>
  </main>

  <!-- Toast -->
  <div class="fixed top-5 left-5 z-[9999] flex flex-col gap-2 max-md:left-3 max-md:right-3 max-md:top-[72px]" id="toastContainer"></div>

  <!-- Mobile Bottom Nav + زر + في المنتصف -->
  <nav id="mobileBottomNav" class="hidden max-lg:flex fixed bottom-0 left-0 right-0 min-h-[65px] bg-white border-t border-slate-200 items-end z-[999] shadow-[0_-2px_10px_rgba(0,0,0,0.05)] pb-[env(safe-area-inset-bottom,0)] px-1 pt-1">
    <div class="flex flex-1 justify-evenly items-end pb-2 min-w-0">
      <a href="/dashboard" class="flex flex-col items-center gap-0.5 text-[0.65rem] font-medium py-1 px-1 rounded-lg transition-all duration-300 <%= page === 'home' ? 'text-indigo-600' : 'text-slate-400' %>">
        <i class="fas fa-home text-lg"></i>
        <span>الرئيسية</span>
      </a>
      <a href="/sheet" class="flex flex-col items-center gap-0.5 text-[0.65rem] font-medium py-1 px-1 rounded-lg transition-all duration-300 <%= page === 'sheet' ? 'text-indigo-600' : 'text-slate-400' %>">
        <i class="fas fa-file-excel text-lg"></i>
        <span>Sheet</span>
      </a>
    </div>
    <div class="flex flex-col items-center justify-end shrink-0 w-[3.25rem] px-0.5 pb-1">
      <button type="button" id="quickActionFabMobile" class="w-12 h-12 rounded-full bg-indigo-600 text-white shadow-lg border-4 border-white -mt-5 flex items-center justify-center active:scale-95 transition-transform focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2" aria-haspopup="true" aria-expanded="false" aria-label="إجراء سريع">
        <i class="fas fa-plus text-xl"></i>
      </button>
    </div>
    <div class="flex flex-1 justify-evenly items-end pb-2 min-w-0">
      <a href="/clients" class="flex flex-col items-center gap-0.5 text-[0.65rem] font-medium py-1 px-1 rounded-lg transition-all duration-300 <%= page === 'clients' ? 'text-indigo-600' : 'text-slate-400' %>">
        <i class="fas fa-users text-lg"></i>
        <span>العملاء</span>
      </a>
      <a href="/search" class="flex flex-col items-center gap-0.5 text-[0.65rem] font-medium py-1 px-1 rounded-lg transition-all duration-300 <%= page === 'search' ? 'text-indigo-600' : 'text-slate-400' %>">
        <i class="fas fa-search text-lg"></i>
        <span>البحث</span>
      </a>
    </div>
  </nav>

  <!-- زر + ثابت يمين الشاشة (لابتوب فقط) -->
  <button type="button" id="quickActionFabDesktop" class="hidden lg:flex fixed bottom-8 right-8 z-[998] w-14 h-14 rounded-full bg-indigo-600 text-white shadow-xl border-4 border-white items-center justify-center active:scale-95 transition-transform focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2" aria-haspopup="true" aria-expanded="false" aria-label="إجراء سريع">
    <i class="fas fa-plus text-2xl"></i>
  </button>

  <!-- خلفية + قائمة الإجراءات السريعة -->
  <div id="quickActionBackdrop" class="hidden fixed inset-0 bg-slate-900/40 z-[1002] backdrop-blur-[1px]" aria-hidden="true"></div>
  <div id="quickActionMenu" class="hidden fixed z-[1003] left-4 right-4 max-lg:bottom-[calc(4.5rem+env(safe-area-inset-bottom,0px))] lg:left-auto lg:right-8 lg:bottom-[7.5rem] lg:w-56 rounded-2xl bg-white shadow-2xl border border-slate-200 overflow-hidden" role="menu" aria-label="خيارات سريعة">
    <button type="button" class="quick-action-item w-full flex items-center gap-3 px-4 py-3.5 text-right text-sm font-semibold text-slate-800 hover:bg-slate-50 border-b border-slate-100 transition-colors" data-quick-type="صادر" role="menuitem">
      <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-rose-100 text-rose-600"><i class="fas fa-upload"></i></span>
      صادر
    </button>
    <button type="button" class="quick-action-item w-full flex items-center gap-3 px-4 py-3.5 text-right text-sm font-semibold text-slate-800 hover:bg-slate-50 border-b border-slate-100 transition-colors" data-quick-type="وارد" role="menuitem">
      <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-emerald-100 text-emerald-600"><i class="fas fa-download"></i></span>
      وارد
    </button>
    <button type="button" class="quick-action-item w-full flex items-center gap-3 px-4 py-3.5 text-right text-sm font-semibold text-slate-800 hover:bg-slate-50 transition-colors" data-quick-type="مرتجع" role="menuitem">
      <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-amber-100 text-amber-600"><i class="fas fa-rotate-left"></i></span>
      مرتجع
    </button>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/socket.io/4.7.5/socket.io.min.js"></script>
  <script src="/js/app.js"></script>
  <% if (page === 'sheet') { %>
    <script src="/js/sheets.js"></script>
  <% } %>
  <% if (page === 'settings') { %>
    <script src="/js/ai-settings.js"></script>
  <% } %>
  <% if (page === 'shipping') { %>
    <script src="/js/shipping.js"></script>
  <% } %>
  <% if (page === 'sub-agencies') { %>
    <script src="/js/sub-agencies.js"></script>
  <% } %>
  <% if (page === 'funds') { %>
    <script src="/js/funds.js"></script>
  <% } %>
  <% if (page === 'transfer-companies') { %>
    <script src="/js/transfer-companies.js"></script>
  <% } %>
  <% if (page === 'approvals') { %>
    <script src="/js/approvals.js"></script>
  <% } %>
</body>
</html>
