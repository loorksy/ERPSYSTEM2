            <span>الوكالات الفرعية</span>
          </a>
        </li>
        <li>
          <a href="/main-agency" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'main-agency' ? 'bg-[#c9a227]/10 text-white' : 'text-slate-400 hover:bg-white/[0.06] hover:text-white' %>">
