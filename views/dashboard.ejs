        </li>

        <li class="pt-4 pb-2 px-4 text-[0.7rem] font-bold uppercase text-white/35 tracking-wider">العمليات</li>
        <li>
          <a href="/payroll" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'payroll-native' ? 'bg-indigo-600/30 text-white' : 'text-slate-300 hover:bg-white/[0.08] hover:text-white' %>">
            <i class="fas fa-money-check-alt w-5 text-center <%= page === 'payroll-native' ? 'text-indigo-400' : '' %>"></i>
            <span>تدقيق الرواتب</span>
          </a>
        </li>
        <li>
          <a href="/payroll-google" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.85rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'payroll-google' ? 'bg-indigo-600/30 text-white' : 'text-slate-300 hover:bg-white/[0.08] hover:text-white' %>">
            <i class="fab fa-google-drive w-5 text-center <%= page === 'payroll-google' ? 'text-indigo-400' : '' %>"></i>
            <span>تدقيق الرواتب (Google)</span>
          </a>
        </li>
        <li>
          <a href="/local-audit" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'local-audit' ? 'bg-indigo-600/30 text-white' : 'text-slate-300 hover:bg-white/[0.08] hover:text-white' %>">
            <i class="fas fa-clipboard-check w-5 text-center <%= page === 'local-audit' ? 'text-indigo-400' : '' %>"></i>
            <span>تدقيق محلي</span>
          </a>
        </li>
        <li>
          <a href="/search" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'search' ? 'bg-indigo-600/30 text-white' : 'text-slate-300 hover:bg-white/[0.08] hover:text-white' %>">
            <i class="fas fa-search w-5 text-center <%= page === 'search' ? 'text-indigo-400' : '' %>"></i>
            <span>البحث</span>
          </a>
        </li>
        <li>
          <a href="/clients" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'clients' ? 'bg-indigo-600/30 text-white' : 'text-slate-300 hover:bg-white/[0.08] hover:text-white' %>">
            <i class="fas fa-users w-5 text-center <%= page === 'clients' ? 'text-indigo-400' : '' %>"></i>
            <span>بيانات العملاء</span>
          </a>
        </li>
        <li>
          <a href="/messages" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'messages' ? 'bg-indigo-600/30 text-white' : 'text-slate-300 hover:bg-white/[0.08] hover:text-white' %>">
            <i class="fas fa-envelope-open-text w-5 text-center <%= page === 'messages' ? 'text-indigo-400' : '' %>"></i>
            <span>ترتيب الرسائل</span>
          </a>
        </li>
        <li>
          <a href="/approvals" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'approvals' ? 'bg-indigo-600/30 text-white' : 'text-slate-300 hover:bg-white/[0.08] hover:text-white' %>">
