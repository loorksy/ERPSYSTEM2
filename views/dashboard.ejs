          </a>
        </li>
        <li>
          <a href="/fx-spread" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'fx-spread' ? 'bg-[#c9a227]/10 text-white' : 'text-slate-400 hover:bg-white/[0.06] hover:text-white' %>">
            <i class="fas fa-chart-line w-5 text-center <%= page === 'fx-spread' ? 'text-[#c9a227]' : '' %>"></i>
            <span>فرق التصريف</span>
          </a>
        </li>
        <li>
          <a href="/shipping" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'shipping' ? 'bg-[#c9a227]/10 text-white' : 'text-slate-400 hover:bg-white/[0.06] hover:text-white' %>">
            <i class="fas fa-truck w-5 text-center <%= page === 'shipping' ? 'text-[#c9a227]' : '' %>"></i>
            <span>الشحن</span>
          </a>
