<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="theme-color" content="#1a1a2e">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>LorkERP - <%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/tailwind.css">
  <style>
    /* Tailwind المُجمَّع لا يضمّ كل مرافقات lg — نُثبّت FAB وشريط الموبايل هنا */
    @media (max-width: 63.99rem) {
      #mobileBottomNav {
        display: grid !important;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        align-items: end;
        justify-items: stretch;
        column-gap: 0;
        overflow: visible;
      }
      #mobileBottomNav > a,
      #mobileBottomNav > .mobile-bottom-nav-fab-wrap {
        min-width: 0;
        justify-self: stretch;
      }
      #mobileBottomNav > .mobile-bottom-nav-fab-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-end;
        padding-bottom: 0.25rem;
      }
    }
    @media (min-width: 64rem) {
      #quickActionRadialDesktop {
        display: block !important;
        position: fixed;
        bottom: 2rem;
        left: 2.35rem;
        right: auto;
        z-index: 1004;
      }
    }
    /* زر إجراءات شعاعي (مستوحى من Uiverse — ألوان LorkERP) */
    .quick-action-radial {
      position: relative;
      width: 3.5rem;
      height: 3.5rem;
      flex-shrink: 0;
    }
    .quick-action-radial--desktop {
      width: 3.75rem;
      height: 3.75rem;
    }
    .quick-action-radial-circle {
      position: relative;
      z-index: 6;
      width: 3rem;
      height: 3rem;
      margin: 0 auto;
      border-radius: 50%;
      border: 4px solid #fff;
      background: linear-gradient(155deg, #6366f1 0%, #4f46e5 48%, #4338ca 100%);
      box-shadow: 0 6px 18px rgba(79, 70, 229, 0.38);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      cursor: pointer;
      transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
    }
    .quick-action-radial--desktop .quick-action-radial-circle {
      width: 3.5rem;
      height: 3.5rem;
    }
    .quick-action-radial-circle:hover {
      filter: brightness(1.06);
      box-shadow: 0 8px 22px rgba(79, 70, 229, 0.45);
    }
    .quick-action-radial--open .quick-action-radial-circle {
      transform: scale(0.93);
      box-shadow: 0 4px 16px rgba(26, 26, 46, 0.2);
      background: linear-gradient(155deg, #4f46e5 0%, #3730a3 100%);
    }
    .quick-action-radial-icon {
      transition: transform 0.38s cubic-bezier(0.34, 1.35, 0.64, 1);
      display: block;
      line-height: 1;
    }
    .quick-action-radial--open .quick-action-radial-icon {
      transform: rotate(45deg);
    }
    .quick-action-radial-subs {
      position: absolute;
      left: 50%;
      top: 50%;
      width: 0;
      height: 0;
      z-index: 5;
      pointer-events: none;
    }
    .quick-action-radial--open .quick-action-radial-subs {
      pointer-events: auto;
    }
    .quick-action-radial-sub {
      position: absolute;
      left: 0;
      top: 0;
      width: 2.5rem;
      height: 2.5rem;
      margin-left: -1.25rem;
      margin-top: -1.25rem;
      border-radius: 50%;
      border: 3px solid #fff;
      transform: scale(0.35);
      opacity: 0;
      transition: transform 0.28s cubic-bezier(0.34, 1.35, 0.64, 1), opacity 0.22s ease, box-shadow 0.2s ease;
      box-shadow: 0 6px 14px rgba(15, 23, 42, 0.18);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-size: 0.7rem;
      font-weight: 700;
      padding: 0;
    }
    .quick-action-radial--desktop .quick-action-radial-sub {
      width: 2.75rem;
      height: 2.75rem;
      margin-left: -1.375rem;
      margin-top: -1.375rem;
      font-size: 0.75rem;
    }
    .quick-action-radial-sub[data-quick-type="qa-out"],
    .quick-action-radial-sub[data-quick-type="صادر"] {
      background: linear-gradient(145deg, #fb7185, #e11d48);
    }
    .quick-action-radial-sub[data-quick-type="qa-in"],
    .quick-action-radial-sub[data-quick-type="وارد"] {
      background: linear-gradient(145deg, #34d399, #059669);
    }
    .quick-action-radial-sub[data-quick-type="مرتجع"] {
      background: linear-gradient(145deg, #fbbf24, #d97706);
    }
    .quick-action-radial-sub--wide {
      width: auto !important;
      min-width: 3.25rem;
      padding: 0 0.35rem !important;
      font-size: 0.62rem !important;
      line-height: 1.1;
    }
    .quick-action-radial-sub:hover {
      filter: brightness(1.08);
      box-shadow: 0 8px 18px rgba(15, 23, 42, 0.22);
    }
    /* زرّان فقط: صادر / وارد */
    .quick-action-radial--open .quick-action-radial-sub:nth-child(1) {
      transform: translate(-3.5rem, -4.6rem) scale(1);
      opacity: 1;
      transition-delay: 0.04s;
    }
    .quick-action-radial--open .quick-action-radial-sub:nth-child(2) {
      transform: translate(3.5rem, -4.6rem) scale(1);
      opacity: 1;
      transition-delay: 0.09s;
    }
    @media (min-width: 64rem) {
      .quick-action-radial--desktop.quick-action-radial--open .quick-action-radial-sub:nth-child(1) {
        transform: translate(-3.85rem, -4.4rem) scale(1);
      }
      .quick-action-radial--desktop.quick-action-radial--open .quick-action-radial-sub:nth-child(2) {
        transform: translate(3.85rem, -4.4rem) scale(1);
      }
    }
    #mobileBottomNav:has(.quick-action-radial--open) {
      z-index: 1005;
    }
    .mobile-bottom-nav-fab-wrap {
      overflow: visible;
    }
    /* حركة الضغط على زر + */
    @keyframes quick-action-fab-press {
      0% { transform: scale(1); }
      40% { transform: scale(0.86); }
      70% { transform: scale(1.06); }
      100% { transform: scale(1); }
    }
    button.quick-action-fab {
      transition: box-shadow 0.2s ease, filter 0.2s ease;
    }
    button.quick-action-fab.quick-action-fab-pulse {
      animation: quick-action-fab-press 0.45s cubic-bezier(0.34, 1.45, 0.64, 1);
    }
    /* خلفية عند فتح الإجراءات الشعاعية */
    #quickActionBackdrop {
      opacity: 0;
      transition: opacity 0.22s ease;
    }
    #quickActionBackdrop.quick-action-panel-open {
      opacity: 1;
    }
    @media (max-width: 63.99rem) {
      #quickActionRadialDesktop {
        display: none !important;
      }
    }
  </style>
</head>
<body class="min-h-screen bg-slate-100 font-[Tajawal] text-slate-800">

  <!-- Mobile Header (يُخفى عند فتح نافذة إنشاء/تعديل الدورة) -->
  <header id="mobileHeader" class="hidden lg:hidden fixed top-0 left-0 right-0 h-[60px] bg-white border-b border-slate-200 px-4 items-center justify-between z-[1000] shadow-sm max-lg:flex">
    <button class="w-[42px] h-[42px] flex items-center justify-center rounded-xl text-slate-800 text-xl active:bg-slate-50" id="menuToggle" aria-label="القائمة">
      <i class="fas fa-bars"></i>
    </button>
    <div class="flex items-center gap-2 font-bold text-lg text-indigo-600">
      <i class="fas fa-chart-line text-xl"></i>
      <span>LorkERP</span>
    </div>
    <div class="cursor-pointer" id="mobileUserBtn">
      <div class="w-9 h-9 rounded-full bg-gradient-to-br from-indigo-600 to-indigo-400 text-white flex items-center justify-center font-bold text-sm">
        <%= user.displayName.charAt(0) %>
      </div>
    </div>
  </header>

  <!-- Sidebar Overlay -->
  <div class="hidden fixed inset-0 bg-black/50 z-[1000] backdrop-blur-sm" id="sidebarOverlay"></div>

  <!-- Sidebar -->
