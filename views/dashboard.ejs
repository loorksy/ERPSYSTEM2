            <span>إضافات وخصومات</span>
          </a>
        </li>
        <li>
          <a href="/messages" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'messages' ? 'bg-[#c9a227]/10 text-white' : 'text-slate-400 hover:bg-white/[0.06] hover:text-white' %>">
            <i class="fas fa-envelope-open-text w-5 text-center <%= page === 'messages' ? 'text-[#c9a227]' : '' %>"></i>
            <span>ترتيب الرسائل</span>
          </a>
        </li>
        <li>
          <a href="/approvals" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'approvals' ? 'bg-[#c9a227]/10 text-white' : 'text-slate-400 hover:bg-white/[0.06] hover:text-white' %>">
            <i class="fas fa-clipboard-check w-5 text-center <%= page === 'approvals' ? 'text-[#c9a227]' : '' %>"></i>
            <span>الاعتمادات</span>
          </a>
        </li>

        <li class="pt-5 pb-2 px-4 text-[0.65rem] font-bold uppercase text-white/25 tracking-widest">الوكالات والتحويل</li>
        <li>
          <a href="/sub-agencies" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-300 mb-0.5 <%= page === 'sub-agencies' ? 'bg-[#c9a227]/10 text-white' : 'text-slate-400 hover:bg-white/[0.06] hover:text-white' %>">
