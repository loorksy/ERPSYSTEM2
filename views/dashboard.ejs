<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="theme-color" content="#0f2744">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>LorkERP - <%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/tailwind.css">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    /* Tailwind المُجمَّع لا يضمّ كل مرافقات lg — نُثبّت FAB وشريط الموبايل هنا */
    @media (max-width: 63.99rem) {
      #mobileBottomNav {
        display: grid !important;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        align-items: end;
        justify-items: stretch;
        column-gap: 0;
        overflow: visible;
      }
      #mobileBottomNav > a,
      #mobileBottomNav > .mobile-bottom-nav-fab-wrap {
        min-width: 0;
        justify-self: stretch;
      }
      #mobileBottomNav > .mobile-bottom-nav-fab-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-end;
        padding-bottom: 0.25rem;
      }
    }
    @media (min-width: 64rem) {
      #quickActionRadialDesktop {
        display: block !important;
        position: fixed;
        bottom: 2rem;
        left: 2.35rem;
        right: auto;
        z-index: 1004;
      }
    }
    :root {
      --mv-refund: #b91c1c;
      --mv-debt: #c2410c;
      --mv-payout: #9a3412;
      --mv-balance: #047857;
    }
    .mv-border-refund { border-left: 3px solid var(--mv-refund); }
    .mv-border-debt { border-left: 3px solid var(--mv-debt); }
    .mv-border-payout { border-left: 3px solid var(--mv-payout); }
    .mv-border-balance { border-left: 3px solid var(--mv-balance); }
    /* زر إجراءات شعاعي (مستوحى من Uiverse — ألوان LorkERP) */
    .quick-action-radial {
      position: relative;
      width: 3.5rem;
      height: 3.5rem;
      flex-shrink: 0;
    }
    .quick-action-radial--desktop {
      width: 3.75rem;
      height: 3.75rem;
    }
    .quick-action-radial-circle {
      position: relative;
      z-index: 6;
      width: 3rem;
      height: 3rem;
      margin: 0 auto;
      border-radius: 50%;
      border: 4px solid #fff;
      background: linear-gradient(155deg, #1e3a5f 0%, #0f2744 100%);
      box-shadow: 0 6px 18px rgba(30, 58, 95, 0.38);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      cursor: pointer;
      transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
    }
    .quick-action-radial--desktop .quick-action-radial-circle {
      width: 3.5rem;
      height: 3.5rem;
    }
    .quick-action-radial-circle:hover {
      filter: brightness(1.06);
      box-shadow: 0 8px 22px rgba(30, 58, 95, 0.45);
    }
    .quick-action-radial--open .quick-action-radial-circle {
      transform: scale(0.93);
      box-shadow: 0 4px 16px rgba(15, 39, 68, 0.2);
      background: linear-gradient(155deg, #1e3a5f 0%, #0f2744 100%);
    }
    .quick-action-radial-icon {
      transition: transform 0.38s cubic-bezier(0.34, 1.35, 0.64, 1);
      display: block;
      line-height: 1;
    }
    .quick-action-radial--open .quick-action-radial-icon {
      transform: rotate(45deg);
    }
    .quick-action-radial-subs {
      position: absolute;
      left: 50%;
      top: 50%;
      width: 0;
      height: 0;
      z-index: 5;
      pointer-events: none;
    }
    .quick-action-radial--open .quick-action-radial-subs {
      pointer-events: auto;
    }
    .quick-action-radial-sub {
      position: absolute;
      left: 0;
      top: 0;
      width: 2.5rem;
      height: 2.5rem;
      margin-left: -1.25rem;
      margin-top: -1.25rem;
      border-radius: 50%;
      border: 3px solid #fff;
      transform: scale(0.35);
      opacity: 0;
      transition: transform 0.28s cubic-bezier(0.34, 1.35, 0.64, 1), opacity 0.22s ease, box-shadow 0.2s ease;
      box-shadow: 0 6px 14px rgba(15, 23, 42, 0.18);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-size: 0.7rem;
      font-weight: 700;
      padding: 0;
    }
    .quick-action-radial--desktop .quick-action-radial-sub {
      width: 2.75rem;
      height: 2.75rem;
      margin-left: -1.375rem;
      margin-top: -1.375rem;
      font-size: 0.75rem;
    }
    .quick-action-radial-sub[data-quick-type="qa-out"],
    .quick-action-radial-sub[data-quick-type="صادر"] {
      background: linear-gradient(145deg, #fb7185, #e11d48);
    }
    .quick-action-radial-sub[data-quick-type="qa-in"],
    .quick-action-radial-sub[data-quick-type="وارد"] {
      background: linear-gradient(145deg, #34d399, #059669);
    }
    .quick-action-radial-sub[data-quick-type="مرتجع"] {
      background: linear-gradient(145deg, #fbbf24, #d97706);
    }
    .quick-action-radial-sub--wide {
      width: auto !important;
      min-width: 3.25rem;
      padding: 0 0.35rem !important;
      font-size: 0.62rem !important;
      line-height: 1.1;
    }
    .quick-action-radial-sub:hover {
      filter: brightness(1.08);
      box-shadow: 0 8px 18px rgba(15, 23, 42, 0.22);
    }
    /* زرّان فقط: صادر / وارد */
    .quick-action-radial--open .quick-action-radial-sub:nth-child(1) {
      transform: translate(-3.5rem, -4.6rem) scale(1);
      opacity: 1;
      transition-delay: 0.04s;
    }
    .quick-action-radial--open .quick-action-radial-sub:nth-child(2) {
      transform: translate(3.5rem, -4.6rem) scale(1);
      opacity: 1;
      transition-delay: 0.09s;
    }
    @media (min-width: 64rem) {
      .quick-action-radial--desktop.quick-action-radial--open .quick-action-radial-sub:nth-child(1) {
        transform: translate(-3.85rem, -4.4rem) scale(1);
      }
      .quick-action-radial--desktop.quick-action-radial--open .quick-action-radial-sub:nth-child(2) {
        transform: translate(3.85rem, -4.4rem) scale(1);
      }
    }
    #mobileBottomNav:has(.quick-action-radial--open) {
      z-index: 1005;
    }
    .mobile-bottom-nav-fab-wrap {
      overflow: visible;
    }
    /* حركة الضغط على زر + */
    @keyframes quick-action-fab-press {
      0% { transform: scale(1); }
      40% { transform: scale(0.86); }
      70% { transform: scale(1.06); }
      100% { transform: scale(1); }
    }
    button.quick-action-fab {
      transition: box-shadow 0.2s ease, filter 0.2s ease;
    }
    button.quick-action-fab.quick-action-fab-pulse {
      animation: quick-action-fab-press 0.45s cubic-bezier(0.34, 1.45, 0.64, 1);
    }
    /* خلفية عند فتح الإجراءات الشعاعية */
    #quickActionBackdrop {
      opacity: 0;
      transition: opacity 0.22s ease;
    }
    #quickActionBackdrop.quick-action-panel-open {
      opacity: 1;
    }
    @media (max-width: 63.99rem) {
      #quickActionRadialDesktop {
        display: none !important;
      }
    }
    /* موبايل: إخفاء الشريط الجانبي بالكامل (تفادي ظهور شريط بسبب subpixel أو translate-x-full) */
    @media (max-width: 63.99rem) {
      #sidebar {
        transform: translateX(calc(100% + 4px));
      }
      #sidebar.translate-x-0 {
        transform: translateX(0);
      }
    }
  </style>
</head>
<body class="min-h-screen bg-slate-50 font-[Tajawal] text-slate-800 max-lg:overflow-x-hidden">

  <!-- Mobile Header -->
  <header id="mobileHeader" class="hidden lg:hidden fixed top-0 left-0 right-0 h-[64px] bg-white/98 backdrop-blur-xl border-b border-slate-200 px-4 items-center justify-between z-[1000] shadow-sm max-lg:flex">
    <button class="w-11 h-11 flex items-center justify-center rounded-xl text-slate-700 text-xl active:bg-slate-100 transition-all duration-200" id="menuToggle" aria-label="القائمة">
      <i class="fas fa-bars"></i>
    </button>
    <div class="flex items-center gap-2.5 font-bold text-xl text-[#1e3a5f]">
      <div class="w-9 h-9 bg-gradient-to-br from-[#1e3a5f] to-[#0f2744] rounded-xl flex items-center justify-center shadow-sm border border-[#c9a227]/20">
        <i class="fas fa-chart-line text-[#c9a227] text-base"></i>
      </div>
      <span>LorkERP</span>
    </div>
    <div class="cursor-pointer" id="mobileUserBtn">
      <div class="w-10 h-10 rounded-full bg-gradient-to-br from-[#1e3a5f] to-[#0f2744] text-white flex items-center justify-center font-bold text-sm shadow-md border-2 border-[#c9a227]/30">
        <%= user.displayName.charAt(0) %>
      </div>
    </div>
  </header>

  <!-- Sidebar Overlay -->
  <div class="hidden fixed inset-0 bg-slate-900/60 z-[1000] backdrop-blur-sm" id="sidebarOverlay"></div>

  <!-- Sidebar -->
  <aside class="fixed top-0 right-0 w-[280px] h-screen bg-[#0f2744] z-[1001] flex flex-col transition-all duration-300 overflow-y-auto overflow-x-hidden" id="sidebar">
    <!-- Logo -->
    <div class="p-6 flex items-center justify-between border-b border-white/[0.05]">
      <div class="flex items-center gap-3.5">
        <div class="w-12 h-12 bg-gradient-to-br from-[#1e3a5f] to-[#2d5a87] rounded-[14px] flex items-center justify-center shrink-0 shadow-lg border border-[#c9a227]/20">
          <i class="fas fa-chart-line text-[#c9a227] text-xl"></i>
        </div>
        <div>
          <h2 class="text-white text-xl font-bold leading-tight tracking-tight">LorkERP</h2>
          <span class="text-slate-400 text-[0.7rem]">نظام المحاسبة المتكامل</span>
        </div>
      </div>
      <button class="hidden max-lg:flex w-10 h-10 rounded-xl text-slate-400 items-center justify-center text-lg hover:bg-white/[0.06] hover:text-white transition-all duration-200" id="sidebarClose">
        <i class="fas fa-times"></i>
      </button>
    </div>

    <!-- User -->
    <div class="py-4 px-4 mx-4 mt-5 bg-white/[0.03] rounded-2xl flex items-center gap-3.5 border border-white/[0.05]">
      <div class="w-12 h-12 rounded-full bg-gradient-to-br from-[#c9a227] to-[#a68621] text-white flex items-center justify-center font-bold text-lg shrink-0 shadow-md">
        <%= user.displayName.charAt(0) %>
      </div>
      <div>
        <h4 class="text-white text-[0.95rem] font-semibold"><%= user.displayName %></h4>
        <span class="text-slate-400 text-xs"><%= user.role === 'admin' ? 'مدير النظام' : 'مستخدم' %></span>
      </div>
    </div>

    <!-- Navigation -->
    <nav class="flex-1 py-4">
      <ul class="px-3">
        <li class="pt-5 pb-2 px-4 text-[0.65rem] font-bold uppercase text-white/25 tracking-widest">الرئيسية</li>
        <li>
          <a href="/dashboard" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-200 mb-1 relative <%= page === 'home' ? 'bg-[#c9a227]/10 text-white' : 'text-slate-400 hover:bg-white/[0.06] hover:text-white' %>">
            <% if (page === 'home') { %><span class="absolute right-0 top-1/2 -translate-y-1/2 w-[3px] h-6 bg-[#c9a227] rounded-l-full"></span><% } %>
            <i class="fas fa-home w-5 text-center <%= page === 'home' ? 'text-[#c9a227]' : '' %>"></i>
            <span>لوحة التحكم</span>
          </a>
        </li>
        <li>
          <a href="/sheet" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-200 mb-1 relative <%= page === 'sheet' ? 'bg-[#c9a227]/10 text-white' : 'text-slate-400 hover:bg-white/[0.06] hover:text-white' %>">
            <% if (page === 'sheet') { %><span class="absolute right-0 top-1/2 -translate-y-1/2 w-[3px] h-6 bg-[#c9a227] rounded-l-full"></span><% } %>
            <i class="fas fa-file-excel w-5 text-center <%= page === 'sheet' ? 'text-[#c9a227]' : '' %>"></i>
            <span>Sheet</span>
          </a>
        </li>

        <li class="pt-5 pb-2 px-4 text-[0.65rem] font-bold uppercase text-white/25 tracking-widest">العمليات</li>
        <li>
          <a href="/payroll" class="flex items-center gap-3 py-3 px-4 rounded-xl text-[0.9rem] font-medium transition-all duration-200 mb-1 relative <%= page === 'payroll-google' ? 'bg-[#c9a227]/10 text-white' : 'text-slate-400 hover:bg-white/[0.06] hover:text-white' %>">
            <% if (page === 'payroll-google') { %><span class="absolute right-0 top-1/2 -translate-y-1/2 w-[3px] h-6 bg-[#c9a227] rounded-l-full"></span><% } %>
            <i class="fas fa-money-check-alt w-5 text-center <%= page === 'payroll-google' ? 'text-[#c9a227]' : '' %>"></i>
            <span class="flex items-center gap-2 flex-wrap">
              <span>تدقيق الرواتب</span>
