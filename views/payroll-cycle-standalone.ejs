<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5, viewport-fit=cover">
  <meta name="theme-color" content="#1e293b">
  <title>LorkERP — محرّر الدورة</title>
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/tailwind.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/handsontable@14.1.0/dist/handsontable.full.min.css">
  <style>
    html, body { height: 100%; }
    body { font-family: 'Tajawal', system-ui, sans-serif; }
    .pn-panel { min-height: 260px; }
    @media (min-width: 1024px) {
      .pn-split { height: calc(100vh - 11.5rem); min-height: 320px; }
    }
  </style>
</head>
<body class="bg-slate-100 text-slate-800 flex flex-col min-h-full">
  <header class="sticky top-0 z-50 shrink-0 border-b border-slate-200 bg-white/95 backdrop-blur shadow-sm">
    <div class="px-3 py-2.5 md:px-4 flex flex-col gap-2 lg:flex-row lg:items-center lg:justify-between">
      <div class="flex flex-wrap items-center gap-2 min-w-0">
        <a href="/payroll" class="inline-flex items-center gap-1.5 px-3 py-2 rounded-xl border border-slate-200 text-sm text-slate-700 hover:bg-slate-50 shrink-0">
          <i class="fas fa-arrow-right"></i> القائمة
        </a>
        <a href="/dashboard" class="inline-flex items-center gap-1.5 px-3 py-2 rounded-xl text-sm text-indigo-600 hover:bg-indigo-50 shrink-0">
          <i class="fas fa-home"></i> لوحة التحكم
        </a>
        <div class="flex items-center gap-2 flex-1 min-w-0 max-w-full">
          <label class="text-sm text-slate-500 shrink-0 hidden sm:inline">اسم الدورة</label>
          <input type="text" id="pnCycleName" class="flex-1 min-w-0 py-2 px-3 border border-slate-200 rounded-xl text-sm bg-white" placeholder="اسم الدورة" />
          <button type="button" id="pnSaveNameBtn" class="px-3 py-2 rounded-xl bg-slate-700 text-white text-sm shrink-0">حفظ الاسم</button>
        </div>
      </div>
      <div class="flex flex-wrap gap-1.5 items-center justify-end">
        <button type="button" id="pnSaveSheetsBtn" class="inline-flex items-center gap-1.5 px-3 py-2 rounded-xl bg-indigo-600 text-white text-sm font-medium">
          <i class="fas fa-save"></i> حفظ الجداول
        </button>
        <button type="button" id="pnAuditBtn" class="inline-flex items-center gap-1.5 px-3 py-2 rounded-xl bg-slate-800 text-white text-sm font-medium">
          <i class="fas fa-check-double"></i> تدقيق
        </button>
        <button type="button" id="pnExportMgmt" class="inline-flex items-center gap-1 px-2.5 py-2 rounded-xl border border-emerald-200 bg-emerald-50 text-emerald-900 text-xs font-medium" title="تصدير الإدارة إلى Google">إدارة</button>
        <button type="button" id="pnExportAgent" class="inline-flex items-center gap-1 px-2.5 py-2 rounded-xl border border-emerald-200 bg-emerald-50 text-emerald-900 text-xs font-medium" title="تصدير الوكيل">وكيل</button>
        <button type="button" id="pnExportUser" class="inline-flex items-center gap-1 px-2.5 py-2 rounded-xl border border-emerald-200 bg-emerald-50 text-emerald-900 text-xs font-medium" title="معلومات المستخدمين">مستخدمين</button>
      </div>
    </div>
  </header>

  <main class="flex-1 flex flex-col gap-2 p-2 md:p-3 min-h-0 overflow-auto">
    <p class="text-xs text-slate-500 px-1 md:hidden"><i class="fas fa-mobile-alt ml-1"></i> مرّر أفقياً داخل كل جدول إذا لزم الأمر.</p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-2 lg:gap-3 pn-split min-h-0">
      <!-- إدارة -->
      <section class="pn-panel flex flex-col bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden min-h-0">
        <div class="px-3 py-2 border-b border-slate-100 bg-amber-50/80 flex flex-wrap items-center gap-2 justify-between">
          <h2 class="font-bold text-slate-800 text-sm flex items-center gap-2"><i class="fas fa-building text-amber-600"></i> جدول الإدارة</h2>
          <div class="flex flex-wrap gap-1">
            <button type="button" class="pn-add-sheet px-2 py-1 rounded-lg border border-dashed border-amber-300 text-xs text-amber-900" data-kind="management">+ ورقة</button>
            <label class="px-2 py-1 rounded-lg border border-slate-200 text-xs cursor-pointer hover:bg-slate-50">
              استبدال
              <input type="file" class="hidden pn-replace-file" data-kind="management" accept=".xlsx,.xls" />
            </label>
          </div>
        </div>
        <div id="pnMgmtSheetTabs" class="flex flex-wrap gap-1 px-2 py-1.5 border-b border-slate-100 bg-white min-h-[40px]"></div>
        <div id="pnHotMgmt" class="flex-1 w-full overflow-auto min-h-[240px] p-1"></div>
      </section>

      <!-- وكيل -->
      <section class="pn-panel flex flex-col bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden min-h-0">
        <div class="px-3 py-2 border-b border-slate-100 bg-violet-50/80 flex flex-wrap items-center gap-2 justify-between">
          <h2 class="font-bold text-slate-800 text-sm flex items-center gap-2"><i class="fas fa-hand-holding-usd text-violet-600"></i> جدول الوكيل</h2>
          <div class="flex flex-wrap gap-1">
            <button type="button" class="pn-add-sheet px-2 py-1 rounded-lg border border-dashed border-violet-300 text-xs text-violet-900" data-kind="agent">+ ورقة</button>
            <label class="px-2 py-1 rounded-lg border border-slate-200 text-xs cursor-pointer hover:bg-slate-50">
              استبدال
              <input type="file" class="hidden pn-replace-file" data-kind="agent" accept=".xlsx,.xls" />
            </label>
          </div>
        </div>
        <div id="pnAgentSheetTabs" class="flex flex-wrap gap-1 px-2 py-1.5 border-b border-slate-100 bg-white min-h-[40px]"></div>
        <div id="pnHotAgent" class="flex-1 w-full overflow-auto min-h-[240px] p-1"></div>
      </section>
    </div>

    <!-- معلومات المستخدمين -->
    <section class="flex flex-col bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden min-h-[280px] lg:min-h-[36vh]">
      <div class="px-3 py-2 border-b border-slate-100 bg-sky-50/80 flex flex-wrap items-center gap-2 justify-between">
        <h2 class="font-bold text-slate-800 text-sm flex items-center gap-2"><i class="fas fa-id-card text-sky-600"></i> معلومات المستخدمين (للتدقيق)</h2>
        <div class="flex flex-wrap gap-1">
          <button type="button" class="pn-add-sheet px-2 py-1 rounded-lg border border-dashed border-sky-300 text-xs text-sky-900" data-kind="userInfo">+ ورقة</button>
          <label class="px-2 py-1 rounded-lg border border-slate-200 text-xs cursor-pointer hover:bg-slate-50">
            استبدال
            <input type="file" class="hidden pn-replace-file" data-kind="userInfo" accept=".xlsx,.xls" />
          </label>
        </div>
      </div>
      <div id="pnUserSheetTabs" class="flex flex-wrap gap-1 px-2 py-1.5 border-b border-slate-100 bg-white min-h-[40px]"></div>
      <div id="pnHotUser" class="flex-1 w-full overflow-auto min-h-[220px] p-1"></div>
    </section>

    <details class="bg-white rounded-2xl border border-slate-200 p-4 group">
      <summary class="font-semibold text-slate-800 cursor-pointer list-none flex items-center justify-between text-sm">
        <span>إعدادات التدقيق (أعمدة، خصم، ألوان)</span>
        <i class="fas fa-chevron-down text-slate-400 group-open:rotate-180 transition-transform"></i>
      </summary>
      <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 pt-3 border-t border-slate-100">
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">ورقة معلومات المستخدمين (فهرس من 0)</label>
          <input type="number" id="pnUserInfoSheetIdx" min="0" value="0" class="w-full py-2 px-3 border border-slate-200 rounded-lg text-sm" />
        </div>
        <div><label class="block text-xs text-slate-600 mb-1">عمود رقم المستخدم — المستخدمين</label><select id="pnColUiUid" class="w-full py-2 px-3 border rounded-lg text-sm pn-col-select"></select></div>
        <div><label class="block text-xs text-slate-600 mb-1">عمود الاسم — المستخدمين</label><select id="pnColUiTitle" class="w-full py-2 px-3 border rounded-lg text-sm pn-col-select"></select></div>
        <div><label class="block text-xs text-slate-600 mb-1">عمود الراتب — المستخدمين</label><select id="pnColUiSal" class="w-full py-2 px-3 border rounded-lg text-sm pn-col-select"></select></div>
        <div><label class="block text-xs text-slate-600 mb-1">عمود رقم المستخدم — الإدارة</label><select id="pnColMgmt" class="w-full py-2 px-3 border rounded-lg text-sm pn-col-select"></select></div>
        <div><label class="block text-xs text-slate-600 mb-1">عمود رقم المستخدم — الوكيل</label><select id="pnColAgentUid" class="w-full py-2 px-3 border rounded-lg text-sm pn-col-select"></select></div>
        <div><label class="block text-xs text-slate-600 mb-1">عمود الراتب — الوكيل</label><select id="pnColAgentSal" class="w-full py-2 px-3 border rounded-lg text-sm pn-col-select"></select></div>
        <div>
          <label class="block text-xs text-slate-600 mb-1">نسبة الخصم %</label>
          <input type="number" id="pnDiscount" min="0" max="100" step="0.01" value="0" class="w-full py-2 px-3 border rounded-lg text-sm" />
        </div>
        <div class="flex gap-2 items-end">
          <div class="flex-1"><label class="block text-xs text-slate-600 mb-1">لون الوكيل</label><input type="color" id="pnColorAgent" value="#3b82f6" class="h-10 w-full rounded-lg border" /></div>
          <div class="flex-1"><label class="block text-xs text-slate-600 mb-1">لون الإدارة</label><input type="color" id="pnColorMgmt" value="#10b981" class="h-10 w-full rounded-lg border" /></div>
        </div>
      </div>
    </details>

    <section id="pnResultsSection" class="bg-white rounded-2xl border border-slate-200 overflow-hidden hidden">
      <div class="px-4 py-3 border-b border-slate-100 font-semibold text-slate-800 text-sm">نتائج التدقيق</div>
      <div id="pnResultsBody" class="p-4 text-sm text-slate-600 max-h-[50vh] overflow-y-auto"></div>
    </section>
  </main>

  <script>
    window.PN_CYCLE_ID = <%= typeof cycleId !== 'undefined' ? Number(cycleId) : 0 %>;
  </script>
  <script src="https://cdn.jsdelivr.net/npm/handsontable@14.1.0/dist/handsontable.full.min.js"></script>
  <script src="/js/payroll-cycle-standalone.js"></script>
</body>
</html>
