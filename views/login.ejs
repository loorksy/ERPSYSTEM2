<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="theme-color" content="#1e293b">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>LorkERP - تسجيل الدخول</title>
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/tailwind.css">
</head>
<body class="min-h-screen flex items-center justify-center bg-gradient-to-br from-slate-900 via-blue-900 to-slate-900 p-5 font-[Tajawal] relative overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute w-[800px] h-[800px] bg-amber-500/5 rounded-full blur-3xl -top-64 -right-64"></div>
    <div class="absolute w-[600px] h-[600px] bg-amber-500/3 rounded-full blur-3xl -bottom-48 -left-48"></div>
  </div>

  <div class="w-full max-w-[460px] relative z-10">
    <div class="bg-white rounded-3xl p-10 sm:p-12 shadow-2xl shadow-black/20 border border-slate-200/50">
      <!-- Logo -->
      <div class="text-center mb-10">
        <div class="w-[88px] h-[88px] bg-gradient-to-br from-blue-900 to-slate-900 rounded-3xl flex items-center justify-center mx-auto mb-6 shadow-xl shadow-blue-900/30 relative border-2 border-amber-500/20">
          <i class="fas fa-chart-line text-4xl text-amber-500"></i>
        </div>
        <h1 class="text-4xl font-extrabold text-slate-800 tracking-tight">LorkERP</h1>
        <p class="text-slate-500 text-base mt-2">نظام المحاسبة المتكامل</p>
      </div>

      <% if (error) { %>
        <div class="flex items-center gap-3 py-4 px-5 rounded-xl mb-6 text-sm font-medium bg-red-50 text-red-600 border border-red-100">
          <i class="fas fa-exclamation-circle text-lg"></i>
          <span><%= error %></span>
        </div>
      <% } %>

      <form method="POST" action="/login">
        <div class="mb-5">
          <label class="block text-sm font-semibold text-slate-700 mb-2">اسم المستخدم</label>
          <div class="relative flex items-center">
            <i class="fas fa-user absolute right-4 text-slate-400 z-10"></i>
            <input type="text" name="username" placeholder="أدخل اسم المستخدم" required autocomplete="username" autofocus
              class="w-full py-4 pr-12 pl-12 border-2 border-slate-200 rounded-xl text-base bg-slate-50 transition-all duration-200 focus:outline-none focus:border-blue-900 focus:bg-white focus:ring-4 focus:ring-blue-900/10">
          </div>
        </div>

        <div class="mb-6">
          <label class="block text-sm font-semibold text-slate-700 mb-2">كلمة المرور</label>
          <div class="relative flex items-center">
            <i class="fas fa-lock absolute right-4 text-slate-400 z-10"></i>
            <input type="password" name="password" placeholder="أدخل كلمة المرور" required autocomplete="current-password"
              class="w-full py-4 pr-12 pl-12 border-2 border-slate-200 rounded-xl text-base bg-slate-50 transition-all duration-200 focus:outline-none focus:border-blue-900 focus:bg-white focus:ring-4 focus:ring-blue-900/10">
            <button type="button" class="absolute left-4 text-slate-400 hover:text-blue-900 p-1 transition-colors duration-200" onclick="togglePassword(this)">
              <i class="fas fa-eye text-lg"></i>
            </button>
          </div>
        </div>

        <button type="submit" class="w-full bg-gradient-to-r from-blue-900 to-slate-900 text-white py-4 rounded-xl text-base font-semibold shadow-lg shadow-blue-900/25 hover:shadow-xl hover:shadow-blue-900/30 hover:-translate-y-0.5 transition-all duration-200 flex items-center justify-center gap-2 border border-amber-500/20">
          <i class="fas fa-sign-in-alt text-amber-500"></i>
          <span>تسجيل الدخول</span>
        </button>
      </form>

      <div class="text-center mt-8 text-slate-400 text-sm">
        <p>LorkERP &copy; <%= new Date().getFullYear() %></p>
      </div>
    </div>
  </div>

  <script>
    function togglePassword(btn) {
      const input = btn.parentElement.querySelector('input');
      const icon = btn.querySelector('i');
      if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('fa-eye', 'fa-eye-slash');
      } else {
        input.type = 'password';
        icon.classList.replace('fa-eye-slash', 'fa-eye');
      }
    }
  </script>
</body>
</html>
