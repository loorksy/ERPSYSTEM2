<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="theme-color" content="#0f2744">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>LorkERP - تسجيل الدخول</title>
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/tailwind.css">
</head>
<body class="min-h-screen flex items-center justify-center bg-gradient-to-br from-[#0f2744] via-[#1e3a5f] to-[#0f2744] p-5 font-[Tajawal] relative overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute w-[800px] h-[800px] bg-[#c9a227]/5 rounded-full blur-3xl -top-64 -right-64"></div>
    <div class="absolute w-[600px] h-[600px] bg-[#c9a227]/3 rounded-full blur-3xl -bottom-48 -left-48"></div>
    <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width=\"60\" height=\"60\" viewBox=\"0 0 60 60\" xmlns=\"http://www.w3.org/2000/svg\"%3E%3Cg fill=\"none\" fill-rule=\"evenodd\"%3E%3Cg fill=\"%23c9a227\" fill-opacity=\"0.02\"%3E%3Cpath d=\"M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')]"></div>
  </div>

  <div class="w-full max-w-[460px] relative z-10">
    <div class="bg-white rounded-[28px] p-10 sm:p-12 shadow-2xl shadow-black/20 animate-[slideUp_0.5s_ease] border border-slate-200/50">
      <!-- Logo -->
      <div class="text-center mb-10">
        <div class="w-[88px] h-[88px] bg-gradient-to-br from-[#1e3a5f] to-[#0f2744] rounded-[24px] flex items-center justify-center mx-auto mb-6 shadow-xl shadow-[#1e3a5f]/30 relative">
          <div class="absolute inset-[-3px] bg-gradient-to-br from-[#c9a227] to-[#a68621] rounded-[27px] -z-10 opacity-30"></div>
          <i class="fas fa-chart-line text-4xl text-[#c9a227]"></i>
        </div>
        <h1 class="text-[2.25rem] font-extrabold text-slate-800 tracking-tight">LorkERP</h1>
        <p class="text-slate-500 text-base mt-2">نظام المحاسبة المتكامل</p>
      </div>

      <% if (error) { %>
        <div class="flex items-center gap-3 py-4 px-5 rounded-xl mb-6 text-sm font-medium bg-red-50 text-red-600 border border-red-100">
          <i class="fas fa-exclamation-circle text-lg"></i>
          <span><%= error %></span>
        </div>
      <% } %>

      <form method="POST" action="/login">
        <div class="mb-5">
          <label class="block text-sm font-semibold text-slate-700 mb-2">اسم المستخدم</label>
          <div class="relative flex items-center">
            <i class="fas fa-user absolute right-4 text-slate-400 z-10"></i>
            <input type="text" name="username" placeholder="أدخل اسم المستخدم" required autocomplete="username" autofocus
              class="w-full py-4 pr-12 pl-12 border-2 border-slate-200 rounded-xl text-base bg-slate-50 transition-all duration-200 focus:outline-none focus:border-[#1e3a5f] focus:bg-white focus:ring-4 focus:ring-[#1e3a5f]/10">
          </div>
        </div>

        <div class="mb-6">
          <label class="block text-sm font-semibold text-slate-700 mb-2">كلمة المرور</label>
          <div class="relative flex items-center">
            <i class="fas fa-lock absolute right-4 text-slate-400 z-10"></i>
            <input type="password" name="password" placeholder="أدخل كلمة المرور" required autocomplete="current-password"
              class="w-full py-4 pr-12 pl-12 border-2 border-slate-200 rounded-xl text-base bg-slate-50 transition-all duration-200 focus:outline-none focus:border-[#1e3a5f] focus:bg-white focus:ring-4 focus:ring-[#1e3a5f]/10">
            <button type="button" class="absolute left-4 text-slate-400 hover:text-[#1e3a5f] p-1 transition-colors duration-200" onclick="togglePassword(this)">
              <i class="fas fa-eye text-lg"></i>
            </button>
          </div>
        </div>

        <button type="submit" class="w-full bg-gradient-to-r from-[#1e3a5f] to-[#0f2744] text-white py-4 rounded-xl text-base font-semibold shadow-lg shadow-[#1e3a5f]/25 hover:shadow-xl hover:shadow-[#1e3a5f]/30 hover:-translate-y-0.5 transition-all duration-200 flex items-center justify-center gap-2 border border-[#c9a227]/20">
          <i class="fas fa-sign-in-alt text-[#c9a227]"></i>
          <span>تسجيل الدخول</span>
        </button>
      </form>

      <div class="text-center mt-8 text-slate-400 text-sm">
        <p>LorkERP &copy; <%= new Date().getFullYear() %></p>
      </div>
    </div>
  </div>

  <script>
    function togglePassword(btn) {
      const input = btn.parentElement.querySelector('input');
      const icon = btn.querySelector('i');
      if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('fa-eye', 'fa-eye-slash');
      } else {
        input.type = 'password';
        icon.classList.replace('fa-eye-slash', 'fa-eye');
      }
    }
  </script>
</body>
</html>
