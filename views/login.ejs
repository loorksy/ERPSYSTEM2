<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="theme-color" content="#0f172a">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>LorkERP - تسجيل الدخول</title>
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/tailwind.css">
</head>
<body class="min-h-screen flex items-center justify-center bg-[#0f172a] p-5 font-[Tajawal] relative overflow-hidden">
  <!-- Background Effects -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute w-[600px] h-[600px] bg-sky-500/10 rounded-full blur-3xl -top-48 -right-48"></div>
    <div class="absolute w-[500px] h-[500px] bg-cyan-500/10 rounded-full blur-3xl -bottom-32 -left-32"></div>
    <div class="absolute w-[300px] h-[300px] bg-sky-600/5 rounded-full blur-2xl top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"></div>
  </div>

  <div class="w-full max-w-[440px] relative z-10">
    <div class="bg-white rounded-3xl p-10 sm:p-12 shadow-2xl shadow-black/20 animate-[slideUp_0.5s_ease] border border-slate-200/50">
      <!-- Logo -->
      <div class="text-center mb-10">
        <div class="w-20 h-20 bg-gradient-to-br from-sky-500 to-cyan-500 rounded-3xl flex items-center justify-center mx-auto mb-5 shadow-xl shadow-sky-500/30 relative">
          <div class="absolute inset-[-3px] bg-gradient-to-br from-sky-400 to-cyan-400 rounded-[26px] -z-10 opacity-40 blur-sm"></div>
          <i class="fas fa-chart-line text-4xl text-white"></i>
        </div>
        <h1 class="text-3xl font-extrabold text-slate-800 tracking-tight">LorkERP</h1>
        <p class="text-slate-500 text-base mt-2">نظام المحاسبة المتكامل</p>
      </div>

      <% if (error) { %>
        <div class="flex items-center gap-3 py-4 px-5 rounded-2xl mb-6 text-sm font-medium bg-gradient-to-br from-red-50 to-red-100/80 text-red-600 border border-red-200">
          <i class="fas fa-exclamation-circle text-lg"></i>
          <span><%= error %></span>
        </div>
      <% } %>

      <form method="POST" action="/login">
        <div class="mb-5">
          <label class="block text-sm font-semibold text-slate-700 mb-2">اسم المستخدم</label>
          <div class="relative flex items-center">
            <i class="fas fa-user absolute right-4 text-slate-400 z-10"></i>
            <input type="text" name="username" placeholder="أدخل اسم المستخدم" required autocomplete="username" autofocus
              class="w-full py-4 pr-12 pl-12 border-2 border-slate-200 rounded-xl text-base bg-slate-50 transition-all duration-200 focus:outline-none focus:border-sky-500 focus:bg-white focus:ring-4 focus:ring-sky-500/10">
          </div>
        </div>

        <div class="mb-6">
          <label class="block text-sm font-semibold text-slate-700 mb-2">كلمة المرور</label>
          <div class="relative flex items-center">
            <i class="fas fa-lock absolute right-4 text-slate-400 z-10"></i>
            <input type="password" name="password" placeholder="أدخل كلمة المرور" required autocomplete="current-password"
              class="w-full py-4 pr-12 pl-12 border-2 border-slate-200 rounded-xl text-base bg-slate-50 transition-all duration-200 focus:outline-none focus:border-sky-500 focus:bg-white focus:ring-4 focus:ring-sky-500/10">
            <button type="button" class="absolute left-4 text-slate-400 hover:text-sky-500 p-1 transition-colors duration-200" onclick="togglePassword(this)">
              <i class="fas fa-eye text-lg"></i>
            </button>
          </div>
        </div>

        <button type="submit" class="w-full bg-gradient-to-r from-sky-500 to-cyan-500 text-white py-4 rounded-xl text-base font-semibold shadow-lg shadow-sky-500/25 hover:shadow-xl hover:shadow-sky-500/30 hover:-translate-y-0.5 transition-all duration-200 flex items-center justify-center gap-2">
          <i class="fas fa-sign-in-alt"></i>
          <span>تسجيل الدخول</span>
        </button>
      </form>

      <div class="text-center mt-8 text-slate-400 text-sm">
        <p>LorkERP &copy; <%= new Date().getFullYear() %></p>
      </div>
    </div>
  </div>

  <script>
    function togglePassword(btn) {
      const input = btn.parentElement.querySelector('input');
      const icon = btn.querySelector('i');
      if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('fa-eye', 'fa-eye-slash');
      } else {
        input.type = 'password';
        icon.classList.replace('fa-eye-slash', 'fa-eye');
      }
    }
  </script>
</body>
</html>
