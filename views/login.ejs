<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="theme-color" content="#1a1a2e">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>LorkERP - تسجيل الدخول</title>
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/tailwind.css">
</head>
<body class="min-h-screen flex items-center justify-center bg-gradient-to-br from-[#1a1a2e] via-[#16213e] to-[#0f3460] p-5 font-[Tajawal]">
  <div class="w-full max-w-[420px]">
    <div class="bg-white rounded-2xl p-8 sm:p-10 shadow-2xl animate-[slideUp_0.5s_ease]">
      <!-- Logo -->
      <div class="text-center mb-8">
        <div class="w-[72px] h-[72px] bg-gradient-to-br from-indigo-600 to-indigo-400 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-[0_8px_24px_rgba(79,70,229,0.35)]">
          <i class="fas fa-chart-line text-3xl text-white"></i>
        </div>
        <h1 class="text-3xl font-extrabold text-slate-800 tracking-tight">LorkERP</h1>
        <p class="text-slate-500 text-[0.95rem] mt-1">نظام المحاسبة المتكامل</p>
      </div>

      <% if (error) { %>
        <div class="flex items-center gap-2.5 py-3.5 px-4 rounded-xl mb-5 text-sm font-medium bg-red-50 text-red-500 border border-red-200">
          <i class="fas fa-exclamation-circle"></i>
          <span><%= error %></span>
        </div>
      <% } %>

      <form method="POST" action="/login">
        <div class="mb-5">
          <div class="relative flex items-center">
            <i class="fas fa-user absolute right-4 text-slate-400 z-10"></i>
            <input type="text" name="username" placeholder="اسم المستخدم" required autocomplete="username" autofocus
              class="w-full py-3.5 pr-12 pl-12 border-2 border-slate-200 rounded-xl text-base bg-slate-50 transition-all duration-300 focus:outline-none focus:border-indigo-600 focus:bg-white focus:ring-2 focus:ring-indigo-600/10">
          </div>
        </div>

        <div class="mb-5">
          <div class="relative flex items-center">
            <i class="fas fa-lock absolute right-4 text-slate-400 z-10"></i>
            <input type="password" name="password" placeholder="كلمة المرور" required autocomplete="current-password"
              class="w-full py-3.5 pr-12 pl-12 border-2 border-slate-200 rounded-xl text-base bg-slate-50 transition-all duration-300 focus:outline-none focus:border-indigo-600 focus:bg-white focus:ring-2 focus:ring-indigo-600/10">
            <button type="button" class="absolute left-3.5 text-slate-400 hover:text-slate-500 p-1" onclick="togglePassword(this)">
              <i class="fas fa-eye"></i>
            </button>
          </div>
        </div>

        <button type="submit" class="btn btn-primary btn-block mt-2 py-3.5 text-base">
          <i class="fas fa-sign-in-alt"></i>
          <span>تسجيل الدخول</span>
        </button>
      </form>

      <div class="text-center mt-6 text-slate-400 text-sm">
        <p>LorkERP &copy; <%= new Date().getFullYear() %></p>
      </div>
    </div>
  </div>

  <script>
    function togglePassword(btn) {
      const input = btn.parentElement.querySelector('input');
      const icon = btn.querySelector('i');
      if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('fa-eye', 'fa-eye-slash');
      } else {
        input.type = 'password';
        icon.classList.replace('fa-eye-slash', 'fa-eye');
      }
    }
  </script>
</body>
</html>
