{
  "name": "lorkerp",
  "version": "1.0.0",
  "description": "LorkERP - نظام محاسبة متكامل",
  "main": "server.js",
  "scripts": {
    "css:build": "postcss src/input.css -o public/css/tailwind.css",
    "css:watch": "postcss src/input.css -o public/css/tailwind.css --watch",
    "prestart": "npm run css:build",
    "start": "node server.js",
    "dev": "npm run css:build && nodemon server.js"
  },
  "keywords": [
    "erp",
    "accounting",
    "arabic"
  ],
  "author": "LorkERP",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@tailwindcss/postcss": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-session": "^1.18.0",
    "googleapis": "^144.0.0",
    "helmet": "^8.0.0",
    "html2canvas": "^1.4.1",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.29.0",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "session-file-store": "^1.5.0",
    "socket.io": "^4.8.0",
    "sql.js": "^1.10.3",
    "tailwindcss": "^4.2.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "portfinder": "^1.0.38"
  },
  "nodemonConfig": {
    "delay": "2500",
    "ignore": [
      "sessions",
      "sessions/*",
      "uploads",
      "uploads/*",
      "db/*.db",
      "db/*.db-shm",
      "db/*.db-wal",
      "node_modules",
      ".git"
    ]
  }
}
